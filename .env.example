# =============================================================================
# Tashkheesa Portal — Environment Variables Reference
# Copy this to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# ── App Mode ──────────────────────────────────────────────────────────────────
MODE=development                        # development | staging | production
PORT=3000
NODE_ENV=development                    # development | production
BASE_URL=http://localhost:3000          # Full URL (no trailing slash)
APP_URL=http://localhost:3000           # Alias used by email templates

# ── Auth & Security ───────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS
SESSION_COOKIE_NAME=tashkheesa_portal

# Staging basic auth (required when MODE=staging)
BASIC_AUTH_USER=demo
BASIC_AUTH_PASS=demo123

# CSRF protection: off | log | enforce
CSRF_MODE=enforce

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/tashkheesa
PG_SSL=false                            # Set to true on Render/production

# ── SLA Worker ────────────────────────────────────────────────────────────────
SLA_MODE=passive                        # passive | primary (ONE instance only)
SLA_PRIMARY_TOKEN=YES_I_UNDERSTAND      # Required when SLA_MODE=primary
ALLOW_PRIMARY_IN_DEV=false             # Set true to allow primary in dev
SLA_ENFORCEMENT_ENABLED=1
SLA_ENFORCEMENT_INTERVAL_MS=300000     # 5 minutes
SLA_REMINDER_MINUTES=60
SLA_DRY_RUN=false

# ── Payments (Paymob) ─────────────────────────────────────────────────────────
PAYMOB_PUBLIC_KEY=                      # From Paymob dashboard
PAYMOB_SECRET_KEY=                      # From Paymob dashboard
PAYMOB_HMAC_SECRET=                     # Settings → Account Info → HMAC field
PAYMENT_WEBHOOK_SECRET=                 # Legacy fallback (used before HMAC)

# ── API Keys ──────────────────────────────────────────────────────────────────
TASH_API_KEY=REPLACE_WITH_STRONG_RANDOM_KEY
PUBLIC_ORDER_API_KEY=REPLACE_WITH_STRONG_RANDOM_KEY
UNSUBSCRIBE_SECRET=REPLACE_WITH_STRONG_RANDOM_KEY

# ── AI Services ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                      # Anthropic console → API Keys
OPENAI_API_KEY=                         # Optional: OpenAI fallback

# ── File Storage (Uploadcare) ────────────────────────────────────────────────
UPLOADCARE_PUBLIC_KEY=
UPLOADCARE_SECRET_KEY=

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_ENABLED=true
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@tashkheesa.com
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@tashkheesa.com
SMTP_FROM_NAME=Tashkheesa

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────────
WHATSAPP_ENABLED=true
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v22.0

# ── Video Consultations (Twilio) ─────────────────────────────────────────────
VIDEO_CONSULTATION_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY=
TWILIO_API_SECRET=

# ── Instagram / Social ────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
IG_ACCESS_TOKEN=
IG_BUSINESS_ACCOUNT_ID=
FB_PAGE_ID=
MEDIA_BASE_URL=https://tashkheesa.com

# ── Cloudinary (Instagram image hosting) ─────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Notification Worker ───────────────────────────────────────────────────────
NOTIFICATION_WORKER_ENABLED=true
NOTIFICATION_WORKER_INTERVAL_MS=30000
NOTIFICATION_MAX_RETRIES=3
NOTIFICATION_DRY_RUN=false

# ── Smoke Tests ───────────────────────────────────────────────────────────────
SMOKE_BASE_URL=http://localhost:3000

# ── Ops Dashboard ───────────────────────────────────────────────────────────
OPS_USER=                               # Username for /ops login
OPS_PASS=                               # Password for /ops login
OPS_SSH_HOST=100.106.122.55             # Mac mini Tailscale IP for agent monitoring
OPS_SSH_USER=macmini                    # SSH user on Mac mini
OPS_SSH_KEY_PATH=                       # Path to SSH private key (e.g. /etc/secrets/render_ops_key)

# ── Git / Deploy ──────────────────────────────────────────────────────────────
# Injected automatically by Render:
# RENDER_GIT_COMMIT, RENDER_SERVICE_ID, RENDER_SERVICE_NAME
