# =============================================================================
# Tashkheesa Portal — Environment Variables Reference
# Copy this to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# ── App Mode ──────────────────────────────────────────────────────────────────
MODE=development                        # development | staging | production
PORT=3000
LAUNCH_DATE=                            # Displayed on /coming-soon page (e.g. "February 28, 2026"). Leave blank to omit date.

# ── Business Info (homepage footer + JSON-LD schema) ─────────────────────────
BUSINESS_EMAIL=info@tashkheesa.com
BUSINESS_PHONE=+20 110 200 9886
BUSINESS_ADDRESS=Cairo, Egypt
PRICE_RANGE_MIN=200
PRICE_RANGE_MAX=18,250

NODE_ENV=development                    # development | production
BASE_URL=http://localhost:3000          # Full URL (no trailing slash)
APP_URL=http://localhost:3000           # Alias used by email templates

# ── Auth & Security ───────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS
SESSION_COOKIE_NAME=tashkheesa_portal

# Staging basic auth (required when MODE=staging)
BASIC_AUTH_USER=demo
BASIC_AUTH_PASS=demo123

# CSRF protection: off | log | enforce
CSRF_MODE=enforce

# Symmetric key used by pgcrypto's pgp_sym_encrypt / pgp_sym_decrypt to
# protect doctors' national IDs at rest in users.national_id_encrypted.
# REQUIRED in any environment that runs doctor signup or admin national-ID
# review. Treat as a top-tier secret — rotating it requires re-encrypting
# every existing row with the new key inside a single transaction.
# Generate with: openssl rand -base64 48
NATIONAL_ID_ENCRYPTION_KEY=REPLACE_WITH_LONG_RANDOM_SECRET_MIN_32_CHARS

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/tashkheesa
PG_SSL=false                            # Set to true on Render/production

# pg-boss (durable job queue) needs a session-mode Postgres connection because
# it uses LISTEN/NOTIFY and Postgres advisory locks for cross-instance
# singleton crons. The Supabase pgbouncer transaction-mode pooler (the URL
# above on Render production) silently breaks both. Set this to the Supabase
# "Session pooler" connection string (Project Settings → Database → Session
# pooler — typically port 5432). REQUIRED when MODE=production or MODE=staging
# (job_queue.js will fail fast at boot otherwise). Optional in development —
# pg-boss falls back to DATABASE_URL with a warning.
DATABASE_URL_DIRECT=

# Optional pool tuning (defaults shown).
# PG_POOL_MAX=10
# PG_POOL_CONNECT_TIMEOUT_MS=15000
# PG_POOL_IDLE_TIMEOUT_MS=30000
# PG_STATEMENT_TIMEOUT_MS=30000          # Per-query cap; kills runaway queries.

# ── SLA Worker ────────────────────────────────────────────────────────────────
SLA_MODE=passive                        # passive | primary (ONE instance only)
SLA_PRIMARY_TOKEN=YES_I_UNDERSTAND      # Required when SLA_MODE=primary
ALLOW_PRIMARY_IN_DEV=false             # Set true to allow primary in dev
SLA_ENFORCEMENT_ENABLED=1
SLA_ENFORCEMENT_INTERVAL_MS=300000     # 5 minutes
SLA_REMINDER_MINUTES=60
SLA_DRY_RUN=false

# P1-FIN-2: auto-pause repeat SLA breachers from new assignments.
# When a doctor accumulates SLA_AUTO_PAUSE_BREACHES reassignment-out
# events within SLA_AUTO_PAUSE_WINDOW_DAYS days, users.is_paused is
# flipped true (excluded from open-pool routing; existing cases continue;
# login still works). Set BREACHES=0 to disable the auto-pause behavior.
SLA_AUTO_PAUSE_BREACHES=3
SLA_AUTO_PAUSE_WINDOW_DAYS=30

# Per-doctor SLA tuning (defaults shown; uncomment to override).
# DOCTOR_RESPONSE_TIMEOUT_HOURS sets the standard-tier response window
# (src/case_sla_worker.js:16, src/case_lifecycle.js:1842 — VIP/Urgent
# tiers ignore this and use their own SLA). MAX_ACTIVE_CASES_PER_DOCTOR
# caps how many simultaneously-active cases a doctor can hold before the
# auto-assigner skips them (src/case_sla_worker.js:19).
# DOCTOR_RESPONSE_TIMEOUT_HOURS=24
# MAX_ACTIVE_CASES_PER_DOCTOR=4

# ── Payments (Paymob) ─────────────────────────────────────────────────────────
# Three API keys live in: Paymob dashboard → Settings → API Keys
PAYMOB_PUBLIC_KEY=                      # Settings → API Keys → Public Key
PAYMOB_SECRET_KEY=                      # Settings → API Keys → Secret Key
PAYMOB_HMAC_SECRET=                     # Settings → Account Info → HMAC field
# Card integration ID for the Unified Intention API:
PAYMOB_CARD_INTEGRATION_ID=             # Payments → Integrations → (your card integration) → ID
# Public webhook URL Paymob calls on transaction events.
# Also set this exact URL in the Paymob dashboard: Payments → Integrations → Transaction Processed Callback
PAYMOB_NOTIFICATION_URL=                # e.g. https://tashkheesa.com/payments/callback
# Mode safety guard. services/paymob.js throws if not 'test' — switching to
# live requires editing services/paymob.js intentionally.
PAYMOB_MODE=test                        # test | live (live not permitted in code yet)

# ── API Keys ──────────────────────────────────────────────────────────────────
TASH_API_KEY=REPLACE_WITH_STRONG_RANDOM_KEY
PUBLIC_ORDER_API_KEY=REPLACE_WITH_STRONG_RANDOM_KEY
UNSUBSCRIBE_SECRET=REPLACE_WITH_STRONG_RANDOM_KEY

# ── AI Services ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                      # Anthropic console → API Keys
OPENAI_API_KEY=                         # Optional: OpenAI fallback

# ── AI: Anthropic model selection (Theme 9 Sub-issue D) ──────────────────────
# Override the per-pipeline default model. Leave blank to use the in-code
# default in src/config/anthropic.js, which tracks the canonical Claude family
# at deploy time. Update on Anthropic model rotation — no code change required.
# Verify Active status: https://docs.claude.com/en/docs/about-claude/model-deprecations
ANTHROPIC_MODEL_SONNET=                 # default: claude-sonnet-4-6 (case extraction + chat)
ANTHROPIC_MODEL_HAIKU=                  # default: claude-haiku-4-5 (fast triage)
ANTHROPIC_MODEL_VISION=                 # default: claude-sonnet-4-6 (image quality check)

# ── File Storage: Uploadcare (patient medical photos, doctor signup widget) ──
# Patient medical photos and doctor profile photos at signup are uploaded
# directly to ucarecdn.com from the browser via the Uploadcare 3.x widget.
# Server-side stores only the resulting URL string — there is no server-side
# Uploadcare API surface today (see src/server.js validator comment for why
# UPLOADCARE_SECRET_KEY is documented but not validated).
UPLOADCARE_PUBLIC_KEY=
UPLOADCARE_SECRET_KEY=

# ── File Storage: Cloudflare R2 (case files, prescriptions, doctor photos) ───
# REQUIRED in staging/production. R2 stores server-generated artefacts and
# multipart uploads that don't go through the Uploadcare widget:
#   - prescription PDFs (src/routes/prescriptions.js — writer + reader)
#   - case reports (src/report-generator.js — writer)
#   - doctor profile photos + signatures (src/routes/doctor.js — writer + reader)
#   - patient case attachments via the order intake form (src/routes/order_flow.js)
#   - mobile API prescription downloads (src/routes/api_v1.js)
#   - generic GET /files/:id signed-URL serve (src/server.js)
# Files are served via 1-hour signed URLs; no public R2 URLs leak. If any of
# the four vars is missing in staging/production, src/server.js
# validateCriticalEnvVars hard-exits at boot. In development the server boots
# with a warning (src/storage.js:19) and uploads/downloads fail inside the
# request handler with "File temporarily unavailable" until the vars are set.
#
# Get the values from: Cloudflare → R2 → Manage R2 API Tokens → Create Account
# API Token (admin read+write on the bucket). The endpoint is on the bucket
# overview page; the bucket must exist before tokens can be scoped to it.
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# ── Email (Resend HTTP API) ───────────────────────────────────────────────────
# Migrated from Gmail SMTP / nodemailer to Resend on 2026-04-30
# (see src/services/emailService.js header). Resend is now the only transport;
# SMTP_HOST / SMTP_PORT / SMTP_USER / SMTP_PASS / SMTP_SECURE have been removed
# from this file because nothing in the codebase reads them.
#
# RESEND_API_KEY is REQUIRED in staging/production for all transactional email:
# case lifecycle notifications, password reset, payment receipts, doctor signup
# verification. Without it, src/server.js validateCriticalEnvVars hard-exits at
# boot. In development the server boots with a warning and lifecycle email
# silently stubs (sendMail returns {stub: true}).
# Get the key from: https://resend.com → API Keys.
RESEND_API_KEY=
EMAIL_ENABLED=true

# Resend "from" identity. Variable names are kept from the pre-2026-04-30 SMTP
# era for backward compatibility with src/routes/static-pages.js (which reads
# SMTP_FROM_EMAIL as a contact-form recipient default). They configure the
# Resend "from" header only — they do NOT configure SMTP transport.
SMTP_FROM_EMAIL=noreply@tashkheesa.com
SMTP_FROM_NAME=Tashkheesa

# Recipient guard: hardcoded blocklist (demo.local, example.com, test.com, …)
# is ALWAYS enforced. EMAIL_GUARD_STRICT additionally enables MX-record
# validation. Default OFF for the first ~30 days while we monitor
# blocked_send_attempts for false positives against legitimate domains under
# Render's DNS. Flip to true after 30 days if no false positives observed.
EMAIL_GUARD_STRICT=false

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────────
WHATSAPP_ENABLED=true
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_VERSION=v22.0
# Meta-approved authentication-category template used for mobile-app OTP delivery.
# Must exist in WhatsApp Business Manager and accept ONE body parameter (the OTP code).
# When unset (or token missing), src/services/whatsapp_otp.js stubs and the OTP route
# returns "OTP generated. SMS delivery is not configured" so the OTP can be read from
# the otp_codes table in dev.
WHATSAPP_OTP_TEMPLATE_NAME=otp_verify_en
WHATSAPP_OTP_TEMPLATE_LANG=en

# ── Critical Alerts ──────────────────────────────────────────────────────────
# Admin phone for crash alerts via WhatsApp (digits with country code, no +)
ADMIN_PHONE=

# Theme 9 Sub-issue B: critical-alert WhatsApp template.
# Required for sendCriticalAlert to fire outside Meta's 24h customer-service
# window. Provision a utility-category template via Meta Business Manager
# with ONE body parameter (the alert text). Until this env is set,
# sendCriticalAlert logs every attempt as `template_not_configured` in
# critical_alert_log + error_logs but does not call Meta.
CRITICAL_ALERT_TEMPLATE_NAME=
CRITICAL_ALERT_TEMPLATE_LANG=en

# ── Twilio ───────────────────────────────────────────────────────────────────
# Shared credentials (used by both Video and OTP Verify)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Twilio Verify — OTP delivery for mobile app login (SMS)
# Create at: console.twilio.com → Verify → Services → Create Service
# Set the service friendly name to "Tashkheesa" so SMS reads:
#   "Your Tashkheesa verification code is: 847291"
TWILIO_VERIFY_SERVICE_SID=

# Video Consultations
VIDEO_CONSULTATION_ENABLED=false
TWILIO_API_KEY=
TWILIO_API_SECRET=

# ── Instagram / Social ────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
IG_ACCESS_TOKEN=
IG_BUSINESS_ACCOUNT_ID=
FB_PAGE_ID=
MEDIA_BASE_URL=https://tashkheesa.com

# ── Cloudinary (Instagram image hosting) ─────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Notification Worker ───────────────────────────────────────────────────────
NOTIFICATION_WORKER_ENABLED=true
NOTIFICATION_WORKER_INTERVAL_MS=30000
NOTIFICATION_MAX_RETRIES=3
NOTIFICATION_DRY_RUN=false

# ── Smoke Tests ───────────────────────────────────────────────────────────────
SMOKE_BASE_URL=http://localhost:3000

# ── Ops Dashboard ───────────────────────────────────────────────────────────
OPS_USER=                               # Username for /ops login
OPS_PASS=                               # Password for /ops login
OPS_SSH_HOST=100.106.122.55             # Mac mini Tailscale IP for agent monitoring
OPS_SSH_USER=macmini                    # SSH user on Mac mini
OPS_SSH_KEY_PATH=                       # Path to SSH private key (e.g. /etc/secrets/render_ops_key)

# Theme 3 Stage 1 — optional. When set, /ops/agent/* routes log
# "agent <route> signed OK" if the X-Ops-Agent-Key request header matches;
# otherwise log "agent <route> unsigned" but continue (no rejection).
# Stage 2 cutover (after one full uptime cycle with signing observed in
# logs) flips to mandatory and the validator promotes this to prodRequired.
# See docs/runbooks/THEME_03_OPS_AGENT_KEY_CUTOVER.md.
OPS_AGENT_KEY=

# ── Mobile App Links ────────────────────────────────────────────────────────
# Public URL the iOS landing page uses to point patients at TestFlight before
# App Store launch (src/routes/app_landing.js:42). Safe default
# https://tashkheesa.com/app keeps the page rendering; override on staging or
# when TestFlight invitation URLs change.
TESTFLIGHT_URL=

# ── Git / Deploy ──────────────────────────────────────────────────────────────
# Injected automatically by Render:
# RENDER_GIT_COMMIT, RENDER_SERVICE_ID, RENDER_SERVICE_NAME
