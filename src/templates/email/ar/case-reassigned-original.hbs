  <tr>
    <td style="padding:20px 24px;">
      <p style="margin:0 0 8px 0;font-size:13px;font-weight:600;color:#9a3412;letter-spacing:0.5px;">دفع جزئي</p>
      <p style="margin:0;font-size:15px;line-height:1.8;color:#4a5568;">
        ستتلقى <strong>{{partialPct}}% دفع جزئي ({{partialAmount}} جنيه)</strong> مقابل الوقت الذي قضيته في مراجعة هذه الحالة.
      </p>
    </td>
  </tr>
</table>

<p style="margin:24px 0 0 0;font-size:13px;color:#718096;line-height:1.8;">
