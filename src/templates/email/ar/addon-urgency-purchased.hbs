<!-- ترقية لعاجلة — تأكيد للمريض -->
<h2 style="margin:0 0 16px 0;font-size:22px;font-weight:700;color:#1a365d;">
  تم ترقية الحالة لعاجلة
</h2>

<p style="margin:0 0 16px 0;font-size:15px;line-height:1.8;color:#4a5568;">
  مرحباً {{patientName}}،
</p>

<p style="margin:0 0 16px 0;font-size:15px;line-height:1.8;color:#4a5568;">
  حالتك <strong>{{caseReference}}</strong> تم ترقيتها لعاجلة. فريقنا الطبي هيبدأ المراجعة بأسرع وقت ممكن.
</p>

{{#if slaHours}}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:24px 0;background-color:#fff5f5;border-radius:8px;border:1px solid #fc8181;">
  <tr>
    <td style="padding:20px 24px;">
      <p style="margin:0 0 4px 0;font-size:13px;font-weight:600;color:#c53030;letter-spacing:0.5px;">الميعاد الجديد</p>
      <p style="margin:0;font-size:18px;font-weight:700;color:#2d3748;">{{slaHours}} ساعة</p>
    </td>
  </tr>
</table>
{{/if}}

{{#if dashboardUrl}}
<table role="presentation" cellpadding="0" cellspacing="0" style="margin:0 auto;">
  <tr>
    <td align="center" style="background-color:#c53030;border-radius:8px;">
      <a href="{{dashboardUrl}}" style="display:inline-block;padding:14px 32px;font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;">
        متابعة الحالة
      </a>
    </td>
  </tr>
</table>
{{/if}}
