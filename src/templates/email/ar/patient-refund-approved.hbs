<!-- Patient Refund Approved — EG-AR (Theme 7b Phase 3) -->
<h2 style="margin:0 0 16px 0;font-size:22px;font-weight:700;color:#1a365d;direction:rtl;text-align:right;">
  تم اعتماد طلب الاسترداد
</h2>
<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;color:#4a5568;direction:rtl;text-align:right;">
  أهلاً {{patientName}},
</p>
<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;color:#4a5568;direction:rtl;text-align:right;">
  تم اعتماد طلب استرداد المبلغ. هنجهز التحويل عبر الإنستاباي.
</p>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:24px 0;background-color:#f7fafc;border-radius:8px;border:1px solid #e2e8f0;direction:rtl;">
  <tr>
    <td style="padding:20px 24px;text-align:right;">
      <p style="margin:0 0 8px 0;font-size:13px;font-weight:600;color:#718096;letter-spacing:0.5px;">المبلغ المعتمد</p>
      <p style="margin:0;font-size:18px;font-weight:700;color:#2d3748;">{{approvedAmount}} جنيه</p>
      {{#if caseReference}}
      <p style="margin:12px 0 0 0;font-size:13px;color:#718096;">رقم الحالة: {{caseReference}}</p>
      {{/if}}
    </td>
  </tr>
</table>
<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;color:#4a5568;direction:rtl;text-align:right;">
  <strong>الوقت المتوقع:</strong> 3-5 أيام عمل لاستلام المبلغ عبر الإنستاباي. هنبعتلك إيميل تاني فيه رقم تحويل الإنستاباي لما الفلوس تتحول.
</p>
{{#if caseUrl}}
<table role="presentation" cellpadding="0" cellspacing="0" style="margin:0 auto;">
  <tr>
    <td align="center" style="background-color:#2b6cb0;border-radius:8px;">
      <a href="{{caseUrl}}" style="display:inline-block;padding:14px 32px;font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;">افتح صفحة الحالة</a>
    </td>
  </tr>
</table>
{{/if}}
