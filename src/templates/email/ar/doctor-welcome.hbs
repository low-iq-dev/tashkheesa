<!-- مرحباً بالطبيب — تمت الموافقة (P1-NOTIF-5) -->
<h2 style="margin:0 0 16px 0;font-size:22px;font-weight:700;color:#1a365d;">
  مرحباً بك في شبكة الأطباء في تشخيصة
</h2>

<p style="margin:0 0 16px 0;font-size:15px;line-height:1.8;color:#4a5568;">
  مرحباً د. {{doctorName}}،
</p>

<p style="margin:0 0 16px 0;font-size:15px;line-height:1.8;color:#4a5568;">
  تهانينا — تمت الموافقة على طلبك. للبدء، قم بإعداد الوصول إلى البوابة باستخدام الرابط الآمن أدناه.
</p>

{{#if magicLinkUrl}}
<table role="presentation" cellpadding="0" cellspacing="0" style="margin:24px auto 8px auto;">
  <tr>
    <td align="center" style="background-color:#38b2ac;border-radius:8px;">
      <a href="{{magicLinkUrl}}" style="display:inline-block;padding:14px 32px;font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;">
        تفعيل حسابك
      </a>
    </td>
  </tr>
</table>
<p style="margin:0 0 24px 0;font-size:13px;line-height:1.6;color:#718096;text-align:center;">
  ينتهي هذا الرابط لمرة واحدة خلال {{expiryDays}} أيام.
</p>
{{/if}}

<!-- بمجرد الدخول -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:24px 0;background-color:#f0fff4;border-radius:8px;border:1px solid #c6f6d5;">
  <tr>
    <td style="padding:20px 24px;">
      <p style="margin:0 0 12px 0;font-size:13px;font-weight:600;color:#276749;letter-spacing:0.5px;">بمجرد الدخول</p>
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
        <tr>
          <td style="padding:8px 0;font-size:14px;color:#4a5568;">
            <span style="color:#38a169;font-weight:700;margin-left:8px;">&#10003;</span>
            عرض الحالات الجديدة في تخصصك
          </td>
        </tr>
        <tr>
          <td style="padding:8px 0;font-size:14px;color:#4a5568;">
            <span style="color:#38a169;font-weight:700;margin-left:8px;">&#10003;</span>
            تحديد أوقات تواجدك للاستشارات المرئية
          </td>
        </tr>
        <tr>
          <td style="padding:8px 0;font-size:14px;color:#4a5568;">
            <span style="color:#38a169;font-weight:700;margin-left:8px;">&#10003;</span>
            تقديم آراء طبية وتقارير مفصلة
          </td>
        </tr>
        <tr>
          <td style="padding:8px 0;font-size:14px;color:#4a5568;">
            <span style="color:#38a169;font-weight:700;margin-left:8px;">&#10003;</span>
            تتبع أرباحك من لوحة التحكم الخاصة بك
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>

{{#if portalUrl}}
<p style="margin:24px 0 0 0;font-size:13px;line-height:1.8;color:#718096;">
  إذا كنت قد أعددت حسابك بالفعل، يمكنك <a href="{{portalUrl}}" style="color:#2b6cb0;text-decoration:none;">تسجيل الدخول مباشرة</a>.
</p>
{{/if}}

<p style="margin:24px 0 0 0;font-size:13px;color:#a0aec0;line-height:1.6;">
  شكراً لانضمامك إلينا في جعل الآراء الطبية المتخصصة متاحة للجميع. يمكنك الرد على هذا البريد إذا كان لديك أي أسئلة.
</p>
