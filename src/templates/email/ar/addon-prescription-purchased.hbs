<!-- روشتة إضافية — تأكيد للمريض -->
<h2 style="margin:0 0 16px 0;font-size:22px;font-weight:700;color:#1a365d;">
  تم تأكيد الروشتة الإضافية
</h2>

<p style="margin:0 0 16px 0;font-size:15px;line-height:1.8;color:#4a5568;">
  مرحباً {{patientName}}،
</p>

<p style="margin:0 0 16px 0;font-size:15px;line-height:1.8;color:#4a5568;">
  الروشتة الإضافية تمت إضافتها لحالة <strong>{{caseReference}}</strong>. د. {{doctorName}} هيصدرها مع التقرير الطبي.
</p>

{{#if dashboardUrl}}
<table role="presentation" cellpadding="0" cellspacing="0" style="margin:24px 0 0 0;">
  <tr>
    <td align="center" style="background-color:#38b2ac;border-radius:8px;">
      <a href="{{dashboardUrl}}" style="display:inline-block;padding:14px 32px;font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;">
        متابعة الحالة
      </a>
    </td>
  </tr>
</table>
{{/if}}
