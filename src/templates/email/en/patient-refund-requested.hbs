<!-- Patient Refund Request — Patient confirmation (Theme 7b Phase 2) -->
<h2 style="margin:0 0 16px 0;font-size:22px;font-weight:700;color:#1a365d;">
  Refund Request Received
</h2>

<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;color:#4a5568;">
  Hi {{patientName}},
</p>

<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;color:#4a5568;">
  We received your refund request. Our care team will review it and get back to you within one business day.
</p>

<!-- Request details box -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:24px 0;background-color:#f7fafc;border-radius:8px;border:1px solid #e2e8f0;">
  <tr>
    <td style="padding:20px 24px;">
      <p style="margin:0 0 8px 0;font-size:13px;font-weight:600;color:#718096;text-transform:uppercase;letter-spacing:0.5px;">Request Details</p>

      <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
        {{#if caseReference}}
        <tr>
          <td style="padding:6px 0;font-size:14px;color:#718096;width:160px;">Case reference:</td>
          <td style="padding:6px 0;font-size:14px;font-weight:600;color:#2d3748;">{{caseReference}}</td>
        </tr>
        {{/if}}
        {{#if requestedAmount}}
        <tr>
          <td style="padding:6px 0;font-size:14px;color:#718096;width:160px;">Amount requested:</td>
          <td style="padding:6px 0;font-size:14px;color:#2d3748;">EGP {{requestedAmount}}</td>
        </tr>
        {{/if}}
        {{#if instapayHandle}}
        <tr>
          <td style="padding:6px 0;font-size:14px;color:#718096;width:160px;">Instapay:</td>
          <td style="padding:6px 0;font-size:14px;color:#2d3748;">{{instapayHandle}}</td>
        </tr>
        {{/if}}
      </table>
    </td>
  </tr>
</table>

<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;color:#4a5568;">
  <strong>What happens next:</strong>
</p>

<ul style="margin:0 0 24px 0;padding-left:20px;font-size:15px;line-height:1.7;color:#4a5568;">
  <li>Our care team reviews your request within one business day.</li>
  <li>If approved, your refund is paid via Instapay within 3-5 business days.</li>
  <li>You'll receive an email confirmation when the payment is sent, including the Instapay reference.</li>
</ul>

<p style="margin:0 0 24px 0;font-size:14px;line-height:1.6;color:#4a5568;background:#FBF9F4;padding:14px;border-radius:8px;">
  <strong>Changed your mind?</strong> You can cancel this request from your case page within one hour of submitting.
</p>

{{#if caseUrl}}
<table role="presentation" cellpadding="0" cellspacing="0" style="margin:0 auto;">
  <tr>
    <td align="center" style="background-color:#2b6cb0;border-radius:8px;">
      <a href="{{caseUrl}}" style="display:inline-block;padding:14px 32px;font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;">
        View Your Case
      </a>
    </td>
  </tr>
</table>
{{/if}}

<p style="margin:24px 0 0 0;font-size:13px;color:#a0aec0;line-height:1.5;">
  If you have any questions about your refund, please reply to this email or contact our support team.
</p>
