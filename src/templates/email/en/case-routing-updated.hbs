<!-- Case routing updated (manual-queue approve, specialty changed) — Patient -->
<h2 style="margin:0 0 16px 0;font-size:22px;font-weight:700;color:#1a365d;">
  We Updated Your Case Routing
</h2>

<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;color:#4a5568;">
  Hi {{patientName}},
</p>

<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;color:#4a5568;">
  We updated your case routing based on the details you provided in case <strong>{{caseReference}}</strong>. Your case will be reviewed by a specialist whose focus is the best match for your submission.
</p>

<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;color:#4a5568;">
  Nothing changes on your end — review continues from here.
</p>

{{#if dashboardUrl}}
<table role="presentation" cellpadding="0" cellspacing="0" style="margin:24px 0 0 0;">
  <tr>
    <td align="center" style="background-color:#38b2ac;border-radius:8px;">
      <a href="{{dashboardUrl}}" style="display:inline-block;padding:14px 32px;font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;">
        Open Your Dashboard
      </a>
    </td>
  </tr>
</table>
{{/if}}

<p style="margin:24px 0 0 0;font-size:13px;color:#a0aec0;line-height:1.5;">
  Questions? Reply to this email and our team will help.
</p>
