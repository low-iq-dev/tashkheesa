<!-- Doctor Welcome — bilingual founder-signed onboarding email
     Same body shipped in en/ AND ar/ paths (option (a)) so the
     template is language-agnostic at send time; user.lang only
     picks which file the loader reads first.
     Variables: firstName, password_setup_link, expiryDays. -->

<!-- ── العربية ───────────────────────────────────────────────── -->
<div dir="rtl" style="text-align:right;font-family:'Cormorant Garamond','Amiri',Georgia,serif;">
  <h2 style="margin:0 0 18px 0;font-size:22px;font-weight:600;color:#0B6B5F;font-family:'Cormorant Garamond','Amiri',Georgia,serif;">
    أهلاً بك في تشخيصة
  </h2>

  <p style="margin:0 0 16px 0;font-size:16px;line-height:1.8;color:#1F2937;font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">
    د. {{firstName}}،
  </p>

  <p style="margin:0 0 16px 0;font-size:15px;line-height:1.8;color:#1F2937;font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">
    أهلاً بك في تشخيصة، أول منصة في مصر للحصول على رأي طبي ثاني من استشاريين متخصصين.
  </p>

  <p style="margin:0 0 16px 0;font-size:15px;line-height:1.8;color:#1F2937;font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">
    حسابك على البورتال جاهز للاستخدام. يكفي تفعيل كلمة السر للدخول:
  </p>

  {{#if password_setup_link}}
  <table role="presentation" cellpadding="0" cellspacing="0" style="margin:24px 0;">
    <tr>
      <td style="background-color:#0B6B5F;border-radius:8px;">
        <a href="{{{password_setup_link}}}" style="display:inline-block;padding:14px 32px;font-size:15px;font-weight:600;color:#F8F5EF;text-decoration:none;font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">
          👉 تفعيل الحساب
        </a>
      </td>
    </tr>
  </table>
  <p style="margin:0 0 24px 0;font-size:13px;line-height:1.7;color:#6B7280;font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">
    (الرابط صالح لمدة {{expiryDays}} أيام)
  </p>
  {{/if}}

  <p style="margin:0 0 12px 0;font-size:15px;line-height:1.8;color:#1F2937;font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">
    بعد التفعيل، هتدخل على حسابك وتقدر:
  </p>

  <ul style="margin:0 0 20px 0;padding-inline-start:20px;font-size:15px;line-height:1.9;color:#1F2937;font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">
    <li>تستعرض الحالات المتاحة في تخصصك</li>
    <li>تكتب التقارير وترفعها بسهولة</li>
    <li>تتابع أرباحك وجدول الحالات</li>
    <li>تعدّل بياناتك الشخصية والشهادات</li>
  </ul>

  <p style="margin:0 0 16px 0;font-size:15px;line-height:1.8;color:#1F2937;font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">
    الحالات هتوصلك تلقائياً حسب التخصص، وأنت اللي تختار اللي تقبله. هنبدأ تدريجياً، وبتدفع بعد كل تقرير يتم تسليمه.
  </p>

  <p style="margin:0 0 24px 0;font-size:14px;line-height:1.8;color:#1F2937;font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">
    أي سؤال — رد على الرسالة دي أو كلمنا على واتساب:
    <a href="https://wa.me/201102009886" style="color:#0B6B5F;text-decoration:none;font-weight:600;">+20 110 200 9886</a>
  </p>

  <p style="margin:0 0 4px 0;font-size:15px;line-height:1.6;color:#1F2937;font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">
    شكراً لانضمامك،
  </p>
  <p style="margin:0 0 4px 0;font-size:16px;line-height:1.5;color:#0B6B5F;font-weight:600;font-family:'Cormorant Garamond','Amiri',Georgia,serif;">
    زياد الوحش
  </p>
  <p style="margin:0;font-size:13px;line-height:1.5;color:#B38B3E;font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">
    مؤسس تشخيصة
  </p>
</div>

<!-- ── Separator ──────────────────────────────────────────────── -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:36px 0;">
  <tr>
    <td align="center" style="font-size:14px;color:#B38B3E;letter-spacing:8px;font-family:'Inter',-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;">
      — — —
    </td>
  </tr>
</table>

