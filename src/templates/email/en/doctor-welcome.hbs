<!-- Doctor Welcome — Doctor approved (P1-NOTIF-5) -->
<h2 style="margin:0 0 16px 0;font-size:22px;font-weight:700;color:#1a365d;">
  Welcome to the Tashkheesa Medical Network
</h2>

<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;color:#4a5568;">
  Hi Dr. {{doctorName}},
</p>

<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;color:#4a5568;">
  Congratulations — your application has been approved. To get started, set up your portal access using the secure link below.
</p>

{{#if magicLinkUrl}}
<table role="presentation" cellpadding="0" cellspacing="0" style="margin:24px auto 8px auto;">
  <tr>
    <td align="center" style="background-color:#38b2ac;border-radius:8px;">
      <a href="{{magicLinkUrl}}" style="display:inline-block;padding:14px 32px;font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;">
        Set Up Your Account
      </a>
    </td>
  </tr>
</table>
<p style="margin:0 0 24px 0;font-size:13px;line-height:1.5;color:#718096;text-align:center;">
  This one-time link expires in {{expiryDays}} days.
</p>
{{/if}}

<!-- Once you're in -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:24px 0;background-color:#f0fff4;border-radius:8px;border:1px solid #c6f6d5;">
  <tr>
    <td style="padding:20px 24px;">
      <p style="margin:0 0 12px 0;font-size:13px;font-weight:600;color:#276749;text-transform:uppercase;letter-spacing:0.5px;">Once You're In</p>

      <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
        <tr>
          <td style="padding:8px 0;font-size:14px;color:#4a5568;">
            <span style="color:#38a169;font-weight:700;margin-right:8px;">&#10003;</span>
            View incoming cases assigned to your specialty
          </td>
        </tr>
        <tr>
          <td style="padding:8px 0;font-size:14px;color:#4a5568;">
            <span style="color:#38a169;font-weight:700;margin-right:8px;">&#10003;</span>
            Set your availability for video consultations
          </td>
        </tr>
        <tr>
          <td style="padding:8px 0;font-size:14px;color:#4a5568;">
            <span style="color:#38a169;font-weight:700;margin-right:8px;">&#10003;</span>
            Submit medical opinions and detailed reports
          </td>
        </tr>
        <tr>
          <td style="padding:8px 0;font-size:14px;color:#4a5568;">
            <span style="color:#38a169;font-weight:700;margin-right:8px;">&#10003;</span>
            Track your earnings in your doctor dashboard
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>

{{#if portalUrl}}
<p style="margin:24px 0 0 0;font-size:13px;line-height:1.6;color:#718096;">
  If you've already set up your account, you can <a href="{{portalUrl}}" style="color:#2b6cb0;text-decoration:none;">log in directly</a>.
</p>
{{/if}}

<p style="margin:24px 0 0 0;font-size:13px;color:#a0aec0;line-height:1.5;">
  Thank you for joining our mission to make expert medical opinions accessible to everyone. Reply to this email if you have any questions.
</p>
