<!-- Payment Reminder — 30 minutes (soft nudge) -->
<h2 style="margin:0 0 16px 0;font-size:22px;font-weight:600;color:#1a365d;">
  Just a quick reminder
</h2>

<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;color:#4a5568;">
  Hi {{patientName}},
</p>

<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;color:#4a5568;">
  Your case is held with us, waiting for payment to proceed. Whenever you're ready, you can complete it through the link below and a specialist will start your review.
</p>

{{#if caseReference}}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:24px 0;background-color:#ebf8ff;border-radius:8px;border:1px solid #bee3f8;">
  <tr>
    <td style="padding:16px 24px;">
      <p style="margin:0 0 4px 0;font-size:12px;font-weight:600;color:#2b6cb0;text-transform:uppercase;letter-spacing:0.5px;">Reference</p>
      <p style="margin:0;font-size:15px;font-weight:600;color:#2d3748;">{{caseReference}}</p>
    </td>
  </tr>
</table>
{{/if}}

{{#if paymentUrl}}
<table role="presentation" cellpadding="0" cellspacing="0" style="margin:0 auto 24px auto;">
  <tr>
    <td align="center" style="background-color:#2b6cb0;border-radius:8px;">
      <a href="{{paymentUrl}}" style="display:inline-block;padding:14px 32px;font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;">
        Complete Payment
      </a>
    </td>
  </tr>
</table>
{{/if}}

<p style="margin:24px 0 0 0;font-size:13px;color:#718096;line-height:1.5;">
  No rush — your case stays held while we wait. If you need a different payment method or have questions, just reply to this email.
</p>
