<!-- Patient Refund Denied (Theme 7b Phase 3) -->
<h2 style="margin:0 0 16px 0;font-size:22px;font-weight:700;color:#1a365d;">
  Refund Request Reviewed
</h2>
<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;color:#4a5568;">
  Hi {{patientName}},
</p>
<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;color:#4a5568;">
  We've reviewed your refund request and are unable to approve it on this occasion.
</p>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:24px 0;background-color:#fff5f5;border-radius:8px;border:1px solid #feb2b2;">
  <tr>
    <td style="padding:20px 24px;">
      <p style="margin:0 0 8px 0;font-size:13px;font-weight:600;color:#742a2a;text-transform:uppercase;letter-spacing:0.5px;">Reason</p>
      <p style="margin:0;font-size:15px;line-height:1.6;color:#4a5568;">{{denialReason}}</p>
      {{#if caseReference}}
      <p style="margin:12px 0 0 0;font-size:13px;color:#718096;">Case: {{caseReference}}</p>
      {{/if}}
    </td>
  </tr>
</table>
<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;color:#4a5568;">
  If you'd like to discuss this further or have additional context to share, please reply to this email or contact our support team.
</p>
{{#if caseUrl}}
<table role="presentation" cellpadding="0" cellspacing="0" style="margin:0 auto;">
  <tr>
    <td align="center" style="background-color:#718096;border-radius:8px;">
      <a href="{{caseUrl}}" style="display:inline-block;padding:14px 32px;font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;">View Your Case</a>
    </td>
  </tr>
</table>
{{/if}}
