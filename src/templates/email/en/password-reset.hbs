<!-- Password Reset -->
<h2 style="margin:0 0 16px 0;font-size:22px;font-weight:700;color:#1a365d;">
  Reset your password
</h2>

<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;color:#4a5568;">
  Hi {{patientName}},
</p>

<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;color:#4a5568;">
  We received a request to reset the password for your Tashkheesa account. Click the button below to choose a new password. This link expires in {{expiryHours}} hours.
</p>

<table role="presentation" cellpadding="0" cellspacing="0" style="margin:24px auto;">
  <tr>
    <td align="center" style="background-color:#38b2ac;border-radius:8px;">
      <a href="{{resetLink}}" style="display:inline-block;padding:14px 32px;font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;">
        Reset password
      </a>
    </td>
  </tr>
</table>

<p style="margin:16px 0 0 0;font-size:13px;color:#718096;line-height:1.6;word-break:break-all;">
  Or copy and paste this link into your browser:<br>
  <a href="{{resetLink}}" style="color:#2b6cb0;text-decoration:none;">{{resetLink}}</a>
</p>

<p style="margin:24px 0 0 0;font-size:13px;color:#a0aec0;line-height:1.5;">
  If you did not request a password reset, you can safely ignore this email — your password will not change.
</p>
