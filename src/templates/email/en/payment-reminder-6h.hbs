<!-- Payment Reminder — 6 hours (warm urgency) -->
<h2 style="margin:0 0 16px 0;font-size:22px;font-weight:600;color:#1a365d;">
  Your case is waiting
</h2>

<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;color:#4a5568;">
  Hi {{patientName}},
</p>

<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;color:#4a5568;">
  It's been about six hours since you submitted your case. We'd love to start your specialist review — but we need to confirm payment first to begin.
</p>

{{#if caseReference}}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:24px 0;background-color:#fffaf0;border-radius:8px;border:1px solid #feebc8;">
  <tr>
    <td style="padding:16px 24px;">
      <p style="margin:0 0 4px 0;font-size:12px;font-weight:600;color:#c05621;text-transform:uppercase;letter-spacing:0.5px;">Reference</p>
      <p style="margin:0;font-size:15px;font-weight:600;color:#2d3748;">{{caseReference}}</p>
    </td>
  </tr>
</table>
{{/if}}

{{#if paymentUrl}}
<table role="presentation" cellpadding="0" cellspacing="0" style="margin:0 auto 24px auto;">
  <tr>
    <td align="center" style="background-color:#dd6b20;border-radius:8px;">
      <a href="{{paymentUrl}}" style="display:inline-block;padding:14px 32px;font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;">
        Complete Payment
      </a>
    </td>
  </tr>
</table>
{{/if}}

<p style="margin:24px 0 0 0;font-size:13px;color:#718096;line-height:1.5;">
  If you've already paid, this email may have crossed in transit — please ignore it. If you need help with payment options, reply to this email and we'll get back to you.
</p>
