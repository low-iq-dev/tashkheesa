<!-- Payment Reminder — 24 hours (informational, hold-window ending) -->
<h2 style="margin:0 0 16px 0;font-size:22px;font-weight:600;color:#1a365d;">
  A heads-up about your case
</h2>

<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;color:#4a5568;">
  Hi {{patientName}},
</p>

<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;color:#4a5568;">
  Your case has been held with us for 24 hours waiting for payment. To keep things moving, we hold cases for a final {{#if hoursRemaining}}{{hoursRemaining}}{{else}}24{{/if}} hours before the spot is released so another patient can be reviewed.
</p>

{{#if caseReference}}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:24px 0;background-color:#fef5e7;border-radius:8px;border:1px solid #fbd38d;">
  <tr>
    <td style="padding:16px 24px;">
      <p style="margin:0 0 4px 0;font-size:12px;font-weight:600;color:#9c4221;text-transform:uppercase;letter-spacing:0.5px;">Reference</p>
      <p style="margin:0;font-size:15px;font-weight:600;color:#2d3748;">{{caseReference}}</p>
    </td>
  </tr>
</table>
{{/if}}

<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;color:#4a5568;">
  You can still complete payment any time in the next {{#if hoursRemaining}}{{hoursRemaining}}{{else}}24{{/if}} hours and we'll pick up exactly where you left off.
</p>

{{#if paymentUrl}}
<table role="presentation" cellpadding="0" cellspacing="0" style="margin:0 auto 24px auto;">
  <tr>
    <td align="center" style="background-color:#dd6b20;border-radius:8px;">
      <a href="{{paymentUrl}}" style="display:inline-block;padding:14px 32px;font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;">
        Complete Payment
      </a>
    </td>
  </tr>
</table>
{{/if}}

<p style="margin:24px 0 0 0;font-size:13px;color:#718096;line-height:1.5;">
  If you've decided not to proceed, no action needed — your case will be released automatically. You can always start a fresh case whenever you're ready.
</p>
