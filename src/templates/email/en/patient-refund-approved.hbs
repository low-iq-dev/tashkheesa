<!-- Patient Refund Approved (Theme 7b Phase 3) -->
<h2 style="margin:0 0 16px 0;font-size:22px;font-weight:700;color:#1a365d;">
  Refund Approved
</h2>
<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;color:#4a5568;">
  Hi {{patientName}},
</p>
<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;color:#4a5568;">
  Your refund request has been approved. We're now preparing the Instapay payment.
</p>
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin:24px 0;background-color:#f7fafc;border-radius:8px;border:1px solid #e2e8f0;">
  <tr>
    <td style="padding:20px 24px;">
      <p style="margin:0 0 8px 0;font-size:13px;font-weight:600;color:#718096;text-transform:uppercase;letter-spacing:0.5px;">Approved Amount</p>
      <p style="margin:0;font-size:18px;font-weight:700;color:#2d3748;">EGP {{approvedAmount}}</p>
      {{#if caseReference}}
      <p style="margin:12px 0 0 0;font-size:13px;color:#718096;">Case: {{caseReference}}</p>
      {{/if}}
    </td>
  </tr>
</table>
<p style="margin:0 0 16px 0;font-size:15px;line-height:1.6;color:#4a5568;">
  <strong>Expected timeline:</strong> 3-5 business days for the Instapay payment to land in your account. We'll send you another email with the transaction reference when it goes through.
</p>
{{#if caseUrl}}
<table role="presentation" cellpadding="0" cellspacing="0" style="margin:0 auto;">
  <tr>
    <td align="center" style="background-color:#2b6cb0;border-radius:8px;">
      <a href="{{caseUrl}}" style="display:inline-block;padding:14px 32px;font-size:15px;font-weight:600;color:#ffffff;text-decoration:none;">View Your Case</a>
    </td>
  </tr>
</table>
{{/if}}
