<%
  // Create order form. Locals: patients, doctors, specialties, services,
  // defaults (optional), error (optional).
  var isAr = (typeof lang !== 'undefined' && lang === 'ar');
  var _err = (typeof error !== 'undefined' && error) ? error : '';
  var _def = (typeof defaults !== 'undefined' && defaults) ? defaults : {};
  var _patients = (typeof patients !== 'undefined' && patients) ? patients : [];
  var _doctors = (typeof doctors !== 'undefined' && doctors) ? doctors : [];
  var _specialties = (typeof specialties !== 'undefined' && specialties) ? specialties : [];
  var _services = (typeof services !== 'undefined' && services) ? services : [];
  var patientOpts = [{ value: '', label: 'Select patient' }].concat(
    _patients.map(function(p) { return { value: p.id, label: (p.name || 'Patient') + ' – ' + p.email }; })
  );
  var doctorOpts = [{ value: '', label: 'Unassigned (auto-assign if available)' }].concat(
    _doctors.slice().sort(function(a, b) { return (a.name || '').localeCompare(b.name || ''); })
      .map(function(d) { return { value: d.id, label: (d.name || 'Doctor') + ' – ' + d.email }; })
  );
  var specOpts = [{ value: '', label: 'Select specialty' }].concat(
    _specialties.map(function(s) { return { value: s.id, label: s.name }; })
  );
  var svcOpts = [{ value: '', label: 'Select service' }].concat(
    _services.map(function(sv) { return { value: sv.id, label: sv.name + (sv.code ? ' (' + sv.code + ')' : '') }; })
  );
%>
<%- include('partials/superadmin/header', {
      title: 'Create case',
      currentSection: 'orders',
      user: user,
      lang: lang || 'en',
      showTabBar: false,
      sidebarBadges: (typeof sidebarBadges !== 'undefined' && sidebarBadges) ? sidebarBadges : {},
      cspNonce: (typeof cspNonce !== 'undefined') ? cspNonce : ''
    }) %>

<%- include('partials/superadmin/page_header', {
      title: 'Create case',
      subtitle: 'Manually create a case for a patient and assign to a doctor.',
      breadcrumb: [
        { label: 'Dashboard', href: '/superadmin' },
        { label: 'Cases', href: '/superadmin/orders' },
        { label: 'New' }
      ],
      actionsHtml: '<a class="btn" href="/superadmin/orders">Cancel</a>'
    }) %>

<div class="page-body">
  <% if (_err) { %>
    <div class="flash err"><%= _err %></div>
  <% } %>

  <%- include('partials/superadmin/c_card_open', { title: 'Case details' }) %>
    <form method="post" action="/superadmin/orders" style="max-width:880px;">
      <%- (typeof csrfField === 'function') ? csrfField() : '' %>
      <div class="c-form-row">
        <%- include('partials/superadmin/c_form_field', { name: 'patient_id', label: 'Patient', type: 'select', options: patientOpts, required: true, value: String(_def.patient_id || '') }) %>
        <%- include('partials/superadmin/c_form_field', { name: 'doctor_id', label: 'Doctor', type: 'select', options: doctorOpts, value: String(_def.doctor_id || '') }) %>
      </div>
      <div class="c-form-row">
        <%- include('partials/superadmin/c_form_field', { name: 'specialty_id', label: 'Specialty', type: 'select', options: specOpts, required: true, value: String(_def.specialty_id || '') }) %>
        <%- include('partials/superadmin/c_form_field', { name: 'service_id', label: 'Service / test', type: 'select', options: svcOpts, required: true, value: String(_def.service_id || '') }) %>
      </div>
      <div class="c-form-row-3">
        <%- include('partials/superadmin/c_form_field', { name: 'sla_hours', label: 'SLA', type: 'select', required: true, value: String(_def.sla_hours || 48), options: [
              { value: '24', label: '24 hours (VIP)' },
              { value: '48', label: '48 hours (Standard)' }
            ] }) %>
        <%- include('partials/superadmin/c_form_field', { name: 'price', label: 'Price (EGP)', type: 'number', value: String(_def.price || '') }) %>
        <%- include('partials/superadmin/c_form_field', { name: 'doctor_fee', label: 'Doctor fee (EGP)', type: 'number', value: String(_def.doctor_fee || '') }) %>
      </div>
      <%- include('partials/superadmin/c_form_field', { name: 'notes', label: 'Internal notes', type: 'textarea', value: String(_def.notes || ''), rows: 4, help: 'Optional. Visible to the assigned doctor.' }) %>
      <div style="display:flex;gap:8px;justify-content:flex-end;">
        <a class="btn" href="/superadmin/orders">Cancel</a>
        <button type="submit" class="btn primary">Create case</button>
      </div>
    </form>
  <%- include('partials/superadmin/c_card_close') %>
</div>

<%- include('partials/superadmin/footer', { isAr: isAr }) %>
