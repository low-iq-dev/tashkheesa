<%- include('partials/header', { title: (typeof isAr !== 'undefined' && isAr) ? 'الرسائل' : 'Messages', layout: 'portal', showNav: true, portalFrame: true, portalRole: 'doctor', portalActive: 'messages', portalNext: '/portal/doctor/messages' }) %>
<%
  var _isAr = (typeof isAr !== 'undefined') ? !!isAr : false;
  function _t(en, ar) { return _isAr ? ar : en; }
%>
<%- include('partials/doctor/topbar', {
  isAr: _isAr,
  topbarTitle: _t('Messages', 'الرسائل'),
  topbarSub: _t('Patient and referring-physician threads, all in one place', 'محادثات المرضى والأطباء المحوّلين في مكان واحد'),
  topbarShowSearch: false
}) %>

<div class="v2-coming-soon" style="margin-block-end:18px;">
  <div class="v2-coming-soon__glyph">→</div>
  <div>
    <div class="v2-coming-soon__title"><%= _t('Coming in Phase 2', 'قريباً — المرحلة الثانية') %></div>
    <div class="v2-coming-soon__sub"><%= _t('We are building unified secure messaging — patients, referring physicians, and care coordinators in one inbox tied to each case.', 'نعمل على إنشاء نظام رسائل موحّد وآمن يربط المرضى والأطباء ومنسّقي الرعاية بكل حالة.') %></div>
  </div>
</div>

<div class="v2-card">
  <div class="v2-card__body--flush">
    <div class="v2-empty">
      <img src="/icons/empty_states/empty_no_alerts.svg" alt="" onerror="this.style.display='none'" />
      <div class="v2-empty__title"><%= _t('Inbox arrives next sprint', 'صندوق الوارد قريباً') %></div>
      <div class="v2-empty__msg"><%= _t('Until then, urgent patient messages route through your case timeline. Open a case from "Cases" to see and reply to its conversation.', 'حتى ذلك الحين، تُحال الرسائل العاجلة عبر سجل الحالة. افتح أي حالة من "الحالات" لمشاهدة المحادثة والرد.') %></div>
      <div class="v2-empty__actions">
        <a class="v2-btn v2-btn--primary" href="/portal/doctor/cases"><%= _t('Open my cases', 'افتح حالاتي') %></a>
        <a class="v2-btn v2-btn--ghost" href="/portal/doctor/today"><%= _t('Back to Today', 'عُد إلى اليوم') %></a>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
