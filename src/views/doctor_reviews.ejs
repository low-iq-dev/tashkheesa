<%- include('partials/header', { title: 'Reviews', layout: 'portal', showNav: true, portalFrame: true, portalRole: 'doctor', portalActive: 'reviews', portalNext: '/portal/doctor/reviews' }) %>
<%
  var _lang = (typeof lang !== 'undefined') ? lang : 'en';
  var _isAr = (typeof isAr !== 'undefined') ? isAr : false;
  var _reviews = (typeof reviews !== 'undefined' && Array.isArray(reviews)) ? reviews : [];
  var _avgRating = (typeof avgRating !== 'undefined') ? avgRating : 0;
  var _totalReviews = (typeof totalReviews !== 'undefined') ? totalReviews : 0;
  var _distribution = (typeof distribution !== 'undefined' && Array.isArray(distribution)) ? distribution : [];

  function stars(n) {
    var s = '';
    for (var i = 1; i <= 5; i++) {
      s += i <= n
        ? '<span class="dr-star is-on" aria-hidden="true">&#9733;</span>'
        : '<span class="dr-star" aria-hidden="true">&#9733;</span>';
    }
    return s;
  }

  function initials(name) {
    if (!name) return '?';
    var parts = String(name).split(/\s+/).filter(Boolean).slice(0, 2);
    return (parts.map(function(w){ return w.charAt(0); }).join('') || '?').toUpperCase();
  }

  function fmtDate(iso) {
    if (!iso) return '';
    var d = new Date(iso);
    return d.toLocaleDateString(_lang === 'ar' ? 'ar-EG' : 'en-US', { year: 'numeric', month: 'short', day: 'numeric' });
  }

  var _avgRounded = Math.round(Number(_avgRating) || 0);
%>

<link rel="stylesheet" href="/css/doctor-reviews.css" />

<div class="dr-page">

  <div class="dr-header">
    <div class="dr-header-main">
      <h1 class="dr-header-title"><%= _isAr ? 'التقييمات' : 'My Reviews' %></h1>
      <p class="dr-header-sub"><%= _isAr ? 'تقييمات المرضى لخدماتك' : 'Patient ratings for your services' %></p>
    </div>
  </div>

  <!-- Summary card -->
  <section class="dr-summary">
    <div class="dr-summary-score">
      <div class="dr-summary-num"><%= _avgRating %></div>
      <div class="dr-summary-stars"><%- stars(_avgRounded) %></div>
      <div class="dr-summary-count">
        <%= _totalReviews %> <%= _isAr ? (_totalReviews === 1 ? 'تقييم' : 'تقييمات') : (_totalReviews === 1 ? 'review' : 'reviews') %>
      </div>
    </div>
    <div class="dr-summary-dist">
      <% for (var r = 5; r >= 1; r--) {
        var dRow = _distribution.find(function(d) { return d.rating === r; });
        var cnt = dRow ? dRow.count : 0;
        var pct = _totalReviews > 0 ? Math.round((cnt / _totalReviews) * 100) : 0;
      %>
        <div class="dr-dist-row">
          <span class="dr-dist-label"><%= r %>&#9733;</span>
          <div class="dr-dist-track"><div class="dr-dist-fill" style="width: <%= pct %>%;"></div></div>
          <span class="dr-dist-count"><%= cnt %></span>
        </div>
      <% } %>
    </div>
  </section>

  <!-- Reviews list -->
  <section class="dr-list">
    <% if (_reviews.length === 0) { %>
      <div class="dr-empty">
        <div class="dr-empty-k"><%= _isAr ? 'لا توجد تقييمات بعد' : 'No reviews yet' %></div>
        <div class="dr-empty-v"><%= _isAr ? 'ستظهر هنا تقييمات المرضى عند وصولها.' : 'Patient reviews will appear here once they come in.' %></div>
      </div>
    <% } %>
    <% _reviews.forEach(function(rv) {
      var nameDisplay = rv.is_anonymous
        ? (_isAr ? 'مريض مجهول' : 'Anonymous Patient')
        : (rv.patient_name || (_isAr ? 'مريض' : 'Patient'));
      var initialsDisplay = rv.is_anonymous ? '?' : initials(nameDisplay);
    %>
      <article class="dr-card">
        <header class="dr-card-head">
          <div class="dr-card-avatar" aria-hidden="true"><%= initialsDisplay %></div>
          <div class="dr-card-who">
            <div class="dr-card-name"><%= nameDisplay %></div>
            <div class="dr-card-date"><%= fmtDate(rv.created_at) %></div>
          </div>
          <div class="dr-card-stars"><%- stars(rv.rating) %></div>
        </header>
        <% if (rv.review_text) { %>
          <div class="dr-card-text"><%= rv.review_text %></div>
        <% } %>
      </article>
    <% }); %>
  </section>

</div>

<%- include('partials/footer') %>
