<%- include('partials/header', {
  title: (typeof isAr !== 'undefined' && isAr) ? 'الوصفات' : 'Prescriptions',
  layout: 'portal',
  showNav: true,
  portalFrame: true,
  portalRole: 'doctor',
  portalActive: 'prescriptions',
  portalNext: '/portal/doctor/prescriptions'
}) %>
<%
  var _isAr = (typeof isAr !== 'undefined') ? !!isAr : false;
  var _eligible = Array.isArray(typeof eligibleCases !== 'undefined' ? eligibleCases : []) ? eligibleCases : [];
  var _issued   = Array.isArray(typeof prescriptions !== 'undefined' ? prescriptions : []) ? prescriptions : [];
  function _t(en, ar) { return _isAr ? ar : en; }
  function _initials(name) {
    var s = String(name || '').trim();
    if (!s) return '?';
    var parts = s.split(/\s+/).slice(0, 2);
    return parts.map(function(p){ return (p[0] || '').toUpperCase(); }).join('') || '?';
  }
  function _shortId(id) { return String(id || '').slice(0, 8).toUpperCase(); }
  function _humanDate(s) {
    if (!s) return '';
    try { return new Date(s).toLocaleDateString(_isAr ? 'ar-EG' : 'en-US', { year: 'numeric', month: 'short', day: 'numeric' }); }
    catch (_) { return String(s); }
  }
%>

<%- include('partials/doctor/topbar', {
  isAr: _isAr,
  topbarTitle: _t('Prescriptions', 'الوصفات'),
  topbarSub: _t('Cases ready for a prescription, and the prescriptions you have already issued.', 'الحالات الجاهزة لكتابة وصفة، والوصفات التي أصدرتها سابقاً.'),
  topbarShowSearch: false
}) %>

<div class="v2-stack">

  <!-- ============== ELIGIBLE CASES (write a prescription) ============== -->
  <div class="v2-card">
    <div class="v2-card__header">
      <div class="v2-card__title"><%= _t('Cases ready for a prescription', 'حالات جاهزة لوصفة') %></div>
      <span class="v2-card__title-sub" data-numeric><%= _eligible.length %> <%= _t(_eligible.length === 1 ? 'case' : 'cases', 'حالة') %></span>
    </div>
    <% if (!_eligible.length) { %>
      <div class="v2-card__body">
        <div class="v2-empty">
          <div class="v2-empty__title"><%= _t('No cases waiting', 'لا توجد حالات بانتظار وصفة') %></div>
          <div class="v2-empty__msg"><%= _t('When a case you have accepted is ready for a prescription, it will appear here.', 'عند جاهزية حالة قبلتها لكتابة وصفة، ستظهر هنا.') %></div>
          <div class="v2-empty__actions">
            <a class="v2-btn v2-btn--ghost" href="/portal/doctor/cases"><%= _t('View all cases', 'عرض كل الحالات') %></a>
          </div>
        </div>
      </div>
    <% } else { %>
      <div class="v2-card__body v2-card__body--flush">
        <% _eligible.forEach(function(c, idx) { %>
          <a href="/portal/doctor/case/<%= encodeURIComponent(c.id) %>/prescribe" class="rxlist-row" style="text-decoration:none;color:inherit;display:flex;align-items:center;gap:14px;padding:14px 18px;<%= idx > 0 ? 'border-block-start:1px solid var(--v2-rule);' : '' %>">
            <div class="rxlist-row__avatar" style="flex-shrink:0;width:40px;height:40px;border-radius:50%;background:var(--v2-brand-bg);color:var(--v2-brand);display:flex;align-items:center;justify-content:center;font-weight:600;font-size:13px;">
              <%= _initials(c.patient_name) %>
            </div>
            <div style="flex:1;min-width:0;">
              <div style="font-size:14px;font-weight:600;color:var(--v2-ink);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                <%= c.patient_name || _t('Patient', 'مريض') %>
                <span style="font-weight:400;color:var(--v2-muted);font-size:12px;margin-inline-start:8px;">#<%= _shortId(c.id) %></span>
              </div>
              <div style="font-size:12px;color:var(--v2-ink-2);margin-block-start:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                <%= c.service_name || _t('Second-opinion case', 'حالة رأي ثاني') %>
                <% if (c.completed_at) { %>
                  · <%= _t('Report submitted', 'تم إرسال التقرير') %> · <%= _humanDate(c.completed_at) %>
                <% } else { %>
                  · <%= _t('In review', 'قيد المراجعة') %>
                <% } %>
              </div>
            </div>
            <span class="v2-btn v2-btn--brass v2-btn--sm" style="flex-shrink:0;display:inline-flex;align-items:center;gap:6px;pointer-events:none;">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
              <%= _t('Write', 'كتابة') %>
            </span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color:var(--v2-muted);flex-shrink:0;<%= _isAr ? 'transform:scaleX(-1);' : '' %>"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        <% }); %>
      </div>
    <% } %>
  </div>

  <!-- ============== ISSUED PRESCRIPTIONS (history) ============== -->
  <div class="v2-card">
    <div class="v2-card__header">
      <div class="v2-card__title"><%= _t('Issued prescriptions', 'الوصفات المُصدَرة') %></div>
      <span class="v2-card__title-sub" data-numeric><%= _issued.length %> <%= _t(_issued.length === 1 ? 'prescription' : 'prescriptions', 'وصفة') %></span>
    </div>
    <% if (!_issued.length) { %>
      <div class="v2-card__body">
        <div class="v2-empty">
          <div class="v2-empty__title"><%= _t('No prescriptions yet', 'لم تُصدَر وصفات بعد') %></div>
          <div class="v2-empty__msg"><%= _t('Prescriptions you issue will be listed here for your reference.', 'ستظهر الوصفات التي تصدرها هنا للرجوع إليها.') %></div>
        </div>
      </div>
    <% } else { %>
      <div class="v2-card__body v2-card__body--flush">
        <% _issued.forEach(function(rx, idx) { %>
          <a href="/portal/doctor/prescription/<%= encodeURIComponent(rx.id) %>" class="rxlist-row" style="text-decoration:none;color:inherit;display:flex;align-items:center;gap:14px;padding:14px 18px;<%= idx > 0 ? 'border-block-start:1px solid var(--v2-rule);' : '' %>">
            <div style="flex-shrink:0;width:40px;height:40px;border-radius:10px;background:linear-gradient(135deg,var(--v2-brass-light),var(--v2-brass-bg));color:var(--v2-accent);display:flex;align-items:center;justify-content:center;">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            </div>
            <div style="flex:1;min-width:0;">
              <div style="font-size:14px;font-weight:600;color:var(--v2-ink);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                <%= rx.patient_name || _t('Patient', 'مريض') %>
                <span style="font-weight:400;color:var(--v2-muted);font-size:12px;margin-inline-start:8px;">#<%= _shortId(rx.id) %></span>
              </div>
              <div style="font-size:12px;color:var(--v2-ink-2);margin-block-start:2px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                <%= rx.medications_count %> <%= _t(rx.medications_count === 1 ? 'medication' : 'medications', 'دواء') %> · <%= _humanDate(rx.created_at) %>
                <% if (rx.is_active) { %>
                  · <span style="color:var(--v2-success);"><%= _t('Active', 'نشطة') %></span>
                <% } else { %>
                  · <span style="color:var(--v2-muted);"><%= _t('Inactive', 'غير نشطة') %></span>
                <% } %>
              </div>
            </div>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="color:var(--v2-muted);flex-shrink:0;<%= _isAr ? 'transform:scaleX(-1);' : '' %>"><polyline points="9 18 15 12 9 6"/></svg>
          </a>
        <% }); %>
      </div>
    <% } %>
  </div>

</div>

<%- include('partials/footer') %>
