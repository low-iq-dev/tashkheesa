<%- include('partials/header', { title: 'My Analytics', layout: 'portal', showNav: true, portalFrame: true, portalRole: 'doctor', portalActive: 'analytics', portalNext: '/portal/doctor/analytics' }) %>
<%
  const lang = (locals.lang) || 'en';
  const isAr = lang === 'ar';
  const kpis = locals.kpis || {};
  const charts = locals.charts || {};
  const period = locals.period || '30d';
  const recentCases = Array.isArray(locals.recentCases) ? locals.recentCases : [];

  function fmtNum(n) { return typeof n === 'number' ? n.toLocaleString() : '0'; }
  function fmtMoney(n) { return typeof n === 'number' ? n.toLocaleString(undefined, { minimumFractionDigits: 0 }) : '0'; }

  function statusBadgeClass(s) {
    s = String(s || '').toLowerCase();
    if (s === 'completed' || s === 'done') return 'dan-badge dan-badge--completed';
    if (s === 'assigned' || s === 'accepted') return 'dan-badge dan-badge--assigned';
    if (s === 'in_review') return 'dan-badge dan-badge--in-review';
    if (s.includes('breach')) return 'dan-badge dan-badge--breached';
    return 'dan-badge dan-badge--pending';
  }

  var _slaPct = Number(kpis.slaCompliance || 0);
  var _slaIsGood = _slaPct >= 95;
%>

<link rel="stylesheet" href="/css/doctor-analytics.css" />

<%- include('partials/doctor/topbar', {
  isAr: isAr,
  topbarTitle: tt('Analytics', 'Analytics', 'الأداء'),
  topbarSub: tt('Track your performance and revenue', 'Track your performance and revenue', 'تتبع أدائك وإيراداتك'),
  topbarShowSearch: false
}) %>

<div class="doctor-analytics-page">
<div class="dan-page">

  <%# Period toggle — title + subtitle now live in the v2 topbar partial
      above, so we render the period selector on its own row. %>
  <div class="dan-period" role="tablist" aria-label="<%= isAr ? 'الفترة' : 'Period' %>" style="margin-block-end:18px;">
    <a href="?period=7d" role="tab" aria-selected="<%= period === '7d' %>" class="dan-period-btn <%= period === '7d' ? 'is-active' : '' %>">7D</a>
    <a href="?period=30d" role="tab" aria-selected="<%= period === '30d' %>" class="dan-period-btn <%= period === '30d' ? 'is-active' : '' %>">30D</a>
    <a href="?period=90d" role="tab" aria-selected="<%= period === '90d' %>" class="dan-period-btn <%= period === '90d' ? 'is-active' : '' %>">90D</a>
    <a href="?period=12m" role="tab" aria-selected="<%= period === '12m' %>" class="dan-period-btn <%= period === '12m' ? 'is-active' : '' %>">12M</a>
  </div>

  <!-- KPI grid -->
  <div class="dan-kpi-grid">
    <div class="dan-kpi">
      <div class="dan-kpi-label"><%= isAr ? 'حالاتي' : 'My cases' %></div>
      <div class="dan-kpi-value"><%= fmtNum(kpis.totalCases) %></div>
    </div>
    <div class="dan-kpi">
      <div class="dan-kpi-label"><%= isAr ? 'مكتملة' : 'Completed' %></div>
      <div class="dan-kpi-value"><%= fmtNum(kpis.completedCases) %></div>
    </div>
    <div class="dan-kpi">
      <div class="dan-kpi-label"><%= isAr ? 'إيراداتي' : 'My revenue' %></div>
      <div class="dan-kpi-value">
        <%= fmtMoney(kpis.totalRevenue) %>
        <span class="dan-kpi-unit">EGP</span>
      </div>
    </div>
    <div class="dan-kpi dan-kpi--sla">
      <div class="dan-kpi-label"><%= isAr ? 'التزام SLA' : 'SLA compliance' %></div>
      <div class="dan-kpi-value"><%= _slaPct %><span class="dan-kpi-unit">%</span></div>
      <div class="dan-sla-track">
        <div class="dan-sla-fill <%= _slaIsGood ? 'is-good' : 'is-warn' %>" style="width: <%= Math.min(100, _slaPct) %>%;"></div>
      </div>
    </div>
  </div>

  <!-- Charts row -->
  <div class="dan-charts-row">
    <section class="dan-sec">
      <header class="dan-sec-head">
        <span class="dan-sec-num">01</span>
        <span class="dan-sec-label"><%= isAr ? 'الإيرادات الشهرية' : 'Monthly revenue' %></span>
      </header>
      <div class="dan-chart-wrap">
        <% if (charts.monthlyRevenue && charts.monthlyRevenue.length) { %>
          <canvas id="monthlyRevenueChart"></canvas>
        <% } else { %>
          <div class="dan-chart-empty"><%= isAr ? 'لا توجد بيانات بعد' : 'No data yet' %></div>
        <% } %>
      </div>
    </section>

    <section class="dan-sec">
      <header class="dan-sec-head">
        <span class="dan-sec-num">02</span>
        <span class="dan-sec-label"><%= isAr ? 'الحالات حسب التخصص' : 'Cases by specialty' %></span>
      </header>
      <div class="dan-chart-wrap">
        <% if (charts.casesBySpecialty && charts.casesBySpecialty.length) { %>
          <canvas id="casesBySpecialtyChart"></canvas>
        <% } else { %>
          <div class="dan-chart-empty"><%= isAr ? 'لا توجد بيانات بعد' : 'No data yet' %></div>
        <% } %>
      </div>
    </section>
  </div>

  <!-- Recent cases -->
  <section class="dan-sec">
    <header class="dan-sec-head">
      <span class="dan-sec-num">03</span>
      <span class="dan-sec-label"><%= isAr ? 'الحالات الأخيرة' : 'Recent cases' %></span>
      <span class="dan-sec-count"><%= recentCases.length %></span>
    </header>
    <div class="dan-table-wrap">
      <table class="dan-table">
        <thead>
          <tr>
            <th><%= isAr ? 'رقم' : 'ID' %></th>
            <th><%= isAr ? 'المريض' : 'Patient' %></th>
            <th><%= isAr ? 'الخدمة' : 'Service' %></th>
            <th><%= isAr ? 'الحالة' : 'Status' %></th>
            <th><%= isAr ? 'المبلغ' : 'Amount' %></th>
            <th><%= isAr ? 'التاريخ' : 'Date' %></th>
          </tr>
        </thead>
        <tbody>
          <% if (!recentCases.length) { %>
            <tr>
              <td colspan="6">
                <div class="dan-empty">
                  <div class="dan-empty-k"><%= isAr ? 'لا توجد حالات' : 'No cases yet' %></div>
                  <div class="dan-empty-v"><%= isAr ? 'ستظهر هنا أحدث حالاتك المعالجة.' : 'Your most recent cases will show up here.' %></div>
                </div>
              </td>
            </tr>
          <% } else { %>
            <% recentCases.forEach(function(c) { %>
              <tr>
                <td class="dan-cell-strong"><a class="dan-cell-link" href="/portal/doctor/case/<%= c.id %>">#<%= String(c.id).slice(0, 8).toUpperCase() %></a></td>
                <td><%= c.patient_name || '—' %></td>
                <td class="dan-cell-muted"><%= c.service_name || '—' %></td>
                <td><span class="<%= statusBadgeClass(c.status) %>"><%= c.status %></span></td>
                <td class="dan-cell-strong"><%= c.price || 0 %> <span class="dan-cell-muted">EGP</span></td>
                <td class="dan-cell-muted"><%= c.created_at ? new Date(c.created_at).toLocaleDateString() : '—' %></td>
              </tr>
            <% }); %>
          <% } %>
        </tbody>
      </table>
    </div>
  </section>

</div>
</div><%# /.doctor-analytics-page %>

<% var _nonce = (typeof locals !== 'undefined' && locals && (locals.cspNonce || locals.csp_nonce || locals.nonce)) ? String(locals.cspNonce || locals.csp_nonce || locals.nonce) : ''; %>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"<% if (_nonce) { %> nonce="<%= _nonce %>"<% } %>></script>
<script<% if (_nonce) { %> nonce="<%= _nonce %>"<% } %>>
(function() {
  /* Chart.js needs literal color values (can't resolve CSS custom properties
     directly in canvas fills). We pull the v2 design tokens out of the
     :root computedStyle at script-run time, so the chart palette stays in
     sync with the warm-clinical system tokens defined in
     portal-variables.css — no hard-coded hexes. */
  function _v2(token) {
    return getComputedStyle(document.documentElement)
      .getPropertyValue('--v2-' + token)
      .trim();
  }
  /* Donut palette (Cases by Specialty) — ordered by visual prominence:
     brand, accent, info, success, warn, danger, brand-dk, accent-dk. */
  var COLORS = [
    _v2('brand'),
    _v2('accent'),
    _v2('info'),
    _v2('success'),
    _v2('warn'),
    _v2('danger'),
    _v2('brand-dk'),
    _v2('accent-dk')
  ];

  // Monthly Revenue
  var revData = <%- JSON.stringify(charts.monthlyRevenue || []) %>;
  if (revData.length && document.getElementById('monthlyRevenueChart')) {
    new Chart(document.getElementById('monthlyRevenueChart'), {
      type: 'bar',
      data: {
        labels: revData.map(function(r) { return r.month; }),
        datasets: [{
          label: '<%= isAr ? "الإيرادات" : "Revenue" %>',
          data: revData.map(function(r) { return r.revenue; }),
          backgroundColor: _v2('brand'),
          borderRadius: 4
        }]
      },
      options: { responsive: true, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } }
    });
  }

  // Cases by Specialty
  var specData = <%- JSON.stringify(charts.casesBySpecialty || []) %>;
  if (specData.length && document.getElementById('casesBySpecialtyChart')) {
    new Chart(document.getElementById('casesBySpecialtyChart'), {
      type: 'doughnut',
      data: {
        labels: specData.map(function(s) { return s.name; }),
        datasets: [{
          data: specData.map(function(s) { return s.count; }),
          backgroundColor: COLORS.slice(0, specData.length)
        }]
      },
      options: { responsive: true, plugins: { legend: { position: 'bottom' } } }
    });
  }
})();
</script>
<%- include('partials/footer') %>
