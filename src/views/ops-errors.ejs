<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Ops — Error Logs</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #0f0f0f; color: #e0e0e0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, monospace; padding: 20px 24px 40px; font-size: 14px; }
    a { color: #00d4ff; text-decoration: none; }
    a:hover { text-decoration: underline; }
    .header { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #222; padding-bottom: 12px; margin-bottom: 16px; flex-wrap: wrap; gap: 8px; }
    .header h1 { font-size: 18px; letter-spacing: 2px; color: #00d4ff; }
    .header .back { font-size: 13px; color: #888; }
    .filters { display: flex; gap: 6px; margin-bottom: 14px; flex-wrap: wrap; }
    .filters a { background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 3px; padding: 5px 14px; font-size: 12px; color: #888; }
    .filters a.active { border-color: #00d4ff; color: #00d4ff; }
    .filters a:hover { border-color: #555; }
    table { width: 100%; border-collapse: collapse; background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 6px; overflow: hidden; }
    th { text-align: left; font-size: 10px; text-transform: uppercase; letter-spacing: 1px; color: #666; padding: 9px 12px; border-bottom: 1px solid #2a2a2a; }
    td { padding: 8px 12px; border-bottom: 1px solid #1f1f1f; font-size: 12px; }
    tr:last-child td { border-bottom: none; }
    tr.clickable { cursor: pointer; }
    tr.clickable:hover { background: #1f1f1f; }
    tr.lvl-fatal { border-left: 3px solid #8b0000; }
    tr.lvl-error { border-left: 3px solid rgba(255,60,60,0.33); }
    tr.lvl-warn { border-left: 3px solid rgba(255,152,0,0.33); }
    .lvl { font-size: 10px; font-weight: 700; text-transform: uppercase; padding: 2px 6px; border-radius: 3px; }
    .lvl-c-fatal { background: rgba(255,0,0,0.25); color: #ff0000; }
    .lvl-c-error { background: rgba(255,60,60,0.15); color: #ff3c3c; }
    .lvl-c-warn { background: rgba(255,152,0,0.15); color: #ff9800; }
    .lvl-c-info { background: rgba(0,212,255,0.1); color: #00d4ff; }
    .msg { max-width: 500px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; color: #ccc; }
    .url-col { color: #888; max-width: 180px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .time-col { color: #555; white-space: nowrap; }
    .num-col { color: #444; font-size: 11px; }
    .pager { display: flex; gap: 10px; margin-top: 14px; align-items: center; font-size: 12px; color: #666; }
    .pager a { background: #1a1a1a; border: 1px solid #2a2a2a; padding: 5px 12px; border-radius: 3px; font-size: 12px; }
    .pager a:hover { border-color: #555; }
    .empty-msg { background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 6px; padding: 24px; text-align: center; color: #555; }
    .note { font-size: 11px; color: #444; margin-top: 12px; }
  </style>
</head>
<body>
  <div class="header">
    <h1>ERROR LOGS</h1>
    <a href="/ops" class="back">&larr; Back to Dashboard</a>
  </div>

  <div class="filters">
    <a href="/ops/errors"<%= !levelFilter ? ' class="active"' : '' %>>All (<%= totalCount %>)</a>
    <a href="/ops/errors?level=fatal"<%= levelFilter === 'fatal' ? ' class="active"' : '' %>>fatal</a>
    <a href="/ops/errors?level=error"<%= levelFilter === 'error' ? ' class="active"' : '' %>>error</a>
    <a href="/ops/errors?level=warn"<%= levelFilter === 'warn' ? ' class="active"' : '' %>>warn</a>
    <a href="/ops/errors?level=info"<%= levelFilter === 'info' ? ' class="active"' : '' %>>info</a>
  </div>

  <% if (errors.length === 0) { %>
    <div class="empty-msg">No errors found.</div>
  <% } else { %>
    <table>
      <thead>
        <tr>
          <th>#</th>
          <th>Level</th>
          <th>Message</th>
          <th>URL</th>
          <th>Method</th>
          <th>When</th>
        </tr>
      </thead>
      <tbody>
        <% errors.forEach(function(e) {
          var lvlCls = 'lvl-c-' + (e.level || 'info');
          var rowCls = 'lvl-' + (e.level || 'info');
        %>
        <tr class="clickable <%= rowCls %>" onclick="location.href='/ops/errors/<%= e.id %>'">
          <td class="num-col"><%= e.row_num %></td>
          <td><span class="lvl <%= lvlCls %>"><%= e.level %></span></td>
          <td class="msg" title="<%= e.message_short %>"><%= e.message_short || '(no message)' %></td>
          <td class="url-col" title="<%= e.url || '' %>"><%= e.url || '\u2014' %></td>
          <td><%= e.method || '\u2014' %></td>
          <td class="time-col"><%= e.time_ago %></td>
        </tr>
        <% }); %>
      </tbody>
    </table>

    <div class="pager">
      <% if (page > 1) { %>
        <a href="/ops/errors?page=<%= page - 1 %><%= levelFilter ? '&level=' + levelFilter : '' %>">&larr; prev</a>
      <% } %>
      <span>Page <%= page %> of <%= totalPages %> &mdash; showing <%= offset + 1 %>-<%= Math.min(offset + perPage, totalCount) %> of <%= totalCount %></span>
      <% if (page < totalPages) { %>
        <a href="/ops/errors?page=<%= page + 1 %><%= levelFilter ? '&level=' + levelFilter : '' %>">next &rarr;</a>
      <% } %>
    </div>
  <% } %>

  <div class="note">Errors auto-clear after 30 days.</div>
</body>
</html>
