<script>
(function() {
  var total = <%= totalSteps %>;
  var current = 1;
  var isAr = <%= isAr ? 'true' : 'false' %>;

  var steps = document.querySelectorAll('[data-wt-step]');
  var dots = document.querySelectorAll('.wt-dot');
  var connectors = document.querySelectorAll('.wt-connector');
  var prevBtn = document.getElementById('wtPrev');
  var nextBtn = document.getElementById('wtNext');
  var counter = document.getElementById('wtCounter');

  function toArabicNum(n) {
    return String(n).replace(/\d/g, function(d) { return '\u0660\u0661\u0662\u0663\u0664\u0665\u0666\u0667\u0668\u0669'[d]; });
  }

  function goTo(n) {
    if (n < 1 || n > total) return;
    current = n;

    steps.forEach(function(s) { s.classList.remove('active'); });
    var target = document.querySelector('[data-wt-step="' + n + '"]');
    if (target) target.classList.add('active');

    dots.forEach(function(d, i) {
      var step = i + 1;
      d.classList.remove('active', 'done');
      if (step === n) d.classList.add('active');
      else if (step < n) d.classList.add('done');
    });

    connectors.forEach(function(c, i) {
      var step = i + 1;
      if (step < n) c.classList.add('done');
      else c.classList.remove('done');
    });

    prevBtn.disabled = (n === 1);
    if (n === total) {
      nextBtn.textContent = isAr ? 'تم' : 'Done';
    } else {
      nextBtn.innerHTML = (isAr ? 'التالي ' : 'Next ') +
        '<svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><polyline points="' +
        (isAr ? '9 11 3 7 9 3' : '5 3 11 7 5 11') + '"/></svg>';
    }

    counter.textContent = isAr
      ? '\u0627\u0644\u062E\u0637\u0648\u0629 ' + toArabicNum(n) + ' \u0645\u0646 ' + toArabicNum(total)
      : 'Step ' + n + ' of ' + total;

    window.scrollTo({ top: document.querySelector('.wt-indicator').offsetTop - 20, behavior: 'smooth' });
  }

  prevBtn.addEventListener('click', function() { goTo(current - 1); });
  nextBtn.addEventListener('click', function() {
    if (current === total) {
      window.location.href = isAr ? '/help/ar/patient-guide' : '/help/patient-guide';
    } else {
      goTo(current + 1);
    }
  });

  dots.forEach(function(d) {
    d.addEventListener('click', function() {
      goTo(parseInt(d.getAttribute('data-step'), 10));
    });
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'ArrowRight') goTo(current + (isAr ? -1 : 1));
    else if (e.key === 'ArrowLeft') goTo(current + (isAr ? 1 : -1));
  });
})();
</script>

