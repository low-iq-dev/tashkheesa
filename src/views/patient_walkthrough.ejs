<%- include('partials/header', { title: ((typeof lang !== 'undefined' && lang === 'ar') ? "الدليل التفاعلي للمريض" : "Interactive Patient Walkthrough"), layout: "public", showNav: true, showFooter: false }) %>
<%
  const isAr = (typeof lang !== 'undefined' && lang === 'ar');
  const brandSafe = (typeof brand !== 'undefined' && brand) ? brand : 'Tashkheesa';
  const totalSteps = 7;
%>

<style>
  /* ── Walkthrough Layout ── */
  .wt-container {
    max-width: 960px; margin: 0 auto; padding: 32px 20px 60px;
    font-family: 'DM Sans', system-ui, -apple-system, sans-serif;
  }
  .wt-hero { text-align: center; margin-bottom: 32px; }
  .wt-hero h1 { font-size: 1.6rem; font-weight: 800; color: var(--p1-text, #0f172a); margin-bottom: 6px; }
  .wt-hero p { font-size: 0.9rem; color: var(--p1-text2, #64748b); max-width: 520px; margin: 0 auto; }
  .wt-lang-toggle {
    display: inline-flex; align-items: center; gap: 6px; margin-top: 12px;
    font-size: 0.8rem; color: var(--p1-primary, #2563eb); cursor: pointer;
    text-decoration: none; border: 1px solid var(--p1-border, #e2e8f0);
    padding: 4px 14px; border-radius: 6px; background: var(--p1-surface, #fff);
  }
  .wt-lang-toggle:hover { background: var(--p1-primary-light, #eff6ff); }

  /* ── Step Indicator ── */
  .wt-indicator { display: flex; align-items: center; justify-content: center; gap: 0; margin-bottom: 28px; flex-wrap: wrap; }
  .wt-dot-wrap { display: flex; align-items: center; }
  .wt-dot {
    width: 32px; height: 32px; border-radius: 50%; border: 2px solid var(--p1-border, #e2e8f0);
    background: var(--p1-surface, #fff); display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 700; color: var(--p1-text3, #94a3b8); cursor: pointer;
    transition: all 0.2s;
  }
  .wt-dot:hover { border-color: var(--p1-primary, #2563eb); color: var(--p1-primary, #2563eb); }
  .wt-dot.active {
    background: var(--p1-primary, #2563eb); color: #fff;
    border-color: var(--p1-primary, #2563eb); box-shadow: 0 0 0 3px rgba(37,99,235,.18);
  }
  .wt-dot.done { background: #059669; color: #fff; border-color: #059669; }
  .wt-connector { width: 28px; height: 2px; background: var(--p1-border, #e2e8f0); }
  .wt-connector.done { background: #059669; }
  .wt-step-label {
    text-align: center; font-size: 0.7rem; color: var(--p1-text3, #94a3b8);
    margin-top: 4px; max-width: 80px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  /* ── Step Content ── */
  .wt-step { display: none; animation: wtFadeIn 0.3s ease; }
  .wt-step.active { display: block; }
  @keyframes wtFadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }

  .wt-split { display: grid; grid-template-columns: 1.2fr 1fr; gap: 24px; align-items: start; }
  .wt-mockup-col { position: relative; }
  .wt-info-col {}

  .wt-step-tag {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: .5px;
    color: var(--p1-primary, #2563eb); background: var(--p1-primary-light, #eff6ff);
    padding: 4px 12px; border-radius: 6px; margin-bottom: 12px;
  }
  .wt-step-title { font-size: 1.2rem; font-weight: 700; color: var(--p1-text, #0f172a); margin-bottom: 8px; }
  .wt-step-desc { font-size: 0.85rem; color: var(--p1-text2, #64748b); line-height: 1.6; margin-bottom: 16px; }

  /* Annotations */
  .wt-annotations { list-style: none; padding: 0; margin: 0; }
  .wt-annotation {
    display: flex; gap: 10px; align-items: flex-start; margin-bottom: 12px;
    padding: 10px 12px; border-radius: 8px; background: var(--p1-surface, #fff);
    border: 1px solid var(--p1-border, #e2e8f0);
  }
  .wt-ann-num {
    width: 22px; height: 22px; min-width: 22px; border-radius: 50%;
    background: var(--p1-primary, #2563eb); color: #fff; font-size: 11px; font-weight: 700;
    display: flex; align-items: center; justify-content: center; margin-top: 1px;
  }
  .wt-ann-text { font-size: 0.8rem; color: var(--p1-text2, #64748b); line-height: 1.5; }
  .wt-ann-text strong { color: var(--p1-text, #0f172a); }

  .wt-tip {
    background: var(--p1-warn-light, #fffbeb); border: 1px solid #fde68a; border-radius: 8px;
    padding: 10px 14px; font-size: 0.8rem; color: #92400e; margin-top: 12px;
  }

  /* ── Navigation ── */
  .wt-nav {
    display: flex; justify-content: space-between; align-items: center;
    margin-top: 28px; padding-top: 20px; border-top: 1px solid var(--p1-border, #e2e8f0);
  }
  .wt-nav-btn {
    display: inline-flex; align-items: center; gap: 6px; padding: 10px 22px;
    border-radius: 8px; font-size: 0.85rem; font-weight: 600; cursor: pointer;
    border: 1px solid var(--p1-border, #e2e8f0); background: var(--p1-surface, #fff);
    color: var(--p1-text, #0f172a); font-family: inherit; transition: all 0.15s;
  }
  .wt-nav-btn:hover { border-color: var(--p1-primary, #2563eb); color: var(--p1-primary, #2563eb); }
  .wt-nav-btn.primary { background: var(--p1-primary, #2563eb); color: #fff; border-color: var(--p1-primary, #2563eb); }
  .wt-nav-btn.primary:hover { opacity: 0.9; }
  .wt-nav-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .wt-nav-center { font-size: 0.8rem; color: var(--p1-text3, #94a3b8); }

  /* ── Reuse mockup classes from patient guide ── */
  .guide-mockup {
    background: var(--p1-bg, #f1f5f9); border-radius: 10px; overflow: hidden;
    border: 1px solid var(--p1-border, #e2e8f0); font-family: 'DM Sans', sans-serif;
  }
  .mockup-browser-bar {
    background: var(--p1-surface, #f8fafc); border-bottom: 1px solid var(--p1-border, #e2e8f0);
    padding: 6px 10px; display: flex; align-items: center; gap: 5px;
  }
  .mockup-dot { width: 7px; height: 7px; border-radius: 50%; background: #d1d5db; }
  .mockup-dot:first-child { background: #fca5a5; }
  .mockup-dot:nth-child(2) { background: #fcd34d; }
  .mockup-dot:nth-child(3) { background: #86efac; }
  .mockup-url {
    margin-left: 10px; font-size: 10px; color: var(--p1-text3, #94a3b8);
    background: var(--p1-surface, #fff); padding: 2px 10px; border-radius: 4px;
    border: 1px solid var(--p1-border, #e2e8f0);
  }
  .mockup-content {
    padding: 20px; min-height: 220px; display: flex; align-items: center; justify-content: center;
  }
  .mockup-card {
    background: var(--p1-surface, #fff); padding: 20px; border-radius: 10px;
    box-shadow: 0 2px 8px rgba(0,0,0,.05); text-align: center;
  }
  .mockup-input {
    background: var(--p1-bg, #f1f5f9); border: 1px solid var(--p1-border, #e2e8f0); border-radius: 6px;
    padding: 6px 10px; font-size: 10px; color: var(--p1-text3, #94a3b8); margin-bottom: 6px; text-align: left;
  }
  .mockup-btn {
    background: var(--p1-primary, #2563eb); color: #fff; padding: 7px 14px; border-radius: 6px;
    font-size: 11px; font-weight: 600; margin-top: 4px; text-align: center;
  }
  .mockup-btn-outline {
    background: var(--p1-surface, #fff); color: var(--p1-primary, #2563eb); border: 1px solid var(--p1-primary, #2563eb);
    padding: 5px 12px; border-radius: 6px; font-size: 10px; font-weight: 600;
  }
  .mockup-heading { font-size: 12px; font-weight: 700; color: var(--p1-text, #0f172a); margin-bottom: 8px; }
  .mockup-subtext { font-size: 9px; color: var(--p1-text3, #94a3b8); }
  .mockup-form-label { font-size: 9px; font-weight: 600; color: var(--p1-text, #0f172a); margin-bottom: 3px; }
  .mockup-form-group { margin-bottom: 8px; text-align: left; }
  .mockup-textarea {
    background: var(--p1-surface, #fff); border: 1px solid var(--p1-border, #e2e8f0); border-radius: 6px;
    padding: 8px; font-size: 9px; color: var(--p1-text3, #94a3b8); min-height: 40px; text-align: left; width: 100%;
  }
  .mockup-badge { font-size: 7px; padding: 2px 5px; border-radius: 3px; font-weight: 600; }
  .mockup-badge-blue { background: #eff6ff; color: #2563eb; }
  .mockup-badge-green { background: #ecfdf5; color: #059669; }
  .mockup-badge-amber { background: #fffbeb; color: #d97706; }
  .mockup-layout {
    display: flex; min-height: 220px; overflow: hidden;
    background: var(--p1-bg, #f1f5f9); width: 100%;
  }
  .mockup-sidebar {
    width: 110px; min-width: 110px; background: var(--p1-surface, #fff);
    border-right: 1px solid var(--p1-border, #e2e8f0);
    padding: 12px 8px; display: flex; flex-direction: column; gap: 3px;
  }
  .mockup-sidebar-brand { font-size: 11px; font-weight: 700; color: var(--p1-primary, #2563eb); margin-bottom: 8px; padding: 0 4px; }
  .mockup-nav-item { padding: 4px 8px; border-radius: 5px; font-size: 8px; color: var(--p1-text3, #94a3b8); }
  .mockup-nav-item.active { background: var(--p1-primary-light, #eff6ff); color: var(--p1-primary, #2563eb); font-weight: 600; }
  .mockup-main { flex: 1; padding: 12px; overflow: hidden; }
  .mockup-table-row {
    display: flex; align-items: center; gap: 6px; background: var(--p1-surface, #fff);
    border: 1px solid var(--p1-border, #e2e8f0); border-radius: 5px; padding: 5px 8px;
    margin-bottom: 3px; font-size: 9px; color: var(--p1-text2, #64748b);
  }
  .mockup-dropzone {
    border: 2px dashed var(--p1-border, #e2e8f0); border-radius: 10px; padding: 20px;
    text-align: center; background: var(--p1-surface, #fff);
  }
  .mockup-upload-icon {
    width: 36px; height: 36px; border-radius: 10px; background: #eff6ff;
    margin: 0 auto 6px; display: flex; align-items: center; justify-content: center;
  }
  .mockup-service-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 6px; }
  .mockup-service-card {
    background: var(--p1-surface, #fff); border: 1px solid var(--p1-border, #e2e8f0);
    border-radius: 6px; padding: 10px; text-align: center;
  }
  .mockup-service-icon {
    width: 26px; height: 26px; border-radius: 6px;
    margin: 0 auto 4px; display: flex; align-items: center; justify-content: center; font-size: 12px;
  }
  .mockup-service-name { font-size: 8px; font-weight: 600; color: var(--p1-text, #0f172a); }
  .mockup-service-price { font-size: 7px; color: var(--p1-primary, #2563eb); margin-top: 2px; }
  .mockup-timeline { display: flex; flex-direction: column; gap: 0; padding: 0 12px; }
  .mockup-timeline-item {
    display: flex; gap: 10px; align-items: flex-start; position: relative; padding-bottom: 14px;
  }
  .mockup-timeline-dot {
    width: 10px; height: 10px; border-radius: 50%; background: var(--p1-border, #e2e8f0);
    flex-shrink: 0; position: relative; z-index: 1;
  }
  .mockup-timeline-dot.done { background: #059669; }
  .mockup-timeline-dot.active { background: var(--p1-primary, #2563eb); box-shadow: 0 0 0 3px #bfdbfe; }
  .mockup-timeline-item:not(:last-child)::before {
    content: ''; position: absolute; left: 4px; top: 10px; bottom: 0;
    width: 2px; background: var(--p1-border, #e2e8f0);
  }
  .mockup-timeline-text { font-size: 9px; color: var(--p1-text2, #64748b); }
  .mockup-timeline-text strong { color: var(--p1-text, #0f172a); display: block; }
  .mockup-pdf-icon {
    width: 56px; height: 70px; background: var(--p1-surface, #fff); border: 1px solid var(--p1-border, #e2e8f0);
    border-radius: 6px; margin: 0 auto 8px; display: flex; align-items: center;
    justify-content: center; font-size: 9px; font-weight: 700; color: #dc2626; position: relative;
  }
  .mockup-pdf-icon::after {
    content: 'PDF'; position: absolute; bottom: 5px; font-size: 8px;
    background: #fef2f2; padding: 1px 5px; border-radius: 3px;
  }
  .mockup-kpi-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px; margin-bottom: 10px; }
  .mockup-kpi {
    background: var(--p1-surface, #fff); border: 1px solid var(--p1-border, #e2e8f0); border-radius: 6px;
    padding: 6px 8px; border-left: 3px solid var(--p1-primary, #2563eb);
  }
  .mockup-kpi-value { font-size: 14px; font-weight: 700; color: var(--p1-text, #0f172a); }
  .mockup-kpi-label { font-size: 7px; color: var(--p1-text3, #94a3b8); }

  /* ── Onboarding wizard mockup ── */
  .mockup-wizard-bar {
    display: flex; align-items: center; gap: 0; margin-bottom: 12px; padding: 0 4px;
  }
  .mockup-wizard-step {
    display: flex; align-items: center; gap: 4px; font-size: 8px; color: var(--p1-text3, #94a3b8);
  }
  .mockup-wizard-step.active { color: var(--p1-primary, #2563eb); font-weight: 700; }
  .mockup-wizard-step.done { color: #059669; }
  .mockup-wizard-num {
    width: 16px; height: 16px; border-radius: 50%; border: 1.5px solid var(--p1-border, #e2e8f0);
    display: flex; align-items: center; justify-content: center; font-size: 7px; font-weight: 700;
  }
  .mockup-wizard-step.active .mockup-wizard-num {
    background: var(--p1-primary, #2563eb); color: #fff; border-color: var(--p1-primary, #2563eb);
  }
  .mockup-wizard-step.done .mockup-wizard-num {
    background: #059669; color: #fff; border-color: #059669;
  }
  .mockup-wizard-line { width: 20px; height: 1.5px; background: var(--p1-border, #e2e8f0); margin: 0 4px; }
  .mockup-wizard-line.done { background: #059669; }

  /* ── Annotation markers on mockup ── */
  .mockup-marker {
    position: absolute; width: 20px; height: 20px; border-radius: 50%;
    background: var(--p1-primary, #2563eb); color: #fff; font-size: 10px; font-weight: 700;
    display: flex; align-items: center; justify-content: center; z-index: 2;
    box-shadow: 0 2px 6px rgba(37,99,235,.3); animation: wtPulse 2s infinite;
  }
  @keyframes wtPulse { 0%, 100% { box-shadow: 0 2px 6px rgba(37,99,235,.3); } 50% { box-shadow: 0 2px 12px rgba(37,99,235,.5); } }

  /* ── Responsive ── */
  @media (max-width: 700px) {
    .wt-split { grid-template-columns: 1fr; }
    .wt-indicator { gap: 0; }
    .wt-connector { width: 16px; }
    .wt-dot { width: 28px; height: 28px; font-size: 11px; }
    .mockup-layout { flex-direction: column; }
    .mockup-sidebar { width: 100%; min-width: 100%; flex-direction: row; flex-wrap: wrap; border-right: none; border-bottom: 1px solid var(--p1-border, #e2e8f0); }
    .mockup-service-grid { grid-template-columns: 1fr; }
    .mockup-kpi-row { grid-template-columns: repeat(2, 1fr); }
    .wt-hero h1 { font-size: 1.3rem; }
  }

  @media print {
    .wt-nav, .wt-indicator, .wt-lang-toggle, .site-header { display: none !important; }
    .wt-step { display: block !important; page-break-inside: avoid; margin-bottom: 24px; }
  }
</style>

<div class="wt-container" dir="<%= isAr ? 'rtl' : 'ltr' %>">
  <!-- Hero -->
  <div class="wt-hero">
    <h1><%= isAr ? 'كيف تقدم حالة طبية على تشخيصة' : 'How to Submit a Medical Case on Tashkheesa' %></h1>
    <p><%= isAr ? 'دليل مرئي تفاعلي يأخذك خطوة بخطوة من التسجيل حتى استلام تقرير الأخصائي' : 'An interactive visual guide walking you through each step — from registration to receiving your specialist report' %></p>
    <a class="wt-lang-toggle" href="<%= isAr ? '/help/patient-walkthrough' : '/help/ar/patient-walkthrough' %>"><%= isAr ? 'English' : 'العربية' %></a>
  </div>

  <!-- Step Indicator -->
  <div class="wt-indicator" id="wtIndicator">
    <% const dotLabels = isAr
      ? ['التسجيل', 'الملف الشخصي', 'حالة جديدة', 'الدفع', 'متابعة', 'ملفات إضافية', 'التقرير']
      : ['Register', 'Onboarding', 'New Case', 'Payment', 'Track', 'More Files', 'Report'];
    for (let i = 1; i <= totalSteps; i++) { %>
      <div class="wt-dot-wrap">
        <div style="display:flex;flex-direction:column;align-items:center;">
          <div class="wt-dot<%= i === 1 ? ' active' : '' %>" data-step="<%= i %>"><%= i %></div>
          <div class="wt-step-label"><%= dotLabels[i - 1] %></div>
        </div>
      </div>
      <% if (i < totalSteps) { %><div class="wt-connector" data-conn="<%= i %>"></div><% } %>
    <% } %>
  </div>

  <!-- ═══════════════════════════════════════ -->
  <!-- STEP 1: Register & Login               -->
  <!-- ═══════════════════════════════════════ -->
  <div class="wt-step active" data-wt-step="1">
    <div class="wt-split">
      <div class="wt-mockup-col" style="position:relative;">
        <div class="guide-mockup">
          <div class="mockup-browser-bar">
            <span class="mockup-dot"></span><span class="mockup-dot"></span><span class="mockup-dot"></span>
            <span class="mockup-url">tashkheesa.com/register</span>
          </div>
          <div class="mockup-content">
            <div class="mockup-card" style="width:240px;">
              <div style="font-weight:700;color:var(--p1-primary,#2563eb);font-size:16px;margin-bottom:2px;"><%= brandSafe %></div>
              <div style="font-size:9px;color:var(--p1-text3,#94a3b8);margin-bottom:14px;"><%= isAr ? 'إنشاء حساب جديد' : 'Create your account' %></div>
              <div class="mockup-input"><%= isAr ? 'الاسم الكامل' : 'Full Name' %></div>
              <div class="mockup-input"><%= isAr ? 'البريد الإلكتروني' : 'Email address' %></div>
              <div class="mockup-input"><%= isAr ? 'رقم الهاتف' : 'Phone number' %></div>
              <div class="mockup-input"><%= isAr ? 'كلمة المرور' : 'Password' %></div>
              <div class="mockup-btn" style="width:100%;"><%= isAr ? 'إنشاء حساب' : 'Create Account' %></div>
              <div style="margin-top:10px;font-size:9px;color:var(--p1-text3,#94a3b8);">
                <%= isAr ? 'لديك حساب بالفعل؟' : 'Already have an account?' %>
                <span style="color:var(--p1-primary,#2563eb);font-weight:600;"><%= isAr ? 'سجل دخول' : 'Sign in' %></span>
              </div>
            </div>
          </div>
        </div>
      </div>
      <div class="wt-info-col">
        <div class="wt-step-tag"><%= isAr ? 'الخطوة ١ من ٧' : 'Step 1 of 7' %></div>
        <h2 class="wt-step-title"><%= isAr ? 'التسجيل وتسجيل الدخول' : 'Register & Login' %></h2>
        <p class="wt-step-desc"><%= isAr
          ? 'أنشئ حسابك على تشخيصة بإدخال اسمك وبريدك الإلكتروني ورقم هاتفك وكلمة مرور. إذا كان لديك حساب بالفعل، سجل دخولك مباشرة.'
          : 'Create your Tashkheesa account by entering your name, email, phone, and a password. If you already have an account, simply sign in.' %></p>
        <ul class="wt-annotations">
          <li class="wt-annotation">
            <span class="wt-ann-num">1</span>
            <span class="wt-ann-text"><strong><%= isAr ? 'نموذج التسجيل' : 'Registration form' %></strong> — <%= isAr ? 'أدخل بياناتك الأساسية: الاسم، البريد، الهاتف، وكلمة المرور' : 'Enter your basic details: name, email, phone, and password' %></span>
          </li>
          <li class="wt-annotation">
            <span class="wt-ann-num">2</span>
            <span class="wt-ann-text"><strong><%= isAr ? 'رابط تسجيل الدخول' : 'Sign-in link' %></strong> — <%= isAr ? 'إذا كنت مسجلاً مسبقاً، اضغط هنا للانتقال لصفحة تسجيل الدخول' : 'If you already have an account, click here to go to the login page' %></span>
          </li>
          <li class="wt-annotation">
            <span class="wt-ann-num">3</span>
            <span class="wt-ann-text"><strong><%= isAr ? 'تأكيد البريد' : 'Email verification' %></strong> — <%= isAr ? 'ستصلك رسالة تأكيد على بريدك الإلكتروني — اضغط على الرابط لتفعيل حسابك' : 'You\'ll receive a verification email — click the link to activate your account' %></span>
          </li>
        </ul>
        <div class="wt-tip"><%= isAr ? 'نصيحة: استخدم بريداً إلكترونياً تتفقده بانتظام — سنرسل لك إشعارات مهمة عن حالتك عليه.' : 'Tip: Use an email you check regularly — we\'ll send important case notifications there.' %></div>
      </div>
    </div>
  </div>

  <!-- ═══════════════════════════════════════ -->
  <!-- STEP 2: Complete Onboarding             -->
  <!-- ═══════════════════════════════════════ -->
  <div class="wt-step" data-wt-step="2">
    <div class="wt-split">
      <div class="wt-mockup-col">
        <div class="guide-mockup">
          <div class="mockup-browser-bar">
            <span class="mockup-dot"></span><span class="mockup-dot"></span><span class="mockup-dot"></span>
            <span class="mockup-url">tashkheesa.com/onboarding</span>
          </div>
