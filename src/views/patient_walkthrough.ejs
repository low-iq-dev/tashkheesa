                <svg width="22" height="22" fill="none" stroke="#dc2626" stroke-width="2"><path d="M5 2h8l5 5v13a2 2 0 01-2 2H5a2 2 0 01-2-2V4a2 2 0 012-2z"/><polyline points="12 2 12 7 17 7"/></svg>
              </div>
              <div style="font-size:10px;font-weight:600;color:var(--p1-text,#0f172a);margin-bottom:2px;"><%= isAr ? 'تقرير الأخصائي جاهز' : 'Specialist Report Ready' %></div>
              <div style="font-size:8px;color:var(--p1-text3,#94a3b8);margin-bottom:10px;">report-42.pdf (1.2 MB)</div>
              <div class="mockup-btn" style="display:inline-block;"><%= isAr ? 'تحميل التقرير' : 'Download Report' %></div>
              <div style="margin-top:8px;">
                <div class="mockup-btn-outline" style="display:inline-block;"><%= isAr ? 'عرض التقرير' : 'View Report' %></div>
              </div>
