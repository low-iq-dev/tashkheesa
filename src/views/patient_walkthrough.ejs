      <%= isAr ? 'السابق' : 'Previous' %>
    </button>
    <span class="wt-nav-center" id="wtCounter"><%= isAr ? 'الخطوة ١ من ٧' : 'Step 1 of 7' %></span>
    <button class="wt-nav-btn primary" id="wtNext">
      <%= isAr ? 'التالي' : 'Next' %>
      <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><polyline points="<%= isAr ? '9 11 3 7 9 3' : '5 3 11 7 5 11' %>"/></svg>
    </button>
