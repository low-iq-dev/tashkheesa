      <div class="wt-mockup-col">
        <div class="guide-mockup">
          <div class="mockup-browser-bar">
            <span class="mockup-dot"></span><span class="mockup-dot"></span><span class="mockup-dot"></span>
            <span class="mockup-url">tashkheesa.com/patient/orders/42</span>
          </div>
          <div class="mockup-layout">
            <div class="mockup-sidebar">
              <div class="mockup-sidebar-brand"><%= brandSafe %></div>
              <div class="mockup-nav-item"><%= isAr ? 'لوحة التحكم' : 'Dashboard' %></div>
              <div class="mockup-nav-item active"><%= isAr ? 'حالاتي' : 'My Cases' %></div>
            </div>
            <div class="mockup-main" style="text-align:center;padding:16px;">
              <div style="display:inline-block;background:#ecfdf5;color:#059669;font-size:9px;font-weight:700;padding:3px 10px;border-radius:10px;margin-bottom:10px;"><%= isAr ? 'مكتملة' : 'Completed' %></div>
