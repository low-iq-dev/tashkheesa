<%- include('partials/header', { title: "Forgot Password", layout: "auth", showNav: false, showFooter: false }) %>
<% const C = (typeof copy !== 'undefined' && copy) ? copy : {}; %>
<%
  const currentLang = ((typeof lang !== 'undefined' && lang) ? lang : ((typeof isAr !== 'undefined' && isAr) ? 'ar' : 'en'));
  const isArabicUi = (currentLang === 'ar') || (typeof isAr !== 'undefined' && isAr);
  const nextEn = encodeURIComponent('/forgot-password?lang=en');
  const nextAr = encodeURIComponent('/forgot-password?lang=ar');
  const __submittedEmail = (typeof submittedEmail === 'string' && submittedEmail) ? submittedEmail : '';
  const __isSuccess = !!(typeof info !== 'undefined' && info);
  const __nonce = (typeof cspNonce !== 'undefined' && cspNonce) ? String(cspNonce) : '';
%>
  <div class="auth-page">
    <div class="auth-card">

      <% if (__isSuccess) { %>
        <%# ── Success state — replaces the form so the user can't accidentally re-submit ── %>
        <div class="auth-header">
          <div aria-hidden="true" style="width:56px;height:56px;border-radius:999px;background:#E6F4F0;color:#0B6B5F;display:flex;align-items:center;justify-content:center;margin:0 auto 16px;font-size:28px;font-weight:700;line-height:1;">&#10003;</div>
          <h1><%= C.forgot_success_title || (isArabicUi ? 'تحقق من بريدك الإلكتروني' : 'Check your inbox') %></h1>
          <p><%= C.forgot_info || (isArabicUi ? 'إذا كان هناك حساب بهذا البريد الإلكتروني، ستصلك رسالة لإعادة تعيين كلمة المرور.' : 'If an account exists for this email, you will receive a reset link.') %></p>
        </div>

        <% if (__submittedEmail) { %>
          <div style="margin:8px 0 16px;padding:12px 16px;background:#F7FAFC;border:1px solid #E2E8F0;border-radius:8px;text-align:center;font-family:ui-monospace,SFMono-Regular,Menlo,Consolas,monospace;font-size:14px;color:#1A365D;word-break:break-all;">
            <%= __submittedEmail %>
          </div>
        <% } %>

        <p style="text-align:center;font-size:13px;color:#718096;margin:0 0 20px;">
          <%= C.forgot_success_expiry || (isArabicUi ? 'تنتهي صلاحية الرابط خلال ساعتين.' : 'The link expires in 2 hours.') %>
        </p>

        <div class="auth-actions">
          <a class="btn btn-primary btn-full" href="/login?lang=<%= isArabicUi ? 'ar' : 'en' %>" style="text-align:center;text-decoration:none;display:inline-block;">
            <%= C.forgot_back_to_login || (isArabicUi ? 'العودة لتسجيل الدخول' : 'Back to login') %>
          </a>
        </div>

      <% } else { %>
        <%# ── Form state ── %>
        <div class="auth-header">
          <h1><%= (C.forgotPasswordTitle) ? C.forgotPasswordTitle : ((typeof isAr !== 'undefined' && isAr) ? 'هل نسيت كلمة المرور؟' : 'Forgot your password?') %></h1>
          <p><%= (C.forgotPasswordSubtitle) ? C.forgotPasswordSubtitle : ((typeof isAr !== 'undefined' && isAr) ? 'أدخل بريدك الإلكتروني وسنرسل لك رابط إعادة التعيين.' : "Enter your email and we’ll send you a reset link.") %></p>
        </div>

        <div class="auth-actions">
          <a href="/lang/en?next=<%= nextEn %>">EN</a>
          <a href="/lang/ar?next=<%= nextAr %>">AR</a>
        </div>

        <%
          const isArabic = ((typeof isAr !== 'undefined' && isAr) || ((typeof lang !== 'undefined' && lang) === 'ar'));
          const msgMapAr = {
            "Please enter your email.": "يرجى إدخال بريدك الإلكتروني.",
            "Please enter a valid email address.": "يرجى إدخال بريد إلكتروني صحيح.",
            "Too many attempts. Please try again later.": "محاولات كثيرة. يرجى المحاولة لاحقًا.",
            "Something went wrong. Please try again.": "حدث خطأ ما. يرجى المحاولة مرة أخرى."
          };
          function localizeServerMessage(msg) {
            if (!msg) return msg;
            if (!isArabic) return msg;
            return msgMapAr[msg] || msg;
          }
        %>

        <% if (typeof error !== 'undefined' && error) { %>
          <div class="auth-actions">
            <p><%= localizeServerMessage(error) %></p>
          </div>
        <% } %>

        <form id="forgot-form" method="post" action="/forgot-password?lang=<%= (isArabicUi ? 'ar' : 'en') %>">
          <%- (typeof csrfField === 'function') ? csrfField() : '' %>

          <div class="form-group">
            <label class="form-label"><%= (C.emailLabel) ? C.emailLabel : ((typeof isAr !== 'undefined' && isAr) ? 'البريد الإلكتروني' : 'Email') %></label>
            <input class="form-control" type="email" name="email" autocomplete="email"
                   placeholder="<%= C.forgot_email_placeholder || 'you@example.com' %>" required />
          </div>

          <div class="auth-actions">
            <button id="forgot-submit" class="btn btn-primary btn-full" type="submit"
                    data-label="<%= (C.sendResetLinkCta) ? C.sendResetLinkCta : ((typeof isAr !== 'undefined' && isAr) ? 'إرسال رابط إعادة التعيين' : 'Send reset link') %>"
                    data-sending="<%= C.forgot_sending || (isArabicUi ? 'جارٍ الإرسال…' : 'Sending…') %>">
              <%= (C.sendResetLinkCta) ? C.sendResetLinkCta : ((typeof isAr !== 'undefined' && isAr) ? 'إرسال رابط إعادة التعيين' : 'Send reset link') %>
            </button>
          </div>
        </form>

        <div class="auth-actions">
          <a href="/login?lang=<%= (isArabicUi ? 'ar' : 'en') %>"><%= (C.backToLoginLink) ? C.backToLoginLink : ((typeof isAr !== 'undefined' && isAr) ? 'العودة لتسجيل الدخول' : 'Back to login') %></a>
        </div>

        <script<% if (__nonce) { %> nonce="<%= __nonce %>"<% } %>>
          (function () {
            var form = document.getElementById('forgot-form');
            var btn  = document.getElementById('forgot-submit');
            if (!form || !btn) return;
            form.addEventListener('submit', function () {
              if (typeof form.checkValidity === 'function' && !form.checkValidity()) return;
              var sending = btn.getAttribute('data-sending');
              if (sending) btn.textContent = sending;
              btn.disabled = true;
              btn.setAttribute('aria-busy', 'true');
            });
          })();
        </script>

      <% } %>

    </div>
  </div>

<%- include('partials/footer', { showFooter: false }) %>
