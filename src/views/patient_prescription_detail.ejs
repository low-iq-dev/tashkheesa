<%
  // Patient prescription detail — V2 chrome.
  // Locals from src/routes/patient.js / prescriptions.js:
  //   prescription   — { id, doctor_name, specialty_name, created_at, order_id, pdf_url, notes, ... }
  //   pdfIsImage     — boolean (computed by route from original storage key)
  //   pdfIsPdf       — boolean (computed by route from original storage key)
  //   user, lang, isAr, brand
  //   pageTitle      — optional

  var _lang = (typeof lang !== 'undefined') ? lang : 'en';
  var isAr = (typeof isAr !== 'undefined') ? isAr : (String(_lang).toLowerCase() === 'ar');
  var __isAr = isAr;
  var __lang = _lang;
  function L(en, ar) { return isAr ? ar : en; }

  var _rx = (typeof prescription !== 'undefined') ? prescription : {};

  function fmtDate(iso) {
    if (!iso) return '';
    try {
      var d = new Date(iso);
      if (isNaN(d.getTime())) return String(iso);
      return d.toLocaleDateString(_lang === 'ar' ? 'ar-EG' : 'en-US', { year: 'numeric', month: 'long', day: 'numeric' });
    } catch (e) { return String(iso); }
  }

  // Phase 3: pdf_url is a signed-URL endpoint after the R2 migration, so
  // extension can no longer be inferred from it. The route computes these
  // flags from the original storage key and passes them in.
  var isImage = !!(typeof pdfIsImage !== 'undefined' ? pdfIsImage : (_rx.pdf_url && /\.(jpg|jpeg|png|webp|heic)$/i.test(_rx.pdf_url)));
  var isPdf = !!(typeof pdfIsPdf !== 'undefined' ? pdfIsPdf : (_rx.pdf_url && /\.pdf$/i.test(_rx.pdf_url)));
%>
<%- include('partials/patient/head', {
  active: 'prescriptions',
  title: L('Prescription Details', 'تفاصيل الوصفة'),
  user: (typeof user !== 'undefined' ? user : {}),
  lang: __lang,
  bodyClass: 'p-page-prescription-detail'
}) %>

<%- include('partials/patient/topbar', {
  title: L('Prescription Details', 'تفاصيل الوصفة الطبية'),
  sub:   (L('Dr. ', 'د. ') + (_rx.doctor_name || '-') + (_rx.created_at ? ' — ' + fmtDate(_rx.created_at) : '')),
  serif: false,
  isAr:  __isAr,
  hideBell: false
}) %>

<%# Chrome (sidebar, topbar, tabbar, .p-btn) is already hidden by the global
    @media print rules in patient-portal-v2.css, so no per-page print block
    is needed. %>

<div class="rxd-action-bar" style="display:flex;gap:0.5rem;margin-bottom:1rem;flex-wrap:wrap;">
  <a href="/portal/patient/prescriptions" class="p-btn p-btn--secondary">← <%= L('Back', 'العودة') %></a>
  <% if (_rx.pdf_url) { %>
    <a href="/portal/patient/prescription/<%= _rx.id %>/download" class="p-btn p-btn--primary"><%= L('Download', 'تحميل') %></a>
  <% } %>
  <a href="javascript:window.print()" class="p-btn p-btn--secondary"><%= L('Print', 'طباعة') %></a>
</div>

<div class="p-card" style="margin-bottom:1rem;padding:18px;">
  <div class="section-head">
    <span class="section-title"><%= L('Prescription Info', 'معلومات الوصفة') %></span>
  </div>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
    <div>
      <label><%= L('Doctor', 'الطبيب') %></label>
      <span style="display:block;font-size:0.88rem;font-weight:500;color:var(--ink);"><%= L('Dr. ', 'د. ') %><%= _rx.doctor_name || '-' %></span>
    </div>
    <div>
      <label><%= L('Specialty', 'التخصص') %></label>
      <span style="display:block;font-size:0.88rem;font-weight:500;color:var(--ink);"><%= _rx.specialty_name || '-' %></span>
    </div>
    <div>
      <label><%= L('Date', 'التاريخ') %></label>
      <span style="display:block;font-size:0.88rem;font-weight:500;color:var(--ink);"><%= fmtDate(_rx.created_at) || '-' %></span>
    </div>
    <div>
      <label><%= L('Case', 'الحالة') %></label>
      <span style="display:block;font-size:0.88rem;font-weight:500;color:var(--ink);"><%= _rx.order_id ? String(_rx.order_id).slice(0, 8) : '-' %></span>
    </div>
  </div>
</div>

<% if (_rx.pdf_url) { %>
  <div class="p-card" style="margin-bottom:1rem;padding:18px;">
    <div class="section-head">
      <span class="section-title"><%= L('Prescription File', 'ملف الوصفة') %></span>
    </div>
    <div style="text-align:center;">
      <% if (isImage) { %>
        <img src="<%= _rx.pdf_url %>" alt="<%= L('Prescription image', 'صورة الوصفة') %>" style="max-width:100%;border-radius:var(--r-sm);border:1px solid var(--rule);" />
      <% } else if (isPdf) { %>
        <iframe src="<%= _rx.pdf_url %>" title="<%= L('Prescription PDF', 'ملف الوصفة') %>" style="width:100%;height:500px;border:1px solid var(--rule);border-radius:var(--r-sm);"></iframe>
      <% } else { %>
        <a href="<%= _rx.pdf_url %>" target="_blank" rel="noopener" class="p-btn p-btn--primary"><%= L('Open File', 'فتح الملف') %></a>
      <% } %>
    </div>
  </div>
<% } %>

<% if (_rx.notes) { %>
  <div class="p-card" style="padding:18px;">
    <div class="section-head">
      <span class="section-title"><%= L("Doctor's Notes", 'ملاحظات الطبيب') %></span>
    </div>
    <p style="margin:0;font-size:0.88rem;color:var(--ink-2);line-height:1.7;"><%= _rx.notes %></p>
  </div>
<% } %>

<%- include('partials/patient/foot', { active: 'prescriptions', isAr: __isAr }) %>
