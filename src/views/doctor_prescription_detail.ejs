<%- include('partials/header', {
  title: (typeof isAr !== 'undefined' && isAr) ? 'تفاصيل الوصفة' : 'Prescription Details',
  layout: 'portal',
  showNav: true,
  portalFrame: true,
  portalRole: 'doctor',
  portalActive: 'prescriptions',
  portalNext: '/portal/doctor/prescriptions'
}) %>
<%
  var _isAr = (typeof isAr !== 'undefined') ? !!isAr : false;
  var _rx = (typeof prescription !== 'undefined' && prescription) ? prescription : {};
  var _meds = Array.isArray(typeof medications !== 'undefined' ? medications : []) ? medications : [];
  var _pdfIsImage = !!(typeof pdfIsImage !== 'undefined' && pdfIsImage);
  var _pdfIsPdf = !!(typeof pdfIsPdf !== 'undefined' && pdfIsPdf);
  function _t(en, ar) { return _isAr ? ar : en; }
  function _initials(name) {
    var s = String(name || '').trim();
    if (!s) return '?';
    var parts = s.split(/\s+/).slice(0, 2);
    return parts.map(function(p){ return (p[0] || '').toUpperCase(); }).join('') || '?';
  }
  function _humanDate(s) {
    if (!s) return '';
    try { return new Date(s).toLocaleDateString(_isAr ? 'ar-EG' : 'en-US', { year: 'numeric', month: 'short', day: 'numeric' }); }
    catch (_) { return String(s); }
  }
  function _val(v) { return v == null ? '' : String(v); }
  function _shortId(id) { return String(id || '').slice(0, 8).toUpperCase(); }
  var _patientAge = (function(){
    if (!_rx.patient_dob) return null;
    try {
      var d = new Date(_rx.patient_dob);
      var diff = (Date.now() - d.getTime()) / (365.25 * 24 * 3600 * 1000);
      return Math.floor(diff);
    } catch (_) { return null; }
  })();
%>

<%- include('partials/doctor/topbar', {
  isAr: _isAr,
  topbarTitle: _t('Prescription', 'الوصفة') + ' #' + _shortId(_rx.id),
  topbarSub: _t('Issued', 'صادرة في') + ' ' + _humanDate(_rx.created_at),
  topbarShowSearch: false,
  topbarActions: '<a class="v2-btn v2-btn--ghost" href="/portal/doctor/prescriptions">' + (_isAr ? '→ الرجوع للقائمة' : '← Back to list') + '</a>'
}) %>

<div class="v2-stack">

  <!-- Patient header card -->
  <div class="v2-card">
    <div class="v2-card__body" style="display:flex;gap:16px;align-items:center;">
      <div style="flex-shrink:0;width:56px;height:56px;border-radius:50%;background:var(--v2-brand-bg);color:var(--v2-brand);display:flex;align-items:center;justify-content:center;font-size:18px;font-weight:600;">
        <%= _initials(_rx.patient_name) %>
      </div>
      <div style="flex:1;min-width:0;">
        <div style="font-size:18px;font-weight:600;color:var(--v2-ink);"><%= _val(_rx.patient_name) || _t('Patient', 'مريض') %></div>
        <div style="font-size:13px;color:var(--v2-ink-2);margin-block-start:4px;display:flex;flex-wrap:wrap;gap:14px;">
          <% if (_patientAge != null) { %>
            <span><%= _patientAge %> <%= _t('years', 'سنة') %></span>
          <% } %>
          <% if (_rx.patient_gender) { %>
            <span><%= _t(String(_rx.patient_gender).charAt(0).toUpperCase() + String(_rx.patient_gender).slice(1), _val(_rx.patient_gender)) %></span>
          <% } %>
          <% if (_rx.service_name) { %>
            <span><%= _rx.service_name %></span>
          <% } %>
        </div>
      </div>
      <% if (_rx.order_id) { %>
        <a class="v2-btn v2-btn--secondary v2-btn--sm" href="/portal/doctor/case/<%= encodeURIComponent(_rx.order_id) %>" style="text-decoration:none;flex-shrink:0;">
          <%= _t('Open case', 'فتح الحالة') %>
        </a>
      <% } %>
    </div>
  </div>

  <!-- Diagnosis (if recorded) -->
  <% if (_rx.diagnosis) { %>
    <div class="v2-card">
      <div class="v2-card__header">
        <div class="v2-card__title"><%= _t('Diagnosis', 'التشخيص') %></div>
      </div>
      <div class="v2-card__body" style="font-size:14px;color:var(--v2-ink);line-height:1.6;white-space:pre-wrap;">
        <%= _rx.diagnosis %>
      </div>
    </div>
  <% } %>

  <!-- Medications -->
  <div class="v2-card">
    <div class="v2-card__header">
      <div class="v2-card__title"><%= _t('Medications', 'الأدوية') %></div>
      <span class="v2-card__title-sub" data-numeric><%= _meds.length %></span>
    </div>
    <% if (!_meds.length) { %>
      <div class="v2-card__body">
        <div style="color:var(--v2-ink-2);font-size:13px;"><%= _t('No medications recorded. The prescription may have been uploaded as a file only.', 'لا توجد أدوية مسجَّلة. ربما تم رفع الوصفة كملف فقط.') %></div>
      </div>
    <% } else { %>
      <div class="v2-card__body v2-card__body--flush">
        <% _meds.forEach(function(med, idx) { %>
          <div style="padding:16px 18px;<%= idx > 0 ? 'border-block-start:1px solid var(--v2-rule);' : '' %>">
            <div style="display:flex;align-items:flex-start;gap:14px;">
              <div style="flex-shrink:0;width:32px;height:32px;border-radius:8px;background:var(--v2-brass-bg);color:var(--v2-accent);display:flex;align-items:center;justify-content:center;font-family:var(--v2-font-display, 'Cormorant Garamond', serif);font-size:16px;font-weight:600;" data-numeric>
                <%= String(idx + 1).padStart(2, '0') %>
              </div>
              <div style="flex:1;min-width:0;">
                <div style="font-size:15px;font-weight:600;color:var(--v2-ink);"><%= _val(med.name) || _t('Medication', 'دواء') %></div>
                <div style="display:flex;flex-wrap:wrap;gap:14px;margin-block-start:6px;font-size:13px;color:var(--v2-ink-2);">
                  <% if (med.dosage) { %>
                    <div><span style="color:var(--v2-muted);font-size:11px;text-transform:uppercase;letter-spacing:0.5px;display:block;margin-block-end:2px;"><%= _t('Dosage', 'الجرعة') %></span><%= med.dosage %></div>
                  <% } %>
                  <% if (med.frequency) { %>
                    <div><span style="color:var(--v2-muted);font-size:11px;text-transform:uppercase;letter-spacing:0.5px;display:block;margin-block-end:2px;"><%= _t('Frequency', 'التكرار') %></span><%= med.frequency %></div>
                  <% } %>
                  <% if (med.duration) { %>
                    <div><span style="color:var(--v2-muted);font-size:11px;text-transform:uppercase;letter-spacing:0.5px;display:block;margin-block-end:2px;"><%= _t('Duration', 'المدة') %></span><%= med.duration %></div>
                  <% } %>
                </div>
                <% if (med.instructions) { %>
                  <div style="font-size:13px;color:var(--v2-ink-2);margin-block-start:8px;font-style:italic;line-height:1.5;"><%= med.instructions %></div>
                <% } %>
              </div>
            </div>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>

  <!-- Notes -->
  <% if (_rx.notes) { %>
    <div class="v2-card">
      <div class="v2-card__header">
        <div class="v2-card__title"><%= _t('Instructions for patient', 'تعليمات للمريض') %></div>
      </div>
      <div class="v2-card__body" style="font-size:14px;color:var(--v2-ink);line-height:1.6;white-space:pre-wrap;">
        <%= _rx.notes %>
      </div>
    </div>
  <% } %>

  <!-- Attached file -->
  <% if (_rx.pdf_url) { %>
    <div class="v2-card">
      <div class="v2-card__header">
        <div class="v2-card__title"><%= _t('Attached file', 'الملف المرفق') %></div>
      </div>
      <div class="v2-card__body" style="display:flex;gap:14px;align-items:center;">
        <div style="flex-shrink:0;width:40px;height:40px;border-radius:8px;background:var(--v2-bg);display:flex;align-items:center;justify-content:center;color:var(--v2-ink-2);">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        </div>
        <div style="flex:1;min-width:0;">
          <div style="font-size:14px;font-weight:600;color:var(--v2-ink);"><%= _pdfIsPdf ? _t('PDF prescription', 'ملف PDF للوصفة') : (_pdfIsImage ? _t('Image prescription', 'صورة الوصفة') : _t('Prescription file', 'ملف الوصفة')) %></div>
          <div style="font-size:12px;color:var(--v2-ink-2);margin-block-start:2px;"><%= _t('Click to download a fresh signed link', 'اضغط لتحميل رابط موقَّع جديد') %></div>
        </div>
        <a class="v2-btn v2-btn--secondary v2-btn--sm" href="<%= _rx.pdf_url %>" target="_blank" rel="noopener" style="text-decoration:none;flex-shrink:0;">
          <%= _t('Download', 'تحميل') %>
        </a>
      </div>
    </div>
  <% } %>

  <!-- Meta footer -->
  <div style="font-size:12px;color:var(--v2-muted);text-align:center;padding:8px 0 24px;">
    <%= _t('Prescription ID', 'رقم الوصفة') %> · <code style="font-family:ui-monospace,monospace;"><%= _val(_rx.id) %></code>
    · <%= _t('Created', 'تاريخ الإنشاء') %> <%= _humanDate(_rx.created_at) %>
    <% if (_rx.updated_at && _rx.updated_at !== _rx.created_at) { %>
      · <%= _t('Updated', 'آخر تحديث') %> <%= _humanDate(_rx.updated_at) %>
    <% } %>
  </div>

</div>

<%- include('partials/footer') %>
