<%- include('partials/header', { title: 'Prescriptions', layout: 'portal', showNav: true, portalFrame: true, portalRole: 'doctor', portalActive: 'prescriptions', portalNext: '/portal/doctor/prescriptions' }) %>
<%
  var _prescriptions = (typeof prescriptions !== 'undefined' && Array.isArray(prescriptions)) ? prescriptions : [];
  var _isAr = (typeof isAr !== 'undefined') ? isAr : (typeof lang !== 'undefined' && lang === 'ar');

  function _fmtDate(iso) {
    if (!iso) return '—';
    try {
      var d = new Date(iso);
      return d.toLocaleDateString(_isAr ? 'ar-EG' : 'en-US', { year: 'numeric', month: 'short', day: 'numeric' });
    } catch (_) { return '—'; }
  }

  function _trunc(s, n) {
    s = String(s || '');
    return s.length > n ? s.slice(0, n) + '…' : s;
  }
%>

<link rel="stylesheet" href="/css/doctor-prescriptions.css" />

<div class="dpl-page">

  <div class="dpl-header">
    <div class="dpl-header-main">
      <h1 class="dpl-header-title"><%= _isAr ? 'الوصفات' : 'Prescriptions' %></h1>
      <p class="dpl-header-sub"><%= _isAr ? 'الوصفات الطبية التي أصدرتها' : 'Prescriptions you have issued' %></p>
    </div>
    <% if (_prescriptions.length) { %>
      <span class="dpl-count"><%= _prescriptions.length %> <%= _isAr ? (_prescriptions.length === 1 ? 'وصفة' : 'وصفات') : (_prescriptions.length === 1 ? 'prescription' : 'prescriptions') %></span>
    <% } %>
  </div>

  <section class="dpl-sec">
    <% if (_prescriptions.length === 0) { %>
      <div class="dpl-empty">
        <div class="dpl-empty-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="12" y1="12" x2="12" y2="18"/>
            <line x1="9" y1="15" x2="15" y2="15"/>
          </svg>
        </div>
        <h2 class="dpl-empty-title"><%= _isAr ? 'لم تصدر أي وصفات بعد' : 'No prescriptions yet' %></h2>
        <p class="dpl-empty-body">
          <%= _isAr
              ? 'تُكتب الوصفات من داخل صفحة الحالة. افتح أي حالة نشطة لإصدار وصفة.'
              : 'Prescriptions are written from within a case. Open any active case to issue a prescription.' %>
        </p>
        <a class="dpl-empty-cta" href="/portal/doctor/queue">
          <%= _isAr ? 'الذهاب إلى قائمة الحالات' : 'Go to case queue' %>
          <span class="dpl-empty-cta-arrow" aria-hidden="true"><%= _isAr ? '←' : '→' %></span>
        </a>
      </div>
    <% } else { %>
      <table class="dpl-table">
        <thead>
          <tr>
            <th><%= _isAr ? 'المريض' : 'Patient' %></th>
            <th><%= _isAr ? 'الخدمة' : 'Service' %></th>
            <th><%= _isAr ? 'الأدوية' : 'Medications' %></th>
            <th><%= _isAr ? 'الحالة' : 'Status' %></th>
            <th><%= _isAr ? 'التاريخ' : 'Date' %></th>
            <th aria-label="<%= _isAr ? 'إجراءات' : 'Actions' %>"></th>
          </tr>
        </thead>
        <tbody>
          <% _prescriptions.forEach(function(rx) { %>
            <tr>
              <td class="dpl-cell-patient" data-label="<%= _isAr ? 'المريض' : 'Patient' %>">
                <%= rx.patient_name || '—' %>
              </td>
              <td class="dpl-cell-service" data-label="<%= _isAr ? 'الخدمة' : 'Service' %>">
                <%= rx.service_name || '—' %>
              </td>
              <td class="dpl-cell-meds" data-label="<%= _isAr ? 'الأدوية' : 'Medications' %>" title="<%= rx.medications || '' %>">
                <%= _trunc(rx.medications || '', 60) || '—' %>
              </td>
              <td data-label="<%= _isAr ? 'الحالة' : 'Status' %>">
                <% if (rx.is_active) { %>
                  <span class="dpl-status dpl-status--active"><%= _isAr ? 'نشطة' : 'Active' %></span>
                <% } else { %>
                  <span class="dpl-status dpl-status--expired"><%= _isAr ? 'منتهية' : 'Expired' %></span>
                <% } %>
              </td>
              <td class="dpl-cell-date" data-label="<%= _isAr ? 'التاريخ' : 'Date' %>">
                <%= _fmtDate(rx.created_at) %>
              </td>
              <td class="dpl-cell-actions" data-label="<%= _isAr ? 'إجراءات' : 'Actions' %>">
                <% if (rx.pdf_url) { %>
                  <a class="dpl-link" href="<%= rx.pdf_url %>" target="_blank" rel="noopener">
                    <%= _isAr ? 'تحميل' : 'Download' %>
                  </a>
                <% } %>
                <% if (rx.order_id) { %>
                  <a class="dpl-link dpl-link--muted" href="/portal/doctor/case/<%= encodeURIComponent(rx.order_id) %>">
                    <%= _isAr ? 'الحالة' : 'Case' %>
                  </a>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    <% } %>
  </section>

</div>

<%- include('partials/footer') %>
