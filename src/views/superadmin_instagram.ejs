<%- include('partials/header', { title: "Instagram Manager", layout: "portal", showNav: false, showFooter: false, portalFrame: true, portalRole: 'superadmin', portalActive: 'instagram', portalNext: '/superadmin' }) %>
<%
  const _nonce = (typeof locals !== 'undefined' && locals && (locals.cspNonce || locals.csp_nonce || locals.nonce))
    ? String(locals.cspNonce || locals.csp_nonce || locals.nonce)
    : '';
  const _nonceAttr = _nonce ? ` nonce="${_nonce}"` : '';
%>

<style>
  /* ── Instagram Manager — Scoped Styles ── */
  .ig-wrap { max-width:1200px; margin:0 auto; }

  /* Page header */
  .ig-hdr { display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; gap:12px; flex-wrap:wrap; }
  .ig-hdr h2 { font-size:1.25rem; font-weight:700; margin:0; color:#fff; }
  .ig-hdr p  { color:#94a3b8; font-size:0.78rem; margin:2px 0 0; }
  .ig-hdr-add { padding:8px 16px; background:#2563eb; color:#fff; border:none; border-radius:8px; font-size:0.78rem; font-weight:600; cursor:pointer; transition:background 0.15s; }
  .ig-hdr-add:hover { background:#3b82f6; }

  /* Stats row */
  .ig-kpis { display:grid; grid-template-columns:repeat(4,1fr); gap:10px; margin-bottom:20px; }
  .ig-kpi { background:rgba(255,255,255,0.06); border:1px solid rgba(255,255,255,0.08); border-radius:10px; padding:14px 10px; text-align:center; }
  .ig-kpi-n { font-size:1.6rem; font-weight:700; line-height:1; }
  .ig-kpi-l { font-size:0.65rem; color:#94a3b8; text-transform:uppercase; letter-spacing:0.5px; margin-top:4px; }

  /* Toggle bar */
  .ig-toggle { text-align:center; margin-bottom:16px; }
  .ig-toggle a { display:inline-block; padding:6px 16px; background:rgba(255,255,255,0.06); color:#94a3b8; border-radius:6px; font-size:0.75rem; font-weight:600; text-decoration:none; transition:all 0.15s; }
  .ig-toggle a:hover { background:rgba(255,255,255,0.12); color:#fff; }

  /* Card grid */
  .ig-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:16px; }
  @media (max-width:1024px) { .ig-grid { grid-template-columns:repeat(2,1fr); } }
  @media (max-width:640px)  { .ig-grid { grid-template-columns:1fr; } .ig-kpis { grid-template-columns:repeat(2,1fr); } }

  /* Card */
  .ig-card { background:#1e293b; border-radius:12px; overflow:hidden; border:1px solid rgba(255,255,255,0.06); display:flex; flex-direction:column; transition:transform 0.15s, box-shadow 0.15s; }
  .ig-card:hover { transform:translateY(-2px); box-shadow:0 8px 24px rgba(0,0,0,0.3); }

  /* Image area — 1:1 square */
  .ig-img { position:relative; aspect-ratio:1/1; overflow:hidden; background:#0f172a; }
  .ig-img img { width:100%; height:100%; object-fit:cover; display:block; }

  /* Placeholder */
  .ig-ph { width:100%; height:100%; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:10px; background:linear-gradient(135deg,#0f172a,#1e293b); }
  .ig-ph-icon { font-size:2.5rem; opacity:0.3; }
  .ig-ph-btn { padding:10px 22px; background:#2563eb; color:#fff; border:none; border-radius:8px; font-size:0.8rem; font-weight:600; cursor:pointer; transition:all 0.15s; display:inline-flex; align-items:center; gap:6px; }
  .ig-ph-btn:hover { background:#3b82f6; transform:scale(1.03); }
  .ig-ph-btn:disabled { opacity:0.4; cursor:not-allowed; transform:none; }
  .ig-ph-sub { font-size:0.68rem; color:#475569; }

  /* Spinner */
  .ig-spinner { display:none; flex-direction:column; align-items:center; gap:10px; }
  .ig-spinner.active { display:flex; }
  .ig-spinner-ring { width:36px; height:36px; border:3px solid rgba(255,255,255,0.1); border-top-color:#3b82f6; border-radius:50%; animation:ig-spin 0.8s linear infinite; }
  .ig-spinner-text { font-size:0.72rem; color:#64748b; }
  @keyframes ig-spin { to { transform:rotate(360deg); } }

  /* Badges */
  .ig-badge { position:absolute; padding:3px 8px; border-radius:6px; font-size:0.62rem; font-weight:700; letter-spacing:0.3px; text-transform:uppercase; backdrop-filter:blur(8px); -webkit-backdrop-filter:blur(8px); }
  .ig-b-day  { top:8px; left:8px; background:rgba(37,99,235,0.85); color:#fff; }
  .ig-b-date { bottom:8px; left:8px; background:rgba(0,0,0,0.6); color:#e2e8f0; font-weight:500; text-transform:none; }
  .ig-b-status { top:8px; right:8px; }
  .ig-b-pending_approval { background:rgba(245,158,11,0.2); color:#fbbf24; }
  .ig-b-approved          { background:rgba(34,197,94,0.2);  color:#4ade80; }
  .ig-b-rejected          { background:rgba(239,68,68,0.2);  color:#f87171; }
  .ig-b-published         { background:rgba(59,130,246,0.2); color:#60a5fa; }

  /* Card body */
  .ig-body { padding:12px 14px; flex:1; display:flex; flex-direction:column; gap:6px; }
  .ig-cap-en { font-size:0.78rem; color:#e2e8f0; line-height:1.45; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
  .ig-cap-ar { font-size:0.74rem; color:#94a3b8; line-height:1.5; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; direction:rtl; text-align:right; }
  .ig-meta { font-size:0.68rem; color:#475569; display:flex; align-items:center; gap:6px; flex-wrap:wrap; }
  .ig-meta-dot { width:3px; height:3px; border-radius:50%; background:#475569; }
  .ig-feedback-box { font-size:0.72rem; color:#f87171; background:rgba(239,68,68,0.08); border:1px solid rgba(239,68,68,0.15); padding:6px 10px; border-radius:6px; }

  /* Actions */
  .ig-actions { padding:0 14px 12px; display:flex; gap:6px; flex-wrap:wrap; }
  .ig-btn { padding:6px 12px; border-radius:6px; font-size:0.7rem; font-weight:600; border:none; cursor:pointer; transition:all 0.15s; display:inline-flex; align-items:center; gap:4px; }
  .ig-btn:disabled { opacity:0.4; cursor:not-allowed; }
  .ig-btn-approve { background:rgba(34,197,94,0.15); color:#4ade80; }
  .ig-btn-approve:hover:not(:disabled) { background:#22c55e; color:#fff; }
  .ig-btn-regen { background:rgba(251,146,60,0.15); color:#fb923c; }
  .ig-btn-regen:hover:not(:disabled) { background:#f97316; color:#fff; }
  .ig-btn-reject { background:rgba(239,68,68,0.1); color:#f87171; }
  .ig-btn-reject:hover:not(:disabled) { background:#ef4444; color:#fff; }
  .ig-done-label { font-size:0.72rem; font-weight:600; }

  /* Inline forms */
  .ig-form { padding:0 14px 12px; display:none; }
  .ig-form.open { display:block; }
  .ig-form textarea { width:100%; min-height:50px; background:#0f172a; color:#e2e8f0; border:1px solid rgba(255,255,255,0.1); border-radius:6px; padding:8px; font-size:0.78rem; box-sizing:border-box; resize:vertical; font-family:inherit; }
  .ig-form textarea::placeholder { color:#475569; }
  .ig-form-btns { display:flex; gap:6px; margin-top:6px; }
  .ig-form-submit { padding:6px 14px; border-radius:6px; font-size:0.72rem; font-weight:600; border:none; cursor:pointer; color:#fff; }
  .ig-form-cancel { padding:6px 14px; border-radius:6px; font-size:0.72rem; font-weight:600; border:none; cursor:pointer; background:rgba(255,255,255,0.06); color:#94a3b8; }
  .ig-form-cancel:hover { background:rgba(255,255,255,0.12); }

  /* Modal */
  .ig-modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,0.6); z-index:1000; align-items:center; justify-content:center; backdrop-filter:blur(4px); -webkit-backdrop-filter:blur(4px); }
  .ig-modal-overlay.open { display:flex; }
  .ig-modal { background:#1e293b; border:1px solid rgba(255,255,255,0.08); border-radius:14px; padding:24px; max-width:480px; width:90%; max-height:80vh; overflow-y:auto; }
  .ig-modal h3 { font-size:1.05rem; font-weight:700; margin:0; color:#fff; }
  .ig-modal label { display:block; font-size:0.78rem; font-weight:600; color:#e2e8f0; margin-bottom:4px; }
  .ig-modal input, .ig-modal select, .ig-modal textarea { width:100%; padding:10px; background:#0f172a; color:#e2e8f0; border:1px solid rgba(255,255,255,0.1); border-radius:8px; font-size:0.82rem; box-sizing:border-box; font-family:inherit; }
  .ig-modal textarea { resize:vertical; }
  .ig-modal .form-row { margin-bottom:14px; }

  /* Empty state */
  .ig-empty { text-align:center; padding:60px 20px; color:#64748b; }
  .ig-empty p { margin:4px 0; }
  .ig-empty code { background:rgba(255,255,255,0.06); padding:2px 8px; border-radius:4px; font-size:0.8rem; }
</style>

<div class="ig-wrap">
  <!-- Header -->
  <div class="ig-hdr">
    <div>
      <h2>Instagram Campaign</h2>
      <p>Generate AI images, review and approve posts before publishing</p>
    </div>
    <button class="ig-hdr-add" data-action="open-modal">+ New Post</button>
  </div>

  <!-- KPIs -->
  <div class="ig-kpis">
    <div class="ig-kpi">
      <div class="ig-kpi-n" style="color:#e2e8f0;"><%= stats.totalPosts %></div>
      <div class="ig-kpi-l">Total</div>
    </div>
    <div class="ig-kpi">
      <div class="ig-kpi-n" style="color:#4ade80;"><%= stats.published %></div>
      <div class="ig-kpi-l">Published</div>
    </div>
    <div class="ig-kpi">
      <div class="ig-kpi-n" style="color:#60a5fa;"><%= stats.scheduled %></div>
      <div class="ig-kpi-l">Approved</div>
    </div>
    <div class="ig-kpi">
      <div class="ig-kpi-n" style="color:#fbbf24;"><%= stats.pending %></div>
      <div class="ig-kpi-l">Pending</div>
    </div>
  </div>

  <!-- Toggle -->
  <div class="ig-toggle">
    <% if (typeof showAll !== 'undefined' && showAll) { %>
      <a href="/superadmin/instagram">Show Upcoming Only</a>
    <% } else { %>
      <a href="/superadmin/instagram?all=1">Show All Posts</a>
    <% } %>
  </div>

  <!-- Card Grid -->
  <% if (posts && posts.length > 0) { %>
  <div class="ig-grid">
    <% posts.forEach(function(post) {
      var pubDate = post.scheduled_at ? new Date(post.scheduled_at) : new Date();
      var dateStr = pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
      var timeStr = pubDate.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit', hour12: true });
      var lineEn = (post.caption_en || '').split('\n')[0].substring(0, 120);
      var lineAr = (post.caption_ar || '').split('\n')[0].substring(0, 120);
      var hasImage = !!post.imageUrl;
      var hasPrompt = !!post.image_prompt;
      var isPublished = post.status === 'published';
      var isApproved  = post.status === 'approved';
      var isRejected  = post.status === 'rejected';
      var isPending   = post.status === 'pending_approval';
      var statusLabel = isPublished ? 'Published' : isApproved ? 'Approved' : isRejected ? 'Rejected' : 'Pending';
    %>
    <div class="ig-card" data-id="<%= post.id %>">
      <!-- Image area (1:1 square) -->
      <div class="ig-img">
        <% if (hasImage) { %>
          <% var thumb = post.imageUrl.includes('cloudinary') ? post.imageUrl.replace('/upload/', '/upload/w_400,q_80,f_auto/') : post.imageUrl; %>
          <img src="<%= thumb %>" alt="Post image" loading="lazy">
        <% } else { %>
          <div class="ig-ph" data-ph="<%= post.id %>">
            <div class="ig-ph-icon">&#9878;</div>
            <button class="ig-ph-btn" data-action="generate" data-post="<%= post.id %>" <% if (!hasPrompt) { %>disabled title="No image prompt set"<% } %>>
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>
              Generate Image
            </button>
            <div class="ig-spinner" data-spinner="<%= post.id %>">
              <div class="ig-spinner-ring"></div>
              <span class="ig-spinner-text">Generating with DALL-E...</span>
            </div>
            <% if (hasPrompt) { %><div class="ig-ph-sub">AI prompt ready</div><% } %>
          </div>
        <% } %>
        <% if (post.day_number) { %><span class="ig-badge ig-b-day">Day <%= post.day_number %></span><% } %>
        <span class="ig-badge ig-b-date"><%= dateStr %> &middot; <%= timeStr %></span>
        <span class="ig-badge ig-b-status ig-b-<%= post.status %>"><%= statusLabel %></span>
      </div>

      <!-- Body -->
      <div class="ig-body">
        <div class="ig-cap-en"><%= lineEn %></div>
        <% if (lineAr) { %><div class="ig-cap-ar"><%= lineAr %></div><% } %>
        <div class="ig-meta">
          <span><%= post.post_type %></span>
          <% if (post.generation_count) { %>
            <span class="ig-meta-dot"></span>
            <span>Gen #<%= post.generation_count %></span>
          <% } %>
        </div>
        <% if (isRejected && post.rejection_feedback) { %>
          <div class="ig-feedback-box">Feedback: <%= post.rejection_feedback %></div>
        <% } %>
      </div>

      <!-- Actions -->
      <div class="ig-actions">
        <% if (isPublished) { %>
          <span class="ig-done-label" style="color:#60a5fa;">Published<%= post.published_at ? ' ' + new Date(post.published_at).toLocaleDateString('en-US', {month:'short',day:'numeric'}) : '' %></span>
        <% } else if (isApproved) { %>
          <span class="ig-done-label" style="color:#4ade80;">Approved &mdash; awaiting publish</span>
        <% } else { %>
          <% if (hasImage) { %>
            <button class="ig-btn ig-btn-approve" data-action="approve" data-post="<%= post.id %>">Approve</button>
          <% } %>
          <button class="ig-btn ig-btn-regen" data-action="show-regen" data-post="<%= post.id %>"><%= hasImage ? 'Regenerate' : 'Generate' %></button>
          <button class="ig-btn ig-btn-reject" data-action="show-reject" data-post="<%= post.id %>">Reject</button>
        <% } %>
      </div>

      <!-- Reject form -->
      <div class="ig-form" data-form="reject-<%= post.id %>">
        <textarea data-input="reject-<%= post.id %>" placeholder="What should change? (e.g. 'too dark, need more blue')"></textarea>
        <div class="ig-form-btns">
          <button class="ig-form-submit" style="background:#ef4444;" data-action="submit-reject" data-post="<%= post.id %>">Reject</button>
          <button class="ig-form-cancel" data-action="hide-form" data-form-target="reject-<%= post.id %>">Cancel</button>
        </div>
      </div>

      <!-- Regen form -->
      <div class="ig-form" data-form="regen-<%= post.id %>">
        <textarea data-input="regen-<%= post.id %>" placeholder="Revision instructions (e.g. 'more medical icons, lighter background')"></textarea>
        <div class="ig-form-btns">
          <button class="ig-form-submit" style="background:#f97316;" data-action="submit-regen" data-post="<%= post.id %>">Regenerate</button>
          <button class="ig-form-cancel" data-action="hide-form" data-form-target="regen-<%= post.id %>">Cancel</button>
        </div>
      </div>
    </div>
    <% }); %>
  </div>
  <% } else { %>
  <div class="ig-empty">
    <p style="font-size:2rem;margin-bottom:8px;">&#128247;</p>
    <p style="color:#e2e8f0;font-weight:600;">No posts found</p>
    <% if (typeof error !== 'undefined' && error) { %><p style="color:#f87171;">Error: <%= error %></p><% } %>
    <p>Run <code>node scripts/instagram-publish-campaign.js --seed</code> to seed campaign posts.</p>
  </div>
  <% } %>
</div>

<!-- Add Post Modal -->
<div class="ig-modal-overlay" data-modal="add-post">
  <div class="ig-modal">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
      <h3>New Post</h3>
      <button data-action="close-modal" style="background:none;border:none;font-size:1.2rem;cursor:pointer;color:#94a3b8;">&times;</button>
    </div>
    <form method="POST" action="/superadmin/instagram/add-post">
      <%- (typeof csrfField === 'function') ? csrfField() : '' %>
      <div class="form-row">
        <label>Scheduled Date & Time</label>
        <input type="datetime-local" name="scheduled_at" required />
      </div>
      <div class="form-row">
        <label>Post Type</label>
        <select name="post_type">
          <option value="IMAGE">Image</option>
          <option value="CAROUSEL">Carousel</option>
          <option value="STORY">Story</option>
          <option value="REEL">Reel</option>
        </select>
      </div>
      <div class="form-row">
        <label>Caption (English)</label>
        <textarea name="caption_en" rows="3" required placeholder="English caption..."></textarea>
      </div>
      <div class="form-row">
        <label>Caption (Arabic)</label>
        <textarea name="caption_ar" rows="3" dir="rtl" placeholder="...الكابشن بالعربي"></textarea>
      </div>
      <div class="form-row">
        <label>Image Prompt (for AI generation)</label>
        <textarea name="image_prompt" rows="2" placeholder="Describe the image you want AI to generate..."></textarea>
      </div>
      <div style="display:flex;gap:8px;">
        <button type="submit" class="ig-hdr-add" style="flex:1;">Create Post</button>
        <button type="button" data-action="close-modal" class="ig-form-cancel" style="padding:10px 18px;">Cancel</button>
      </div>
    </form>
  </div>
</div>

<script<%- _nonceAttr %>>
(function() {
  'use strict';
  var csrfToken = '<%= typeof csrfToken !== "undefined" && csrfToken ? csrfToken : "" %>';
  console.log('[IG Script] Loaded — event delegation active');

  // ── Helpers ──

  function card(postId) {
    return document.querySelector('.ig-card[data-id="' + CSS.escape(postId) + '"]');
  }

  function showForm(type, postId) {
    var el = document.querySelector('[data-form="' + type + '-' + CSS.escape(postId) + '"]');
    if (el) el.classList.add('open');
  }

  function hideForm(type, postId) {
    var el = document.querySelector('[data-form="' + type + '-' + CSS.escape(postId) + '"]');
    if (el) el.classList.remove('open');
  }

  function hideAllForms(postId) {
    hideForm('reject', postId);
    hideForm('regen', postId);
  }

  function getInput(type, postId) {
    var el = document.querySelector('[data-input="' + type + '-' + CSS.escape(postId) + '"]');
    return el ? el.value : '';
  }

  // ── Generate Image ──

  async function generateImage(postId) {
    console.log('[IG Generate] clicked for postId:', postId);
    var c = card(postId);
    if (!c) { console.error('[IG Generate] card not found for:', postId); return; }
    var ph = c.querySelector('[data-ph]');
    var btn = c.querySelector('[data-action="generate"]');
    var spinner = c.querySelector('[data-spinner]');

    if (btn) btn.style.display = 'none';
    if (spinner) spinner.classList.add('active');

    try {
      var res = await fetch('/api/admin/instagram/generate/' + encodeURIComponent(postId), {
        method: 'POST',
        headers: { 'x-csrf-token': csrfToken },
        credentials: 'same-origin'
      });

      if (res.redirected || !res.ok) {
        alert('Auth error (status ' + res.status + '). Make sure you are logged in as superadmin.');
        if (btn) btn.style.display = '';
        if (spinner) spinner.classList.remove('active');
        return;
      }

      var data = await res.json();

      if (data.success && data.imageUrl) {
        // Replace placeholder with generated image
        var imgArea = c.querySelector('.ig-img');
        var thumb = data.imageUrl.includes('cloudinary')
          ? data.imageUrl.replace('/upload/', '/upload/w_400,q_80,f_auto/')
          : data.imageUrl;

        // Remove placeholder, insert image
        if (ph) ph.remove();
        var img = document.createElement('img');
        img.src = thumb;
        img.alt = 'Generated image';
        img.style.cssText = 'width:100%;height:100%;object-fit:cover;display:block;';
        imgArea.insertBefore(img, imgArea.firstChild);

        // Add Approve button if not present
        var actions = c.querySelector('.ig-actions');
        if (actions && !actions.querySelector('[data-action="approve"]')) {
          var approveBtn = document.createElement('button');
          approveBtn.className = 'ig-btn ig-btn-approve';
          approveBtn.setAttribute('data-action', 'approve');
          approveBtn.setAttribute('data-post', postId);
          approveBtn.textContent = 'Approve';
          actions.prepend(approveBtn);
        }
      } else {
        alert('Generation failed: ' + (data.error || 'Unknown error'));
        if (btn) btn.style.display = '';
        if (spinner) spinner.classList.remove('active');
      }
    } catch (e) {
      alert('Network error: ' + e.message);
      if (btn) btn.style.display = '';
      if (spinner) spinner.classList.remove('active');
    }
  }

  // ── Approve ──

  async function approvePost(postId, btn) {
    btn.disabled = true;
    btn.textContent = 'Approving...';
    try {
      var res = await fetch('/superadmin/instagram/approve/' + encodeURIComponent(postId), {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'x-csrf-token': csrfToken },
        credentials: 'same-origin'
      });
      var data = await res.json();
      if (data.success) {
        btn.textContent = 'Approved';
        btn.style.background = '#22c55e';
        btn.style.color = '#fff';
        setTimeout(function() { location.reload(); }, 600);
      } else {
        alert('Error: ' + (data.error || 'Unknown'));
        btn.disabled = false;
        btn.textContent = 'Approve';
      }
    } catch (e) {
      alert('Error: ' + e.message);
      btn.disabled = false;
      btn.textContent = 'Approve';
    }
  }

  // ── Reject ──

  async function submitReject(postId) {
    var feedback = getInput('reject', postId);
    try {
      await fetch('/superadmin/instagram/reject/' + encodeURIComponent(postId), {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'x-csrf-token': csrfToken },
        body: JSON.stringify({ feedback: feedback }),
        credentials: 'same-origin'
      });
      location.reload();
    } catch (e) {
      alert('Error: ' + e.message);
    }
  }

  // ── Regenerate ──

  async function submitRegenerate(postId, btn) {
    var feedback = getInput('regen', postId);
    btn.disabled = true;
    btn.textContent = 'Regenerating...';

    try {
      var res = await fetch('/api/admin/instagram/regenerate/' + encodeURIComponent(postId), {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'x-csrf-token': csrfToken },
        body: JSON.stringify({ feedback: feedback }),
        credentials: 'same-origin'
      });
      var data = await res.json();
      if (data.success) {
        location.reload();
      } else {
        alert('Failed: ' + (data.error || 'Unknown'));
        btn.disabled = false;
        btn.textContent = 'Regenerate';
      }
    } catch (e) {
      alert('Error: ' + e.message);
      btn.disabled = false;
      btn.textContent = 'Regenerate';
    }
  }

  // ── Event Delegation ──
  // All click handling via data-action attributes (CSP-safe — no inline handlers)

  document.addEventListener('click', function(e) {
    var target = e.target.closest('[data-action]');
    if (!target) return;

    var action = target.getAttribute('data-action');
    var postId = target.getAttribute('data-post');
    console.log('[IG Action]', action, 'post:', postId);
    var formTarget = target.getAttribute('data-form-target');

    switch (action) {
      case 'generate':
        e.preventDefault();
        generateImage(postId);
        break;

      case 'approve':
        e.preventDefault();
        approvePost(postId, target);
        break;

      case 'show-reject':
        e.preventDefault();
        hideAllForms(postId);
        showForm('reject', postId);
        break;

      case 'show-regen':
        e.preventDefault();
        hideAllForms(postId);
        showForm('regen', postId);
        break;

      case 'submit-reject':
        e.preventDefault();
        submitReject(postId);
        break;

      case 'submit-regen':
        e.preventDefault();
        submitRegenerate(postId, target);
        break;

      case 'hide-form':
        e.preventDefault();
        if (formTarget) {
          var el = document.querySelector('[data-form="' + formTarget + '"]');
          if (el) el.classList.remove('open');
        }
        break;

      case 'open-modal':
        e.preventDefault();
        var modal = document.querySelector('[data-modal="add-post"]');
        if (modal) modal.classList.add('open');
        break;

      case 'close-modal':
        e.preventDefault();
        var m = e.target.closest('.ig-modal-overlay');
        if (m) m.classList.remove('open');
        break;
    }
  });

  // Close modal on overlay click
  document.addEventListener('click', function(e) {
    if (e.target.classList.contains('ig-modal-overlay') && e.target.classList.contains('open')) {
      e.target.classList.remove('open');
    }
  });

})();
</script>

