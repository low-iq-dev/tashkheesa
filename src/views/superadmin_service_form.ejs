<%
  // Service create/edit. Locals: service (optional), specialties, isEdit, error.
  var isAr = (typeof lang !== 'undefined' && lang === 'ar');
  var _service = (typeof service !== 'undefined' && service) ? service : null;
  var _specialties = (typeof specialties !== 'undefined' && specialties) ? specialties : [];
  var _isEdit = !!(typeof isEdit !== 'undefined' ? isEdit : (_service && _service.id));
  var _err = (typeof error !== 'undefined' && error) ? error : '';
  var _formAction = _isEdit
    ? ('/superadmin/services/' + _service.id + '/edit')
    : '/superadmin/services/new';
  var specOpts = [{ value: '', label: '— Select —' }].concat(
    _specialties.map(function(sp) { return { value: String(sp.id), label: sp.name }; })
  );
  var curr = (_service && _service.currency) ? _service.currency : 'EGP';
%>
<%- include('partials/superadmin/header', {
      title: _isEdit ? 'Edit service' : 'New service',
      currentSection: 'services',
      user: user,
      lang: lang || 'en',
      showTabBar: false,
      sidebarBadges: (typeof sidebarBadges !== 'undefined' && sidebarBadges) ? sidebarBadges : {},
      cspNonce: (typeof cspNonce !== 'undefined') ? cspNonce : ''
    }) %>

<%- include('partials/superadmin/page_header', {
      title: _isEdit ? 'Edit service' : 'New service',
      subtitle: _isEdit && _service ? _service.name : 'Add a new entry to the service catalog.',
      breadcrumb: [
        { label: 'Dashboard', href: '/superadmin' },
        { label: isAr ? 'الخدمات' : 'Services', href: '/superadmin/services' },
        { label: _isEdit ? 'Edit' : 'New' }
      ],
      actionsHtml: '<a class="btn" href="/superadmin/services">Cancel</a>'
    }) %>

<div class="page-body">
  <% if (_err) { %>
    <div class="flash err"><%= _err %></div>
  <% } %>

  <%- include('partials/superadmin/c_card_open', { title: _isEdit ? 'Service profile' : 'New service' }) %>
    <form method="post" action="<%= _formAction %>" style="max-width:880px;">
      <%- (typeof csrfField === 'function') ? csrfField() : '' %>

      <div class="c-form-row">
        <%- include('partials/superadmin/c_form_field', { name: 'specialty_id', label: 'Specialty', type: 'select', required: true, value: String(_service && _service.specialty_id || ''), options: specOpts }) %>
        <%- include('partials/superadmin/c_form_field', { name: 'name', label: 'Name', required: true, value: String(_service && _service.name || '') }) %>
      </div>

      <div class="c-form-row-3">
        <%- include('partials/superadmin/c_form_field', { name: 'code', label: 'Code', value: String(_service && _service.code || ''), help: 'Short identifier (e.g. ECG_REVIEW)' }) %>
        <%- include('partials/superadmin/c_form_field', { name: 'base_price', label: 'Base price', type: 'number', value: String(_service && _service.base_price != null ? _service.base_price : '') }) %>
        <%- include('partials/superadmin/c_form_field', { name: 'doctor_fee', label: 'Doctor fee', type: 'number', value: String(_service && _service.doctor_fee != null ? _service.doctor_fee : '') }) %>
      </div>

      <div class="c-form-row">
        <%- include('partials/superadmin/c_form_field', { name: 'currency', label: 'Currency', type: 'select', value: curr, options: [
              { value: 'EGP', label: 'EGP' },
              { value: 'USD', label: 'USD' },
              { value: 'EUR', label: 'EUR' }
            ] }) %>
        <%- include('partials/superadmin/c_form_field', { name: 'payment_link', label: 'Payment link', value: String(_service && _service.payment_link || ''), placeholder: 'https://...' }) %>
      </div>

      <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:14px;">
        <a class="btn" href="/superadmin/services">Cancel</a>
        <button type="submit" class="btn primary"><%= _isEdit ? 'Save changes' : 'Create service' %></button>
      </div>
    </form>
  <%- include('partials/superadmin/c_card_close') %>
</div>

<%- include('partials/superadmin/footer', { isAr: isAr }) %>
