<%
  // Patient New-Case Wizard — v2 5-step flow.
  //
  // Locals from routes/patient.js:
  //   user                 — req.user
  //   lang                 — 'en' | 'ar'
  //   isAr                 — boolean
  //   step                 — 1..5
  //   draft                — orders row (or null on fresh Step 1)
  //   files                — array (only populated for step >= 2)
  //   countryCurrency      — currency code (used Step 5)
  //   uploadcarePublicKey  — env-derived
  //   uploaderConfigured   — boolean (legacy Uploadcare widget gate)
  //   r2DirectEnabled      — boolean (Theme 13: when true, the wizard's
  //                          step-2 uploader posts directly to R2 via
  //                          /portal/patient/files instead of the Uploadcare
  //                          widget. Both code paths coexist below; the flag
  //                          decides which renders. See
  //                          docs/audits/THEME_13_R2_MIGRATION_FIX_PLAN.md §7.)
  //   error                — { step, message } | undefined
  //
  // Privacy: this view is for case ASSEMBLY. It never displays report content
  // (the case has not been completed yet). Form values are echoed back on
  // re-render only for the active step.

  const __isAr = !!isAr;
  const __step = Math.min(5, Math.max(1, Number(step) || 1));
  // P2-VIEW-1 defensive read for CSP nonce — needed for inline <script>
  // tags (line 402, 878). Express's res.render normally merges res.locals
  // into the template scope, but if an upstream config disables `with` or
  // a render call-site overrides the locals object without spreading
  // res.locals, the nonce would be missing → CSP blocks the script silently
  // → drop zone unresponsive. Fall through every plausible source.
  const __nonce = String(
    (typeof cspNonce !== 'undefined' && cspNonce) ||
    (typeof locals !== 'undefined' && locals && (locals.cspNonce || locals.csp_nonce || locals.nonce)) ||
    ''
  );
  const __nonceAttr = __nonce ? (' nonce="' + __nonce + '"') : '';
  const __draft = (typeof draft === 'object' && draft) ? draft : null;
  const __files = Array.isArray(files) ? files : [];
  const __error = (typeof error === 'object' && error) ? error : null;
  // typeof-guarded — only the happy-path GET handler at routes/patient.js:1315
  // passes these locals; all 7 error-rerender paths in the POST step1/2/3/4/5
  // handlers omit them, which previously caused EJS to throw a ReferenceError
  // on any form-validation re-render. The 7-site fix to spread uploadcareLocals
  // is filed as P3-VIEW-2; this guard is the surgical defense in depth.
  const __uploaderConfigured = !!(typeof uploaderConfigured !== 'undefined' && uploaderConfigured);
  const __uploadcarePk = String((typeof uploadcarePublicKey !== 'undefined' && uploadcarePublicKey) || '').trim();
  // Theme 13 Sub-issue B — typeof-guarded read mirrors the pattern used for
  // every other render-locals field on this view. When true, the new R2
  // FormData uploader renders below in place of the Uploadcare widget.
  const __r2DirectEnabled = !!(typeof r2DirectEnabled !== 'undefined' && r2DirectEnabled);
  const __uploadedFlash = !!(typeof locals !== 'undefined' && locals && locals.uploaded);


  const stepLabels = [
    tt('Condition', 'Condition', 'الحالة'),
    tt('Documents', 'Documents', 'الملفات'),
    tt('Specialty', 'Specialty', 'التخصص'),
    tt('Review', 'Review', 'المراجعة'),
    tt('Payment', 'Payment', 'الدفع')
  ];

  const __title = tt('New case', 'New case', 'حالة جديدة') + ' · ' + tt('Step ' + __step + ' of 5', 'Step ' + __step + ' of 5', 'الخطوة ' + __step + ' من 5');
  const __sub   = stepLabels[__step - 1];

  // Field values for the active step (echo back the draft if any).
  const v = {
    clinical_question:   __draft && __draft.clinical_question   ? String(__draft.clinical_question)   : '',
    medical_history:     __draft && __draft.medical_history     ? String(__draft.medical_history)     : '',
    current_medications: __draft && __draft.current_medications ? String(__draft.current_medications) : ''
  };
  const draftId = __draft ? __draft.id : '';

  // Step-2 query flags: passed by the route handler via locals (queryErr, uploadedFlash).
  const __queryErr = (typeof queryErr === 'string') ? queryErr : '';
  const __uploadedFlashLocal = !!(typeof uploadedFlash !== 'undefined' && uploadedFlash);
%>
<%- include('partials/patient/head', {
  title: __title,
  active: 'new_case',
  variant: 'dark',
  trustDensity: 'medium',
  user: user,
  lang: lang,
  cspNonce: cspNonce
}) %>

<%- include('partials/patient/topbar', {
  title: tt('Start a new case', 'Start a new case', 'ابدأ حالة جديدة'),
  sub: __sub,
  serif: true
}) %>

<div style="margin-bottom:24px;">
  <%- include('partials/patient/progress-track', {
    step: __step - 1,
    total: 5,
    labels: stepLabels
  }) %>
</div>

<% if (__error && __error.step === __step) { %>
  <div role="alert" class="p-card" style="padding:14px 18px;background:var(--danger-bg);border-color:#F2C7C7;color:var(--danger);margin-bottom:16px;font-size:13px;">
    <strong style="color:var(--danger);"><%= __error.message %></strong>
  </div>
<% } %>

<% if (__step === 1) { %>
  <%# ─── STEP 1 — CONDITION ─────────────────────────────────────────── %>
  <div style="display:grid;grid-template-columns:2fr 1fr;gap:18px;" class="p-dash-cols">
    <div class="p-card">
      <div class="p-card__header">
        <div class="p-card__title"><%= tt('Tell us what’s going on', 'Tell us what’s going on', 'أخبرنا بما يحدث') %></div>
        <div class="p-card__sub"><%= tt('A few sentences. Plain language is fine — your specialist reads it personally.', 'A few sentences. Plain language is fine — your specialist reads it personally.', 'بضع جمل بلغة بسيطة — سيقرأها الطبيب بنفسه.') %></div>
      </div>
      <div class="p-card__body">
        <form method="post" action="/patient/new-case/step1" autocomplete="off" novalidate>
          <%- (typeof csrfField === 'function') ? csrfField() : '' %>
          <% if (draftId) { %><input type="hidden" name="id" value="<%= draftId %>" /><% } %>

          <div class="p-field" style="margin-bottom:18px;">
            <label class="p-field__label" for="clinical_question">
              <%= tt('Your concern', 'Your concern', 'ما يقلقك') %>
              <span style="color:var(--danger);">*</span>
            </label>
            <textarea id="clinical_question" name="clinical_question" rows="6" required
                      minlength="10" maxlength="4000"
                      class="p-field__textarea"
                      placeholder="<%= tt('Describe what brought you here. Symptoms, what the first doctor said, anything that worries you.', 'Describe what brought you here. Symptoms, what the first doctor said, anything that worries you.', 'صف ما الذي جاء بك. الأعراض، ما قاله الطبيب الأول، أي شيء يقلقك.') %>"
            ><%= v.clinical_question %></textarea>
            <div class="p-field__hint"><%= tt('At least 10 characters. Up to about 4,000.', 'At least 10 characters. Up to about 4,000.', 'لا يقل عن 10 أحرف، حتى نحو 4000.') %></div>
          </div>

          <details style="margin-bottom:18px;">
            <summary style="font-size:13px;color:var(--primary);font-weight:600;cursor:pointer;">
              <%= tt('Add medical history (optional)', 'Add medical history (optional)', 'أضف التاريخ الطبي (اختياري)') %>
            </summary>
            <div class="p-field" style="margin-top:14px;">
              <label class="p-field__label" for="medical_history"><%= tt('Conditions, surgeries, allergies', 'Conditions, surgeries, allergies', 'الحالات، العمليات، الحساسية') %></label>
              <textarea id="medical_history" name="medical_history" rows="3" maxlength="4000" class="p-field__textarea"
                        placeholder="<%= tt('e.g., Type 2 diabetes (8 years), hypertension, mild aspirin allergy', 'e.g., Type 2 diabetes (8 years), hypertension, mild aspirin allergy', 'مثلاً: داء سكري نوع 2 منذ 8 سنوات، ضغط مرتفع، حساسية خفيفة من الأسبرين') %>"><%= v.medical_history %></textarea>
            </div>
            <div class="p-field" style="margin-top:14px;">
              <label class="p-field__label" for="current_medications"><%= tt('Current medications', 'Current medications', 'الأدوية الحالية') %></label>
              <textarea id="current_medications" name="current_medications" rows="3" maxlength="4000" class="p-field__textarea"
                        placeholder="<%= tt('Names, doses, how often', 'Names, doses, how often', 'الأسماء، الجرعات، عدد المرات') %>"><%= v.current_medications %></textarea>
            </div>
          </details>

          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
            <button class="p-btn p-btn--primary p-btn--lg" type="submit">
              <%= tt('Continue to documents', 'Continue to documents', 'متابعة إلى الملفات') %>
              <%- include('partials/patient/icon', { name: 'chevR', size: 14, flipRtl: true }) %>
            </button>
            <a class="p-btn p-btn--ghost" href="/dashboard"><%= tt('Save & exit', 'Save & exit', 'حفظ والخروج') %></a>
          </div>
        </form>
      </div>
    </div>

    <div class="stack">
      <%- include('partials/patient/reassure-card', {
        eyebrow: tt('Privacy', 'Privacy', 'الخصوصية'),
        title: tt('Your story stays between you and the specialist.', 'Your story stays between you and the specialist.', 'قصتك تبقى بينك وبين الطبيب.'),
        body: tt('We never share what you write here with anyone else. Files are encrypted, and you can delete them anytime.', 'We never share what you write here with anyone else. Files are encrypted, and you can delete them anytime.', 'لا نشارك ما تكتبه هنا مع أي طرف. الملفات مشفّرة، ويمكنك حذفها في أي وقت.'),
        isAr: __isAr
      }) %>
      <%- include('partials/patient/need-help-card', { isAr: __isAr }) %>
    </div>
  </div>

<% } else if (__step === 2) { %>
  <%# ─── STEP 2 — DOCUMENTS ─────────────────────────────────────────── %>
  <%
    const returnTo = '/patient/new-case?step=2&id=' + encodeURIComponent(draftId);
    const showFilesError = String(__queryErr || '') === 'needs_files';
    const hasCheckingFile = __files.some(f => f.is_valid === null || f.is_valid === undefined);
  %>
  <% if (showFilesError) { %>
    <div role="alert" class="p-card" style="padding:14px 18px;background:var(--warn-bg);border-color:#E6C7A8;color:var(--warn);margin-bottom:16px;font-size:13px;">
      <strong><%= tt('Add at least one file before continuing — your specialist needs something to review.', 'Add at least one file before continuing — your specialist needs something to review.', 'يرجى إضافة ملف واحد على الأقل قبل المتابعة — يحتاجها الطبيب للمراجعة.') %></strong>
    </div>
  <% } %>
  <% if (__uploadedFlashLocal) { %>
    <div class="p-card" style="padding:12px 18px;background:var(--success-bg);border-color:#B9DDC8;color:var(--success);margin-bottom:16px;font-size:13px;">
      <%= tt('File added. We’re checking it now — feel free to upload more.', 'File added. We’re checking it now — feel free to upload more.', 'تم إضافة الملف. نقوم بالتحقق منه الآن — يمكنك إضافة المزيد.') %>
    </div>
  <% } %>

  <div style="display:grid;grid-template-columns:2fr 1fr;gap:18px;" class="p-dash-cols">
    <div class="stack">
      <div class="p-card">
        <div class="p-card__header">
          <div class="p-card__title"><%= tt('Your files', 'Your files', 'ملفاتك') %></div>
          <div class="p-card__sub"><%= tt('We organize them so your doctor can move fast', 'We organize them so your doctor can move fast', 'نرتبها بحيث يستطيع طبيبك العمل بسرعة') %></div>
        </div>
        <div class="p-card__body" id="files-list" data-poll-url="/patient/new-case/<%= draftId %>/files.json" data-poll-active="<%= hasCheckingFile ? '1' : '0' %>">
          <% if (__files.length === 0) { %>
            <div style="padding:24px 0;text-align:center;color:var(--muted);font-size:13px;">
              <%= tt('No files yet. Drop scans, labs, or prior reports below.', 'No files yet. Drop scans, labs, or prior reports below.', 'لا توجد ملفات بعد. أضف الفحوصات، التحاليل، أو التقارير السابقة أدناه.') %>
            </div>
          <% } else { %>
            <div style="display:flex;flex-direction:column;gap:10px;">
              <% __files.forEach(function(f) {
                const validation = (f.is_valid === true || f.is_valid === 1) ? 'readable'
                                 : (f.is_valid === false || f.is_valid === 0) ? 'flagged'
                                 : 'checking';
              %>
                <div class="p-file-row" data-file-id="<%= f.id %>" data-validation="<%= validation %>"
                     style="display:grid;grid-template-columns:36px 1fr auto;gap:12px;align-items:center;padding:12px;border:1px solid var(--rule);border-radius:10px;background:<%= validation === 'flagged' ? 'var(--accent-tint)' : '#fff' %>;">
                  <div style="width:36px;height:36px;border-radius:9px;background:<%= validation === 'flagged' ? 'var(--accent-light)' : 'var(--primary-light)' %>;color:<%= validation === 'flagged' ? 'var(--accent-dark)' : 'var(--primary-dark)' %>;display:flex;align-items:center;justify-content:center;">
                    <% if (validation === 'flagged') { %>
                      <%- include('partials/patient/icon', { name: 'alert', size: 16 }) %>
                    <% } else { %>
                      <%- include('partials/patient/icon', { name: 'file', size: 16 }) %>
                    <% } %>
                  </div>
                  <div style="min-width:0;">
                    <div style="font-size:13px;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                      <%= f.label || tt('Uploaded file', 'Uploaded file', 'ملف مرفوع') %>
                    </div>
                    <div class="p-file-status" style="font-size:11.5px;margin-top:4px;color:var(--muted);">
                      <% if (validation === 'readable') { %>
                        <span style="color:var(--success);">✓ <%= tt('Readable', 'Readable', 'مقروء') %></span>
                      <% } else if (validation === 'flagged') { %>
                        <span style="color:var(--accent-dark);"><%= tt('We couldn’t read parts of this file. Your specialist may ask for a clearer copy.', 'We couldn’t read parts of this file. Your specialist may ask for a clearer copy.', 'لم نتمكن من قراءة أجزاء من هذا الملف. قد يطلب الطبيب نسخة أوضح.') %></span>
                      <% } else { %>
                        <span style="color:var(--accent-dark);"><%= tt('Checking file is complete and readable…', 'Checking file is complete and readable…', 'جارٍ التحقق من اكتمال وسهولة قراءة الملف…') %></span>
                      <% } %>
                    </div>
                  </div>
                  <a class="p-btn p-btn--ghost p-btn--sm" href="<%= f.url %>" target="_blank" rel="noopener">
                    <%- include('partials/patient/icon', { name: 'eye', size: 14 }) %>
                    <%= tt('View', 'View', 'عرض') %>
                  </a>
                </div>
              <% }); %>
            </div>
          <% } %>
        </div>
      </div>

      <% if (__uploaderConfigured || __r2DirectEnabled) { %>
        <form id="upload-form" method="post" action="/portal/patient/orders/<%= draftId %>/upload"
              style="border:2px dashed var(--rule-strong);border-radius:14px;padding:36px;text-align:center;background:#FBF9F4;">
          <%- (typeof csrfField === 'function') ? csrfField() : '' %>
          <%# Two parallel hidden fields for the upload result. Exactly one is %>
          <%# populated per submit (the wizard's two scripts are mutually     %>
          <%# exclusive — see the if/else below). The /portal/patient/orders/ %>
          <%# :id/upload handler reads both and accepts either.               %>
          <input type="hidden" name="file_url" id="file_url_input" />
          <input type="hidden" name="file_key" id="file_key_input" />
          <input type="hidden" name="label" id="label_input" />
          <%- include('partials/patient/icon', { name: 'upload', size: 22, color: 'var(--primary-dark)' }) %>
          <div style="font-size:14px;font-weight:600;margin-top:8px;"><%= tt('Drop a file or click to choose', 'Drop a file or click to choose', 'أفلت ملفاً أو انقر للاختيار') %></div>
          <div style="font-size:12px;color:var(--muted);margin-top:4px;"><%= tt('PDF, DICOM, JPG, PNG · up to 500 MB each', 'PDF, DICOM, JPG, PNG · up to 500 MB each', 'PDF، DICOM، JPG، PNG · حتى 500 ميغابايت لكل ملف') %></div>
          <div id="upload-progress" style="display:none;margin-top:12px;font-size:12px;color:var(--accent-dark);"></div>
          <input type="file" id="native_file" style="display:none;" accept="*/*" />
        </form>
      <% } else { %>
        <div class="p-card" style="padding:18px;background:var(--warn-bg);border-color:#E6C7A8;">
          <div style="font-size:13px;font-weight:600;color:var(--warn);margin-bottom:6px;">
            <%= tt('Uploader not configured', 'Uploader not configured', 'أداة الرفع غير مفعّلة') %>
          </div>
          <div style="font-size:12px;color:var(--ink-2);">
            <%= tt('Files cannot be added right now. Please contact support.', 'Files cannot be added right now. Please contact support.', 'لا يمكن إضافة ملفات الآن. يرجى التواصل مع الدعم.') %>
          </div>
        </div>
      <% } %>
    </div>

    <div class="stack">
      <div class="p-card" style="padding:18px;">
        <div style="font-size:10.5px;letter-spacing:0.14em;text-transform:uppercase;color:var(--muted);font-weight:700;margin-bottom:10px;">
          <%= tt('What helps most', 'What helps most', 'ما يساعد أكثر') %>
        </div>
        <ul style="margin:0;padding:0;list-style:none;display:flex;flex-direction:column;gap:10px;">
          <% [
            tt('The original scan files (DICOM if you have them)', 'The original scan files (DICOM if you have them)', 'ملفات الفحوصات الأصلية (DICOM إن أمكن)'),
            tt('Any prior imaging for comparison', 'Any prior imaging for comparison', 'أي صور أشعة سابقة للمقارنة'),
            tt('Lab panels — CBC, liver, tumor markers', 'Lab panels — CBC, liver, tumor markers', 'تحاليل المعمل — صورة دم، وظائف كبد، دلالات الأورام'),
            tt('The previous doctor’s written report', 'The previous doctor’s written report', 'التقرير المكتوب للطبيب السابق')
          ].forEach(function(t) { %>
            <li style="font-size:13px;color:var(--ink-2);display:flex;gap:8px;align-items:flex-start;">
              <%- include('partials/patient/icon', { name: 'check', size: 14, color: 'var(--primary)' }) %>
              <span><%= t %></span>
            </li>
          <% }); %>
        </ul>
      </div>
      <%- include('partials/patient/reassure-card', {
        eyebrow: tt('Privacy', 'Privacy', 'الخصوصية'),
        title: tt('Files are encrypted end-to-end.', 'Files are encrypted end-to-end.', 'الملفات مشفّرة من طرف إلى طرف.'),
        body: tt('Only your assigned specialist can see them. You can delete them anytime, even after your case closes.', 'Only your assigned specialist can see them. You can delete them anytime, even after your case closes.', 'يستطيع الطبيب المخصص لك فقط رؤيتها. يمكنك حذفها في أي وقت، حتى بعد إغلاق الحالة.'),
        isAr: __isAr
      }) %>
      <%- include('partials/patient/need-help-card', { isAr: __isAr }) %>
    </div>
  </div>

  <div style="display:flex;gap:10px;align-items:center;justify-content:space-between;margin-top:18px;flex-wrap:wrap;">
    <a class="p-btn p-btn--ghost" href="/patient/new-case?step=1&id=<%= encodeURIComponent(draftId) %>">
      <%- include('partials/patient/icon', { name: 'chevL', size: 14, flipRtl: true }) %>
      <%= tt('Back to condition', 'Back to condition', 'العودة إلى الحالة') %>
    </a>
    <form method="post" action="/patient/new-case/step2" style="margin:0;">
      <%- (typeof csrfField === 'function') ? csrfField() : '' %>
      <input type="hidden" name="id" value="<%= draftId %>" />
      <button class="p-btn p-btn--primary p-btn--lg" type="submit">
        <%= tt('Continue to specialty', 'Continue to specialty', 'متابعة إلى التخصص') %>
        <%- include('partials/patient/icon', { name: 'chevR', size: 14, flipRtl: true }) %>
      </button>
    </form>
  </div>

<% } else if (__step === 3) { %>
  <%# ─── STEP 3 — SPECIALTY ─────────────────────────────────────────── %>
  <%
    const __specialties = Array.isArray(specialties) ? specialties : [];
    const __services = Array.isArray(services) ? services : [];
    const selectedSpecialty = __draft && __draft.specialty_id ? String(__draft.specialty_id) : '';
    const selectedService = __draft && __draft.service_id ? String(__draft.service_id) : '';
    const step3Err = String(__queryErr || '');
  %>
  <% if (step3Err === 'needs_specialty') { %>
    <div role="alert" class="p-card" style="padding:14px 18px;background:var(--warn-bg);border-color:#E6C7A8;color:var(--warn);margin-bottom:16px;font-size:13px;">
      <strong><%= tt('Pick a specialty and service before continuing.', 'Pick a specialty and service before continuing.', 'يرجى اختيار التخصص والخدمة قبل المتابعة.') %></strong>
    </div>
  <% } else if (step3Err === 'specialty_unavailable') { %>
    <div role="alert" class="p-card" style="padding:14px 18px;background:var(--warn-bg);border-color:#E6C7A8;color:var(--warn);margin-bottom:16px;font-size:13px;">
      <strong><%= tt('That specialty has no consultants available right now. Please pick another.', 'That specialty has no consultants available right now. Please pick another.', 'هذا التخصص لا يوجد به استشاري متاح حالياً. اختر تخصصاً آخر.') %></strong>
    </div>
  <% } else if (step3Err === 'invalid_service') { %>
    <div role="alert" class="p-card" style="padding:14px 18px;background:var(--warn-bg);border-color:#E6C7A8;color:var(--warn);margin-bottom:16px;font-size:13px;">
      <strong><%= tt('That service doesn’t belong to the chosen specialty. Please re-select.', 'That service doesn’t belong to the chosen specialty. Please re-select.', 'هذه الخدمة لا تنتمي إلى التخصص المختار. يرجى إعادة الاختيار.') %></strong>
    </div>
  <% } %>

  <form method="post" action="/patient/new-case/step3" autocomplete="off" id="step3-form">
    <%- (typeof csrfField === 'function') ? csrfField() : '' %>
    <input type="hidden" name="id" value="<%= draftId %>" />
    <input type="hidden" name="specialty_id" id="step3-specialty-id" value="<%= selectedSpecialty %>" />
    <input type="hidden" name="service_id" id="step3-service-id" value="<%= selectedService %>" />

    <div class="p-card">
      <div class="p-card__header">
        <div class="p-card__title"><%= tt('Choose the right specialty', 'Choose the right specialty', 'اختر التخصص المناسب') %></div>
        <div class="p-card__sub"><%= tt('Only specialties with active consultants are shown.', 'Only specialties with active consultants are shown.', 'تظهر فقط التخصصات ذات الاستشاريين النشطين.') %></div>
      </div>
      <div class="p-card__body">
        <% if (__specialties.length === 0) { %>
          <div style="padding:24px 0;text-align:center;color:var(--muted);font-size:13px;">
            <%= tt('No specialists are available right now. Please contact us via WhatsApp and we’ll match you manually.', 'No specialists are available right now. Please contact us via WhatsApp and we’ll match you manually.', 'لا يوجد استشاريون متاحون حالياً. يرجى التواصل عبر واتساب وسنوفر لك الطبيب المناسب يدوياً.') %>
          </div>
        <% } else { %>
          <div class="p-spec-grid" style="display:grid;grid-template-columns:repeat(auto-fill, minmax(220px, 1fr));gap:12px;">
            <% __specialties.forEach(function(sp) {
              const sel = String(sp.id) === selectedSpecialty;
              const docCount = Number(sp.active_count) || 0;
              const limited = docCount === 1; // single-consultant specialty: surface as "limited availability"
            %>
              <button type="button"
                      class="p-spec-card<%= sel ? ' is-selected' : '' %>"
                      data-specialty-id="<%= sp.id %>"
                      style="text-align:start;cursor:pointer;border:1px solid <%= sel ? 'var(--primary)' : 'var(--rule)' %>;background:<%= sel ? 'var(--primary-light)' : '#fff' %>;border-radius:12px;padding:14px 16px;transition:border-color var(--t-fast) var(--ease), background var(--t-fast) var(--ease);">
                <div style="font-size:14px;font-weight:600;color:var(--ink);"><%= __isAr && sp.name_ar ? sp.name_ar : sp.name %></div>
                <div style="font-size:11.5px;color:<%= limited ? 'var(--accent-dark)' : 'var(--muted)' %>;margin-top:4px;">
                  <% if (limited) { %>
                    <%= tt('Limited availability', 'Limited availability', 'إتاحة محدودة') %>
                  <% } else { %>
                    <%= tt(docCount + ' consultants available', docCount + ' consultants available', docCount + ' استشاري متاح') %>
                  <% } %>
                </div>
              </button>
            <% }); %>
          </div>
        <% } %>
      </div>
    </div>

    <div class="p-card" id="step3-services-card" style="margin-top:14px;<%= selectedSpecialty ? '' : 'display:none;' %>">
      <div class="p-card__header">
        <div class="p-card__title"><%= tt('Pick the service that matches your case', 'Pick the service that matches your case', 'اختر الخدمة التي تناسب حالتك') %></div>
        <div class="p-card__sub"><%= tt('Each service is a different review depth.', 'Each service is a different review depth.', 'تختلف الخدمات في عمق المراجعة.') %></div>
      </div>
      <div class="p-card__body" id="step3-services-body" style="display:flex;flex-direction:column;gap:10px;">
        <% __services.forEach(function(sv) {
          const matchesSpecialty = String(sv.specialty_id) === selectedSpecialty;
          const sel = String(sv.id) === selectedService;
          if (!selectedSpecialty || !matchesSpecialty) return;
          const cur = String(sv.currency || countryCurrency || 'EGP').toUpperCase();
          const price = Number(sv.base_price) || 0;
          // Theme 10b §C / OQ-2: money always Western digits regardless of lang.
          const priceLabel = cur + ' ' + price.toLocaleString('en-GB', { maximumFractionDigits: 0 });
        %>
          <button type="button"
                  class="p-service-card<%= sel ? ' is-selected' : '' %>"
                  data-service-id="<%= sv.id %>"
                  data-specialty-id="<%= sv.specialty_id %>"
                  style="text-align:start;cursor:pointer;display:flex;align-items:center;justify-content:space-between;gap:12px;border:1px solid <%= sel ? 'var(--primary)' : 'var(--rule)' %>;background:<%= sel ? 'var(--primary-light)' : '#fff' %>;border-radius:12px;padding:14px 16px;">
            <div>
              <div style="font-size:14px;font-weight:600;color:var(--ink);"><%= sv.name %></div>
              <div style="font-size:11.5px;color:var(--muted);margin-top:3px;"><%= tt('Standard ' + (sv.sla_hours || 72) + 'h turnaround', 'Standard ' + (sv.sla_hours || 72) + 'h turnaround', 'تسليم خلال ' + (sv.sla_hours || 72) + ' ساعة قياسي') %></div>
            </div>
            <div class="p-num" style="font-size:14px;font-weight:600;color:var(--accent-dark);"><%= priceLabel %></div>
          </button>
        <% }); %>
      </div>
    </div>

    <div style="display:flex;gap:10px;align-items:center;justify-content:space-between;margin-top:18px;flex-wrap:wrap;">
      <a class="p-btn p-btn--ghost" href="/patient/new-case?step=2&id=<%= encodeURIComponent(draftId) %>">
        <%- include('partials/patient/icon', { name: 'chevL', size: 14, flipRtl: true }) %>
        <%= tt('Back to documents', 'Back to documents', 'العودة إلى الملفات') %>
      </a>
      <button class="p-btn p-btn--primary p-btn--lg" type="submit" id="step3-continue" <%= (selectedSpecialty && selectedService) ? '' : 'disabled' %> style="<%= (selectedSpecialty && selectedService) ? '' : 'opacity:0.5;cursor:not-allowed;' %>">
        <%= tt('Continue to review', 'Continue to review', 'متابعة إلى المراجعة') %>
        <%- include('partials/patient/icon', { name: 'chevR', size: 14, flipRtl: true }) %>
      </button>
    </div>
  </form>

  <% if (__specialties.length > 0) { %>
    <%# Embed services data for client-side filtering when patient picks a specialty. %>
    <script<%- __nonceAttr %>>
      (function() {
        var allServices = <%- JSON.stringify(__services.map(function(sv) { return { id: sv.id, specialty_id: sv.specialty_id, name: sv.name, base_price: Number(sv.base_price) || 0, currency: sv.currency || 'EGP', sla_hours: sv.sla_hours || 72 }; })) %>;
        var specialtyInput = document.getElementById('step3-specialty-id');
        var serviceInput = document.getElementById('step3-service-id');
        var servicesCard = document.getElementById('step3-services-card');
        var servicesBody = document.getElementById('step3-services-body');
        var continueBtn = document.getElementById('step3-continue');
        var labelStandard = <%- JSON.stringify(tt('Standard', 'Standard', 'قياسي')) %>;
        var labelTurn = <%- JSON.stringify(tt('h turnaround', 'h turnaround', 'ساعة')) %>;

        function renderServices() {
          var spId = specialtyInput.value;
          if (!spId) { servicesCard.style.display = "none"; servicesBody.innerHTML = ""; return; }
          var matching = allServices.filter(function(sv) { return String(sv.specialty_id) === spId; });
          servicesBody.innerHTML = "";
          matching.forEach(function(sv) {
            var btn = document.createElement("button");
            btn.type = "button";
            btn.className = "p-service-card" + (String(sv.id) === serviceInput.value ? " is-selected" : "");
            btn.setAttribute("data-service-id", sv.id);
            btn.style.cssText = "text-align:start;cursor:pointer;display:flex;align-items:center;justify-content:space-between;gap:12px;border:1px solid " + (String(sv.id) === serviceInput.value ? "var(--primary)" : "var(--rule)") + ";background:" + (String(sv.id) === serviceInput.value ? "var(--primary-light)" : "#fff") + ";border-radius:12px;padding:14px 16px;";
            var inner = document.createElement("div");
            var name = document.createElement("div");
            name.style.cssText = "font-size:14px;font-weight:600;color:var(--ink);";
            name.textContent = sv.name;
            inner.appendChild(name);
            var sub = document.createElement("div");
            sub.style.cssText = "font-size:11.5px;color:var(--muted);margin-top:3px;";
            sub.textContent = labelStandard + " " + sv.sla_hours + " " + labelTurn;
            inner.appendChild(sub);
            btn.appendChild(inner);
            var price = document.createElement("div");
            price.className = "p-num";
            price.style.cssText = "font-size:14px;font-weight:600;color:var(--accent-dark);";
            // Theme 10b §C / OQ-2: money always Western digits.
            price.textContent = (sv.currency || "EGP") + " " + Number(sv.base_price).toLocaleString('en-GB', { maximumFractionDigits: 0 });
            btn.appendChild(price);
            btn.addEventListener("click", function() {
              serviceInput.value = sv.id;
              renderServices();
              updateContinue();
            });
            servicesBody.appendChild(btn);
          });
          servicesCard.style.display = matching.length > 0 ? "" : "none";
        }
        function updateContinue() {
          var ok = specialtyInput.value && serviceInput.value;
          if (continueBtn) {
            continueBtn.disabled = !ok;
            continueBtn.style.opacity = ok ? "" : "0.5";
            continueBtn.style.cursor = ok ? "" : "not-allowed";
          }
        }

        document.querySelectorAll(".p-spec-card").forEach(function(btn) {
          btn.addEventListener("click", function() {
            var spId = btn.getAttribute("data-specialty-id");
            specialtyInput.value = spId;
            // Clear service when switching specialty.
            serviceInput.value = "";
            // Update visual selection on specialty cards.
            document.querySelectorAll(".p-spec-card").forEach(function(b) {
              var isSel = b === btn;
              b.style.border = "1px solid " + (isSel ? "var(--primary)" : "var(--rule)");
              b.style.background = isSel ? "var(--primary-light)" : "#fff";
            });
            renderServices();
            updateContinue();
          });
        });
        // Bind any pre-rendered service-card buttons (server-rendered above).
        document.querySelectorAll(".p-service-card").forEach(function(btn) {
          btn.addEventListener("click", function() {
            serviceInput.value = btn.getAttribute("data-service-id");
            document.querySelectorAll(".p-service-card").forEach(function(b) {
              var isSel = b === btn;
              b.style.border = "1px solid " + (isSel ? "var(--primary)" : "var(--rule)");
              b.style.background = isSel ? "var(--primary-light)" : "#fff";
            });
            updateContinue();
          });
        });
        updateContinue();
      })();
    </script>
  <% } %>

<% } else if (__step === 4) { %>
  <%# ─── STEP 4 — REVIEW + TIER + PRICING ───────────────────────────── %>
  <%
    const __pricing = (typeof pricing === 'object' && pricing) ? pricing : null;
    // Theme 10b §C / OQ-2: money always Western digits regardless of lang.
    const fmtMoney = function(amt, cur) {
      const n = Math.round(Number(amt) || 0);
      return String(cur || 'EGP').toUpperCase() + ' ' + n.toLocaleString('en-GB', { maximumFractionDigits: 0 });
    };
    const step4Err = String(__queryErr || '');
    // Canonical tier read from orders.urgency_tier ('standard' | 'vip' | 'urgent').
    const tierCurrent = (__draft && __draft.urgency_tier) ? String(__draft.urgency_tier).toLowerCase() : '';
    const filesCount = Array.isArray(files) ? files.length : 0;
  %>
  <% if (step4Err === 'needs_sla' || step4Err === 'invalid_tier') { %>
    <div role="alert" class="p-card" style="padding:14px 18px;background:var(--warn-bg);border-color:#E6C7A8;color:var(--warn);margin-bottom:16px;font-size:13px;">
      <strong><%= tt('Choose how soon you need your opinion before continuing.', 'Choose how soon you need your opinion before continuing.', 'اختر متى تحتاج رأيك قبل المتابعة.') %></strong>
    </div>
  <% } else if (step4Err === 'urgent_outside_window') { %>
    <%# Policy §3 — Urgent submitted outside 7am-7pm Cairo. Two explicit choices. %>
    <div role="alert" class="p-card" style="padding:18px;background:var(--warn-bg);border:1px solid #E6C7A8;margin-bottom:16px;">
      <div style="font-size:13px;font-weight:700;color:var(--warn);margin-bottom:6px;">
        <%= tt('Urgent isn’t available right now', 'Urgent isn’t available right now', 'الخدمة العاجلة غير متاحة الآن') %>
      </div>
      <div style="font-size:12.5px;color:var(--ink-2);line-height:1.5;margin-bottom:14px;">
        <%= tt('Urgent reviews run between 7am and 7pm Cairo time. Pick how you’d like to proceed:', 'Urgent reviews run between 7am and 7pm Cairo time. Pick how you’d like to proceed:', 'تتم المراجعات العاجلة بين 7 صباحاً و7 مساءً بتوقيت القاهرة. اختر كيف تريد المتابعة:') %>
      </div>
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
        <form method="post" action="/patient/new-case/step4/urgency-resolve" style="margin:0;">
          <%- (typeof csrfField === 'function') ? csrfField() : '' %>
          <input type="hidden" name="id" value="<%= draftId %>" />
          <input type="hidden" name="choice" value="wait" />
          <button type="submit" class="p-btn p-btn--secondary p-btn--block" style="text-align:start;padding:14px;">
            <div style="font-size:13px;font-weight:600;color:var(--ink);">
              <%= tt('Wait until 7am Cairo', 'Wait until 7am Cairo', 'الانتظار حتى 7 صباحاً') %>
            </div>
            <div style="font-size:11.5px;color:var(--muted);margin-top:4px;line-height:1.4;">
              <%= tt('Stay urgent. Clock starts at 7am, deadline is 11am.', 'Stay urgent. Clock starts at 7am, deadline is 11am.', 'تبقى الحالة عاجلة. تبدأ الساعة 7 صباحاً والموعد النهائي 11 صباحاً.') %>
            </div>
          </button>
        </form>
        <form method="post" action="/patient/new-case/step4/urgency-resolve" style="margin:0;">
          <%- (typeof csrfField === 'function') ? csrfField() : '' %>
          <input type="hidden" name="id" value="<%= draftId %>" />
          <input type="hidden" name="choice" value="downgrade_vip" />
          <button type="submit" class="p-btn p-btn--primary p-btn--block" style="text-align:start;padding:14px;">
            <div style="font-size:13px;font-weight:600;">
              <%= tt('Downgrade to VIP now', 'Downgrade to VIP now', 'تخفيض إلى VIP الآن') %>
            </div>
            <div style="font-size:11.5px;opacity:0.8;margin-top:4px;line-height:1.4;">
              <%= tt('Process immediately. 18-hour SLA, +30% surcharge.', 'Process immediately. 18-hour SLA, +30% surcharge.', 'معالجة فورية. خلال 18 ساعة، زيادة 30٪.') %>
            </div>
          </button>
        </form>
      </div>
    </div>
  <% } %>

  <div class="p-card">
    <div class="p-card__header">
      <div class="p-card__title"><%= tt('Review your case', 'Review your case', 'راجع حالتك') %></div>
      <div class="p-card__sub"><%= tt('Make sure everything looks right — you can edit any section.', 'Make sure everything looks right — you can edit any section.', 'تأكد أن كل شيء صحيح — يمكنك تعديل أي قسم.') %></div>
    </div>
    <div class="p-card__body" style="display:flex;flex-direction:column;gap:14px;">

      <%# Condition summary %>
      <div style="display:grid;grid-template-columns:1fr auto;gap:14px;align-items:flex-start;padding:14px;border:1px solid var(--rule);border-radius:12px;background:#FBF9F4;">
        <div>
          <div style="font-size:10.5px;letter-spacing:0.14em;text-transform:uppercase;color:var(--muted);font-weight:700;margin-bottom:6px;">
            <%= tt('Your concern', 'Your concern', 'ما يقلقك') %>
          </div>
          <div style="font-size:13px;color:var(--ink);line-height:1.55;white-space:pre-wrap;"><%= __draft && __draft.clinical_question || '' %></div>
        </div>
        <a class="p-btn p-btn--ghost p-btn--sm" href="/patient/new-case?step=1&id=<%= encodeURIComponent(draftId) %>"><%= tt('Edit', 'Edit', 'تعديل') %></a>
      </div>

      <%# Files summary %>
      <div style="display:grid;grid-template-columns:1fr auto;gap:14px;align-items:flex-start;padding:14px;border:1px solid var(--rule);border-radius:12px;background:#FBF9F4;">
        <div>
          <div style="font-size:10.5px;letter-spacing:0.14em;text-transform:uppercase;color:var(--muted);font-weight:700;margin-bottom:6px;">
            <%= tt('Documents', 'Documents', 'الملفات') %>
          </div>
          <div style="font-size:13px;color:var(--ink);">
            <%= tt(filesCount + (filesCount === 1 ? ' file uploaded' : ' files uploaded'), filesCount + (filesCount === 1 ? ' file uploaded' : ' files uploaded'), filesCount + ' ملف مرفوع') %>
          </div>
        </div>
        <a class="p-btn p-btn--ghost p-btn--sm" href="/patient/new-case?step=2&id=<%= encodeURIComponent(draftId) %>"><%= tt('Edit', 'Edit', 'تعديل') %></a>
      </div>

      <%# Specialty + service summary %>
      <div style="display:grid;grid-template-columns:1fr auto;gap:14px;align-items:flex-start;padding:14px;border:1px solid var(--rule);border-radius:12px;background:#FBF9F4;">
        <div>
          <div style="font-size:10.5px;letter-spacing:0.14em;text-transform:uppercase;color:var(--muted);font-weight:700;margin-bottom:6px;">
            <%= tt('Specialty', 'Specialty', 'التخصص') %>
          </div>
          <div style="font-size:13px;color:var(--ink);">
            <%= (__draft && (__isAr && __draft.specialty_name_ar ? __draft.specialty_name_ar : __draft.specialty_name)) || '—' %>
            <% if (__draft && __draft.service_name) { %> · <%= __draft.service_name %><% } %>
          </div>
        </div>
        <a class="p-btn p-btn--ghost p-btn--sm" href="/patient/new-case?step=3&id=<%= encodeURIComponent(draftId) %>"><%= tt('Edit', 'Edit', 'تعديل') %></a>
      </div>
    </div>
  </div>

  <%# Tier + pricing form %>
  <% if (__pricing && __pricing.tiers) { %>
    <%
      // Tier display config — eyebrow / title / sub per tier key.
      // Hours and surcharge percentages match docs/PAYOUT_AND_URGENCY_POLICY.md §2.
      const TIER_DISPLAY = {
        standard: {
          eyebrow: tt('STANDARD', 'STANDARD', 'قياسي'),
          title:   tt('48-hour turnaround', '48-hour turnaround', 'تسليم خلال 48 ساعة'),
          sub:     tt('You receive your written opinion within 48 hours.', 'You receive your written opinion within 48 hours.', 'تستلم رأيك المكتوب خلال 48 ساعة.')
        },
        vip: {
          eyebrow: tt('VIP · +30% surcharge', 'VIP · +30% surcharge', 'VIP · زيادة 30٪'),
          title:   tt('18-hour turnaround', '18-hour turnaround', 'تسليم خلال 18 ساعة'),
          sub:     tt('Same consultant, faster window. Available 24/7.', 'Same consultant, faster window. Available 24/7.', 'نفس الاستشاري، أسرع. متاح على مدار الساعة.')
        },
        urgent: {
          eyebrow: tt('URGENT · +60% surcharge', 'URGENT · +60% surcharge', 'عاجل · زيادة 60٪'),
          title:   tt('4-hour turnaround', '4-hour turnaround', 'تسليم خلال 4 ساعات'),
          sub:     tt('Fastest review. Available 7am–7pm Cairo time.', 'Fastest review. Available 7am–7pm Cairo time.', 'أسرع مراجعة. متاح 7 صباحاً حتى 7 مساءً بتوقيت القاهرة.')
        }
      };
      const TIER_KEYS = ['standard', 'vip', 'urgent'];
    %>
    <form method="post" action="/patient/new-case/step4" id="step4-form" style="margin-top:18px;">
      <%- (typeof csrfField === 'function') ? csrfField() : '' %>
      <input type="hidden" name="id" value="<%= draftId %>" />

      <div class="p-card">
        <div class="p-card__header">
          <div class="p-card__title"><%= tt('How soon do you need your opinion?', 'How soon do you need your opinion?', 'متى تحتاج رأيك؟') %></div>
          <div class="p-card__sub"><%= tt('All options are reviewed by the same consultant-level specialists.', 'All options are reviewed by the same consultant-level specialists.', 'جميع الخيارات يراجعها استشاريون من نفس المستوى.') %></div>
        </div>
        <div class="p-card__body" style="display:flex;flex-direction:column;gap:10px;">
          <% TIER_KEYS.forEach(function(tierKey) {
            const tier = __pricing.tiers[tierKey];
            if (!tier) return;
            const display = TIER_DISPLAY[tierKey];
            const sel = tierCurrent === tierKey;
            const totalLocal = Number(tier.total && tier.total.local) || 0;
            const totalEgp = Number(tier.total && tier.total.egp) || 0;
            const upliftLocal = Number(tier.uplift && tier.uplift.local) || 0;
            const baseLocal = Number(__pricing.base && __pricing.base.local) || 0;
            const isStandard = tierKey === 'standard';
          %>
            <label class="p-sla-option<%= sel ? ' is-selected' : '' %>" style="display:grid;grid-template-columns:auto 1fr auto;gap:14px;align-items:center;padding:16px;border:1px solid <%= sel ? 'var(--primary)' : 'var(--rule)' %>;background:<%= sel ? 'var(--primary-light)' : '#fff' %>;border-radius:12px;cursor:pointer;transition:border-color var(--t-fast) var(--ease), background var(--t-fast) var(--ease);">
              <input type="radio" name="tier" value="<%= tierKey %>" <%= sel ? 'checked' : '' %> required style="accent-color:var(--primary);width:18px;height:18px;" />
              <div>
                <div style="font-size:10.5px;letter-spacing:0.14em;text-transform:uppercase;color:var(--accent-dark);font-weight:700;"><%= display.eyebrow %></div>
                <div style="font-size:14.5px;font-weight:600;margin-top:3px;"><%= display.title %></div>
                <div style="font-size:12.5px;color:var(--muted);margin-top:3px;line-height:1.5;"><%= display.sub %></div>
                <% if (!isStandard) { %>
                  <div style="font-size:11.5px;color:var(--muted);margin-top:8px;line-height:1.5;">
                    <%= fmtMoney(baseLocal, __pricing.localCurrency) %>
                    + <%= fmtMoney(upliftLocal, __pricing.localCurrency) %>
                    = <strong style="color:var(--ink);"><%= fmtMoney(totalLocal, __pricing.localCurrency) %></strong>
                    <span style="display:inline-block;margin-inline-start:6px;color:var(--accent-dark);font-style:italic;"><%= tt('refundable if SLA is breached', 'refundable if SLA is breached', 'تُرد الزيادة إن لم يلتزم بالموعد') %></span>
                  </div>
                <% } %>
              </div>
              <div style="text-align:end;">
                <div class="p-num" style="font-family:var(--font-display);font-size:24px;font-weight:500;color:var(--accent-dark);letter-spacing:-0.005em;">
                  <%= fmtMoney(totalLocal, __pricing.localCurrency) %>
                </div>
                <% if (__pricing.showSecondary) { %>
                  <div class="p-num" style="font-size:11.5px;color:var(--muted);margin-top:2px;">
                    ≈ <%= fmtMoney(totalEgp, 'EGP') %>
                  </div>
                <% } %>
              </div>
            </label>
          <% }); %>
        </div>
      </div>

      <div style="display:flex;gap:10px;align-items:center;justify-content:space-between;margin-top:18px;flex-wrap:wrap;">
        <a class="p-btn p-btn--ghost" href="/patient/new-case?step=3&id=<%= encodeURIComponent(draftId) %>">
          <%- include('partials/patient/icon', { name: 'chevL', size: 14, flipRtl: true }) %>
          <%= tt('Back to specialty', 'Back to specialty', 'العودة إلى التخصص') %>
        </a>
        <button class="p-btn p-btn--primary p-btn--lg" type="submit">
          <%= tt('Continue to payment', 'Continue to payment', 'متابعة إلى الدفع') %>
          <%- include('partials/patient/icon', { name: 'chevR', size: 14, flipRtl: true }) %>
        </button>
      </div>
    </form>
  <% } else { %>
    <div class="p-card" style="margin-top:18px;padding:18px;background:var(--warn-bg);border-color:#E6C7A8;">
      <div style="font-size:13px;font-weight:600;color:var(--warn);margin-bottom:6px;">
        <%= tt('Pricing is unavailable for the selected service.', 'Pricing is unavailable for the selected service.', 'التسعير غير متاح للخدمة المختارة.') %>
      </div>
      <div style="font-size:12px;color:var(--ink-2);">
        <%= tt('Please go back and re-select the specialty / service, or contact us via WhatsApp.', 'Please go back and re-select the specialty / service, or contact us via WhatsApp.', 'يرجى العودة وإعادة اختيار التخصص أو الخدمة، أو التواصل عبر واتساب.') %>
      </div>
    </div>
    <div style="display:flex;gap:10px;align-items:center;justify-content:space-between;margin-top:18px;flex-wrap:wrap;">
      <a class="p-btn p-btn--ghost" href="/patient/new-case?step=3&id=<%= encodeURIComponent(draftId) %>">
        <%- include('partials/patient/icon', { name: 'chevL', size: 14, flipRtl: true }) %>
        <%= tt('Back to specialty', 'Back to specialty', 'العودة إلى التخصص') %>
      </a>
    </div>
  <% } %>

<% } else if (__step === 5) { %>
  <%# ─── STEP 5 — PAYMENT (live Paymob handoff or stub mode) ────────── %>
  <%
    const __pricing = (typeof pricing === 'object' && pricing) ? pricing : null;
    const __failed = !!(typeof paymentFailed !== 'undefined' && paymentFailed);
    // Theme 10b §C / OQ-2: money always Western digits regardless of lang.
    const fmtMoney2 = function(amt, cur) {
      const n = Math.round(Number(amt) || 0);
      return String(cur || 'EGP').toUpperCase() + ' ' + n.toLocaleString('en-GB', { maximumFractionDigits: 0 });
    };
    // Source-of-truth: orders row persisted by Step 4. The wizard
    // catalog (__pricing) is used only for currency / serviceName /
    // showSecondary metadata — never for the displayed total.
    const __tier = (__draft && __draft.urgency_tier) ? String(__draft.urgency_tier).toLowerCase() : '';
    const __basePrice = Number(__draft && __draft.base_price) || 0;
    const __upliftAmount = Number(__draft && __draft.urgency_uplift_amount) || 0;
    const __totalPrice = Number(__draft && __draft.price) || (__basePrice + __upliftAmount);
    const __slaHours = Number(__draft && __draft.sla_hours) || 0;
    const __isStandard = __tier === 'standard';
    const __localCurrency = (__pricing && __pricing.localCurrency) || 'EGP';
    const __showSecondary = !!(__pricing && __pricing.showSecondary);
    // Approximate EGP secondary lane: scale base + uplift by the ratio
    // of EGP-base to local-base (both available on __pricing.base when
    // present). Falls back to 1:1 when __pricing is missing.
    const __egpRatio = (__pricing && __pricing.base && Number(__pricing.base.local) > 0)
      ? (Number(__pricing.base.egp) / Number(__pricing.base.local))
      : 1;
    const __totalEgp = __totalPrice * __egpRatio;
    const __tierLabel = __isStandard
      ? tt('Standard 48h', 'Standard 48h', 'قياسي 48 ساعة')
      : __tier === 'vip'
        ? tt('VIP 18h', 'VIP 18h', 'VIP 18 ساعة')
        : __tier === 'urgent'
          ? tt('Urgent 4h', 'Urgent 4h', 'عاجل 4 ساعات')
          : (__slaHours ? tt(__slaHours + 'h', __slaHours + 'h', __slaHours + ' ساعة') : '');
  %>

  <% if (__failed) { %>
    <div role="alert" class="p-card" style="padding:16px 18px;background:var(--warn-bg);border-color:#E6C7A8;color:var(--warn);margin-bottom:16px;">
      <div style="font-size:13px;font-weight:600;margin-bottom:4px;">
        <%= tt('Your previous payment didn’t go through.', 'Your previous payment didn’t go through.', 'لم يكتمل الدفع في المرة السابقة.') %>
      </div>
      <div style="font-size:12.5px;color:var(--ink-2);line-height:1.5;">
        <%= tt('Your case is still saved — let’s try the payment again. Your details are still here.', 'Your case is still saved — let’s try the payment again. Your details are still here.', 'حالتك محفوظة — لنُعد المحاولة. تفاصيلك لا تزال هنا.') %>
      </div>
    </div>
  <% } %>

  <div style="display:grid;grid-template-columns:2fr 1fr;gap:18px;" class="p-dash-cols">
    <div class="stack">
      <div class="p-card">
        <div class="p-card__header">
          <div class="p-card__title"><%= tt('Final step — payment', 'Final step — payment', 'الخطوة الأخيرة — الدفع') %></div>
          <div class="p-card__sub"><%= tt('Paid upfront, held safely. Full refund if no specialist accepts within 48 hours.', 'Paid upfront, held safely. Full refund if no specialist accepts within 48 hours.', 'يُدفع مقدماً ويُحفظ بأمان. إعادة كاملة إذا لم يقبل أي طبيب خلال 48 ساعة.') %></div>
        </div>
        <div class="p-card__body">
          <% if (__tier && __totalPrice > 0) { %>
            <%# Policy §6 breakdown panel — base + (surcharge if applicable) = total. %>
            <div style="padding:18px;background:#FBF9F4;border-radius:12px;">
              <div style="display:grid;grid-template-columns:1fr auto;gap:8px;align-items:baseline;font-size:13px;color:var(--ink-2);">
                <div><%= tt('Service price', 'Service price', 'سعر الخدمة') %><% if (__draft && __draft.service_name) { %> <span style="color:var(--muted);">· <%= __draft.service_name %></span><% } %></div>
                <div class="p-num" style="font-weight:500;color:var(--ink);"><%= fmtMoney2(__basePrice, __localCurrency) %></div>
              </div>
              <% if (!__isStandard) { %>
                <div style="display:grid;grid-template-columns:1fr auto;gap:8px;align-items:baseline;font-size:13px;color:var(--ink-2);margin-top:8px;">
                  <div>
                    <%= tt('Urgency surcharge', 'Urgency surcharge', 'رسوم الأولوية') %>
                    <span style="color:var(--accent-dark);font-style:italic;font-size:11.5px;">(<%= __tier === 'urgent' ? tt('Urgent', 'Urgent', 'عاجل') : tt('VIP', 'VIP', 'VIP') %> · <%= tt('refundable if SLA is breached', 'refundable if SLA is breached', 'تُرد إن لم يلتزم بالموعد') %>)</span>
                  </div>
                  <div class="p-num" style="font-weight:500;color:var(--ink);">+<%= fmtMoney2(__upliftAmount, __localCurrency) %></div>
                </div>
              <% } %>
              <div style="border-top:1px solid var(--rule);margin-top:12px;padding-top:12px;display:grid;grid-template-columns:1fr auto;gap:8px;align-items:baseline;">
                <div>
                  <div style="font-size:10.5px;letter-spacing:0.14em;text-transform:uppercase;color:var(--muted);font-weight:700;">
                    <%= tt('Total today', 'Total today', 'الإجمالي اليوم') %>
                  </div>
                  <% if (__tierLabel) { %>
                    <div style="font-size:11.5px;color:var(--muted);margin-top:4px;"><%= __tierLabel %></div>
                  <% } %>
                </div>
                <div style="text-align:end;">
                  <div class="p-num" style="font-family:var(--font-display);font-size:34px;font-weight:500;color:var(--accent-dark);letter-spacing:-0.005em;line-height:1;">
                    <%= fmtMoney2(__totalPrice, __localCurrency) %>
                  </div>
                  <% if (__showSecondary) { %>
                    <div class="p-num" style="font-size:12px;color:var(--muted);margin-top:4px;">
                      ≈ <%= fmtMoney2(__totalEgp, 'EGP') %>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>

            <form method="post" action="/patient/new-case/step5" style="margin-top:18px;">
              <%- (typeof csrfField === 'function') ? csrfField() : '' %>
              <input type="hidden" name="id" value="<%= draftId %>" />

              <%# Test mode is the only mode pre-launch. When live Paymob is
                  enabled (see header on POST /patient/new-case/step5 in
                  routes/patient.js), swap the button label to "Pay securely
                  with Paymob" + lock icon and drop the disclaimer below. %>
              <button class="p-btn p-btn--primary p-btn--lg p-btn--block" type="submit" style="font-size:15px;">
                <%- include('partials/patient/icon', { name: 'check', size: 16 }) %>
                <%= tt('Confirm and pay (test mode)', 'Confirm and pay (test mode)', 'تأكيد ودفع (وضع الاختبار)') %>
              </button>

              <div style="margin-top:10px;font-size:11.5px;color:var(--accent-dark);text-align:center;">
                <%= tt('Test mode: live Paymob payments are not yet enabled. Continuing simulates a successful payment for testing.', 'Test mode: live Paymob payments are not yet enabled. Continuing simulates a successful payment for testing.', 'وضع الاختبار: مدفوعات Paymob الحية غير مفعّلة بعد. المتابعة تحاكي عملية ناجحة للاختبار.') %>
              </div>
            </form>

            <div style="margin-top:14px;text-align:center;font-size:12px;color:var(--muted);">
              <%= tt('Cards · Wallets · Apple Pay · Google Pay · supported by Paymob', 'Cards · Wallets · Apple Pay · Google Pay · supported by Paymob', 'بطاقات · محافظ · Apple Pay · Google Pay · عبر Paymob') %>
            </div>
          <% } else { %>
            <div style="padding:18px;background:var(--warn-bg);border:1px solid #E6C7A8;border-radius:12px;font-size:13px;color:var(--warn);">
              <strong><%= tt('Pricing unavailable.', 'Pricing unavailable.', 'التسعير غير متاح.') %></strong>
              <%= tt(' Please go back to Step 4 and re-confirm your selection, or contact us via WhatsApp.', ' Please go back to Step 4 and re-confirm your selection, or contact us via WhatsApp.', ' يرجى العودة إلى الخطوة 4 وإعادة تأكيد اختيارك أو التواصل عبر واتساب.') %>
            </div>
          <% } %>
        </div>
      </div>

      <div style="display:flex;gap:10px;align-items:center;justify-content:flex-start;margin-top:6px;flex-wrap:wrap;">
        <a class="p-btn p-btn--ghost" href="/patient/new-case?step=4&id=<%= encodeURIComponent(draftId) %>">
          <%- include('partials/patient/icon', { name: 'chevL', size: 14, flipRtl: true }) %>
          <%= tt('Back to review', 'Back to review', 'العودة إلى المراجعة') %>
        </a>
        <a class="p-btn p-btn--ghost" href="/dashboard"><%= tt('Save & exit', 'Save & exit', 'حفظ والخروج') %></a>
      </div>
    </div>

    <div class="stack">
      <%- include('partials/patient/reassure-card', {
        eyebrow: tt('How payment works', 'How payment works', 'كيف يتم الدفع'),
        title: tt('Paid upfront, held safely.', 'Paid upfront, held safely.', 'مدفوع مقدماً، محفوظ بأمان.'),
        body: tt('If no specialist accepts your case within 48 hours, the fee is returned in full. You can also cancel before assignment for a full refund.', 'If no specialist accepts your case within 48 hours, the fee is returned in full. You can also cancel before assignment for a full refund.', 'إذا لم يقبل أي طبيب حالتك خلال 48 ساعة، تُعاد الرسوم بالكامل. يمكنك أيضاً الإلغاء قبل التعيين لاسترداد كامل.'),
        isAr: __isAr
      }) %>
      <div class="p-card" style="padding:18px;">
        <div style="font-size:10.5px;letter-spacing:0.14em;text-transform:uppercase;color:var(--muted);font-weight:700;margin-bottom:10px;">
          <%= tt('Secure', 'Secure', 'الأمان') %>
        </div>
        <ul style="margin:0;padding:0;list-style:none;display:flex;flex-direction:column;gap:10px;">
          <% [
            tt('Payment is processed by Paymob, not Tashkheesa.', 'Payment is processed by Paymob, not Tashkheesa.', 'يُعالج الدفع عبر Paymob، وليس عبر تشخيصة مباشرة.'),
            tt('We never see or store your card details.', 'We never see or store your card details.', 'نحن لا نرى أو نخزن بيانات بطاقتك.'),
            tt('Your case remains a private draft until payment confirms.', 'Your case remains a private draft until payment confirms.', 'تبقى حالتك مسودة خاصة حتى يتأكد الدفع.')
          ].forEach(function(t) { %>
            <li style="font-size:12.5px;color:var(--ink-2);display:flex;gap:8px;align-items:flex-start;line-height:1.45;">
              <%- include('partials/patient/icon', { name: 'shield', size: 14, color: 'var(--primary)' }) %>
              <span><%= t %></span>
            </li>
          <% }); %>
        </ul>
      </div>
      <%- include('partials/patient/need-help-card', { isAr: __isAr }) %>
    </div>
  </div>
<% } else { %>
  <%# Step number out of range — defensive fallback. %>
  <div class="p-card" style="padding:24px;text-align:center;">
    <p><%= tt('We couldn’t resolve this step. Returning you to your case.', 'We couldn’t resolve this step. Returning you to your case.', 'تعذّر حلّ هذه الخطوة. سنعيدك إلى حالتك.') %></p>
    <div style="margin-top:12px;"><a class="p-btn p-btn--primary" href="/dashboard"><%= tt('Back to dashboard', 'Back to dashboard', 'العودة إلى اللوحة') %></a></div>
  </div>
<% } %>

<% if (__step === 2 && (__uploaderConfigured || __r2DirectEnabled)) { %>
  <% if (__r2DirectEnabled) { %>
    <%# ── Theme 13 Sub-issue B — Direct-to-R2 upload. ────────────────── %>
    <%# Posts via FormData to /portal/patient/files (Sub-issue A endpoint). %>
    <%# CSP-nonce-safe; no third-party script tag. Validation polling block %>
    <%# is duplicated from the legacy branch below — kept inline for clean %>
    <%# rollback (legacy branch byte-identical to pre-Theme-13 main).      %>
    <script<%- __nonceAttr %>>
      (function() {
        var form = document.getElementById('upload-form');
        var hiddenKey = document.getElementById('file_key_input');
        var nativeFile = document.getElementById('native_file');
        var progress = document.getElementById('upload-progress');
        var filesList = document.getElementById('files-list');
        var statusMsg = {
          uploading: <%- JSON.stringify(tt('Uploading…', 'Uploading…', 'جارٍ الرفع…')) %>,
          failed:    <%- JSON.stringify(tt('Upload failed. Try again.', 'Upload failed. Try again.', 'فشل الرفع. حاول مرة أخرى.')) %>
        };
        var checkingLabel = <%- JSON.stringify(tt('Checking file is complete and readable…', 'Checking file is complete and readable…', 'جارٍ التحقق من اكتمال وسهولة قراءة الملف…')) %>;
        var readableLabel = <%- JSON.stringify('✓ ' + tt('Readable', 'Readable', 'مقروء')) %>;
        var flaggedLabel  = <%- JSON.stringify(tt('We couldn’t read parts of this file. Your specialist may ask for a clearer copy.', 'We couldn’t read parts of this file. Your specialist may ask for a clearer copy.', 'لم نتمكن من قراءة أجزاء من هذا الملف. قد يطلب الطبيب نسخة أوضح.')) %>;

        function showProgress(msg) { if (!progress) return; progress.style.display='block'; progress.textContent = msg; }
        function hideProgress()    { if (!progress) return; progress.style.display='none'; progress.textContent = ''; }

        if (form) {
          form.addEventListener('click', function(e) { if (e.target.tagName !== 'BUTTON' && e.target.tagName !== 'A') nativeFile && nativeFile.click(); });
          form.addEventListener('dragover', function(e) { e.preventDefault(); form.style.background = 'var(--accent-tint)'; });
          form.addEventListener('dragleave', function() { form.style.background = '#FBF9F4'; });
          form.addEventListener('drop', function(e) {
            e.preventDefault();
            form.style.background = '#FBF9F4';
            var f = e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0];
            if (f) doUpload(f);
          });
        }
        if (nativeFile) nativeFile.addEventListener('change', function(e) { var f = e.target.files && e.target.files[0]; if (f) doUpload(f); nativeFile.value = ''; });

        function doUpload(file) {
          if (!file || !hiddenKey || !form) return;
          showProgress(statusMsg.uploading);
          var fd = new FormData();
          fd.append('file', file);
          // CSRF: csrf_token cookie is httpOnly (src/middleware/csrf.js:39),
          // so we read the token from the form's hidden _csrf input that
          // csrfField() rendered into form scope above.
          var csrfInput = form.querySelector('input[name="_csrf"]');
          if (csrfInput && csrfInput.value) fd.append('_csrf', csrfInput.value);
          fetch('/portal/patient/files', {
            method: 'POST',
            body: fd,
            credentials: 'same-origin',
            headers: { 'Accept': 'application/json' }
          })
          .then(function(r) { return r.json().then(function(data) { return { status: r.status, data: data }; }); })
          .then(function(res) {
            if (res.status === 200 && res.data && res.data.ok && res.data.file && res.data.file.key) {
              hiddenKey.value = res.data.file.key;
              form.submit();
            } else {
              showProgress((res.data && res.data.error) || statusMsg.failed);
            }
          })
          .catch(function() { showProgress(statusMsg.failed); });
        }

        // ── Validation polling (mirrors the legacy branch below) ────────
        function poll() {
          if (!filesList) return;
          if (filesList.getAttribute('data-poll-active') !== '1') return;
          var url = filesList.getAttribute('data-poll-url');
          if (!url) return;
          fetch(url, { credentials: 'same-origin', cache: 'no-store' })
            .then(function(r) { return r.ok ? r.json() : null; })
            .then(function(data) {
              if (!data || !data.ok) return;
              var stillChecking = false;
              (data.files || []).forEach(function(f) {
                var row = document.querySelector('.p-file-row[data-file-id="' + f.id + '"]');
                if (!row) return;
                if (f.validation === row.getAttribute('data-validation')) { if (f.validation === 'checking') stillChecking = true; return; }
                row.setAttribute('data-validation', f.validation);
                var status = row.querySelector('.p-file-status');
                if (!status) return;
                if (f.validation === 'readable') {
                  status.innerHTML = '<span style="color:var(--success);">' + readableLabel + '</span>';
                  row.style.background = '#fff';
                } else if (f.validation === 'flagged') {
                  status.innerHTML = '<span style="color:var(--accent-dark);">' + flaggedLabel + '</span>';
                  row.style.background = 'var(--accent-tint)';
                } else {
                  status.innerHTML = '<span style="color:var(--accent-dark);">' + checkingLabel + '</span>';
                  stillChecking = true;
                }
              });
              if (!stillChecking) filesList.setAttribute('data-poll-active', '0');
            })
            .catch(function() { /* swallow — try again next tick */ });
        }
        if (filesList && filesList.getAttribute('data-poll-active') === '1') {
          var iv = setInterval(function() {
            if (filesList.getAttribute('data-poll-active') !== '1') { clearInterval(iv); return; }
            poll();
          }, 5000);
        }
      })();
    </script>
  <% } else { %>
  <%# Inline JS: Uploadcare upload + AI-validation polling. CSP-nonce-safe. %>
  <script src="https://ucarecdn.com/libs/widget/3.x/uploadcare.full.min.js" charset="utf-8"<%- __nonceAttr %>></script>
  <script<%- __nonceAttr %>>
    window.UPLOADCARE_PUBLIC_KEY = <%- JSON.stringify(__uploadcarePk) %>;
    window.UPLOADCARE_SYSTEM_DIALOG = true;
    window.UPLOADCARE_MULTIPLE = false;
    window.UPLOADCARE_LOCALE = <%- JSON.stringify(__isAr ? 'ar' : 'en') %>;

    (function() {
      var form = document.getElementById('upload-form');
      var hidden = document.getElementById('file_url_input');
      var nativeFile = document.getElementById('native_file');
      var progress = document.getElementById('upload-progress');
      var filesList = document.getElementById('files-list');
      var statusMsg = {
        loading:   <%- JSON.stringify(tt('Loading uploader…', 'Loading uploader…', 'جارٍ تحميل أداة الرفع…')) %>,
        uploading: <%- JSON.stringify(tt('Uploading…', 'Uploading…', 'جارٍ الرفع…')) %>,
        failed:    <%- JSON.stringify(tt('Upload failed. Try again.', 'Upload failed. Try again.', 'فشل الرفع. حاول مرة أخرى.')) %>
      };
      var checkingLabel = <%- JSON.stringify(tt('Checking file is complete and readable…', 'Checking file is complete and readable…', 'جارٍ التحقق من اكتمال وسهولة قراءة الملف…')) %>;
      var readableLabel = <%- JSON.stringify('✓ ' + tt('Readable', 'Readable', 'مقروء')) %>;
      var flaggedLabel  = <%- JSON.stringify(tt('We couldn’t read parts of this file. Your specialist may ask for a clearer copy.', 'We couldn’t read parts of this file. Your specialist may ask for a clearer copy.', 'لم نتمكن من قراءة أجزاء من هذا الملف. قد يطلب الطبيب نسخة أوضح.')) %>;

      function showProgress(msg) { if (!progress) return; progress.style.display='block'; progress.textContent = msg; }
      function hideProgress()    { if (!progress) return; progress.style.display='none'; progress.textContent = ''; }
      function waitFor(cb, n) { n=n||0; if (window.uploadcare && window.uploadcare.fileFrom) return cb(true); if (n>=20) return cb(false); showProgress(statusMsg.loading); setTimeout(function(){ waitFor(cb, n+1); }, 150); }

      if (form) {
        form.addEventListener('click', function(e) { if (e.target.tagName !== 'BUTTON' && e.target.tagName !== 'A') nativeFile && nativeFile.click(); });
        form.addEventListener('dragover', function(e) { e.preventDefault(); form.style.background = 'var(--accent-tint)'; });
        form.addEventListener('dragleave', function() { form.style.background = '#FBF9F4'; });
        form.addEventListener('drop', function(e) {
          e.preventDefault();
          form.style.background = '#FBF9F4';
          var f = e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0];
          if (f) doUpload(f);
        });
      }
      if (nativeFile) nativeFile.addEventListener('change', function(e) { var f = e.target.files && e.target.files[0]; if (f) doUpload(f); nativeFile.value = ''; });

      function doUpload(file) {
        if (!file) return;
        waitFor(function(ok) {
          if (!ok) { showProgress(statusMsg.failed); return; }
          showProgress(statusMsg.uploading);
          var f = window.uploadcare.fileFrom('object', file);
          f.done(function(info) {
            var url = info && info.cdnUrl ? info.cdnUrl : '';
            if (url && hidden && form) { hidden.value = url; form.submit(); }
            else showProgress(statusMsg.failed);
          }).fail(function() { showProgress(statusMsg.failed); });
        });
      }

      // ── Validation polling ───────────────────────────────────────────
      // While any file row is in "checking" state, refresh every 5s.
      function poll() {
        if (!filesList) return;
        if (filesList.getAttribute('data-poll-active') !== '1') return;
        var url = filesList.getAttribute('data-poll-url');
        if (!url) return;
        fetch(url, { credentials: 'same-origin', cache: 'no-store' })
          .then(function(r) { return r.ok ? r.json() : null; })
          .then(function(data) {
            if (!data || !data.ok) return;
            var stillChecking = false;
            (data.files || []).forEach(function(f) {
              var row = document.querySelector('.p-file-row[data-file-id="' + f.id + '"]');
              if (!row) return;
              if (f.validation === row.getAttribute('data-validation')) { if (f.validation === 'checking') stillChecking = true; return; }
              row.setAttribute('data-validation', f.validation);
              var status = row.querySelector('.p-file-status');
              if (!status) return;
              if (f.validation === 'readable') {
                status.innerHTML = '<span style="color:var(--success);">' + readableLabel + '</span>';
                row.style.background = '#fff';
              } else if (f.validation === 'flagged') {
                status.innerHTML = '<span style="color:var(--accent-dark);">' + flaggedLabel + '</span>';
                row.style.background = 'var(--accent-tint)';
              } else {
                status.innerHTML = '<span style="color:var(--accent-dark);">' + checkingLabel + '</span>';
                stillChecking = true;
              }
            });
            if (!stillChecking) filesList.setAttribute('data-poll-active', '0');
          })
          .catch(function() { /* swallow — try again next tick */ });
      }
      if (filesList && filesList.getAttribute('data-poll-active') === '1') {
        var iv = setInterval(function() {
          if (filesList.getAttribute('data-poll-active') !== '1') { clearInterval(iv); return; }
          poll();
        }, 5000);
      }
    })();
  </script>
  <% } %>
<% } %>

<%- include('partials/patient/foot', {
  active: 'new_case',
  isAr: __isAr,
  unreadCount: 0,
  cspNonce: cspNonce
}) %>
