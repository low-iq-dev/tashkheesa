<%
  // Patient New-Case Wizard — v2 5-step flow.
  //
  // Locals from routes/patient.js:
  //   user                 — req.user
  //   lang                 — 'en' | 'ar'
  //   isAr                 — boolean
  //   step                 — 1..5
  //   draft                — orders row (or null on fresh Step 1)
  //   files                — array (only populated for step >= 2)
  //   countryCurrency      — currency code (used Step 5)
  //   uploadcarePublicKey  — env-derived
  //   uploaderConfigured   — boolean (legacy Uploadcare widget gate)
  //   r2DirectEnabled      — boolean (Theme 13: when true, the wizard's
  //                          step-2 uploader posts directly to R2 via
  //                          /portal/patient/files instead of the Uploadcare
  //                          widget. Both code paths coexist below; the flag
  //                          decides which renders. See
  //                          docs/audits/THEME_13_R2_MIGRATION_FIX_PLAN.md §7.)
  //   error                — { step, message } | undefined
  //
  // Privacy: this view is for case ASSEMBLY. It never displays report content
  // (the case has not been completed yet). Form values are echoed back on
  // re-render only for the active step.

  const __isAr = !!isAr;
  const __step = Math.min(5, Math.max(1, Number(step) || 1));
  // P2-VIEW-1 defensive read for CSP nonce — needed for inline <script>
  // tags (line 402, 878). Express's res.render normally merges res.locals
  // into the template scope, but if an upstream config disables `with` or
  // a render call-site overrides the locals object without spreading
  // res.locals, the nonce would be missing → CSP blocks the script silently
  // → drop zone unresponsive. Fall through every plausible source.
  const __nonce = String(
    (typeof cspNonce !== 'undefined' && cspNonce) ||
    (typeof locals !== 'undefined' && locals && (locals.cspNonce || locals.csp_nonce || locals.nonce)) ||
    ''
  );
  const __nonceAttr = __nonce ? (' nonce="' + __nonce + '"') : '';
  const __draft = (typeof draft === 'object' && draft) ? draft : null;
  const __files = Array.isArray(files) ? files : [];
  const __error = (typeof error === 'object' && error) ? error : null;
  // typeof-guarded — only the happy-path GET handler at routes/patient.js:1315
  // passes these locals; all 7 error-rerender paths in the POST step1/2/3/4/5
  // handlers omit them, which previously caused EJS to throw a ReferenceError
  // on any form-validation re-render. The 7-site fix to spread uploadcareLocals
  // is filed as P3-VIEW-2; this guard is the surgical defense in depth.
  const __uploaderConfigured = !!(typeof uploaderConfigured !== 'undefined' && uploaderConfigured);
  const __uploadcarePk = String((typeof uploadcarePublicKey !== 'undefined' && uploadcarePublicKey) || '').trim();
  // Theme 13 Sub-issue B — typeof-guarded read mirrors the pattern used for
  // every other render-locals field on this view. When true, the new R2
  // FormData uploader renders below in place of the Uploadcare widget.
  const __r2DirectEnabled = !!(typeof r2DirectEnabled !== 'undefined' && r2DirectEnabled);
  const __uploadedFlash = !!(typeof locals !== 'undefined' && locals && locals.uploaded);


  const stepLabels = [
    tt('Condition', 'Condition', 'الحالة'),
    tt('Documents', 'Documents', 'الملفات'),
    tt('Specialty', 'Specialty', 'التخصص'),
    tt('Review', 'Review', 'المراجعة'),
    tt('Payment', 'Payment', 'الدفع')
  ];

  const __title = tt('New case', 'New case', 'حالة جديدة') + ' · ' + tt('Step ' + __step + ' of 5', 'Step ' + __step + ' of 5', 'الخطوة ' + __step + ' من 5');
  const __sub   = stepLabels[__step - 1];

  // Field values for the active step (echo back the draft if any).
  const v = {
    clinical_question:   __draft && __draft.clinical_question   ? String(__draft.clinical_question)   : '',
    medical_history:     __draft && __draft.medical_history     ? String(__draft.medical_history)     : '',
    current_medications: __draft && __draft.current_medications ? String(__draft.current_medications) : ''
  };
  const draftId = __draft ? __draft.id : '';

  // Step-2 query flags: passed by the route handler via locals (queryErr, uploadedFlash).
  const __queryErr = (typeof queryErr === 'string') ? queryErr : '';
  const __uploadedFlashLocal = !!(typeof uploadedFlash !== 'undefined' && uploadedFlash);
%>
<%- include('partials/patient/head', {
  title: __title,
  active: 'new_case',
  variant: 'dark',
  trustDensity: 'medium',
  user: user,
  lang: lang,
  cspNonce: cspNonce
}) %>

<%- include('partials/patient/topbar', {
  title: tt('Start a new case', 'Start a new case', 'ابدأ حالة جديدة'),
  sub: __sub,
  serif: true
}) %>

<div style="margin-bottom:24px;">
  <%- include('partials/patient/progress-track', {
    step: __step - 1,
    total: 5,
    labels: stepLabels
  }) %>
</div>

<% if (__error && __error.step === __step) { %>
  <div role="alert" class="p-card" style="padding:14px 18px;background:var(--danger-bg);border-color:#F2C7C7;color:var(--danger);margin-bottom:16px;font-size:13px;">
    <strong style="color:var(--danger);"><%= __error.message %></strong>
  </div>
<% } %>

<% if (__step === 1) { %>
  <%# ─── STEP 1 — CONDITION ─────────────────────────────────────────── %>
  <div style="display:grid;grid-template-columns:2fr 1fr;gap:18px;" class="p-dash-cols">
    <div class="p-card">
      <div class="p-card__header">
        <div class="p-card__title"><%= tt('Tell us what’s going on', 'Tell us what’s going on', 'أخبرنا بما يحدث') %></div>
        <div class="p-card__sub"><%= tt('A few sentences. Plain language is fine — your specialist reads it personally.', 'A few sentences. Plain language is fine — your specialist reads it personally.', 'بضع جمل بلغة بسيطة — سيقرأها الطبيب بنفسه.') %></div>
      </div>
      <div class="p-card__body">
        <form method="post" action="/patient/new-case/step1" autocomplete="off" novalidate>
          <%- (typeof csrfField === 'function') ? csrfField() : '' %>
          <% if (draftId) { %><input type="hidden" name="id" value="<%= draftId %>" /><% } %>

          <div class="p-field" style="margin-bottom:18px;">
            <label class="p-field__label" for="clinical_question">
              <%= tt('Your concern', 'Your concern', 'ما يقلقك') %>
              <span style="color:var(--danger);">*</span>
            </label>
            <textarea id="clinical_question" name="clinical_question" rows="6" required
                      minlength="10" maxlength="4000"
                      class="p-field__textarea"
                      placeholder="<%= tt('Describe what brought you here. Symptoms, what the first doctor said, anything that worries you.', 'Describe what brought you here. Symptoms, what the first doctor said, anything that worries you.', 'صف ما الذي جاء بك. الأعراض، ما قاله الطبيب الأول، أي شيء يقلقك.') %>"
            ><%= v.clinical_question %></textarea>
            <div class="p-field__hint"><%= tt('At least 10 characters. Up to about 4,000.', 'At least 10 characters. Up to about 4,000.', 'لا يقل عن 10 أحرف، حتى نحو 4000.') %></div>
          </div>

          <details style="margin-bottom:18px;">
            <summary style="font-size:13px;color:var(--primary);font-weight:600;cursor:pointer;">
              <%= tt('Add medical history (optional)', 'Add medical history (optional)', 'أضف التاريخ الطبي (اختياري)') %>
            </summary>
            <div class="p-field" style="margin-top:14px;">
              <label class="p-field__label" for="medical_history"><%= tt('Conditions, surgeries, allergies', 'Conditions, surgeries, allergies', 'الحالات، العمليات، الحساسية') %></label>
              <textarea id="medical_history" name="medical_history" rows="3" maxlength="4000" class="p-field__textarea"
                        placeholder="<%= tt('e.g., Type 2 diabetes (8 years), hypertension, mild aspirin allergy', 'e.g., Type 2 diabetes (8 years), hypertension, mild aspirin allergy', 'مثلاً: داء سكري نوع 2 منذ 8 سنوات، ضغط مرتفع، حساسية خفيفة من الأسبرين') %>"><%= v.medical_history %></textarea>
            </div>
            <div class="p-field" style="margin-top:14px;">
              <label class="p-field__label" for="current_medications"><%= tt('Current medications', 'Current medications', 'الأدوية الحالية') %></label>
              <textarea id="current_medications" name="current_medications" rows="3" maxlength="4000" class="p-field__textarea"
                        placeholder="<%= tt('Names, doses, how often', 'Names, doses, how often', 'الأسماء، الجرعات، عدد المرات') %>"><%= v.current_medications %></textarea>
            </div>
          </details>

          <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
            <button class="p-btn p-btn--primary p-btn--lg" type="submit">
              <%= tt('Continue to documents', 'Continue to documents', 'متابعة إلى الملفات') %>
              <%- include('partials/patient/icon', { name: 'chevR', size: 14, flipRtl: true }) %>
            </button>
            <a class="p-btn p-btn--ghost" href="/dashboard"><%= tt('Save & exit', 'Save & exit', 'حفظ والخروج') %></a>
          </div>
        </form>
      </div>
    </div>

    <div class="stack">
      <%- include('partials/patient/reassure-card', {
        eyebrow: tt('Privacy', 'Privacy', 'الخصوصية'),
        title: tt('Your story stays between you and the specialist.', 'Your story stays between you and the specialist.', 'قصتك تبقى بينك وبين الطبيب.'),
        body: tt('We never share what you write here with anyone else. Files are encrypted, and you can delete them anytime.', 'We never share what you write here with anyone else. Files are encrypted, and you can delete them anytime.', 'لا نشارك ما تكتبه هنا مع أي طرف. الملفات مشفّرة، ويمكنك حذفها في أي وقت.'),
        isAr: __isAr
      }) %>
      <%- include('partials/patient/need-help-card', { isAr: __isAr }) %>
    </div>
  </div>

<% } else if (__step === 2) { %>
  <%# ─── STEP 2 — DOCUMENTS ─────────────────────────────────────────── %>
  <%
    const returnTo = '/patient/new-case?step=2&id=' + encodeURIComponent(draftId);
    const showFilesError = String(__queryErr || '') === 'needs_files';
    const hasCheckingFile = __files.some(f => f.is_valid === null || f.is_valid === undefined);
  %>
  <% if (showFilesError) { %>
    <div role="alert" class="p-card" style="padding:14px 18px;background:var(--warn-bg);border-color:#E6C7A8;color:var(--warn);margin-bottom:16px;font-size:13px;">
      <strong><%= tt('Add at least one file before continuing — your specialist needs something to review.', 'Add at least one file before continuing — your specialist needs something to review.', 'يرجى إضافة ملف واحد على الأقل قبل المتابعة — يحتاجها الطبيب للمراجعة.') %></strong>
    </div>
  <% } %>
  <% if (__uploadedFlashLocal) { %>
    <div class="p-card" style="padding:12px 18px;background:var(--success-bg);border-color:#B9DDC8;color:var(--success);margin-bottom:16px;font-size:13px;">
      <%= tt('File added. We’re checking it now — feel free to upload more.', 'File added. We’re checking it now — feel free to upload more.', 'تم إضافة الملف. نقوم بالتحقق منه الآن — يمكنك إضافة المزيد.') %>
    </div>
  <% } %>

  <div style="display:grid;grid-template-columns:2fr 1fr;gap:18px;" class="p-dash-cols">
    <div class="stack">
      <div class="p-card">
        <div class="p-card__header">
          <div class="p-card__title"><%= tt('Your files', 'Your files', 'ملفاتك') %></div>
          <div class="p-card__sub"><%= tt('We organize them so your doctor can move fast', 'We organize them so your doctor can move fast', 'نرتبها بحيث يستطيع طبيبك العمل بسرعة') %></div>
        </div>
        <div class="p-card__body" id="files-list" data-poll-url="/patient/new-case/<%= draftId %>/files.json" data-poll-active="<%= hasCheckingFile ? '1' : '0' %>">
          <% if (__files.length === 0) { %>
            <div style="padding:24px 0;text-align:center;color:var(--muted);font-size:13px;">
              <%= tt('No files yet. Drop scans, labs, or prior reports below.', 'No files yet. Drop scans, labs, or prior reports below.', 'لا توجد ملفات بعد. أضف الفحوصات، التحاليل، أو التقارير السابقة أدناه.') %>
            </div>
          <% } else { %>
            <div style="display:flex;flex-direction:column;gap:10px;">
              <% __files.forEach(function(f) {
                const validation = (f.is_valid === true || f.is_valid === 1) ? 'readable'
                                 : (f.is_valid === false || f.is_valid === 0) ? 'flagged'
                                 : 'checking';
              %>
                <div class="p-file-row" data-file-id="<%= f.id %>" data-validation="<%= validation %>"
                     style="display:grid;grid-template-columns:36px 1fr auto;gap:12px;align-items:center;padding:12px;border:1px solid var(--rule);border-radius:10px;background:<%= validation === 'flagged' ? 'var(--accent-tint)' : '#fff' %>;">
                  <div style="width:36px;height:36px;border-radius:9px;background:<%= validation === 'flagged' ? 'var(--accent-light)' : 'var(--primary-light)' %>;color:<%= validation === 'flagged' ? 'var(--accent-dark)' : 'var(--primary-dark)' %>;display:flex;align-items:center;justify-content:center;">
                    <% if (validation === 'flagged') { %>
                      <%- include('partials/patient/icon', { name: 'alert', size: 16 }) %>
                    <% } else { %>
                      <%- include('partials/patient/icon', { name: 'file', size: 16 }) %>
                    <% } %>
                  </div>
                  <div style="min-width:0;">
                    <div style="font-size:13px;font-weight:500;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                      <%= f.label || tt('Uploaded file', 'Uploaded file', 'ملف مرفوع') %>
                    </div>
                    <div class="p-file-status" style="font-size:11.5px;margin-top:4px;color:var(--muted);">
                      <% if (validation === 'readable') { %>
                        <span style="color:var(--success);">✓ <%= tt('Readable', 'Readable', 'مقروء') %></span>
                      <% } else if (validation === 'flagged') { %>
                        <span style="color:var(--accent-dark);"><%= tt('We couldn’t read parts of this file. Your specialist may ask for a clearer copy.', 'We couldn’t read parts of this file. Your specialist may ask for a clearer copy.', 'لم نتمكن من قراءة أجزاء من هذا الملف. قد يطلب الطبيب نسخة أوضح.') %></span>
                      <% } else { %>
                        <span style="color:var(--accent-dark);"><%= tt('Checking file is complete and readable…', 'Checking file is complete and readable…', 'جارٍ التحقق من اكتمال وسهولة قراءة الملف…') %></span>
                      <% } %>
                    </div>
                  </div>
                  <a class="p-btn p-btn--ghost p-btn--sm" href="<%= f.url %>" target="_blank" rel="noopener">
                    <%- include('partials/patient/icon', { name: 'eye', size: 14 }) %>
                    <%= tt('View', 'View', 'عرض') %>
                  </a>
                </div>
              <% }); %>
            </div>
          <% } %>
        </div>
      </div>

      <% if (__uploaderConfigured || __r2DirectEnabled) { %>
        <form id="upload-form" method="post" action="/portal/patient/orders/<%= draftId %>/upload"
              style="border:2px dashed var(--rule-strong);border-radius:14px;padding:36px;text-align:center;background:#FBF9F4;">
          <%- (typeof csrfField === 'function') ? csrfField() : '' %>
          <%# Two parallel hidden fields for the upload result. Exactly one is %>
          <%# populated per submit (the wizard's two scripts are mutually     %>
          <%# exclusive — see the if/else below). The /portal/patient/orders/ %>
          <%# :id/upload handler reads both and accepts either.               %>
          <input type="hidden" name="file_url" id="file_url_input" />
          <input type="hidden" name="file_key" id="file_key_input" />
          <input type="hidden" name="label" id="label_input" />
          <%- include('partials/patient/icon', { name: 'upload', size: 22, color: 'var(--primary-dark)' }) %>
          <div style="font-size:14px;font-weight:600;margin-top:8px;"><%= tt('Drop a file or click to choose', 'Drop a file or click to choose', 'أفلت ملفاً أو انقر للاختيار') %></div>
          <div style="font-size:12px;color:var(--muted);margin-top:4px;"><%= tt('PDF, DICOM, JPG, PNG · up to 500 MB each', 'PDF, DICOM, JPG, PNG · up to 500 MB each', 'PDF، DICOM، JPG، PNG · حتى 500 ميغابايت لكل ملف') %></div>
          <div id="upload-progress" style="display:none;margin-top:12px;font-size:12px;color:var(--accent-dark);"></div>
          <input type="file" id="native_file" style="display:none;" accept="*/*" />
        </form>
      <% } else { %>
        <div class="p-card" style="padding:18px;background:var(--warn-bg);border-color:#E6C7A8;">
          <div style="font-size:13px;font-weight:600;color:var(--warn);margin-bottom:6px;">
            <%= tt('Uploader not configured', 'Uploader not configured', 'أداة الرفع غير مفعّلة') %>
          </div>
          <div style="font-size:12px;color:var(--ink-2);">
            <%= tt('Files cannot be added right now. Please contact support.', 'Files cannot be added right now. Please contact support.', 'لا يمكن إضافة ملفات الآن. يرجى التواصل مع الدعم.') %>
          </div>
        </div>
      <% } %>
    </div>

    <div class="stack">
      <div class="p-card" style="padding:18px;">
        <div style="font-size:10.5px;letter-spacing:0.14em;text-transform:uppercase;color:var(--muted);font-weight:700;margin-bottom:10px;">
          <%= tt('What helps most', 'What helps most', 'ما يساعد أكثر') %>
        </div>
        <ul style="margin:0;padding:0;list-style:none;display:flex;flex-direction:column;gap:10px;">
          <% [
            tt('The original scan files (DICOM if you have them)', 'The original scan files (DICOM if you have them)', 'ملفات الفحوصات الأصلية (DICOM إن أمكن)'),
            tt('Any prior imaging for comparison', 'Any prior imaging for comparison', 'أي صور أشعة سابقة للمقارنة'),
            tt('Lab panels — CBC, liver, tumor markers', 'Lab panels — CBC, liver, tumor markers', 'تحاليل المعمل — صورة دم، وظائف كبد، دلالات الأورام'),
            tt('The previous doctor’s written report', 'The previous doctor’s written report', 'التقرير المكتوب للطبيب السابق')
          ].forEach(function(t) { %>
            <li style="font-size:13px;color:var(--ink-2);display:flex;gap:8px;align-items:flex-start;">
              <%- include('partials/patient/icon', { name: 'check', size: 14, color: 'var(--primary)' }) %>
              <span><%= t %></span>
            </li>
          <% }); %>
        </ul>
      </div>
      <%- include('partials/patient/reassure-card', {
        eyebrow: tt('Privacy', 'Privacy', 'الخصوصية'),
        title: tt('Files are encrypted end-to-end.', 'Files are encrypted end-to-end.', 'الملفات مشفّرة من طرف إلى طرف.'),
        body: tt('Only your assigned specialist can see them. You can delete them anytime, even after your case closes.', 'Only your assigned specialist can see them. You can delete them anytime, even after your case closes.', 'يستطيع الطبيب المخصص لك فقط رؤيتها. يمكنك حذفها في أي وقت، حتى بعد إغلاق الحالة.'),
        isAr: __isAr
      }) %>
      <%- include('partials/patient/need-help-card', { isAr: __isAr }) %>
    </div>
  </div>

  <div style="display:flex;gap:10px;align-items:center;justify-content:space-between;margin-top:18px;flex-wrap:wrap;">
    <a class="p-btn p-btn--ghost" href="/patient/new-case?step=1&id=<%= encodeURIComponent(draftId) %>">
      <%- include('partials/patient/icon', { name: 'chevL', size: 14, flipRtl: true }) %>
      <%= tt('Back to condition', 'Back to condition', 'العودة إلى الحالة') %>
    </a>
    <form method="post" action="/patient/new-case/step2" style="margin:0;">
      <%- (typeof csrfField === 'function') ? csrfField() : '' %>
      <input type="hidden" name="id" value="<%= draftId %>" />
      <button class="p-btn p-btn--primary p-btn--lg" type="submit">
        <%= tt('Continue to specialty', 'Continue to specialty', 'متابعة إلى التخصص') %>
        <%- include('partials/patient/icon', { name: 'chevR', size: 14, flipRtl: true }) %>
      </button>
    </form>
  </div>

<% } else if (__step === 3) { %>
  <%# ─── STEP 3 — SPECIALTY ─────────────────────────────────────────── %>
  <%
    const __specialties = Array.isArray(specialties) ? specialties : [];
    const __services = Array.isArray(services) ? services : [];
    const selectedSpecialty = __draft && __draft.specialty_id ? String(__draft.specialty_id) : '';
    const selectedService = __draft && __draft.service_id ? String(__draft.service_id) : '';
    const step3Err = String(__queryErr || '');

    // Theme 14 Phase 2 — AI specialty recommendation.
    // The route handler passes `specialtyRecommendation` as a local: either
    // null (Phase 2 — classifier not yet wired at case-create) or an object
    // {specialty_id, confidence, reasoning}. When null, the view falls back
    // to the legacy supply-aware grid. Phase 3 (Sub-issue C) wires the
    // classifier and the override flag handling.
    const __rec = (typeof specialtyRecommendation !== 'undefined') ? specialtyRecommendation : null;
    const __recConf = (__rec && typeof __rec.confidence === 'number') ? __rec.confidence : null;
    const __recSpecialty = (__rec && __rec.specialty_id)
      ? __specialties.find(function (s) { return String(s.id) === String(__rec.specialty_id); })
      : null;
    // Theme 14 Phase 4 — thresholds come from the route handler as a
    // `thresholds` local sourced via src/services/admin_settings.js
    // (migration 061 seeded the rows; helper caches for 60s + falls back
    // to hardcoded defaults on DB error). The seven 400/500 error-render
    // paths in src/routes/patient.js don't pass `thresholds` — defensive
    // `typeof` guard falls back to the same defaults so the tier
    // classification keeps working on those paths (the recommendation
    // card itself only engages when specialtyRecommendation is non-null,
    // so this fallback is belt-and-braces, not load-bearing).
    const __thr = (typeof thresholds !== 'undefined' && thresholds) ? thresholds : null;
    const __confLock = (__thr && typeof __thr.lock === 'number') ? __thr.lock : 0.95;
    const __confAuto = (__thr && typeof __thr.auto === 'number') ? __thr.auto : 0.85;
    const __confMin  = (__thr && typeof __thr.min  === 'number') ? __thr.min  : 0.55;
    // Tier: 'locked' | 'auto' | 'recommend' | 'manual' | null (no recommendation; fall back to grid)
    let __tier = null;
    if (__rec && __recConf !== null) {
      if (__recConf < __confMin) {
        __tier = 'manual';
      } else if (__recSpecialty) {
        if (__recConf >= __confLock) __tier = 'locked';
        else if (__recConf >= __confAuto) __tier = 'auto';
        else __tier = 'recommend';
      }
    }
    // Hidden specialty_id input default: locked → recommendation; else → existing draft value
    const __defaultSpecialty = (__tier === 'locked' && __recSpecialty) ? __recSpecialty.id : selectedSpecialty;
    // Localised name for the recommended specialty — used by the recommendation card,
    // the continue button copy, and the override grid's exclusion logic.
    const __recName = __recSpecialty
      ? ((__isAr && __recSpecialty.name_ar) ? __recSpecialty.name_ar : __recSpecialty.name)
      : '';

    // Theme 14 Phase 3 polish — service-level recommendation.
    // The AI's service_id pick lives on the same specialty_classifications
    // row alongside specialty_id (migration 058). Resolve to a service row
    // from the services[] local; render alongside the specialty in the
    // recommendation card and pre-fill the hidden service_id input when
    // the patient continues without overriding.
    const __recService = (__rec && __rec.service_id)
      ? __services.find(function (sv) { return String(sv.id) === String(__rec.service_id); })
      : null;
    const __defaultService = (__tier === 'locked' && __recService) ? __recService.id : selectedService;
    const __recServiceName = __recService ? __recService.name : '';
    const __recServicePrice = __recService
      ? (String(__recService.currency || 'EGP').toUpperCase() + ' ' + Math.round(Number(__recService.base_price) || 0).toLocaleString('en-GB'))
      : '';
    const __recServiceSlaHours = (__recService && __recService.sla_hours) ? Number(__recService.sla_hours) : 72;
  %>
  <% if (step3Err === 'needs_specialty') { %>
    <div role="alert" class="p-card" style="padding:14px 18px;background:var(--warn-bg);border-color:#E6C7A8;color:var(--warn);margin-bottom:16px;font-size:13px;">
      <strong><%= tt('Pick a specialty and service before continuing.', 'Pick a specialty and service before continuing.', 'يرجى اختيار التخصص والخدمة قبل المتابعة.') %></strong>
    </div>
  <% } else if (step3Err === 'override_not_permitted') { %>
    <div role="alert" class="p-card" style="padding:14px 18px;background:var(--warn-bg);border-color:#E6C7A8;color:var(--warn);margin-bottom:16px;font-size:13px;">
      <strong><%= tt('Your case is locked to the recommended specialty at this confidence level. Please continue with the recommendation.', 'Your case is locked to the recommended specialty at this confidence level. Please continue with the recommendation.', 'حالتك مرتبطة بالتخصص الموصى به عند مستوى الثقة هذا. يرجى المتابعة بالاختيار الموصى به.') %></strong>
    </div>
  <% } else if (step3Err === 'invalid_service') { %>
    <div role="alert" class="p-card" style="padding:14px 18px;background:var(--warn-bg);border-color:#E6C7A8;color:var(--warn);margin-bottom:16px;font-size:13px;">
      <strong><%= tt('That service doesn’t belong to the chosen specialty. Please re-select.', 'That service doesn’t belong to the chosen specialty. Please re-select.', 'هذه الخدمة لا تنتمي إلى التخصص المختار. يرجى إعادة الاختيار.') %></strong>
    </div>
  <% } %>

  <form method="post" action="/patient/new-case/step3" autocomplete="off" id="step3-form">
    <%- (typeof csrfField === 'function') ? csrfField() : '' %>
    <input type="hidden" name="id" value="<%= draftId %>" />
    <input type="hidden" name="specialty_id" id="step3-specialty-id" value="<%= __defaultSpecialty %>" />
    <input type="hidden" name="service_id" id="step3-service-id" value="<%= __defaultService %>" />
    <%# Theme 14 — override flag: set by the SLA-disclaimer modal JS when the patient
        overrides an AI recommendation (either dimension — specialty or service).
        POST handler reads this to log the override + flip
        orders.no_sla_refund_eligibility. Defaults to 0. %>
    <input type="hidden" name="override" id="step3-override-flag" value="0" />

    <% if (__tier === 'locked') { %>
      <%# ─── Locked recommendation (confidence >= 0.95). Callout, not grid. ───
          Layout fix (post-Phase-3-polish):
            - Badge moved from absolute → inline flex header row with eyebrow
              (fixes clipping at narrow widths + RTL bleed).
            - Vertical hierarchy with rule dividers between sections.
            - Token-only spacing/type (--s-*, --t-*, --r-*, --primary, etc.).
            - Mobile-safe: header + service rows use flex-wrap; badge has
              flex-shrink: 0 so it never compresses or clips.
          Locked tier: no override link, no override grid, no AI-matched
          subtext (the patient is locked in at >=0.95 confidence). %>
      <div class="p-card p-spec-recommendation" data-tier="locked" id="step3-recommendation-card"
           style="border:1.5px solid var(--primary);background:var(--primary-light);border-radius:var(--r-lg);padding:var(--s-5) var(--s-4);">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:var(--s-3);margin-bottom:var(--s-2);flex-wrap:wrap;">
          <div style="font-size:var(--t-label);color:var(--muted);text-transform:uppercase;letter-spacing:0.4px;line-height:1.4;">
            <%= tt('Your case will be reviewed by', 'Your case will be reviewed by', 'سيتم مراجعة حالتك بواسطة') %>
          </div>
          <div style="background:var(--primary);color:var(--on-primary);font-size:var(--t-meta-sm);font-weight:600;padding:var(--s-1) var(--s-3);border-radius:var(--r-pill);letter-spacing:0.2px;flex-shrink:0;">
            <%= tt('Recommended', 'Recommended', 'موصى به') %>
          </div>
        </div>
        <div style="font-size:var(--t-section);font-weight:700;color:var(--ink);line-height:var(--lh-tight, 1.15);"><%= __recName %></div>
        <% if (__recService) { %>
          <div style="margin-top:var(--s-4);padding-top:var(--s-3);border-top:1px solid var(--rule);display:flex;justify-content:space-between;align-items:baseline;gap:var(--s-3);flex-wrap:wrap;">
            <div style="font-size:var(--t-body);font-weight:600;color:var(--ink-2);"><%= __recServiceName %></div>
            <div class="p-num" style="font-size:var(--t-card-title);font-weight:600;color:var(--accent-dark);font-feature-settings:'tnum' 1, 'lnum' 1;"><%= __recServicePrice %></div>
          </div>
          <div style="font-size:var(--t-meta);color:var(--muted);margin-top:var(--s-1);">
            <%= tt('Standard ' + __recServiceSlaHours + 'h turnaround', 'Standard ' + __recServiceSlaHours + 'h turnaround', 'تسليم خلال ' + __recServiceSlaHours + ' ساعة قياسي') %>
          </div>
        <% } %>
        <div style="margin-top:var(--s-4);padding-top:var(--s-3);border-top:1px solid var(--rule);">
          <button type="button" id="step3-why-toggle" aria-expanded="false" aria-controls="step3-why-content"
                  style="background:none;border:none;color:var(--primary);cursor:pointer;padding:0;font-size:var(--t-body-sm);text-decoration:underline;">
            <%= tt('Why?', 'Why?', 'لماذا؟') %>
          </button>
          <div id="step3-why-content" hidden style="margin-top:var(--s-3);padding:var(--s-3);background:var(--surface);border-radius:var(--r-md);font-size:var(--t-body-sm);color:var(--muted);line-height:1.6;">
            <%= __rec.reasoning %>
          </div>
        </div>
      </div>
    <% } else if (__tier === 'auto' || __tier === 'recommend') { %>
      <%# ─── Recommendation card with override (0.55-0.94). ───
          Same layout shape as the locked tier but with an extra
          AI-matched-subtext section between service + Why?, since the
          patient can override here and needs to know the implications.
          Click → modal → override grid (existing flow). %>
      <div class="p-card p-spec-recommendation" data-tier="<%= __tier %>" id="step3-recommendation-card"
           style="border:1.5px solid var(--primary);background:var(--primary-light);border-radius:var(--r-lg);padding:var(--s-5) var(--s-4);">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:var(--s-3);margin-bottom:var(--s-2);flex-wrap:wrap;">
          <div style="font-size:var(--t-label);color:var(--muted);text-transform:uppercase;letter-spacing:0.4px;line-height:1.4;">
            <%= tt('Recommended specialty', 'Recommended specialty', 'التخصص الموصى به') %>
          </div>
          <div style="background:var(--primary);color:var(--on-primary);font-size:var(--t-meta-sm);font-weight:600;padding:var(--s-1) var(--s-3);border-radius:var(--r-pill);letter-spacing:0.2px;flex-shrink:0;">
            <%= tt('Recommended', 'Recommended', 'موصى به') %>
          </div>
        </div>
        <div style="font-size:var(--t-section);font-weight:700;color:var(--ink);line-height:var(--lh-tight, 1.15);"><%= __recName %></div>
        <% if (__recService) { %>
          <div style="margin-top:var(--s-4);padding-top:var(--s-3);border-top:1px solid var(--rule);display:flex;justify-content:space-between;align-items:baseline;gap:var(--s-3);flex-wrap:wrap;">
            <div style="font-size:var(--t-body);font-weight:600;color:var(--ink-2);"><%= __recServiceName %></div>
            <div class="p-num" style="font-size:var(--t-card-title);font-weight:600;color:var(--accent-dark);font-feature-settings:'tnum' 1, 'lnum' 1;"><%= __recServicePrice %></div>
          </div>
          <div style="font-size:var(--t-meta);color:var(--muted);margin-top:var(--s-1);">
            <%= tt('Standard ' + __recServiceSlaHours + 'h turnaround', 'Standard ' + __recServiceSlaHours + 'h turnaround', 'تسليم خلال ' + __recServiceSlaHours + ' ساعة قياسي') %>
          </div>
        <% } %>
        <div style="margin-top:var(--s-4);padding:var(--s-3);background:var(--surface);border-radius:var(--r-md);font-size:var(--t-body-sm);color:var(--ink-2);line-height:1.5;">
          <%= tt('Our AI matched your case. You can change this if needed, but it may delay your review.', 'Our AI matched your case. You can change this if needed, but it may delay your review.', 'قام الذكاء الاصطناعي بتوجيه حالتك. يمكنك تغيير الاختيار إذا لزم، لكن قد يؤخر ذلك المراجعة.') %>
        </div>
        <div style="margin-top:var(--s-4);padding-top:var(--s-3);border-top:1px solid var(--rule);">
          <button type="button" id="step3-why-toggle" aria-expanded="false" aria-controls="step3-why-content"
                  style="background:none;border:none;color:var(--primary);cursor:pointer;padding:0;font-size:var(--t-body-sm);text-decoration:underline;">
            <%= tt('Why?', 'Why?', 'لماذا؟') %>
          </button>
          <div id="step3-why-content" hidden style="margin-top:var(--s-3);padding:var(--s-3);background:var(--surface);border-radius:var(--r-md);font-size:var(--t-body-sm);color:var(--muted);line-height:1.6;">
            <%= __rec.reasoning %>
          </div>
        </div>
      </div>

      <%# Override grid — hidden until SLA-disclaimer modal is confirmed. ───
          Excludes the recommended specialty (overriding means picking a
          DIFFERENT one). UX fix A: no per-card consultant count. %>
      <div id="step3-override-grid" hidden class="p-card" style="margin-top:14px;">
        <div class="p-card__header">
          <div class="p-card__title"><%= tt('Pick a different specialty', 'Pick a different specialty', 'اختر تخصصاً مختلفاً') %></div>
        </div>
        <div class="p-card__body">
          <% if (__specialties.length === 0) { %>
            <div style="padding:24px 0;text-align:center;color:var(--muted);font-size:13px;">
              <%= tt('No alternative specialties available.', 'No alternative specialties available.', 'لا توجد تخصصات بديلة متاحة.') %>
            </div>
          <% } else { %>
            <div class="p-spec-grid" style="display:grid;grid-template-columns:repeat(auto-fill, minmax(220px, 1fr));gap:12px;">
              <% __specialties.forEach(function(sp) {
                if (String(sp.id) === String(__recSpecialty.id)) return;
                const sel = String(sp.id) === selectedSpecialty;
              %>
                <button type="button"
                        class="p-spec-card<%= sel ? ' is-selected' : '' %>"
                        data-specialty-id="<%= sp.id %>"
                        style="text-align:start;cursor:pointer;border:1px solid <%= sel ? 'var(--primary)' : 'var(--rule)' %>;background:<%= sel ? 'var(--primary-light)' : '#fff' %>;border-radius:12px;padding:14px 16px;transition:border-color var(--t-fast) var(--ease), background var(--t-fast) var(--ease);">
                  <div style="font-size:14px;font-weight:600;color:var(--ink);"><%= __isAr && sp.name_ar ? sp.name_ar : sp.name %></div>
                </button>
              <% }); %>
            </div>
          <% } %>
        </div>
      </div>
    <% } else { %>
      <%# ─── Default grid path. Triggers when:
            (a) __rec === null         — no classification stored yet
            (b) __tier === 'manual'    — AI confidence < 0.55
          Both render the same supply-blind grid. Per UX fix C, the
          header copy varies by tier: "Choose your specialty" for the
          AI-uncertain case, "Choose the right specialty" for the
          classifier-failure fallback.
          When classifierPending is true (Step 3 reached before the
          async worker inserted a specialty_classifications row), an
          "analysing your case…" banner polls /classification.json
          and reloads on status='ready' so the tiered card renders. %>
      <% if (typeof classifierPending !== 'undefined' && classifierPending) { %>
        <div role="status" id="classifier-banner"
             data-poll-url="/patient/new-case/<%= encodeURIComponent(draftId) %>/classification.json"
             data-poll-active="1"
             style="padding:14px 18px;margin-bottom:16px;background:var(--primary-light);border:1px solid var(--primary);border-radius:var(--r-md);color:var(--ink-2);font-size:13px;display:flex;align-items:center;gap:12px;">
          <span aria-hidden="true" style="font-size:18px;line-height:1;">🩺</span>
          <span style="flex:1;line-height:1.5;">
            <%= tt('Analysing your case to suggest the right specialty…', 'Analysing your case to suggest the right specialty…', 'جارٍ تحليل حالتك لاقتراح التخصص المناسب…') %>
          </span>
          <button type="button" id="classifier-banner-dismiss"
                  aria-label="<%= tt('Dismiss', 'Dismiss', 'إغلاق') %>"
                  style="background:none;border:none;color:var(--muted);cursor:pointer;padding:4px 6px;font-size:18px;line-height:1;flex-shrink:0;">×</button>
        </div>
      <% } %>
      <div class="p-card">
        <div class="p-card__header">
          <% if (__tier === 'manual') { %>
            <div class="p-card__title"><%= tt('Choose your specialty', 'Choose your specialty', 'اختر تخصصك') %></div>
            <div class="p-card__sub"><%= tt('Select the specialty that best matches your case.', 'Select the specialty that best matches your case.', 'اختر التخصص الذي يناسب حالتك.') %></div>
          <% } else { %>
            <div class="p-card__title"><%= tt('Choose the right specialty', 'Choose the right specialty', 'اختر التخصص المناسب') %></div>
          <% } %>
        </div>
        <div class="p-card__body">
          <% if (__specialties.length === 0) { %>
            <div style="padding:24px 0;text-align:center;color:var(--muted);font-size:13px;">
              <%= tt('No specialties available right now. Please contact us via WhatsApp and we’ll match you manually.', 'No specialties available right now. Please contact us via WhatsApp and we’ll match you manually.', 'لا توجد تخصصات متاحة حالياً. يرجى التواصل عبر واتساب وسنوفر لك المراجعة المناسبة يدوياً.') %>
            </div>
          <% } else { %>
            <div class="p-spec-grid" style="display:grid;grid-template-columns:repeat(auto-fill, minmax(220px, 1fr));gap:12px;">
              <% __specialties.forEach(function(sp) {
                const sel = String(sp.id) === selectedSpecialty;
              %>
                <button type="button"
                        class="p-spec-card<%= sel ? ' is-selected' : '' %>"
                        data-specialty-id="<%= sp.id %>"
                        style="text-align:start;cursor:pointer;border:1px solid <%= sel ? 'var(--primary)' : 'var(--rule)' %>;background:<%= sel ? 'var(--primary-light)' : '#fff' %>;border-radius:12px;padding:14px 16px;transition:border-color var(--t-fast) var(--ease), background var(--t-fast) var(--ease);">
                  <div style="font-size:14px;font-weight:600;color:var(--ink);"><%= __isAr && sp.name_ar ? sp.name_ar : sp.name %></div>
                </button>
              <% }); %>
            </div>
          <% } %>
        </div>
      </div>
    <% } %>

    <%# Services card — visible when a specialty is in scope. For tier='locked'
        the recommendation card above already shows the AI's service inline, so
        the services-card hides (no second affordance for the same pick). For
        all other tiers, the patient may still need to pick / change service. %>
    <div class="p-card" id="step3-services-card" style="margin-top:14px;<%= (__defaultSpecialty && __tier !== 'locked') ? '' : 'display:none;' %>">
      <div class="p-card__header">
        <div class="p-card__title"><%= tt('Pick the service that matches your case', 'Pick the service that matches your case', 'اختر الخدمة التي تناسب حالتك') %></div>
        <div class="p-card__sub"><%= tt('Each service is a different review depth.', 'Each service is a different review depth.', 'تختلف الخدمات في عمق المراجعة.') %></div>
      </div>
      <div class="p-card__body" id="step3-services-body" style="display:flex;flex-direction:column;gap:10px;">
        <% __services.forEach(function(sv) {
          const matchesSpecialty = String(sv.specialty_id) === __defaultSpecialty;
          const sel = String(sv.id) === __defaultService;
          if (!__defaultSpecialty || !matchesSpecialty) return;
          const cur = String(sv.currency || countryCurrency || 'EGP').toUpperCase();
          const price = Number(sv.base_price) || 0;
          // Theme 10b §C / OQ-2: money always Western digits regardless of lang.
          const priceLabel = cur + ' ' + price.toLocaleString('en-GB', { maximumFractionDigits: 0 });
        %>
          <button type="button"
                  class="p-service-card<%= sel ? ' is-selected' : '' %>"
                  data-service-id="<%= sv.id %>"
                  data-specialty-id="<%= sv.specialty_id %>"
                  style="text-align:start;cursor:pointer;display:flex;align-items:center;justify-content:space-between;gap:12px;border:1px solid <%= sel ? 'var(--primary)' : 'var(--rule)' %>;background:<%= sel ? 'var(--primary-light)' : '#fff' %>;border-radius:12px;padding:14px 16px;">
            <div>
              <div style="font-size:14px;font-weight:600;color:var(--ink);"><%= sv.name %></div>
              <div style="font-size:11.5px;color:var(--muted);margin-top:3px;"><%= tt('Standard ' + (sv.sla_hours || 72) + 'h turnaround', 'Standard ' + (sv.sla_hours || 72) + 'h turnaround', 'تسليم خلال ' + (sv.sla_hours || 72) + ' ساعة قياسي') %></div>
            </div>
            <div class="p-num" style="font-size:14px;font-weight:600;color:var(--accent-dark);"><%= priceLabel %></div>
          </button>
        <% }); %>
      </div>
    </div>

    <div style="display:flex;gap:10px;align-items:center;justify-content:space-between;margin-top:18px;flex-wrap:wrap;">
      <a class="p-btn p-btn--ghost" href="/patient/new-case?step=2&id=<%= encodeURIComponent(draftId) %>">
        <%- include('partials/patient/icon', { name: 'chevL', size: 14, flipRtl: true }) %>
        <%= tt('Back to documents', 'Back to documents', 'العودة إلى الملفات') %>
      </a>
      <div style="display:flex;gap:14px;align-items:center;flex-wrap:wrap;">
        <% if (__tier === 'auto' || __tier === 'recommend') { %>
          <%# "Change my pick" link — only present for tiers where override is allowed.
              Clicking opens the SLA-disclaimer modal (Q4 locked). %>
          <button type="button" id="step3-different-specialty" style="background:none;border:none;color:var(--primary);cursor:pointer;padding:0;font-size:13px;text-decoration:underline;">
            <%= tt('Change my pick', 'Change my pick', 'تغيير اختياري') %>
          </button>
        <% } %>
        <button class="p-btn p-btn--primary p-btn--lg" type="submit" id="step3-continue"
                data-tier="<%= __tier || 'legacy' %>"
                <%= (__defaultSpecialty && __defaultService) ? '' : 'disabled' %>
                style="<%= (__defaultSpecialty && __defaultService) ? '' : 'opacity:0.5;cursor:not-allowed;' %>">
          <% if (__tier === 'locked' || __tier === 'auto') { %>
            <%= tt('Continue with ' + __recName, 'Continue with ' + __recName, 'متابعة مع ' + __recName) %>
          <% } else { %>
            <%= tt('Continue to review', 'Continue to review', 'متابعة إلى المراجعة') %>
          <% } %>
          <%- include('partials/patient/icon', { name: 'chevR', size: 14, flipRtl: true }) %>
        </button>
      </div>
    </div>
  </form>

  <% if (__tier === 'auto' || __tier === 'recommend') { %>
    <%# ─── Theme 14 — SLA-disclaimer modal (Q4 locked). ───────────────────
        Renders only when override is allowed (tiers 'auto' and 'recommend').
        Hidden by default; JS shows it when the patient clicks "Change my
        pick". On confirm, JS flips the override flag to '1', expands the
        override grid, and lets the patient pick a different specialty
        (services-card auto-filters on the new specialty). %>
    <div id="step3-override-modal" hidden role="dialog" aria-modal="true" aria-labelledby="step3-override-modal-title"
         style="position:fixed;inset:0;background:rgba(0,0,0,0.45);display:flex;align-items:center;justify-content:center;z-index:1000;padding:20px;">
      <div role="document" style="background:#fff;max-width:480px;width:100%;border-radius:14px;padding:24px;box-shadow:0 8px 32px rgba(0,0,0,0.18);">
        <div id="step3-override-modal-title" style="font-size:16px;font-weight:600;color:var(--ink);margin-bottom:14px;">
          <%= tt('Are you sure?', 'Are you sure?', 'هل أنت متأكد؟') %>
        </div>
        <p style="font-size:14px;color:var(--ink-2);line-height:1.6;margin:0 0 20px 0;">
          <%= tt('Selecting a different specialty than recommended may delay your case. Tashkheesa carries no responsibility for delays from manual specialty changes. Continue?', 'Selecting a different specialty than recommended may delay your case. Tashkheesa carries no responsibility for delays from manual specialty changes. Continue?', 'اختيار تخصص مختلف عن الموصى به قد يؤخر حالتك. تشخيصة لا تتحمل أي مسؤولية عن التأخير الناتج عن تغيير التخصص يدوياً. هل تريد المتابعة؟') %>
        </p>
        <div style="display:flex;gap:10px;justify-content:flex-end;flex-wrap:wrap;">
          <button type="button" id="step3-modal-cancel" class="p-btn p-btn--ghost">
            <%= tt('Cancel', 'Cancel', 'إلغاء') %>
          </button>
          <button type="button" id="step3-modal-confirm" class="p-btn p-btn--primary">
            <%= tt('Continue with my choice', 'Continue with my choice', 'متابعة باختياري') %>
          </button>
        </div>
      </div>
    </div>
  <% } %>

  <% if (__specialties.length > 0) { %>
    <%# Embed services data for client-side filtering when patient picks a specialty. %>
    <script<%- __nonceAttr %>>
      (function() {
        var allServices = <%- JSON.stringify(__services.map(function(sv) { return { id: sv.id, specialty_id: sv.specialty_id, name: sv.name, base_price: Number(sv.base_price) || 0, currency: sv.currency || 'EGP', sla_hours: sv.sla_hours || 72 }; })) %>;
        var specialtyInput = document.getElementById('step3-specialty-id');
        var serviceInput = document.getElementById('step3-service-id');
        var servicesCard = document.getElementById('step3-services-card');
        var servicesBody = document.getElementById('step3-services-body');
        var continueBtn = document.getElementById('step3-continue');
        var labelStandard = <%- JSON.stringify(tt('Standard', 'Standard', 'قياسي')) %>;
        var labelTurn = <%- JSON.stringify(tt('h turnaround', 'h turnaround', 'ساعة')) %>;

        function renderServices() {
          var spId = specialtyInput.value;
          if (!spId) { servicesCard.style.display = "none"; servicesBody.innerHTML = ""; return; }
          var matching = allServices.filter(function(sv) { return String(sv.specialty_id) === spId; });
          servicesBody.innerHTML = "";
          matching.forEach(function(sv) {
            var btn = document.createElement("button");
            btn.type = "button";
            btn.className = "p-service-card" + (String(sv.id) === serviceInput.value ? " is-selected" : "");
            btn.setAttribute("data-service-id", sv.id);
            btn.style.cssText = "text-align:start;cursor:pointer;display:flex;align-items:center;justify-content:space-between;gap:12px;border:1px solid " + (String(sv.id) === serviceInput.value ? "var(--primary)" : "var(--rule)") + ";background:" + (String(sv.id) === serviceInput.value ? "var(--primary-light)" : "#fff") + ";border-radius:12px;padding:14px 16px;";
            var inner = document.createElement("div");
            var name = document.createElement("div");
            name.style.cssText = "font-size:14px;font-weight:600;color:var(--ink);";
            name.textContent = sv.name;
            inner.appendChild(name);
            var sub = document.createElement("div");
            sub.style.cssText = "font-size:11.5px;color:var(--muted);margin-top:3px;";
            sub.textContent = labelStandard + " " + sv.sla_hours + " " + labelTurn;
            inner.appendChild(sub);
            btn.appendChild(inner);
            var price = document.createElement("div");
            price.className = "p-num";
            price.style.cssText = "font-size:14px;font-weight:600;color:var(--accent-dark);";
            // Theme 10b §C / OQ-2: money always Western digits.
            price.textContent = (sv.currency || "EGP") + " " + Number(sv.base_price).toLocaleString('en-GB', { maximumFractionDigits: 0 });
            btn.appendChild(price);
            btn.addEventListener("click", function() {
              serviceInput.value = sv.id;
              renderServices();
              updateContinue();
            });
            servicesBody.appendChild(btn);
          });
          servicesCard.style.display = matching.length > 0 ? "" : "none";
        }
        function updateContinue() {
          if (!continueBtn) return;
          // All tiers (including manual / null recommendation) require both
          // specialty and service. Locked tier pre-fills both from the AI
          // pick; manual + null show the grid and the patient picks.
          var ok = specialtyInput.value && serviceInput.value;
          continueBtn.disabled = !ok;
          continueBtn.style.opacity = ok ? "" : "0.5";
          continueBtn.style.cursor = ok ? "" : "not-allowed";
        }

        document.querySelectorAll(".p-spec-card").forEach(function(btn) {
          btn.addEventListener("click", function() {
            var spId = btn.getAttribute("data-specialty-id");
            specialtyInput.value = spId;
            // Clear service when switching specialty.
            serviceInput.value = "";
            // Update visual selection on specialty cards.
            document.querySelectorAll(".p-spec-card").forEach(function(b) {
              var isSel = b === btn;
              b.style.border = "1px solid " + (isSel ? "var(--primary)" : "var(--rule)");
              b.style.background = isSel ? "var(--primary-light)" : "#fff";
            });
            renderServices();
            updateContinue();
          });
        });
        // Bind any pre-rendered service-card buttons (server-rendered above).
        document.querySelectorAll(".p-service-card").forEach(function(btn) {
          btn.addEventListener("click", function() {
            serviceInput.value = btn.getAttribute("data-service-id");
            document.querySelectorAll(".p-service-card").forEach(function(b) {
              var isSel = b === btn;
              b.style.border = "1px solid " + (isSel ? "var(--primary)" : "var(--rule)");
              b.style.background = isSel ? "var(--primary-light)" : "#fff";
            });
            updateContinue();
          });
        });
        updateContinue();

        // ── Theme 14 Phase 2 — "Why?" toggle + SLA-disclaimer modal handlers ──
        // Only wires up when the corresponding DOM nodes exist (tier-gated server-side).
        var whyToggle = document.getElementById('step3-why-toggle');
        var whyContent = document.getElementById('step3-why-content');
        if (whyToggle && whyContent) {
          whyToggle.addEventListener('click', function() {
            var willShow = whyContent.hidden;
            whyContent.hidden = !willShow;
            whyToggle.setAttribute('aria-expanded', String(willShow));
          });
        }

        var diffBtn = document.getElementById('step3-different-specialty');
        var modal = document.getElementById('step3-override-modal');
        var modalCancel = document.getElementById('step3-modal-cancel');
        var modalConfirm = document.getElementById('step3-modal-confirm');
        var overrideGrid = document.getElementById('step3-override-grid');
        var overrideFlagInput = document.getElementById('step3-override-flag');
        var recommendationCard = document.getElementById('step3-recommendation-card');

        function closeModal() { if (modal) modal.hidden = true; }
        if (diffBtn) diffBtn.addEventListener('click', function() { if (modal) modal.hidden = false; });
        if (modalCancel) modalCancel.addEventListener('click', closeModal);
        if (modalConfirm) modalConfirm.addEventListener('click', function() {
          closeModal();
          // Reveal the override grid; hide the recommendation card so the
          // patient commits to a different choice rather than seeing both.
          if (overrideGrid) overrideGrid.hidden = false;
          if (recommendationCard) recommendationCard.hidden = true;
          if (overrideFlagInput) overrideFlagInput.value = '1';
          // Clear the locked-in specialty so the patient must pick from the override grid.
          specialtyInput.value = '';
          serviceInput.value = '';
          if (servicesCard) servicesCard.style.display = 'none';
          if (servicesBody) servicesBody.innerHTML = '';
          updateContinue();
        });
        // Escape closes the modal.
        if (modal) {
          document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && !modal.hidden) closeModal();
          });
        }
      })();
    </script>
  <% } %>

  <% if (typeof classifierPending !== 'undefined' && classifierPending) { %>
    <%# ── Async classifier poller. Mirrors the step-2 files.json polling
        contract: 5s cadence, credentials: 'same-origin', cache: 'no-store',
        swallow-on-error, cancellation via DOM attribute. On status='ready'
        the page reloads so the existing server-side tiered-card EJS
        renders the result — JS does NOT reimplement tier logic. Hard
        wall-clock cap at 30s; on timeout the banner hides and the
        patient continues on the supply-blind grid. %>
    <script<%- __nonceAttr %>>
      (function() {
        var banner = document.getElementById('classifier-banner');
        if (!banner) return;
        if (banner.getAttribute('data-poll-active') !== '1') return;
        var url = banner.getAttribute('data-poll-url');
        if (!url) return;
        var startedAt = Date.now();
        var WALL_CLOCK_MS = 30 * 1000;
        function stop() { banner.setAttribute('data-poll-active', '0'); banner.hidden = true; }
        var dismissBtn = document.getElementById('classifier-banner-dismiss');
        if (dismissBtn) dismissBtn.addEventListener('click', stop);
        function poll() {
          if (banner.getAttribute('data-poll-active') !== '1') return;
          if (Date.now() - startedAt > WALL_CLOCK_MS) { stop(); return; }
          fetch(url, { credentials: 'same-origin', cache: 'no-store' })
            .then(function(r) { return r.ok ? r.json() : null; })
            .then(function(data) {
              if (!data || !data.ok) return;
              if (data.status === 'ready') {
                banner.setAttribute('data-poll-active', '0');
                window.location.reload();
              }
            })
            .catch(function() { /* swallow — try again next tick */ });
        }
        var iv = setInterval(function() {
          if (banner.getAttribute('data-poll-active') !== '1') { clearInterval(iv); return; }
          poll();
        }, 5000);
      })();
    </script>
  <% } %>

<% } else if (__step === 4) { %>
