<%
  // Services list. Locals: services.
  var isAr = (typeof lang !== 'undefined' && lang === 'ar');
  var _services = (typeof services !== 'undefined' && services) ? services : [];
%>
<%- include('partials/superadmin/header', {
      title: isAr ? 'الخدمات' : 'Services',
      currentSection: 'services',
      user: user,
      lang: lang || 'en',
      showTabBar: false,
      sidebarBadges: (typeof sidebarBadges !== 'undefined' && sidebarBadges) ? sidebarBadges : {},
      cspNonce: (typeof cspNonce !== 'undefined') ? cspNonce : ''
    }) %>

<%- include('partials/superadmin/page_header', {
      title: isAr ? 'الخدمات' : 'Services',
      subtitle: isAr ? 'إدارة كتالوج الخدمات.' : 'Manage the service catalog.',
      breadcrumb: [
        { label: 'Dashboard', href: '/superadmin' },
        { label: isAr ? 'الخدمات' : 'Services' }
      ],
      actionsHtml: '<a class="btn" href="/superadmin/pricing">Regional pricing →</a> <a class="btn primary" href="/superadmin/services/new">+ ' + (isAr ? 'خدمة جديدة' : 'New service') + '</a>'
    }) %>

<div class="page-body">
  <%- include('partials/superadmin/c_card_open', { tight: true }) %>
    <% if (!_services.length) { %>
      <%- include('partials/superadmin/c_empty', { title: isAr ? 'لا توجد خدمات.' : 'No services defined', sub: 'Create the first service to populate the catalog.' }) %>
    <% } else { %>
      <%- include('partials/superadmin/c_table_open', { headers: ['Code', 'Name', 'Specialty', 'Visibility', { label: 'Actions', align: 'end' }] }) %>
        <% _services.forEach(function(sv) {
             var isVisible = (sv.is_visible == null ? 1 : Number(sv.is_visible)) === 1;
        %>
          <tr>
            <td class="mono" style="font-size:11.5px;"><%= sv.code || '—' %></td>
            <td><a href="/superadmin/services/<%= sv.id %>/edit" style="color:inherit;font-weight:500;"><%= sv.name %></a></td>
            <td><% if (sv.specialty_name) { %><span class="spec-tag"><%= sv.specialty_name %></span><% } else { %>—<% } %></td>
            <td><%- include('partials/superadmin/c_chip', { label: isVisible ? 'Visible' : 'Hidden', tone: isVisible ? 'green' : 'neutral', dot: true }) %></td>
            <td style="text-align:end;">
              <div style="display:inline-flex;gap:6px;justify-content:flex-end;">
                <a class="btn" href="/superadmin/services/<%= sv.id %>/edit">Edit</a>
                <form method="post" action="/superadmin/services/<%= sv.id %>/toggle-visibility" style="display:inline;">
                  <%- (typeof csrfField === 'function') ? csrfField() : '' %>
                  <button type="submit" class="btn"><%= isVisible ? 'Hide' : 'Unhide' %></button>
                </form>
              </div>
            </td>
          </tr>
        <% }); %>
      <%- include('partials/superadmin/c_table_close') %>
    <% } %>
  <%- include('partials/superadmin/c_card_close') %>
</div>

<%- include('partials/superadmin/footer', { isAr: isAr }) %>
