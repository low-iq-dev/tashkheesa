<%- include('partials/header', { title: 'Case File', layout: 'portal', showNav: true, portalFrame: true, portalRole: 'doctor', portalActive: 'queue', portalNext: '/portal/doctor/queue' }) %>
<%
  var lang = (locals && locals.lang) || (locals && locals.user && locals.user.lang) || 'en';
  var isAr = String(lang).toLowerCase() === 'ar';
  var cspNonce = (locals && (locals.cspNonce || locals.csp_nonce || locals.nonce)) ? String(locals.cspNonce || locals.csp_nonce || locals.nonce) : '';

  var order = locals.order || {};
  var extraction = locals.extraction || {};
  var caseFiles = Array.isArray(locals.caseFiles) ? locals.caseFiles : [];
  var orderFiles = Array.isArray(locals.orderFiles) ? locals.orderFiles : [];
  var intelligenceStatus = locals.intelligenceStatus || 'none';
  var orderId = String(order.id || '');

  var labValues = [];
  if (extraction && extraction.lab_values) {
    try { labValues = typeof extraction.lab_values === 'string' ? JSON.parse(extraction.lab_values) : (Array.isArray(extraction.lab_values) ? extraction.lab_values : []); } catch(_) {}
  }

  var patientInfo = {};
  if (extraction && extraction.patient_info) {
    try { patientInfo = typeof extraction.patient_info === 'string' ? JSON.parse(extraction.patient_info) : (extraction.patient_info || {}); } catch(_) {}
  }

  var docsInventory = [];
  if (extraction && extraction.documents_inventory) {
    try { docsInventory = typeof extraction.documents_inventory === 'string' ? JSON.parse(extraction.documents_inventory) : (Array.isArray(extraction.documents_inventory) ? extraction.documents_inventory : []); } catch(_) {}
  }

  var missingDocs = [];
  if (extraction && extraction.missing_documents) {
    try { missingDocs = typeof extraction.missing_documents === 'string' ? JSON.parse(extraction.missing_documents) : (Array.isArray(extraction.missing_documents) ? extraction.missing_documents : []); } catch(_) {}
  }

  var patientName = (order.patient_name || patientInfo.name || '');
  var patientComplaint = (patientInfo.complaint || order.notes || '');
  var fileCount = orderFiles.length || caseFiles.length || 0;
  var submissionDate = order.created_at ? new Date(order.created_at).toLocaleDateString(isAr ? 'ar-EG' : 'en-GB', { day: 'numeric', month: 'short', year: 'numeric' }) : '';

  function statusBadgeClass(s) {
    if (s === 'ready') return 'ci-badge--teal';
    if (s === 'processing') return 'ci-badge--amber';
    return 'ci-badge--gray';
  }
  function statusBadgeText(s, ar) {
    if (s === 'ready') return ar ? 'تم استخلاص البيانات' : 'Data Extracted';
    if (s === 'processing') return ar ? 'جاري المعالجة...' : 'Processing...';
    if (s === 'failed') return ar ? 'فشل الاستخلاص' : 'Extraction Failed';
    return ar ? 'بانتظار الرفع' : 'Pending Upload';
  }

  function typeIcon(type) {
    if (type === 'lab_report') return '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>';
    if (type === 'imaging') return '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>';
    if (type === 'prescription') return '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>';
    if (type === 'referral_letter') return '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>';
    if (type === 'intake_form') return '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/><rect x="8" y="2" width="8" height="4" rx="1" ry="1"/></svg>';
    return '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V9z"/><polyline points="13 2 13 9 20 9"/></svg>';
  }

  function labStatusClass(s) {
    if (s === 'above') return 'ci-lab--above';
    if (s === 'below') return 'ci-lab--below';
    return 'ci-lab--normal';
  }
  function labStatusText(s, ar) {
    if (s === 'above') return ar ? 'مرتفع' : 'ABOVE';
    if (s === 'below') return ar ? 'منخفض' : 'BELOW';
    return ar ? 'طبيعي' : 'IN RANGE';
  }

%>

<style<% if (cspNonce) { %> nonce="<%= cspNonce %>"<% } %>>
/* ── Case Intelligence — v2 retint ──
   All rules scoped under body.doctor-theme.portal-v2 .doctor-case-intelligence-page
   so legacy .ci-* class names continue to work but pull from --v2-* tokens. */
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-page {
  max-width: 1100px; margin: 0 auto; padding: 24px 16px 96px;
}

/* Header bar — light surface, not dark sidebar */
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-header {
  background: var(--v2-surface);
  border: 1px solid var(--v2-rule);
  border-radius: var(--v2-r-lg, 14px);
  padding: 18px 22px;
  margin-bottom: 20px;
  display: flex; align-items: flex-start; justify-content: space-between;
  flex-wrap: wrap; gap: 16px;
  box-shadow: var(--v2-shadow-sm);
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-header-left h1 {
  font-size: 18px; font-weight: 700; color: var(--v2-ink); margin: 0 0 4px;
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-header-left p {
  font-size: 13px; color: var(--v2-muted); margin: 0;
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-meta {
  display: flex; gap: 20px; flex-wrap: wrap; align-items: center;
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-meta-item {
  display: flex; flex-direction: column; gap: 2px;
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-meta-label {
  font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em; color: var(--v2-muted);
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-meta-value {
  font-size: 13px; font-weight: 600; color: var(--v2-ink);
}

/* Status badge */
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-badge {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 4px 10px; border-radius: 999px;
  font-size: 11px; font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.05em;
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-badge--teal {
  background: var(--v2-success-bg); color: var(--v2-success);
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-badge--amber {
  background: var(--v2-warn-bg); color: var(--v2-warn);
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-badge--amber::before {
  content: ''; width: 7px; height: 7px; border-radius: 50%;
  background: var(--v2-warn); animation: ci-pulse 1.5s infinite;
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-badge--gray {
  background: var(--v2-surface-sunk); color: var(--v2-muted);
}
@keyframes ci-pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.3; } }

/* Tabs */
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-tabs {
  display: flex; gap: 0;
  border-bottom: 1px solid var(--v2-rule);
  margin-bottom: 20px;
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-tab {
  padding: 10px 18px;
  font: inherit; font-size: 12px; font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.06em;
  color: var(--v2-muted); background: none; border: none; cursor: pointer;
  border-bottom: 2px solid transparent; margin-bottom: -1px;
  transition: color var(--v2-t-fast, 0.15s) var(--v2-ease, ease),
              border-color var(--v2-t-fast, 0.15s) var(--v2-ease, ease);
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-tab:hover {
  color: var(--v2-ink);
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-tab.active {
  color: var(--v2-brand); border-bottom-color: var(--v2-brand);
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-tab-content { display: none; }
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-tab-content.active { display: block; }

/* Cards */
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-card {
  background: var(--v2-surface);
  border: 1px solid var(--v2-rule);
  border-radius: var(--v2-r-md, 10px);
  padding: 20px; margin-bottom: 16px;
  box-shadow: var(--v2-shadow-sm);
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-card-title {
  font-size: 14px; font-weight: 700; color: var(--v2-ink);
  margin: 0 0 4px; display: flex; align-items: center; gap: 8px;
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-card-subtitle {
  font-size: 12px; color: var(--v2-muted); margin: 0 0 14px;
}

/* Documents inventory grid */
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-docs-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 10px;
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-doc-card {
  display: flex; align-items: center; gap: 10px; padding: 12px;
  border: 1px solid var(--v2-rule);
  border-radius: var(--v2-r-sm, 8px);
  background: var(--v2-surface-tint);
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-doc-icon {
  color: var(--v2-brand); flex-shrink: 0;
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-doc-info { min-width: 0; }
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-doc-name {
  font-size: 13px; font-weight: 600; color: var(--v2-ink);
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-doc-meta {
  font-size: 11px; color: var(--v2-muted);
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-doc-status {
  display: inline-block; width: 7px; height: 7px; border-radius: 50%; margin-right: 4px;
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-doc-status--extracted { background: var(--v2-success); }
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-doc-status--pending   { background: var(--v2-warn); }
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-doc-status--failed    { background: var(--v2-danger); }

/* Lab table */
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-lab-table {
  width: 100%; border-collapse: collapse; font-size: 13px;
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-lab-table th {
  text-align: start; padding: 8px 12px;
  font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em;
  color: var(--v2-muted);
  border-bottom: 1px solid var(--v2-rule-strong);
  font-weight: 700;
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-lab-table td {
  padding: 10px 12px;
  border-bottom: 1px solid var(--v2-rule);
  color: var(--v2-ink);
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-lab-tag {
  display: inline-block; padding: 2px 8px; border-radius: var(--v2-r-xs, 4px);
  font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-lab--above  { background: var(--v2-danger-bg);  color: var(--v2-danger); }
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-lab--below  { background: var(--v2-info-bg);    color: var(--v2-info); }
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-lab--normal { background: var(--v2-success-bg); color: var(--v2-success); }
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-lab-footer {
  font-size: 11px; color: var(--v2-muted); margin-top: 8px; font-style: italic;
}

/* Patient details */
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-patient-grid {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 10px;
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-patient-field {
  padding: 10px 14px;
  background: var(--v2-surface-tint);
  border: 1px solid var(--v2-rule);
  border-radius: var(--v2-r-sm, 8px);
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-patient-label {
  font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em;
  color: var(--v2-muted); margin-bottom: 2px;
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-patient-value {
  font-size: 14px; font-weight: 600; color: var(--v2-ink);
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-patient-source {
  font-size: 10px; color: var(--v2-muted); margin-top: 2px;
}

/* Missing docs callout */
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-missing {
  background: var(--v2-warn-bg);
  border: 1px solid var(--v2-warn);
  border-radius: var(--v2-r-md, 10px);
  padding: 16px 20px;
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-missing-title {
  font-size: 13px; font-weight: 700; color: var(--v2-warn);
  margin: 0 0 8px; display: flex; align-items: center; gap: 8px;
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-missing-list {
  margin: 0; padding-inline-start: 18px;
  font-size: 13px; color: var(--v2-ink);
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-missing-list li { margin-bottom: 4px; }

/* Image thumbnails */
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-thumbs {
  display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: 12px;
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-thumb {
  position: relative;
  border-radius: var(--v2-r-sm, 8px); overflow: hidden;
  border: 1px solid var(--v2-rule);
  cursor: pointer; aspect-ratio: 1;
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-thumb img {
  width: 100%; height: 100%; object-fit: cover;
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-thumb-overlay {
  position: absolute; inset-block-end: 0; inset-inline-start: 0; inset-inline-end: 0;
  padding: 6px 8px;
  background: linear-gradient(transparent, rgba(15,30,45,0.72));
  color: var(--v2-on-brand); font-size: 11px;
}

/* Original files list */
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-file-row {
  display: flex; align-items: center; gap: 12px;
  padding: 12px 0;
  border-bottom: 1px solid var(--v2-rule);
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-file-row:last-child { border-bottom: none; }
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-file-name {
  font-size: 14px; font-weight: 500; color: var(--v2-ink);
  flex: 1; min-width: 0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-file-link {
  font-size: 12px; color: var(--v2-brand);
  text-decoration: none; font-weight: 600; white-space: nowrap;
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-file-link:hover { text-decoration: underline; }

/* Notes */
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-notes-area {
  width: 100%; min-height: 160px; padding: 14px;
  border: 1px solid var(--v2-rule);
  border-radius: var(--v2-r-sm, 8px);
  font-family: inherit; font-size: 14px;
  color: var(--v2-ink); background: var(--v2-surface-tint);
  resize: vertical;
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-notes-area:focus {
  outline: 2px solid var(--v2-brand); outline-offset: -1px;
  border-color: transparent;
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-notes-status {
  font-size: 11px; color: var(--v2-muted); margin-top: 6px; min-height: 16px;
}

/* Bottom action bar — fixed, sidebar-aware */
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-actions {
  position: fixed; bottom: 0;
  left: var(--v2-sidebar-w, 240px); right: 0;
  background: var(--v2-surface);
  border-top: 1px solid var(--v2-rule);
  padding: 12px 24px;
  display: flex; align-items: center; justify-content: space-between;
  gap: 16px; z-index: 100;
  box-shadow: 0 -1px 3px rgba(15,30,45,0.04);
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-actions-info {
  font-size: 12px; color: var(--v2-muted); flex: 1; min-width: 0;
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-actions-btns {
  display: flex; gap: 10px; flex-shrink: 0;
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-btn {
  display: inline-flex; align-items: center; gap: 6px;
  padding: 8px 16px;
  border-radius: var(--v2-r-md, 10px);
  font: inherit; font-size: 13px; font-weight: 600;
  text-decoration: none; border: none; cursor: pointer;
  transition: background var(--v2-t-fast, 0.15s) var(--v2-ease, ease),
              color var(--v2-t-fast, 0.15s) var(--v2-ease, ease);
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-btn--secondary {
  background: var(--v2-surface);
  color: var(--v2-brand);
  border: 1px solid var(--v2-brand);
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-btn--secondary:hover {
  background: var(--v2-brand-lt);
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-btn--primary {
  background: var(--v2-accent);
  color: var(--v2-on-accent);
}
body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-btn--primary:hover {
  background: var(--v2-accent-dk);
  color: var(--v2-on-brand);
}

/* RTL */
body.doctor-theme.portal-v2 .doctor-case-intelligence-page[dir="rtl"] .ci-doc-status,
body.doctor-theme.portal-v2[dir="rtl"] .doctor-case-intelligence-page .ci-doc-status {
  margin-right: 0; margin-left: 4px;
}
body.doctor-theme.portal-v2[dir="rtl"] .doctor-case-intelligence-page .ci-actions {
  left: 0; right: var(--v2-sidebar-w, 240px);
}

/* Responsive */
@media (max-width: 768px) {
  body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-header {
    flex-direction: column; align-items: stretch;
  }
  body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-meta {
    justify-content: space-between;
  }
  body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-docs-grid,
  body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-patient-grid {
    grid-template-columns: 1fr;
  }
  body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-actions {
    left: 0 !important; right: 0 !important;
    flex-direction: column; text-align: center;
  }
  body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-actions-btns {
    width: 100%; justify-content: center;
  }
  body.doctor-theme.portal-v2 .doctor-case-intelligence-page .ci-tabs { overflow-x: auto; }
}
</style>

<%- include('partials/doctor/topbar', {
  isAr: isAr,
  topbarTitle: tt('Case File', 'Case File', 'ملف الحالة'),
  topbarSub: tt('Data extracted and organized — ready for your clinical review', 'Data extracted and organized — ready for your clinical review', 'تم استخلاص البيانات وتنظيمها — جاهز لمراجعتك السريرية'),
  topbarShowSearch: false,
  topbarActions: orderId ? ('<a class="v2-btn v2-btn--ghost" href="/portal/doctor/case/' + encodeURIComponent(orderId) + '">' + tt('← Back to case', '← Back to case', '→ العودة للحالة') + '</a>') : ''
}) %>

<div class="doctor-case-intelligence-page">
<div class="ci-page" id="ciPage">

  <!-- ═══ CASE META STRIP ═══
       Title + subtitle live in the v2 topbar partial above; this strip
       carries the case-context fields the topbar does not surface. -->
  <div class="ci-header">
    <div class="ci-meta">
      <div class="ci-meta-item">
        <span class="ci-meta-label" data-en="Case ID" data-ar="رقم الحالة"><%= isAr ? 'رقم الحالة' : 'Case ID' %></span>
        <span class="ci-meta-value"><%= orderId %></span>
      </div>
      <% if (patientName) { %>
      <div class="ci-meta-item">
        <span class="ci-meta-label" data-en="Patient" data-ar="المريض"><%= isAr ? 'المريض' : 'Patient' %></span>
        <span class="ci-meta-value"><%= patientName %></span>
      </div>
      <% } %>
      <% if (patientComplaint) { %>
      <div class="ci-meta-item">
        <span class="ci-meta-label" data-en="Primary Concern" data-ar="الشكوى الرئيسية"><%= isAr ? 'الشكوى الرئيسية' : 'Primary Concern' %></span>
        <span class="ci-meta-value" style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= patientComplaint %></span>
      </div>
      <% } %>
      <div class="ci-meta-item">
        <span class="ci-meta-label" data-en="Files" data-ar="الملفات"><%= isAr ? 'الملفات' : 'Files' %></span>
        <span class="ci-meta-value"><%= fileCount %></span>
      </div>
      <% if (submissionDate) { %>
      <div class="ci-meta-item">
        <span class="ci-meta-label" data-en="Submitted" data-ar="تاريخ التقديم"><%= isAr ? 'تاريخ التقديم' : 'Submitted' %></span>
        <span class="ci-meta-value"><%= submissionDate %></span>
      </div>
      <% } %>
      <div class="ci-meta-item">
        <span class="ci-badge <%= statusBadgeClass(intelligenceStatus) %>"><%= statusBadgeText(intelligenceStatus, isAr) %></span>
      </div>
    </div>
  </div>

  <!-- ═══ TABS ═══ -->
  <div class="ci-tabs" role="tablist">
    <button class="ci-tab active" role="tab" aria-selected="true" data-tab="extracted" data-en="Extracted Data" data-ar="البيانات المستخلصة"><%= isAr ? 'البيانات المستخلصة' : 'Extracted Data' %></button>
    <button class="ci-tab" role="tab" aria-selected="false" data-tab="files" data-en="Original Files" data-ar="الملفات الأصلية"><%= isAr ? 'الملفات الأصلية' : 'Original Files' %></button>
    <button class="ci-tab" role="tab" aria-selected="false" data-tab="notes" data-en="Your Notes" data-ar="ملاحظاتك"><%= isAr ? 'ملاحظاتك' : 'Your Notes' %></button>
  </div>

  <!-- ═══ TAB 1: EXTRACTED DATA ═══ -->
  <div class="ci-tab-content active" id="tab-extracted">

    <% if (intelligenceStatus === 'processing') { %>
      <div class="ci-card" style="text-align:center;padding:48px;">
        <div class="ci-badge ci-badge--amber" style="font-size:14px;margin-bottom:12px;display:inline-flex;">
          <%= isAr ? 'جاري معالجة الملفات...' : 'Processing files...' %>
        </div>
        <p style="color:var(--dr-text3);font-size:13px;" data-en="Data extraction is in progress. This page will update automatically." data-ar="استخلاص البيانات قيد التقدم. ستتحدث هذه الصفحة تلقائياً."><%= isAr ? 'استخلاص البيانات قيد التقدم. ستتحدث هذه الصفحة تلقائياً.' : 'Data extraction is in progress. This page will update automatically.' %></p>
      </div>
    <% } else { %>

      <!-- Documents Inventory -->
      <% if (docsInventory.length > 0 || caseFiles.length > 0) { %>
      <div class="ci-card">
        <div class="ci-card-title" data-en="Documents Inventory" data-ar="جرد المستندات"><%= isAr ? 'جرد المستندات' : 'Documents Inventory' %></div>
        <div class="ci-docs-grid">
          <% var invItems = docsInventory.length > 0 ? docsInventory : caseFiles; %>
          <% invItems.forEach(function(doc) { %>
            <div class="ci-doc-card">
              <div class="ci-doc-icon"><%- typeIcon(doc.type || doc.document_category || doc.file_type || 'other') %></div>
              <div class="ci-doc-info">
                <div class="ci-doc-name"><%= doc.filename || 'File' %></div>
                <div class="ci-doc-meta">
                  <span class="ci-doc-status ci-doc-status--<%= doc.extracted || doc.processing_status === 'extracted' ? 'extracted' : (doc.processing_status === 'failed' ? 'failed' : 'pending') %>"></span>
                  <%= doc.type || doc.document_category || doc.file_type || 'unknown' %>
                  <% if (doc.language || doc.language_detected) { %> · <%= doc.language || doc.language_detected %><% } %>
                </div>
              </div>
            </div>
          <% }); %>
        </div>
      </div>
      <% } %>

      <!-- Lab Values -->
      <% if (labValues.length > 0) { %>
      <div class="ci-card">
        <div class="ci-card-title" data-en="Lab Values — as reported" data-ar="نتائج المختبر — كما وردت"><%= isAr ? 'نتائج المختبر — كما وردت' : 'Lab Values — as reported' %></div>
        <div style="overflow-x:auto;">
        <table class="ci-lab-table">
          <thead>
            <tr>
              <th data-en="Test" data-ar="الفحص"><%= isAr ? 'الفحص' : 'Test' %></th>
              <th data-en="Result" data-ar="النتيجة"><%= isAr ? 'النتيجة' : 'Result' %></th>
              <th data-en="Reference Range" data-ar="المعدل الطبيعي"><%= isAr ? 'المعدل الطبيعي' : 'Reference Range' %></th>
              <th data-en="Status" data-ar="الحالة"><%= isAr ? 'الحالة' : 'Status' %></th>
            </tr>
          </thead>
          <tbody>
            <% labValues.forEach(function(lv) { %>
            <tr>
              <td><%= lv.test || '—' %></td>
              <td><%= lv.value || '—' %> <% if (lv.unit) { %><span style="color:var(--dr-text3);font-size:11px;"><%= lv.unit %></span><% } %></td>
              <td><%= lv.reference_range || '—' %></td>
              <td><span class="ci-lab-tag <%= labStatusClass(lv.status) %>"><%= labStatusText(lv.status, isAr) %></span></td>
            </tr>
            <% }); %>
          </tbody>
        </table>
        </div>
        <div class="ci-lab-footer" data-en="Values extracted via OCR from uploaded lab report. Reference ranges as printed on original report." data-ar="القيم مستخلصة عبر OCR من تقرير المختبر المرفوع. المعدلات الطبيعية كما هي مطبوعة على التقرير الأصلي.">
          <%= isAr ? 'القيم مستخلصة عبر OCR من تقرير المختبر المرفوع. المعدلات الطبيعية كما هي مطبوعة على التقرير الأصلي.' : 'Values extracted via OCR from uploaded lab report. Reference ranges as printed on original report.' %>
        </div>
      </div>
      <% } %>

      <!-- Patient Details -->
      <% var hasPatientData = Object.keys(patientInfo).some(function(k) { return !k.endsWith('_source_file') && patientInfo[k] !== null && patientInfo[k] !== undefined; }); %>
      <% if (hasPatientData) { %>
      <div class="ci-card">
        <div class="ci-card-title" data-en="Patient Details — as stated" data-ar="بيانات المريض — كما ذُكرت"><%= isAr ? 'بيانات المريض — كما ذُكرت' : 'Patient Details — as stated' %></div>
        <div class="ci-patient-grid">
          <% var piFields = [
               { key: 'name', en: 'Name', ar: 'الاسم' },
               { key: 'age', en: 'Age', ar: 'العمر' },
               { key: 'gender', en: 'Gender', ar: 'الجنس' },
               { key: 'complaint', en: 'Chief Complaint', ar: 'الشكوى الرئيسية' },
               { key: 'medications', en: 'Current Medications', ar: 'الأدوية الحالية' },
               { key: 'allergies', en: 'Allergies', ar: 'الحساسية' },
               { key: 'family_history', en: 'Family History', ar: 'التاريخ العائلي' }
             ];
          %>
          <% piFields.forEach(function(field) { %>
            <% if (patientInfo[field.key] !== null && patientInfo[field.key] !== undefined) { %>
            <div class="ci-patient-field">
              <div class="ci-patient-label"><%= isAr ? field.ar : field.en %></div>
              <div class="ci-patient-value"><%= patientInfo[field.key] %></div>
              <% if (patientInfo[field.key + '_source_file']) { %>
              <div class="ci-patient-source"><%= isAr ? 'المصدر: ' : 'Source: ' %><%= patientInfo[field.key + '_source_file'] %></div>
              <% } %>
            </div>
            <% } %>
          <% }); %>
        </div>
      </div>
      <% } %>

      <!-- Missing Documents -->
      <% if (missingDocs.length > 0) { %>
      <div class="ci-missing">
        <div class="ci-missing-title">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
          <span data-en="Missing Documents" data-ar="مستندات ناقصة"><%= isAr ? 'مستندات ناقصة' : 'Missing Documents' %></span>
        </div>
        <ul class="ci-missing-list">
          <% missingDocs.forEach(function(d) { %>
            <li><%= d %></li>
          <% }); %>
        </ul>
      </div>
      <% } %>

      <!-- Image Thumbnails -->
      <% var imageFiles = caseFiles.filter(function(f) { return f.file_type === 'image' || (f.mime_type && f.mime_type.indexOf('image') === 0); }); %>
      <% if (imageFiles.length > 0) { %>
      <div class="ci-card" style="margin-top:20px;">
        <div class="ci-card-title" data-en="Uploaded Images" data-ar="الصور المرفوعة"><%= isAr ? 'الصور المرفوعة' : 'Uploaded Images' %></div>
        <div class="ci-card-subtitle" data-en="Click to view full resolution" data-ar="اضغط لعرض الحجم الكامل"><%= isAr ? 'اضغط لعرض الحجم الكامل' : 'Click to view full resolution' %></div>
        <div class="ci-thumbs">
          <%
            /* NOTE (Phase 2): These thumbnails read from `case_files.storage_path`,
               which is written by the case-intelligence pipeline (src/case_lifecycle.js +
               src/case-intelligence.js) — a separate writer from order_flow.js. The
               case_files table will be migrated in its own phase. Until then, the
               /uploads/... URLs below are inert (no /uploads static mount). */
          %>
          <% imageFiles.forEach(function(img) { %>
            <a class="ci-thumb" href="/uploads/<%= encodeURI(img.storage_path || '') %>" target="_blank" rel="noopener">
              <img src="/uploads/<%= encodeURI(img.storage_path || '') %>" alt="<%= img.filename || 'Image' %>" loading="lazy" />
              <div class="ci-thumb-overlay"><%= img.filename || 'Image' %></div>
            </a>
          <% }); %>
        </div>
      </div>
      <% } %>

    <% } /* end non-processing */ %>
  </div>

  <!-- ═══ TAB 2: ORIGINAL FILES ═══ -->
  <div class="ci-tab-content" id="tab-files">
    <div class="ci-card">
      <div class="ci-card-title" data-en="All Uploaded Files" data-ar="جميع الملفات المرفوعة"><%= isAr ? 'جميع الملفات المرفوعة' : 'All Uploaded Files' %></div>
      <% if (orderFiles.length === 0) { %>
        <p style="color:var(--dr-text3);font-size:13px;"><%= isAr ? 'لا توجد ملفات مرفوعة.' : 'No files uploaded.' %></p>
      <% } else { %>
        <% orderFiles.forEach(function(f) { %>
          <div class="ci-file-row">
            <div class="ci-doc-icon"><%- typeIcon(f.label || f.name || '') %></div>
            <span class="ci-file-name"><%= f.label || f.name || f.url || 'File' %></span>
            <% var fileHref = f.id ? ('/files/' + encodeURIComponent(String(f.id))) : ''; %>
            <% if (fileHref) { %>
              <a class="ci-file-link" href="<%= fileHref %>" target="_blank" rel="noopener" data-en="View" data-ar="عرض"><%= isAr ? 'عرض' : 'View' %></a>
              <a class="ci-file-link" href="<%= fileHref %>" download data-en="Download" data-ar="تحميل"><%= isAr ? 'تحميل' : 'Download' %></a>
            <% } else { %>
              <span class="ci-file-link" style="opacity:0.5"><%= isAr ? 'غير متاح' : 'Unavailable' %></span>
            <% } %>
          </div>
        <% }); %>
      <% } %>
    </div>
  </div>

  <!-- ═══ TAB 3: YOUR NOTES ═══ -->
  <div class="ci-tab-content" id="tab-notes">
    <div class="ci-card">
      <div class="ci-card-title" data-en="Private Notes" data-ar="ملاحظات خاصة"><%= isAr ? 'ملاحظات خاصة' : 'Private Notes' %></div>
      <div class="ci-card-subtitle" data-en="Only visible to you. Auto-saves as you type." data-ar="مرئية لك فقط. يتم الحفظ تلقائياً أثناء الكتابة."><%= isAr ? 'مرئية لك فقط. يتم الحفظ تلقائياً أثناء الكتابة.' : 'Only visible to you. Auto-saves as you type.' %></div>
      <textarea class="ci-notes-area" id="ciNotesArea" placeholder="<%= isAr ? 'اكتب ملاحظاتك هنا...' : 'Write your notes here...' %>"><%= (order.diagnosis_text || '') %></textarea>
      <div class="ci-notes-status" id="ciNotesSaved"></div>
    </div>
  </div>
</div>

<!-- ═══ BOTTOM ACTION BAR ═══ -->
<div class="ci-actions">
  <div class="ci-actions-info">
    <span data-en="<%= fileCount %> files uploaded" data-ar="<%= fileCount %> ملفات مرفوعة"><%= fileCount %> <%= isAr ? 'ملفات مرفوعة' : 'files uploaded' %></span>
    &middot;
    <span data-en="Data extracted and organized" data-ar="تم استخلاص البيانات وتنظيمها"><%= isAr ? 'تم استخلاص البيانات وتنظيمها' : 'Data extracted and organized' %></span>
    &middot;
    <span data-en="No clinical interpretation applied" data-ar="لم يتم تطبيق أي تفسير سريري"><%= isAr ? 'لم يتم تطبيق أي تفسير سريري' : 'No clinical interpretation applied' %></span>
  </div>
  <div class="ci-actions-btns">
    <a href="/portal/doctor/case/<%= encodeURIComponent(orderId) %>" class="ci-btn ci-btn--secondary" data-en="Back to Case" data-ar="العودة للحالة"><%= isAr ? 'العودة للحالة' : 'Back to Case' %></a>
    <% if (missingDocs.length > 0) { %>
    <form method="post" action="/portal/doctor/case/<%= encodeURIComponent(orderId) %>/reject-files" style="display:inline;">
      <%- (typeof csrfField === 'function') ? csrfField() : '' %>
      <input type="hidden" name="reason" value="<%= isAr ? 'مطلوب ملفات إضافية' : 'Additional files needed' %>" />
      <button type="submit" class="ci-btn ci-btn--secondary" data-en="Ask Patient for More Files" data-ar="طلب ملفات إضافية من المريض"><%= isAr ? 'طلب ملفات إضافية من المريض' : 'Ask Patient for More Files' %></button>
    </form>
    <% } %>
    <a href="/portal/doctor/case/<%= encodeURIComponent(orderId) %>#diagnosis" class="ci-btn ci-btn--primary" data-en="Write Second Opinion" data-ar="كتابة رأي ثاني"><%= isAr ? 'كتابة رأي ثاني' : 'Write Second Opinion' %></a>
  </div>
</div>

</div><%# /.doctor-case-intelligence-page %>

<script<% if (cspNonce) { %> nonce="<%= cspNonce %>"<% } %>>
(function() {
  /* ── Tab switching ── */
  var tabs = document.querySelectorAll('.ci-tab');
  var panels = document.querySelectorAll('.ci-tab-content');

  for (var i = 0; i < tabs.length; i++) {
    tabs[i].addEventListener('click', function() {
      var target = this.getAttribute('data-tab');
      for (var j = 0; j < tabs.length; j++) {
        tabs[j].classList.remove('active');
        tabs[j].setAttribute('aria-selected', 'false');
      }
      for (var k = 0; k < panels.length; k++) {
        panels[k].classList.remove('active');
      }
      this.classList.add('active');
      this.setAttribute('aria-selected', 'true');
      var panel = document.getElementById('tab-' + target);
      if (panel) panel.classList.add('active');
    });
  }

  /* ── Notes autosave (debounced) ── */
  var notesArea = document.getElementById('ciNotesArea');
  var notesSaved = document.getElementById('ciNotesSaved');
  var saveTimer = null;
  var caseId = '<%= orderId %>';

  if (notesArea) {
    notesArea.addEventListener('input', function() {
      if (saveTimer) clearTimeout(saveTimer);
      if (notesSaved) notesSaved.textContent = '<%= isAr ? "جاري الحفظ..." : "Saving..." %>';
      saveTimer = setTimeout(function() {
        var body = 'diagnosis=' + encodeURIComponent(notesArea.value);
        var xhr = new XMLHttpRequest();
        xhr.open('POST', '/portal/doctor/case/' + encodeURIComponent(caseId) + '/diagnosis');
        xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
        // Include CSRF token if available
        var csrfMeta = document.querySelector('meta[name="csrf-token"]');
        if (csrfMeta) {
          xhr.setRequestHeader('x-csrf-token', csrfMeta.getAttribute('content'));
        }
        var csrfCookie = document.cookie.split(';').find(function(c) { return c.trim().indexOf('_csrf_nonce=') === 0; });
        if (csrfCookie) {
          body += '&_csrf_nonce=' + encodeURIComponent(csrfCookie.split('=')[1]);
        }
        xhr.onload = function() {
          if (notesSaved) notesSaved.textContent = '<%= isAr ? "تم الحفظ" : "Saved" %>';
        };
        xhr.onerror = function() {
          if (notesSaved) notesSaved.textContent = '<%= isAr ? "فشل الحفظ" : "Save failed" %>';
        };
        xhr.send(body);
      }, 1200);
    });
  }

  /* ── Auto-poll when processing ── */
  var statusStr = '<%= intelligenceStatus %>';
  if (statusStr === 'processing') {
    var pollInterval = setInterval(function() {
      var xhr = new XMLHttpRequest();
      xhr.open('GET', '/api/cases/' + encodeURIComponent(caseId) + '/intelligence');
      xhr.onload = function() {
        try {
          var data = JSON.parse(xhr.responseText);
          if (data.status && data.status !== 'processing') {
            clearInterval(pollInterval);
            window.location.reload();
          }
        } catch(_) {}
      };
      xhr.send();
    }, 5000);
  }

  /* ── Language toggle ── */
  window.toggleCiLang = function(newLang) {
    var isAr = (newLang === 'ar');
    var html = document.documentElement;
    html.setAttribute('dir', isAr ? 'rtl' : 'ltr');
    html.setAttribute('lang', newLang);

    var els = document.querySelectorAll('[data-en][data-ar]');
    for (var i = 0; i < els.length; i++) {
      var el = els[i];
      var text = isAr ? el.getAttribute('data-ar') : el.getAttribute('data-en');
      if (text !== null) el.textContent = text;
    }
  };
})();
</script>

<%- include('partials/footer') %>
