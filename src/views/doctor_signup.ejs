<%
  var _isAr = (typeof isAr !== 'undefined') ? !!isAr : false;
  var _lang = _isAr ? 'ar' : 'en';
  var _dir  = _isAr ? 'rtl' : 'ltr';
  var _err  = (typeof error !== 'undefined' && error) ? String(error) : '';
  var _form = (typeof form !== 'undefined' && form) ? form : {};
  var _specialties = Array.isArray(typeof specialties !== 'undefined' ? specialties : []) ? specialties : [];
  // _servicesBySpecialty: [{ specialtyId, specialtyName, specialtyNameAr,
  //                          services: [{id, name}] }, ...]
  // Pre-rendered for all specialties; JS toggles which group is visible
  // based on the picked primary specialty (avoids a round-trip).
  var _servicesBySpecialty = Array.isArray(typeof servicesBySpecialty !== 'undefined' ? servicesBySpecialty : []) ? servicesBySpecialty : [];
  var _brand = (typeof brand !== 'undefined' && brand) ? String(brand) : 'Tashkheesa';
  // CSP nonce — emit on inline <script> tags so they survive strict-CSP
  // without 'unsafe-inline' (Theme 2 Sub-issue B).
  var __nonce = String(
    (typeof cspNonce !== 'undefined' && cspNonce) ||
    (typeof locals !== 'undefined' && locals && (locals.cspNonce || locals.csp_nonce || locals.nonce)) ||
    ''
  );
  var __nonceAttr = __nonce ? (' nonce="' + __nonce + '"') : '';
  function _val(v) { return v == null ? '' : String(v); }
  function _has(arr, v) { return Array.isArray(arr) && arr.indexOf(v) !== -1; }
%><!DOCTYPE html>
<html lang="<%= _lang %>" dir="<%= _dir %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= tt('Apply as a specialist', 'Apply as a specialist', 'قدِّم كاستشاري') %> — <%= _brand %></title>
  <link rel="stylesheet" href="/css/portal-variables.css" />
  <link rel="stylesheet" href="/css/doctor-portal-v2.css" />
  <link rel="icon" href="/favicon.ico" />
  <style>
    /* Step transitions and form layout. Self-contained so no edits to
       portal-v2.css are required for this page. */
    .v2-steps { display:flex; gap:10px; margin:0 0 20px 0; padding:0; list-style:none; }
    .v2-steps li {
      flex:1; padding:10px 12px; border-radius:8px;
      background:rgba(255,255,255,0.04); border:1px solid rgba(255,255,255,0.08);
      font-size:13px; color:var(--v2-muted, #9aa6b2); display:flex; gap:10px; align-items:center;
    }
    .v2-steps li.is-active {
      background:rgba(255,255,255,0.08); color:var(--v2-fg, #f4f6f9);
      border-color:var(--v2-brand, #4a90e2);
    }
    .v2-steps li.is-done { color:#5fb37c; border-color:rgba(95,179,124,0.3); }
    .v2-steps li .v2-step-pip {
      width:22px; height:22px; border-radius:50%;
      display:inline-flex; align-items:center; justify-content:center;
      font-size:12px; font-weight:600;
      background:rgba(255,255,255,0.06);
    }
    .v2-step[hidden] { display:none; }
    .v2-fieldgroup { margin-block-end:18px; }
    .v2-fieldgroup-title { font-weight:600; margin:0 0 8px 0; font-size:13px; color:var(--v2-muted, #9aa6b2); text-transform:uppercase; letter-spacing:0.5px; }
    .v2-field-row { display:flex; gap:12px; }
    .v2-field-row > .v2-field { flex:1; min-width:0; }
    @media (max-width: 640px) { .v2-field-row { flex-direction:column; } }
    .v2-checkgrid { display:grid; grid-template-columns:repeat(auto-fill, minmax(180px, 1fr)); gap:8px; padding:12px; border:1px solid rgba(255,255,255,0.08); border-radius:8px; }
    .v2-checkgrid label { display:flex; gap:8px; align-items:flex-start; font-size:14px; cursor:pointer; }
    .v2-checkgrid input[type="checkbox"] { margin-top:3px; flex-shrink:0; }
    .v2-services-group[hidden] { display:none; }
    .v2-repeater-row { display:flex; gap:8px; margin-block-end:6px; }
    .v2-repeater-row > input { flex:1; }
    .v2-repeater-row .v2-repeater-remove { padding:6px 10px; }
    .v2-step-actions { display:flex; gap:10px; justify-content:space-between; margin-block-start:18px; }
    .v2-privacy-note { font-size:12px; color:var(--v2-muted, #9aa6b2); margin-block-start:6px; line-height:1.4; }
    .v2-consents { padding:12px; border:1px solid rgba(255,255,255,0.08); border-radius:8px; }
    .v2-consents label { display:flex; gap:10px; align-items:flex-start; font-size:14px; padding:8px 0; cursor:pointer; }
    .v2-consents input[type="checkbox"] { margin-top:4px; flex-shrink:0; }
  </style>
</head>
<body class="v2-auth">
  <div class="v2-auth">
    <div class="v2-auth__hero">
      <div class="v2-auth__mark">
        <div class="v2-tile">ت</div>
        <div>
          <div class="v2-wordmark"><%= _brand %></div>
          <div class="v2-tag"><%= tt('Specialist Medical Review', 'Specialist Medical Review', 'مراجعة طبية متخصصة') %></div>
        </div>
      </div>
      <div>
        <div class="v2-auth__headline"><%= tt('Apply as a consulting specialist.', 'Apply as a consulting specialist.', 'قدِّم طلبك كاستشاري.') %></div>
        <div class="v2-auth__sub"><%= tt('We review every application personally. Most applicants hear back within 3 working days.', 'We review every application personally. Most applicants hear back within 3 working days.', 'نراجع كل طلب يدوياً. تصل الردود خلال 3 أيام عمل في الغالب.') %></div>
      </div>
      <div class="v2-auth__trust">
        <span><%= tt('Per-case fees', 'Per-case fees', 'أتعاب لكل حالة') %></span>
        <span><%= tt('You set your hours', 'You set your hours', 'أنت تحدّد ساعاتك') %></span>
        <span><%= tt('Audit-logged access', 'Audit-logged access', 'وصول موثَّق') %></span>
      </div>
    </div>
    <div class="v2-auth__form-wrap">
      <form id="doctor-signup-form" class="v2-auth__form" method="post" action="/doctor/signup" novalidate>
        <%- (typeof csrfField === 'function') ? csrfField() : '' %>

        <ol class="v2-steps" aria-label="<%= tt('Signup progress', 'Signup progress', 'تقدّم التسجيل') %>">
          <li data-step-pip="1" class="is-active"><span class="v2-step-pip">1</span><%= tt('Identity', 'Identity', 'الهوية') %></li>
          <li data-step-pip="2"><span class="v2-step-pip">2</span><%= tt('Credentials', 'Credentials', 'الاعتماد') %></li>
          <li data-step-pip="3"><span class="v2-step-pip">3</span><%= tt('Preferences', 'Preferences', 'التفضيلات') %></li>
        </ol>

        <% if (_err) { %><div class="v2-auth__error"><%= _err %></div><% } %>

        <!-- ═════════════ STEP 1 — Identity & contact ═════════════ -->
        <fieldset class="v2-step" data-step="1">
          <legend class="v2-auth__title"><%= tt('Step 1 of 3 · Identity & contact', 'Step 1 of 3 · Identity & contact', 'الخطوة 1 من 3 · الهوية والتواصل') %></legend>

          <div class="v2-fieldgroup">
            <div class="v2-fieldgroup-title"><%= tt('Name', 'Name', 'الاسم') %></div>
            <div class="v2-field-row">
              <div class="v2-field">
                <label class="v2-field__label" for="su-name"><%= tt('Full name (English)', 'Full name (English)', 'الاسم الكامل (إنجليزي)') %></label>
                <input class="v2-field__input" id="su-name" name="name" required maxlength="200" value="<%= _val(_form.name) %>" />
              </div>
              <div class="v2-field">
                <label class="v2-field__label" for="su-name-ar"><%= tt('Full name (Arabic) — optional', 'Full name (Arabic) — optional', 'الاسم الكامل (عربي) — اختياري') %></label>
                <input class="v2-field__input" id="su-name-ar" name="name_ar" maxlength="200" dir="rtl" value="<%= _val(_form.name_ar) %>" />
              </div>
            </div>
          </div>

          <div class="v2-field">
            <label class="v2-field__label" for="su-email"><%= tt('Professional email', 'Professional email', 'البريد الإلكتروني المهني') %></label>
            <input class="v2-field__input" id="su-email" name="email" type="email" required maxlength="320" value="<%= _val(_form.email) %>" />
            <span class="v2-field__hint"><%= tt('Use an institutional or work email if possible.', 'Use an institutional or work email if possible.', 'يفضّل استخدام بريد جهة العمل.') %></span>
          </div>

          <div class="v2-field">
            <label class="v2-field__label" for="su-pw"><%= tt('Password', 'Password', 'كلمة المرور') %></label>
            <input class="v2-field__input" id="su-pw" name="password" type="password" minlength="8" required />
            <span class="v2-field__hint"><%= tt('At least 8 characters.', 'At least 8 characters.', '٨ أحرف على الأقل.') %></span>
          </div>

          <div class="v2-field">
            <label class="v2-field__label" for="su-phone"><%= tt('Phone (WhatsApp)', 'Phone (WhatsApp)', 'الهاتف (واتساب)') %></label>
            <input class="v2-field__input" id="su-phone" name="phone" type="tel" required maxlength="30" placeholder="+201012345678" value="<%= _val(_form.phone) %>" />
          </div>

          <div class="v2-field-row">
            <div class="v2-field">
              <label class="v2-field__label" for="su-country"><%= tt('Country', 'Country', 'الدولة') %></label>
              <select class="v2-field__select" id="su-country" name="country_code" required>
                <option value="">— <%= tt('select', 'select', 'اختر') %> —</option>
                <% ['EG','SA','AE','KW','QA','BH','OM'].forEach(function(cc){
                     var labels = { EG:tt('Egypt', 'Egypt', 'مصر'), SA:tt('Saudi Arabia', 'Saudi Arabia', 'السعودية'), AE:tt('UAE', 'UAE', 'الإمارات'), KW:tt('Kuwait', 'Kuwait', 'الكويت'), QA:tt('Qatar', 'Qatar', 'قطر'), BH:tt('Bahrain', 'Bahrain', 'البحرين'), OM:tt('Oman', 'Oman', 'عُمان') };
                %>
                  <option value="<%= cc %>" <%= String(_form.country_code || '') === cc ? 'selected' : '' %>><%= labels[cc] %></option>
                <% }); %>
              </select>
            </div>
            <div class="v2-field">
              <label class="v2-field__label" for="su-dob"><%= tt('Date of birth', 'Date of birth', 'تاريخ الميلاد') %></label>
              <input class="v2-field__input" id="su-dob" name="date_of_birth" type="date" value="<%= _val(_form.date_of_birth) %>" />
            </div>
          </div>

          <div class="v2-field">
            <label class="v2-field__label" for="su-gender"><%= tt('Gender — optional', 'Gender — optional', 'الجنس — اختياري') %></label>
            <select class="v2-field__select" id="su-gender" name="gender">
              <option value=""><%= tt('Prefer not to say', 'Prefer not to say', 'أفضّل عدم الإجابة') %></option>
              <option value="m" <%= _form.gender === 'm' ? 'selected' : '' %>><%= tt('Male', 'Male', 'ذكر') %></option>
              <option value="f" <%= _form.gender === 'f' ? 'selected' : '' %>><%= tt('Female', 'Female', 'أنثى') %></option>
              <option value="other" <%= _form.gender === 'other' ? 'selected' : '' %>><%= tt('Other', 'Other', 'آخر') %></option>
            </select>
          </div>

          <div class="v2-field">
            <label class="v2-field__label" for="su-natid"><%= tt('National ID', 'National ID', 'الرقم القومي') %></label>
            <input class="v2-field__input" id="su-natid" name="national_id" type="text" required maxlength="30" autocomplete="off" value="<%= _val(_form.national_id) %>" />
            <p class="v2-privacy-note"><%= tt('Stored encrypted at rest; visible only to verified Tashkheesa admins for credentialing. Never shown in UI or logs.', 'Stored encrypted at rest; visible only to verified Tashkheesa admins for credentialing. Never shown in UI or logs.', 'يُخزَّن مشفّراً ولا يظهر إلا لمسؤولي تشخيصة المعتمدين لأغراض التحقق. لا يظهر في الواجهات أو السجلات.') %></p>
          </div>

          <div class="v2-step-actions">
            <span></span>
            <button type="button" class="v2-btn v2-btn--primary" data-action="next-step"><%= tt('Continue → Step 2', 'Continue → Step 2', 'متابعة → الخطوة 2') %></button>
          </div>
        </fieldset>

        <!-- ═════════════ STEP 2 — Credentials & experience ═════════════ -->
        <fieldset class="v2-step" data-step="2" hidden>
          <legend class="v2-auth__title"><%= tt('Step 2 of 3 · Credentials & experience', 'Step 2 of 3 · Credentials & experience', 'الخطوة 2 من 3 · الاعتماد والخبرة') %></legend>

          <div class="v2-field">
            <label class="v2-field__label" for="su-spec"><%= tt('Primary specialty', 'Primary specialty', 'التخصص الرئيسي') %></label>
            <select class="v2-field__select" id="su-spec" name="specialty_id" required>
              <option value="">— <%= tt('select', 'select', 'اختر') %> —</option>
              <% _specialties.forEach(function(s){ %>
                <option value="<%= s.id %>" <%= String(_form.specialty_id || '') === String(s.id) ? 'selected' : '' %>><%= _isAr && s.name_ar ? s.name_ar : s.name %></option>
              <% }); %>
            </select>
          </div>

          <div class="v2-fieldgroup">
            <div class="v2-fieldgroup-title"><%= tt('Secondary specialties — optional, max 4', 'Secondary specialties — optional, max 4', 'تخصصات إضافية — اختيارية، حد أقصى 4') %></div>
            <fieldset class="v2-checkgrid">
              <% _specialties.forEach(function(s){ %>
                <label>
                  <input type="checkbox" name="secondary_specialty_ids[]" value="<%= s.id %>" <%= _has(_form.secondary_specialty_ids, s.id) ? 'checked' : '' %> />
                  <span><%= _isAr && s.name_ar ? s.name_ar : s.name %></span>
                </label>
              <% }); %>
            </fieldset>
          </div>

          <div class="v2-fieldgroup">
            <div class="v2-fieldgroup-title"><%= tt('Sub-specialties — optional, max 8', 'Sub-specialties — optional, max 8', 'تخصصات فرعية — اختيارية، حد أقصى 8') %></div>
            <div data-repeater="sub_specialties" data-max="8" data-fields="text" id="su-subspec-repeater">
              <% (Array.isArray(_form.sub_specialties) ? _form.sub_specialties : []).forEach(function(v){ %>
                <div class="v2-repeater-row">
                  <input class="v2-field__input" type="text" name="sub_specialties[]" maxlength="100" value="<%= _val(v) %>" />
                  <button type="button" class="v2-btn v2-repeater-remove">×</button>
                </div>
              <% }); %>
            </div>
            <button type="button" class="v2-btn" data-repeater-add="sub_specialties">+ <%= tt('Add sub-specialty', 'Add sub-specialty', 'إضافة تخصص فرعي') %></button>
          </div>

          <div class="v2-field-row">
            <div class="v2-field">
              <label class="v2-field__label" for="su-license"><%= tt('Medical license number', 'Medical license number', 'رقم الترخيص الطبي') %></label>
              <input class="v2-field__input" id="su-license" name="medical_license_number" required maxlength="100" value="<%= _val(_form.medical_license_number) %>" />
            </div>
            <div class="v2-field">
              <label class="v2-field__label" for="su-license-country"><%= tt('License country', 'License country', 'دولة الترخيص') %></label>
              <select class="v2-field__select" id="su-license-country" name="license_country" required>
                <option value="">— <%= tt('select', 'select', 'اختر') %> —</option>
                <% ['EG','SA','AE','KW','QA','BH','OM'].forEach(function(cc){
                     var labels = { EG:tt('Egypt', 'Egypt', 'مصر'), SA:tt('Saudi Arabia', 'Saudi Arabia', 'السعودية'), AE:tt('UAE', 'UAE', 'الإمارات'), KW:tt('Kuwait', 'Kuwait', 'الكويت'), QA:tt('Qatar', 'Qatar', 'قطر'), BH:tt('Bahrain', 'Bahrain', 'البحرين'), OM:tt('Oman', 'Oman', 'عُمان') };
                %>
                  <option value="<%= cc %>" <%= String(_form.license_country || '') === cc ? 'selected' : '' %>><%= labels[cc] %></option>
                <% }); %>
              </select>
            </div>
          </div>

          <div class="v2-field-row">
            <div class="v2-field">
              <label class="v2-field__label" for="su-school"><%= tt('Medical school', 'Medical school', 'الكلية الطبية') %></label>
              <input class="v2-field__input" id="su-school" name="medical_school" required maxlength="200" value="<%= _val(_form.medical_school) %>" />
            </div>
            <div class="v2-field">
              <label class="v2-field__label" for="su-grad"><%= tt('Graduation year', 'Graduation year', 'سنة التخرج') %></label>
              <input class="v2-field__input" id="su-grad" name="graduation_year" type="number" required min="1950" max="<%= new Date().getUTCFullYear() %>" value="<%= _val(_form.graduation_year) %>" />
            </div>
            <div class="v2-field">
              <label class="v2-field__label" for="su-yrs"><%= tt('Years of experience', 'Years of experience', 'سنوات الخبرة') %></label>
              <input class="v2-field__input" id="su-yrs" name="years_of_experience" type="number" required min="0" max="60" value="<%= _val(_form.years_of_experience) %>" />
            </div>
          </div>

          <div class="v2-fieldgroup">
            <div class="v2-fieldgroup-title"><%= tt('Certifications — optional, max 10', 'Certifications — optional, max 10', 'الشهادات — اختيارية، حد أقصى 10') %></div>
            <div data-repeater="certifications" data-max="10" data-fields="name,body,year" id="su-certs-repeater">
              <% (Array.isArray(_form.certifications) ? _form.certifications : []).forEach(function(c, i){ %>
                <div class="v2-repeater-row">
                  <input class="v2-field__input" type="text" name="certifications[<%= i %>][name]" placeholder="<%= tt('Certification name', 'Certification name', 'اسم الشهادة') %>" maxlength="200" value="<%= _val(c && c.name) %>" />
                  <input class="v2-field__input" type="text" name="certifications[<%= i %>][body]" placeholder="<%= tt('Issuing body', 'Issuing body', 'الجهة المانحة') %>" maxlength="200" value="<%= _val(c && c.body) %>" />
                  <input class="v2-field__input" type="number" name="certifications[<%= i %>][year]" placeholder="<%= tt('Year', 'Year', 'السنة') %>" value="<%= _val(c && c.year) %>" />
                  <button type="button" class="v2-btn v2-repeater-remove">×</button>
                </div>
              <% }); %>
            </div>
            <button type="button" class="v2-btn" data-repeater-add="certifications">+ <%= tt('Add certification', 'Add certification', 'إضافة شهادة') %></button>
          </div>

          <div class="v2-fieldgroup">
            <div class="v2-fieldgroup-title"><%= tt('Hospital / clinic affiliations — optional, max 10', 'Hospital / clinic affiliations — optional, max 10', 'الجهات والانتسابات — اختيارية، حد أقصى 10') %></div>
            <div data-repeater="affiliations" data-max="10" data-fields="name,role,year" id="su-affil-repeater">
              <% (Array.isArray(_form.affiliations) ? _form.affiliations : []).forEach(function(a, i){ %>
                <div class="v2-repeater-row">
                  <input class="v2-field__input" type="text" name="affiliations[<%= i %>][name]" placeholder="<%= tt('Institution', 'Institution', 'الجهة') %>" maxlength="200" value="<%= _val(a && a.name) %>" />
                  <input class="v2-field__input" type="text" name="affiliations[<%= i %>][role]" placeholder="<%= tt('Role', 'Role', 'الدور') %>" maxlength="200" value="<%= _val(a && a.role) %>" />
                  <input class="v2-field__input" type="number" name="affiliations[<%= i %>][year]" placeholder="<%= tt('From year', 'From year', 'من سنة') %>" value="<%= _val(a && a.year) %>" />
                  <button type="button" class="v2-btn v2-repeater-remove">×</button>
                </div>
              <% }); %>
            </div>
            <button type="button" class="v2-btn" data-repeater-add="affiliations">+ <%= tt('Add affiliation', 'Add affiliation', 'إضافة انتساب') %></button>
          </div>

          <div class="v2-fieldgroup">
            <div class="v2-fieldgroup-title"><%= tt('Spoken languages', 'Spoken languages', 'اللغات') %></div>
            <fieldset class="v2-checkgrid">
              <% [['en','English','الإنجليزية'],['ar','العربية','العربية'],['fr','French','الفرنسية'],['de','German','الألمانية'],['es','Spanish','الإسبانية'],['it','Italian','الإيطالية'],['tr','Turkish','التركية']].forEach(function(L){
                   var checked = _has(_form.spoken_languages, L[0]) || (!_form.spoken_languages && (L[0] === 'en' || L[0] === 'ar'));
              %>
                <label>
                  <input type="checkbox" name="spoken_languages[]" value="<%= L[0] %>" <%= checked ? 'checked' : '' %> />
                  <span><%= _isAr ? L[2] : L[1] %></span>
                </label>
              <% }); %>
            </fieldset>
          </div>

          <div class="v2-step-actions">
            <button type="button" class="v2-btn" data-action="prev-step">← <%= tt('Back', 'Back', 'رجوع') %></button>
            <button type="button" class="v2-btn v2-btn--primary" data-action="next-step"><%= tt('Continue → Step 3', 'Continue → Step 3', 'متابعة → الخطوة 3') %></button>
          </div>
        </fieldset>

        <!-- ═════════════ STEP 3 — Service preferences & consent ═════════════ -->
        <fieldset class="v2-step" data-step="3" hidden>
          <legend class="v2-auth__title"><%= tt('Step 3 of 3 · Service preferences & consent', 'Step 3 of 3 · Service preferences & consent', 'الخطوة 3 من 3 · التفضيلات والموافقة') %></legend>

          <div class="v2-fieldgroup">
            <div class="v2-fieldgroup-title"><%= tt('Services I will review', 'Services I will review', 'الخدمات التي أستعرضها') %></div>
            <p class="v2-field__hint" data-services-empty hidden><%= tt('Pick a primary specialty in Step 2 to see available services.', 'Pick a primary specialty in Step 2 to see available services.', 'اختر التخصص الرئيسي في الخطوة 2 لعرض الخدمات المتاحة.') %></p>
            <% _servicesBySpecialty.forEach(function(group){ %>
              <fieldset class="v2-checkgrid v2-services-group" data-specialty="<%= group.specialtyId %>" hidden>
                <legend><strong><%= _isAr && group.specialtyNameAr ? group.specialtyNameAr : group.specialtyName %></strong></legend>
                <% (group.services || []).forEach(function(svc){ %>
                  <label>
                    <input type="checkbox" name="service_ids[]" value="<%= svc.id %>" <%= _has(_form.service_ids, svc.id) ? 'checked' : '' %> />
                    <span><%= svc.name %></span>
                  </label>
                <% }); %>
              </fieldset>
            <% }); %>
          </div>

          <div class="v2-fieldgroup">
            <div class="v2-fieldgroup-title"><%= tt('SLA tiers I can support', 'SLA tiers I can support', 'مستويات SLA المدعومة') %></div>
            <fieldset class="v2-checkgrid">
              <label><input type="checkbox" name="sla_tiers_supported[]" value="standard" <%= (!_form.sla_tiers_supported || _has(_form.sla_tiers_supported,'standard')) ? 'checked' : '' %> /> <span><%= tt('Standard (48h)', 'Standard (48h)', 'عادي (48 ساعة)') %></span></label>
              <label><input type="checkbox" name="sla_tiers_supported[]" value="vip" <%= _has(_form.sla_tiers_supported,'vip') ? 'checked' : '' %> /> <span><%= tt('VIP (18h)', 'VIP (18h)', 'VIP (18 ساعة)') %></span></label>
              <label><input type="checkbox" name="sla_tiers_supported[]" value="urgent" <%= _has(_form.sla_tiers_supported,'urgent') ? 'checked' : '' %> /> <span><%= tt('Urgent (4h)', 'Urgent (4h)', 'عاجل (4 ساعات)') %></span></label>
            </fieldset>
          </div>

          <div class="v2-fieldgroup">
            <div class="v2-fieldgroup-title"><%= tt('Professional bio', 'Professional bio', 'السيرة المهنية') %></div>
            <div class="v2-field-row">
              <div class="v2-field">
                <label class="v2-field__label" for="su-bio"><%= tt('Bio (English)', 'Bio (English)', 'السيرة (إنجليزي)') %></label>
                <textarea class="v2-field__textarea" id="su-bio" name="bio" rows="4" maxlength="2000"><%= _val(_form.bio) %></textarea>
              </div>
              <div class="v2-field">
                <label class="v2-field__label" for="su-bio-ar"><%= tt('Bio (Arabic)', 'Bio (Arabic)', 'السيرة (عربي)') %></label>
                <textarea class="v2-field__textarea" id="su-bio-ar" name="bio_ar" rows="4" maxlength="2000" dir="rtl"><%= _val(_form.bio_ar) %></textarea>
              </div>
            </div>
          </div>

          <div class="v2-fieldgroup">
            <div class="v2-fieldgroup-title"><%= tt('Consents', 'Consents', 'الموافقات') %></div>
            <fieldset class="v2-consents">
              <label><input type="checkbox" name="consent_accuracy" required /> <span><%= tt('I confirm all the information I provided is accurate and complete.', 'I confirm all the information I provided is accurate and complete.', 'أؤكد أن جميع المعلومات المقدّمة صحيحة وكاملة.') %></span></label>
              <label><input type="checkbox" name="consent_terms" required /> <span><%= tt('I agree to the', 'I agree to the', 'أوافق على') %> <a href="/legal/terms" target="_blank"><%= tt('Specialist Terms', 'Specialist Terms', 'شروط الاستشاريين') %></a> <%= tt('and', 'and', 'و') %> <a href="/legal/code-of-conduct" target="_blank"><%= tt('Code of Conduct', 'Code of Conduct', 'ميثاق السلوك المهني') %></a>.</span></label>
              <label><input type="checkbox" name="consent_audit_log" required /> <span><%= tt('I consent to all PHI access being audit-logged for compliance.', 'I consent to all PHI access being audit-logged for compliance.', 'أوافق على تسجيل كل وصول لبيانات المرضى لأغراض الامتثال.') %></span></label>
              <label><input type="checkbox" name="consent_pii" required /> <span><%= tt('I consent to my National ID being stored encrypted, used solely for credentialing.', 'I consent to my National ID being stored encrypted, used solely for credentialing.', 'أوافق على تخزين رقمي القومي مشفّراً واستخدامه فقط لأغراض التحقق.') %></span></label>
            </fieldset>
          </div>

          <div class="v2-step-actions">
            <button type="button" class="v2-btn" data-action="prev-step">← <%= tt('Back', 'Back', 'رجوع') %></button>
            <button type="submit" class="v2-btn v2-btn--primary v2-btn--lg"><%= tt('Submit application', 'Submit application', 'إرسال الطلب') %></button>
          </div>
        </fieldset>

        <div style="text-align:center;font-size:13px;color:var(--v2-muted);margin-block-start:20px;">
          <%= tt('Already approved?', 'Already approved?', 'تمّت الموافقة على طلبك من قبل؟') %>
          <a href="/doctor/login" style="color:var(--v2-brand);font-weight:600;text-decoration:none;"><%= tt('Sign in', 'Sign in', 'سجِّل الدخول') %></a>
        </div>
      </form>
    </div>
  </div>

  <!-- ═════════════ Step transitions + repeater + service-group toggle ═════════════ -->
  <script<%- __nonceAttr %>>
    (function(){
      var form = document.getElementById('doctor-signup-form');
      if (!form) return;
      var steps = form.querySelectorAll('fieldset[data-step]');
      var pips = form.querySelectorAll('[data-step-pip]');
      var current = 1;

      function setStep(n) {
        if (n < 1) n = 1; if (n > 3) n = 3;
        steps.forEach(function(s){
          s.hidden = (Number(s.dataset.step) !== n);
        });
        pips.forEach(function(p){
          var i = Number(p.dataset.stepPip);
          p.classList.remove('is-active','is-done');
          if (i === n) p.classList.add('is-active');
          else if (i < n) p.classList.add('is-done');
        });
        current = n;
        try { window.scrollTo({ top: 0, behavior: 'smooth' }); } catch (_) {}
      }

      function stepValid(n) {
        var step = form.querySelector('fieldset[data-step="' + n + '"]');
        if (!step) return true;
        var requiredInputs = step.querySelectorAll('[required]');
        for (var i = 0; i < requiredInputs.length; i++) {
          var el = requiredInputs[i];
          if (el.disabled || (el.offsetParent === null && el.type !== 'checkbox')) continue;
          if (typeof el.checkValidity === 'function' && !el.checkValidity()) {
            if (typeof el.reportValidity === 'function') el.reportValidity();
            return false;
          }
        }
        return true;
      }

      function revealServicesForPickedSpecialty() {
        var sel = form.querySelector('[name="specialty_id"]');
        var picked = sel ? sel.value : '';
        var anyShown = false;
        form.querySelectorAll('.v2-services-group').forEach(function(g){
          var match = g.dataset.specialty === picked;
          g.hidden = !match;
          if (match) anyShown = true;
        });
        var emptyMsg = form.querySelector('[data-services-empty]');
        if (emptyMsg) emptyMsg.hidden = anyShown;
      }

      form.addEventListener('click', function(e){
        var btn = e.target && e.target.closest ? e.target.closest('[data-action]') : null;
        if (!btn) return;
        var action = btn.dataset.action;
        if (action === 'next-step') {
          if (!stepValid(current)) return;
          if (current === 2) revealServicesForPickedSpecialty();
          setStep(current + 1);
        } else if (action === 'prev-step') {
          setStep(current - 1);
        }
      });

      // Repeater widget. data-repeater="<key>", data-max="<n>",
      // data-fields="text" for a single text input or "name,body,year"
      // for object-shaped repeaters.
      function addRepeaterRow(key) {
        var container = form.querySelector('[data-repeater="' + key + '"]');
        if (!container) return;
        var max = Number(container.dataset.max) || 99;
        if (container.querySelectorAll('.v2-repeater-row').length >= max) return;
        var fields = (container.dataset.fields || 'text').split(',');
        var row = document.createElement('div');
        row.className = 'v2-repeater-row';
        var i = container.querySelectorAll('.v2-repeater-row').length;
        if (fields.length === 1 && fields[0] === 'text') {
          row.innerHTML =
            '<input class="v2-field__input" type="text" name="' + key + '[]" maxlength="100" />' +
            '<button type="button" class="v2-btn v2-repeater-remove">×</button>';
        } else {
          var inputs = fields.map(function(f){
            var typeAttr = (f === 'year') ? 'number' : 'text';
            return '<input class="v2-field__input" type="' + typeAttr + '" name="' + key + '[' + i + '][' + f + ']" maxlength="200" placeholder="' + f + '" />';
          }).join('');
          row.innerHTML = inputs + '<button type="button" class="v2-btn v2-repeater-remove">×</button>';
        }
        container.appendChild(row);
      }

      form.querySelectorAll('[data-repeater-add]').forEach(function(btn){
        btn.addEventListener('click', function(){
          addRepeaterRow(btn.dataset.repeaterAdd);
        });
      });

      form.addEventListener('click', function(e){
        if (e.target && e.target.classList && e.target.classList.contains('v2-repeater-remove')) {
          var row = e.target.closest('.v2-repeater-row');
          if (row && row.parentNode) row.parentNode.removeChild(row);
        }
      });

      // Initial state — show step 1.
      setStep(1);
    })();
  </script>
</body>
</html>
