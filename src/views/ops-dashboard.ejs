<%
  // CSP nonce — emit on inline <script> tags so they survive strict-CSP
  // without 'unsafe-inline' (Theme 2 Sub-issue B).
  var __nonce = String(
    (typeof cspNonce !== 'undefined' && cspNonce) ||
    (typeof locals !== 'undefined' && locals && (locals.cspNonce || locals.csp_nonce || locals.nonce)) ||
    ''
  );
  var __nonceAttr = __nonce ? (' nonce="' + __nonce + '"') : '';

  // Defensive guards — these objects are always supplied by gatherDashboardStats(),
  // but keep the legacy fallbacks so a partial render never throws.
  var _ph = (typeof paymobHealth !== 'undefined' && paymobHealth) ? paymobHealth
            : { lastIntentionAgo: null, lastWebhookAgo: null, hmacFailures24h: 0 };
  var _wa = (typeof whatsappHealth !== 'undefined' && whatsappHealth) ? whatsappHealth
            : { token401Last15min: 0, sendErrorsLast24h: 0 };
  var _w  = (typeof phase7Widgets !== 'undefined' && phase7Widgets) ? phase7Widgets
            : { notifQueueDepth: 0, notifOldestStuckAgo: null, notifStatusSplit: [], cronWidget: [],
                errorRate: { currentHour: 0, baseline: 0 }, lastCriticalAlert: null,
                resend: { envPresent: false, lastSentAgo: null } };
  var _att = (typeof attention !== 'undefined' && Array.isArray(attention)) ? attention : [];

  // state → presentation maps (kept in sync with the JS poller below)
  var DOT = { live: 'run', stale: 'stale', down: 'dead', off: 'off' };
  var AGO = { live: 'good', stale: 'warn', down: 'err', off: 'good' };
%><!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tashkheesa Ops</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500;600&family=Space+Grotesk:wght@500;600;700&display=swap');
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #0a0a0b; color: #e7e7ea; font-family: 'IBM Plex Mono', ui-monospace, monospace; padding: 22px; font-size: 13px; }
    a { color: #2dd4bf; text-decoration: none; }
    a:hover { text-decoration: underline; }

    .a { max-width: 1320px; margin: 0 auto; background: #0d0d0f; border: 1px solid #1c1c20; border-radius: 14px; overflow: hidden; }

    /* ── Top bar ── */
    .a-top { display: flex; align-items: center; gap: 16px; padding: 16px 24px; border-bottom: 1px solid #1c1c20; flex-wrap: wrap; }
    .a-logo { font-family: 'Space Grotesk', sans-serif; font-size: 17px; font-weight: 700; color: #fff; letter-spacing: -0.01em; }
    .a-logo span { color: #2dd4bf; }
    .a-live { display: inline-flex; align-items: center; gap: 7px; font-size: 11px; color: #6ee7b7; background: #06251d; padding: 4px 10px; border-radius: 20px; border: 1px solid #0f4035; letter-spacing: 0.04em; }
    .a-live .dot { width: 6px; height: 6px; border-radius: 50%; background: #34d399; animation: pulse 2s infinite; }
    .a-live.live-err { color: #fcd34d; background: #251c06; border-color: #40350f; }
    .a-live.live-err .dot { background: #fbbf24; animation: none; }
    .a-live.live-loading { opacity: 0.75; }
    @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.35; } }
    .a-meta { margin-left: auto; display: flex; gap: 18px; font-size: 11px; color: #6b6b73; flex-wrap: wrap; }
    .a-meta b { color: #b8b8c0; font-weight: 500; }
    .a-meta .mode-prod { color: #34d399; }
    .a-meta .mode-dev { color: #fbbf24; }
    .a-meta .sla-primary { color: #34d399; }
    .a-meta .sla-passive { color: #6b6b73; }
    .a-refresh { font-size: 11px; color: #6b6b73; }
    .a-logout { font-size: 11px; color: #6b6b73; }
    .a-logout:hover { color: #f87171; }

    /* ── Health rail ── */
    .a-rail { display: grid; grid-template-columns: repeat(6, 1fr); border-bottom: 1px solid #1c1c20; }
    .a-rail .cell { padding: 14px 18px; border-right: 1px solid #1c1c20; border-bottom: 1px solid #1c1c20; }
    .a-rail .cell:nth-child(6n) { border-right: none; }
    .a-rail .lbl { font-size: 10px; color: #6b6b73; text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 6px; }
    .a-rail .val { font-size: 19px; font-weight: 600; color: #e7e7ea; font-variant-numeric: tabular-nums; }
    .a-rail .val.ok { color: #34d399; }
    .a-rail .val.bad { color: #f87171; }
    .a-rail .sub { font-size: 10px; color: #6b6b73; margin-top: 3px; }

    /* ── Body 2-col ── */
    .a-body { display: grid; grid-template-columns: 1.4fr 1fr; }
    .a-col { padding: 20px 24px; min-width: 0; }
    .a-col + .a-col { border-left: 1px solid #1c1c20; }
    .a-h { font-size: 11px; color: #8a8a93; text-transform: uppercase; letter-spacing: 0.1em; margin: 22px 0 14px; display: flex; align-items: center; gap: 8px; }
    .a-h:first-child { margin-top: 0; }
    .a-h .pip { width: 5px; height: 5px; border-radius: 50%; background: #2dd4bf; flex: none; }
    .a-h .tail { margin-left: auto; font-size: 10px; color: #6b6b73; letter-spacing: 0; text-transform: none; }

    /* ── Metric strips ── */
    .a-metrics { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: #1c1c20; border: 1px solid #1c1c20; border-radius: 8px; overflow: hidden; }
    .a-metrics.cols-3 { grid-template-columns: repeat(3, 1fr); }
    .a-metric { background: #101013; padding: 13px 14px; }
    .a-metric .m-lbl { font-size: 10px; color: #6b6b73; text-transform: uppercase; letter-spacing: 0.06em; }
    .a-metric .m-val { font-family: 'Space Grotesk', sans-serif; font-size: 22px; font-weight: 600; color: #fff; margin-top: 5px; font-variant-numeric: tabular-nums; }
    .a-metric .m-val.green { color: #34d399; }
    .a-metric .m-val a { color: inherit; }
    .a-metric .m-sub { font-size: 10px; color: #6b6b73; margin-top: 2px; }

    /* ── Workers ── */
    .a-agents { display: flex; flex-direction: column; gap: 1px; background: #1c1c20; border: 1px solid #1c1c20; border-radius: 8px; overflow: hidden; }
    .a-agent { background: #101013; padding: 11px 14px; display: grid; grid-template-columns: 14px 1fr auto; align-items: center; gap: 12px; }
    .a-agent .st { width: 8px; height: 8px; border-radius: 50%; }
    .st.run { background: #34d399; } .st.stale { background: #fbbf24; } .st.dead { background: #f87171; } .st.off { background: #4b4b52; }
    .a-agent .nm { font-size: 12px; color: #d4d4da; font-weight: 500; }
    .a-agent .tk { font-size: 10px; color: #6b6b73; margin-top: 2px; }
    .a-agent .ago-wrap { text-align: right; display: flex; flex-direction: column; align-items: flex-end; gap: 3px; }
    .a-agent .ago { font-size: 11px; }
    .ago.good { color: #6b7280; } .ago.warn { color: #fbbf24; } .ago.err { color: #f87171; }
    .a-agent .acost { font-size: 9px; color: #4b4b52; }
    .toggle-btn { font-size: 9px; cursor: pointer; border: 1px solid #2a2a2e; border-radius: 4px; padding: 1px 6px; background: none; color: #6b6b73; }
    .toggle-btn.on { color: #34d399; border-color: #1f4d3c; }
    .toggle-btn.off { color: #f87171; border-color: #4d1f1f; }

    /* ── Needs attention ── */
    .a-alert { background: #1a0e0e; border: 1px solid #3d1a1a; border-radius: 8px; padding: 13px 15px; margin-bottom: 10px; display: flex; gap: 11px; align-items: flex-start; }
    .a-alert.stale { background: #1a150a; border-color: #3d3010; }
    .a-alert .ic { color: #f87171; font-size: 14px; line-height: 1; margin-top: 1px; }
    .a-alert.stale .ic { color: #fbbf24; }
    .a-alert .at { font-size: 12px; color: #fca5a5; font-weight: 600; }
    .a-alert.stale .at { color: #fcd34d; }
    .a-alert .ad { font-size: 11px; color: #9a6b6b; margin-top: 3px; line-height: 1.4; }
    .a-allclear { background: #06251d; border: 1px solid #0f4035; border-radius: 8px; padding: 13px 15px; font-size: 12px; color: #5a8a7a; }

    /* ── Errors clean / list ── */
    .a-err-clean { background: #06251d; border: 1px solid #0f4035; border-radius: 8px; padding: 16px; text-align: center; }
    .a-err-clean.bad { background: #1a0e0e; border-color: #3d1a1a; }
    .a-err-clean .big { font-family: 'Space Grotesk', sans-serif; font-size: 26px; font-weight: 700; color: #34d399; }
    .a-err-clean.bad .big { color: #f87171; }
    .a-err-clean .cap { font-size: 11px; color: #5a8a7a; margin-top: 4px; }
    .a-err-clean.bad .cap { color: #9a6b6b; }
    .lvl-row { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 10px; }
    .lvl-chip { font-size: 10px; color: #8a8a93; border: 1px solid #1c1c20; border-radius: 6px; padding: 4px 9px; }
    .lvl-chip b { color: #e7e7ea; margin-left: 4px; }
    .err-list { margin-top: 10px; display: flex; flex-direction: column; }
    .err-row { display: flex; align-items: center; gap: 9px; padding: 6px 0; border-bottom: 1px solid #161619; font-size: 11px; }
    .err-row:last-child { border-bottom: none; }
    .err-row .el { font-weight: 700; text-transform: uppercase; min-width: 42px; font-size: 10px; }
    .err-row .em { flex: 1; color: #b8b8c0; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
    .err-row .et { color: #6b6b73; min-width: 64px; text-align: right; }

    /* ── Payments / Paymob / WhatsApp / health cells ── */
    .a-pay { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: #1c1c20; border: 1px solid #1c1c20; border-radius: 8px; overflow: hidden; }
    .a-pay .p { background: #101013; padding: 12px 14px; }
    .a-pay .pl { font-size: 10px; color: #6b6b73; text-transform: uppercase; letter-spacing: 0.05em; }
    .a-pay .pv { font-size: 16px; font-weight: 600; color: #e7e7ea; margin-top: 4px; font-variant-numeric: tabular-nums; }
    .a-pay .pv.ok { color: #34d399; } .a-pay .pv.bad { color: #f87171; } .a-pay .pv.warn { color: #fbbf24; }

    /* ── Pills ── */
    .pills { display: flex; gap: 7px; flex-wrap: wrap; }
    .pill { background: #101013; border: 1px solid #1c1c20; border-radius: 20px; padding: 4px 11px; font-size: 11px; color: #b8b8c0; }
    .pill .count { font-weight: 600; color: #2dd4bf; margin-left: 5px; }
    .pill.failed .count { color: #f87171; }
    .pill.sent .count { color: #34d399; }
    .pill.pending .count { color: #fbbf24; }
    .empty-msg { background: #101013; border: 1px solid #1c1c20; border-radius: 8px; padding: 12px; text-align: center; color: #6b6b73; font-size: 11px; }

    /* ── Recent activity feed ── */
    .feed { background: #101013; border: 1px solid #1c1c20; border-radius: 8px; overflow: hidden; }
    .feed-row { display: flex; align-items: center; gap: 10px; padding: 8px 13px; border-bottom: 1px solid #161619; font-size: 11px; }
    .feed-row:last-child { border-bottom: none; }
    .badge { display: inline-block; font-size: 9px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.4px; padding: 2px 7px; border-radius: 4px; min-width: 58px; text-align: center; }
    .badge-completed, .badge-done, .badge-delivered { background: #06251d; color: #6ee7b7; }
    .badge-breached, .badge-failed { background: #2a1010; color: #fca5a5; }
    .badge-new, .badge-pending, .badge-awaiting_review, .badge-review, .badge-paid { background: #2a1e05; color: #fcd34d; }
    .badge-cancelled, .badge-expired_unpaid { background: #1a1a1e; color: #8a8a93; }
    .feed-detail { flex: 1; color: #b8b8c0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .feed-detail .svc { color: #2dd4bf; }
    .feed-detail .spec { color: #6b6b73; }
    .feed-price { color: #8a8a93; min-width: 70px; text-align: right; }
    .feed-time { color: #4b4b52; min-width: 60px; text-align: right; }

    /* ── Cron cards ── */
    .cron-cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr)); gap: 1px; background: #1c1c20; border: 1px solid #1c1c20; border-radius: 8px; overflow: hidden; }
    .cron-card { background: #101013; padding: 10px 12px; }
    .cron-card .cc-n { font-size: 10px; color: #6b6b73; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .cron-card .cc-v { font-size: 13px; margin-top: 4px; color: #e7e7ea; }
    .cron-card.ok .cc-v { color: #34d399; } .cron-card.warn .cc-v { color: #fbbf24; } .cron-card.error .cc-v { color: #f87171; }

    /* ── Foot ── */
    .a-foot { padding: 20px 24px; border-top: 1px solid #1c1c20; }
    table.sched { width: 100%; border-collapse: collapse; background: #101013; border: 1px solid #1c1c20; border-radius: 8px; overflow: hidden; }
    table.sched th { text-align: left; font-size: 9px; text-transform: uppercase; letter-spacing: 0.06em; color: #6b6b73; padding: 8px 12px; border-bottom: 1px solid #1c1c20; }
    table.sched td { padding: 8px 12px; border-bottom: 1px solid #161619; font-size: 11px; color: #8a8a93; }
    table.sched tr:last-child td { border-bottom: none; }
    table.sched td:first-child { color: #d4d4da; font-weight: 500; }
    .links { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 8px; }
    .links a { background: #101013; border: 1px solid #1c1c20; border-radius: 6px; padding: 7px 13px; font-size: 11px; color: #b8b8c0; }
    .links a:hover { border-color: #2dd4bf; color: #2dd4bf; text-decoration: none; }

    [data-stat] { transition: color 0.15s ease; }

    @media (max-width: 980px) {
      .a-body { grid-template-columns: 1fr; }
      .a-col + .a-col { border-left: none; border-top: 1px solid #1c1c20; }
      .a-rail { grid-template-columns: repeat(3, 1fr); }
      .a-rail .cell:nth-child(6n) { border-right: 1px solid #1c1c20; }
      .a-rail .cell:nth-child(3n) { border-right: none; }
    }
    @media (max-width: 560px) {
      .a-metrics, .a-metrics.cols-3 { grid-template-columns: repeat(2, 1fr); }
      .a-rail { grid-template-columns: repeat(2, 1fr); }
    }
  </style>
</head>
<body>
  <div class="a">

    <!-- ── Top bar ── -->
    <div class="a-top">
      <div class="a-logo">TASHKHEESA<span>·</span>OPS</div>
      <span class="a-live" id="liveStatus" title="Live data — auto-refreshes every 5s"><span class="dot"></span><span id="liveText">LIVE</span></span>
      <div class="a-meta">
        <span>UPTIME <b data-stat="uptime"><%= uptime %></b></span>
        <span>NODE <b><%= nodeVersion %></b></span>
        <% if (gitSha) { %><span>SHA <b><%= typeof gitSha === 'string' ? gitSha.slice(0,7) : '' %></b></span><% } %>
        <span>HEAP <b><span data-stat="heapUsedMb"><%= heapUsedMb %></span>/<span data-stat="heapTotalMb"><%= heapTotalMb %></span>MB</b></span>
        <span>RSS <b><span data-stat="rssMb"><%= rssMb %></span>MB</b></span>
        <span>MODE <b class="<%= mode === 'production' ? 'mode-prod' : 'mode-dev' %>"><%= mode %></b></span>
        <span>SLA <b class="<%= slaMode === 'primary' ? 'sla-primary' : 'sla-passive' %>"><%= slaMode %></b></span>
        <span>CAIRO <b data-stat="cairoTime"><%= cairoTime %></b></span>
      </div>
      <span class="a-refresh">&#8635; 5s</span>
      <a href="/ops/logout" class="a-logout">[logout]</a>
    </div>

    <!-- ── Health rail ── -->
    <div class="a-rail">
      <div class="cell">
        <div class="lbl">Errors 24h</div>
        <div class="val <%= errorsOk ? 'ok' : 'bad' %>" data-color-ok="errorsOk" data-stat="errors24h"><%= errors24h %></div>
        <div class="sub">silent: <span data-stat="silentFailures7d"><%= silentFailures7d %></span></div>
      </div>
      <div class="cell">
        <div class="lbl">SLA breached</div>
        <div class="val <%= slaOk ? 'ok' : 'bad' %>" data-color-ok="slaOk" data-stat="breachedCases"><%= breachedCases %></div>
        <div class="sub">near: <span data-stat="nearBreachCases"><%= nearBreachCases %></span></div>
      </div>
      <div class="cell">
        <div class="lbl">DB pool</div>
        <div class="val <%= dbPoolOk ? 'ok' : 'bad' %>" data-color-ok="dbPoolOk"><span data-stat="dbPoolActive"><%= dbPoolActive %></span>/<span data-stat="dbPoolTotal"><%= dbPoolTotal %></span></div>
        <div class="sub"><span data-stat="dbPoolIdle"><%= dbPoolIdle %></span> idle<% if (dbPoolWaiting > 0) { %> · <span data-stat="dbPoolWaiting"><%= dbPoolWaiting %></span> waiting<% } %></div>
      </div>
      <div class="cell">
        <div class="lbl">Workers live</div>
        <div class="val <%= workersOk ? 'ok' : 'bad' %>" data-color-ok="workersOk"><span data-stat="workersLive"><%= workersLive %></span>/<span data-stat="workersTotal"><%= workersTotal %></span></div>
        <div class="sub" data-stat="workersSubLabel"><%= workersSubLabel %></div>
      </div>
      <div class="cell">
        <div class="lbl">Failed pay</div>
        <div class="val <%= payOk ? 'ok' : 'bad' %>" data-color-ok="payOk" data-stat="failedPayments"><%= failedPayments %></div>
        <div class="sub">hmac: <span data-stat="paymobHealth.hmacFailures24h"><%= _ph.hmacFailures24h %></span></div>
      </div>
      <div class="cell">
        <div class="lbl">Mac mini</div>
        <div class="val <%= macMiniOk ? 'ok' : 'bad' %>" data-color-ok="macMiniOk" data-stat="macMiniStatus.gateway"><%= macMiniStatus.gateway %></div>
        <div class="sub"><% if (macMiniCheckedAgo) { %><span data-stat="macMiniCheckedAgo"><%= macMiniCheckedAgo %></span><% } else { %>unknown<% } %></div>
      </div>
    </div>

    <!-- ── Body ── -->
    <div class="a-body">

      <!-- LEFT -->
      <div class="a-col">
        <div class="a-h"><span class="pip"></span>This month</div>
        <div class="a-metrics">
          <div class="a-metric"><div class="m-lbl">Cases</div><div class="m-val" data-stat="casesThisMonth"><%= casesThisMonth %></div><div class="m-sub"><span data-stat="totalCases"><%= totalCases %></span> all-time</div></div>
          <div class="a-metric"><div class="m-lbl">Completed</div><div class="m-val green" data-stat="completedThisMonth"><%= completedThisMonth %></div><div class="m-sub">avg <span data-stat="avgCompletionHrs" data-fmt="hours"><%= avgCompletionHrs !== null ? avgCompletionHrs + 'h' : '--' %></span></div></div>
          <div class="a-metric"><div class="m-lbl">Revenue</div><div class="m-val" data-stat="revenueThisMonth" data-fmt="int"><%= Number(revenueThisMonth).toLocaleString('en-US') %></div><div class="m-sub">EGP · <span data-stat="revenueAllTime" data-fmt="int"><%= Number(revenueAllTime).toLocaleString('en-US') %></span> all-time</div></div>
          <div class="a-metric"><div class="m-lbl">Patients</div><div class="m-val" data-stat="totalPatients"><%= totalPatients %></div><div class="m-sub"><span data-stat="activeDoctors"><%= activeDoctors %></span>/<span data-stat="totalDoctors"><%= totalDoctors %></span> doctors</div></div>
        </div>

        <div class="a-h"><span class="pip"></span>Today &amp; pipeline</div>
        <div class="a-metrics">
          <div class="a-metric"><div class="m-lbl">Cases today</div><div class="m-val" data-stat="casesToday"><%= casesToday %></div><div class="m-sub"><span data-stat="newPatientsToday"><%= newPatientsToday %></span> new patients</div></div>
          <div class="a-metric"><div class="m-lbl">Revenue today</div><div class="m-val" data-stat="revenueToday" data-fmt="int"><%= Number(revenueToday).toLocaleString('en-US') %></div><div class="m-sub">EGP</div></div>
          <div class="a-metric"><div class="m-lbl">Pending</div><div class="m-val" data-stat="pendingCases"><%= pendingCases %></div><div class="m-sub">awaiting review</div></div>
          <div class="a-metric"><div class="m-lbl">Errors today</div><div class="m-val" data-stat="errorsToday"><a href="/ops/errors"><%= errorsToday %></a></div><div class="m-sub">since 00:00 Cairo</div></div>
        </div>

        <div class="a-h"><span class="pip"></span>Workers — last run <span class="tail">$<span data-stat="totalTokenSpend" data-fmt="fixed2"><%= totalTokenSpend.toFixed(2) %></span> MTD</span></div>
        <div class="a-agents" id="agentsList">
          <% agents.forEach(function(a) { %>
          <div class="a-agent" data-agent="<%= a.agent_name %>">
            <span class="st <%= DOT[a.state] || 'off' %>" data-agent-dot></span>
            <div>
              <div class="nm"><%= a.agent_name %></div>
              <div class="tk" data-agent-task><%= a.current_task %></div>
            </div>
            <div class="ago-wrap">
              <span class="ago <%= AGO[a.state] || 'good' %>" data-agent-ago><%= a.state === 'off' ? 'off' : a.last_seen %></span>
              <span class="acost"><span data-agent-tokens><%= a.tokens_used_mtd.toLocaleString('en-US') %></span> tok · $<span data-agent-cost><%= a.token_cost_mtd.toFixed(2) %></span></span>
              <form method="POST" action="/ops/agent/toggle" style="margin:0"><%- (typeof csrfField === 'function') ? csrfField() : '' %><input type="hidden" name="agent_name" value="<%= a.agent_name %>"><button type="submit" class="toggle-btn <%= a.enabled ? 'on' : 'off' %>"><%= a.enabled ? 'on' : 'off' %></button></form>
            </div>
          </div>
          <% }); %>
        </div>

        <div class="a-h"><span class="pip"></span>Recent activity</div>
        <div id="recentOrders">
          <% if (recentOrders.length === 0) { %>
            <div class="empty-msg">No orders yet.</div>
          <% } else { %>
            <div class="feed">
              <% recentOrders.forEach(function(o) { %>
                <div class="feed-row">
                  <span class="badge badge-<%= o.status %>"><%= o.status %></span>
                  <span class="feed-detail"><%= o.patient_name %> &mdash; <span class="svc"><%= o.service_name %></span><% if (o.specialty_name) { %><span class="spec"> / <%= o.specialty_name %></span><% } %></span>
                  <span class="feed-price"><% if (o.price) { %>EGP <%= Number(o.price).toLocaleString('en-US') %><% } else { %>&mdash;<% } %></span>
                  <span class="feed-time"><%= o.time_ago %></span>
                </div>
              <% }); %>
            </div>
          <% } %>
        </div>
      </div>

      <!-- RIGHT -->
      <div class="a-col">
        <div class="a-h"><span class="pip"></span>Needs attention</div>
        <div id="attention">
          <% if (_att.length === 0) { %>
            <div class="a-allclear">All clear — no stale/down workers, no uncleared critical alerts.</div>
          <% } else { %>
            <% _att.forEach(function(it) { %>
              <div class="a-alert<%= it.severity === 'stale' ? ' stale' : '' %>">
                <span class="ic">&#9650;</span>
                <div><div class="at"><%= it.title %></div><div class="ad"><%= it.detail %></div></div>
              </div>
            <% }); %>
          <% } %>
        </div>

        <div class="a-h"><span class="pip"></span>Errors (24h) <span class="tail"><a href="/ops/errors">view all &rarr;</a></span></div>
        <div class="a-err-clean<%= errorsOk ? '' : ' bad' %>" id="errClean">
          <div class="big" data-stat="errors24h"><%= errors24h %></div>
          <div class="cap" id="errCleanCap"><%= errorsOk ? 'No errors or silent failures · production clean' : 'errors logged in last 24h' %></div>
        </div>
        <div class="lvl-row" id="errLevels">
          <% errorsByLevel.forEach(function(e) { %>
            <a href="/ops/errors?level=<%= e.level %>" class="lvl-chip"><%= e.level %><b><%= e.c %></b></a>
          <% }); %>
          <a href="/ops/silent-failures" class="lvl-chip">silent 7d<b data-stat="silentFailures7d"><%= silentFailures7d %></b></a>
        </div>
        <div class="err-list" id="recentErrors">
          <% (recentErrors || []).forEach(function(e) {
            var lvlColor = e.level === 'fatal' ? '#ff6b6b' : e.level === 'error' ? '#f87171' : e.level === 'warn' ? '#fbbf24' : '#2dd4bf';
            var msg = e.message ? (e.message.length > 80 ? e.message.slice(0, 80) + '…' : e.message) : '(no message)';
          %>
            <div class="err-row">
              <span class="el" style="color:<%= lvlColor %>"><%= e.level %></span>
              <a href="/ops/errors/<%= e.id %>" class="em" title="<%= e.message || '' %>"><%= msg %></a>
              <span class="et"><%= e.time_ago %></span>
            </div>
          <% }); %>
        </div>

        <div class="a-h"><span class="pip"></span>Payments</div>
        <div class="a-pay">
          <div class="p"><div class="pl">Unpaid</div><div class="pv" data-stat="unpaidOrders"><%= unpaidOrders %></div></div>
          <div class="p"><div class="pl">Failed</div><div class="pv <%= payOk ? 'ok' : 'bad' %>" data-color-ok="payOk" data-stat="failedPayments"><%= failedPayments %></div></div>
          <div class="p"><div class="pl">Last webhook</div><div class="pv" style="font-size:12px" data-stat="paymobHealth.lastWebhookAgo" data-fmt="ago"><%= _ph.lastWebhookAgo || 'never' %></div></div>
        </div>

        <div class="a-h"><span class="pip"></span>Paymob &amp; WhatsApp</div>
        <div class="a-pay">
          <div class="p"><div class="pl">Last intention</div><div class="pv" style="font-size:12px" data-stat="paymobHealth.lastIntentionAgo" data-fmt="ago"><%= _ph.lastIntentionAgo || 'never' %></div></div>
          <div class="p"><div class="pl">WA 401s (15m)</div><div class="pv" data-stat="whatsappHealth.token401Last15min"><%= _wa.token401Last15min %></div></div>
          <div class="p"><div class="pl">WA errors (24h)</div><div class="pv" data-stat="whatsappHealth.sendErrorsLast24h"><%= _wa.sendErrorsLast24h %></div></div>
        </div>

        <div class="a-h"><span class="pip"></span>Notification &amp; cron health</div>
        <div class="a-pay">
          <div class="p"><div class="pl">Queue depth</div><div class="pv" data-stat="phase7Widgets.notifQueueDepth"><%= _w.notifQueueDepth %></div></div>
          <div class="p"><div class="pl">Error rate</div><div class="pv" style="font-size:13px"><span data-stat="phase7Widgets.errorRate.currentHour"><%= _w.errorRate.currentHour %></span>/<span data-stat="phase7Widgets.errorRate.baseline" data-fmt="fixed1"><%= _w.errorRate.baseline.toFixed(1) %></span></div></div>
          <div class="p"><div class="pl">Resend</div><div class="pv" style="font-size:12px"><%= _w.resend.envPresent ? 'enabled' : 'NO KEY' %></div></div>
        </div>
        <div style="margin-top:10px" id="cronCards">
          <div class="cron-cards">
            <% _w.cronWidget.forEach(function(c) {
              var ageMs = c.lastRun ? (Date.now() - new Date(c.lastRun).getTime()) : null;
              var cls = !c.lastRun ? '' : (ageMs > 25*60*1000) ? 'error' : (ageMs > 10*60*1000) ? 'warn' : 'ok';
            %>
              <div class="cron-card <%= cls %>"><div class="cc-n"><%= c.name %></div><div class="cc-v"><%= c.lastRunAgo || 'never run' %></div></div>
            <% }); %>
          </div>
        </div>

        <div class="a-h"><span class="pip"></span>Notification dispatch (MTD)</div>
        <div id="notifSplit">
          <% if (!_w.notifStatusSplit || _w.notifStatusSplit.length === 0) { %>
            <div class="empty-msg">No notifications dispatched this month.</div>
          <% } else { %>
            <div class="pills">
              <% _w.notifStatusSplit.forEach(function(row) {
                var cls = row.status === 'sent' ? 'sent' : row.status === 'failed' ? 'failed' : row.status === 'skipped' ? '' : 'pending';
              %>
                <span class="pill <%= cls %>"><%= row.status %><span class="count"><%= row.c %></span></span>
              <% }); %>
            </div>
          <% } %>
        </div>

        <div class="a-h"><span class="pip"></span>Notifications &amp; Instagram</div>
        <div id="notifStats">
          <% if (notifStats.length === 0) { %>
            <div class="empty-msg">No notifications this month.</div>
          <% } else { %>
            <div class="pills">
              <% notifStats.forEach(function(n) {
                var cls = n.status === 'failed' ? 'failed' : (n.status === 'sent' ? 'sent' : (n.status === 'pending' ? 'pending' : ''));
              %>
                <span class="pill <%= cls %>"><%= n.status %><span class="count"><%= n.c %></span></span>
              <% }); %>
            </div>
          <% } %>
        </div>
        <div style="margin-top:8px" id="igStats">
          <% if (igStats.length === 0) { %>
            <div class="empty-msg">No Instagram posts tracked.</div>
          <% } else { %>
            <div class="pills">
              <% igStats.forEach(function(s) {
                var cls = s.status === 'failed' ? 'failed' : (s.status === 'published' ? 'sent' : (s.status === 'pending_approval' ? 'pending' : ''));
              %>
                <span class="pill <%= cls %>"><%= s.status %><span class="count"><%= s.c %></span></span>
              <% }); %>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- ── Foot: scheduling + links ── -->
    <div class="a-foot">
      <div class="a-h"><span class="pip"></span>Worker schedule</div>
      <table class="sched">
        <thead><tr><th>Agent</th><th>Schedule</th><th>Responsibility</th></tr></thead>
        <tbody>
          <tr><td>case_sla_worker</td><td>Every 5 min</td><td>SLA pre-breach / breach / timeout sweep</td></tr>
          <tr><td>notification_worker</td><td>Every 30 sec</td><td>Dispatch queued notifications + backoff retries</td></tr>
          <tr><td>video_scheduler</td><td>Every 1 min</td><td>Video reminders + no-show detection + stale-slot sweep</td></tr>
          <tr><td>instagram_scheduler</td><td>Every 5 min</td><td>Instagram content publishing (when IG_ACCESS_TOKEN present)</td></tr>
          <tr><td>acceptance_watcher</td><td>Every 2 min</td><td>Auto-reassign cases doctor didn't accept in window</td></tr>
        </tbody>
      </table>
      <div class="a-h"><span class="pip"></span>Quick links</div>
      <div class="links">
        <a href="/ops/errors">Error Logs</a>
        <a href="/ops/silent-failures">Silent Failures</a>
        <a href="/portal/admin/analytics" target="_blank">Analytics</a>
        <a href="/portal/admin" target="_blank">Admin Panel</a>
        <a href="/healthz" target="_blank">Health Check</a>
        <a href="/__version" target="_blank">Version Info</a>
        <a href="https://dashboard.render.com/web/srv-d5pa87u3jp1c73a0qp5g" target="_blank">Render Dashboard</a>
        <a href="https://github.com/low-iq-dev/tashkheesa" target="_blank">GitHub Repo</a>
      </div>
    </div>
  </div>

  <script<%- __nonceAttr %>>
    (function(){
      var POLL_MS = 5000;
      var pill = document.getElementById('liveStatus');
      var pillText = document.getElementById('liveText');

      var DOT = { live: 'run', stale: 'stale', down: 'dead', off: 'off' };
      var AGO = { live: 'good', stale: 'warn', down: 'err', off: 'good' };

      function esc(s){ return String(s == null ? '' : s).replace(/[&<>"']/g, function(c){
        return { '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;' }[c]; }); }
      function pick(obj, path){ return path.split('.').reduce(function(o,k){ return (o==null)?undefined:o[k]; }, obj); }
      function fmt(v, kind){
        if (kind === 'ago')   return (v == null || v === '') ? 'never' : String(v);
        if (v == null) return '—';
        if (kind === 'money') return 'EGP ' + Number(v).toLocaleString('en-US');
        if (kind === 'int')   return Number(v).toLocaleString('en-US');
        if (kind === 'fixed1') return Number(v).toFixed(1);
        if (kind === 'fixed2') return Number(v).toFixed(2);
        if (kind === 'hours') return (v == null) ? '--' : (v + 'h');
        return String(v);
      }
      function setText(el, txt){ if (el && el.textContent !== txt) el.textContent = txt; }

      function applyScalars(data){
        document.querySelectorAll('[data-stat]').forEach(function(el){
          var v = pick(data, el.getAttribute('data-stat'));
          if (v === undefined) return;
          setText(el, fmt(v, el.getAttribute('data-fmt')));
        });
        // Health-rail / payment ok|bad coloring
        document.querySelectorAll('[data-color-ok]').forEach(function(el){
          var ok = pick(data, el.getAttribute('data-color-ok'));
          if (ok === undefined) return;
          el.classList.toggle('ok', !!ok);
          el.classList.toggle('bad', !ok);
        });
      }

      function applyAgents(agents){
        if (!Array.isArray(agents)) return;
        agents.forEach(function(a){
          var row = document.querySelector('.a-agent[data-agent="' + a.agent_name + '"]');
          if (!row) return;
          var dot = row.querySelector('[data-agent-dot]');
          if (dot) dot.className = 'st ' + (DOT[a.state] || 'off');
          setText(row.querySelector('[data-agent-task]'), a.current_task);
          var ago = row.querySelector('[data-agent-ago]');
          if (ago){ ago.className = 'ago ' + (AGO[a.state] || 'good'); setText(ago, a.state === 'off' ? 'off' : a.last_seen); }
          setText(row.querySelector('[data-agent-tokens]'), Number(a.tokens_used_mtd).toLocaleString('en-US'));
          setText(row.querySelector('[data-agent-cost]'), Number(a.token_cost_mtd).toFixed(2));
        });
      }

      function applyAttention(list){
        var box = document.getElementById('attention');
        if (!box || !Array.isArray(list)) return;
        if (list.length === 0){
          box.innerHTML = '<div class="a-allclear">All clear — no stale/down workers, no uncleared critical alerts.</div>';
          return;
        }
        box.innerHTML = list.map(function(it){
          var cls = it.severity === 'stale' ? ' stale' : '';
          return '<div class="a-alert' + cls + '"><span class="ic">&#9650;</span><div><div class="at">' +
            esc(it.title) + '</div><div class="ad">' + esc(it.detail) + '</div></div></div>';
        }).join('');
      }

      function applyErrClean(data){
        var box = document.getElementById('errClean');
        var cap = document.getElementById('errCleanCap');
        if (box) box.classList.toggle('bad', !data.errorsOk);
        if (cap) setText(cap, data.errorsOk ? 'No errors or silent failures · production clean' : 'errors logged in last 24h');
      }

      function applyErrLevels(data){
        var box = document.getElementById('errLevels');
        if (!box || !Array.isArray(data.errorsByLevel)) return;
        var html = data.errorsByLevel.map(function(e){
          return '<a href="/ops/errors?level=' + encodeURIComponent(e.level) + '" class="lvl-chip">' +
            esc(e.level) + '<b>' + esc(e.c) + '</b></a>';
        }).join('');
        html += '<a href="/ops/silent-failures" class="lvl-chip">silent 7d<b data-stat="silentFailures7d">' + esc(data.silentFailures7d) + '</b></a>';
        box.innerHTML = html;
      }

      function applyRecentErrors(list){
        var box = document.getElementById('recentErrors');
        if (!box || !Array.isArray(list)) return;
        box.innerHTML = list.map(function(e){
          var col = e.level === 'fatal' ? '#ff6b6b' : e.level === 'error' ? '#f87171' : e.level === 'warn' ? '#fbbf24' : '#2dd4bf';
          var msg = e.message ? (e.message.length > 80 ? e.message.slice(0,80) + '…' : e.message) : '(no message)';
          return '<div class="err-row"><span class="el" style="color:' + col + '">' + esc(e.level) +
            '</span><a href="/ops/errors/' + encodeURIComponent(e.id) + '" class="em" title="' + esc(e.message || '') + '">' +
            esc(msg) + '</a><span class="et">' + esc(e.time_ago) + '</span></div>';
        }).join('');
      }

      function applyFeed(orders){
        var box = document.getElementById('recentOrders');
        if (!box || !Array.isArray(orders)) return;
        if (orders.length === 0){ box.innerHTML = '<div class="empty-msg">No orders yet.</div>'; return; }
        box.innerHTML = '<div class="feed">' + orders.map(function(o){
          var price = o.price ? ('EGP ' + Number(o.price).toLocaleString('en-US')) : '—';
          var spec = o.specialty_name ? '<span class="spec"> / ' + esc(o.specialty_name) + '</span>' : '';
          return '<div class="feed-row"><span class="badge badge-' + esc(o.status) + '">' + esc(o.status) +
            '</span><span class="feed-detail">' + esc(o.patient_name) + ' &mdash; <span class="svc">' + esc(o.service_name) +
            '</span>' + spec + '</span><span class="feed-price">' + price + '</span><span class="feed-time">' + esc(o.time_ago) + '</span></div>';
        }).join('') + '</div>';
      }

      function renderPills(container, arr, mapFn, emptyMsg){
        var box = document.getElementById(container);
        if (!box || !Array.isArray(arr)) return;
        if (arr.length === 0){ box.innerHTML = '<div class="empty-msg">' + emptyMsg + '</div>'; return; }
        box.innerHTML = '<div class="pills">' + arr.map(function(r){
          return '<span class="pill ' + mapFn(r.status) + '">' + esc(r.status) + '<span class="count">' + esc(r.c) + '</span></span>';
        }).join('') + '</div>';
      }

      function applyCron(list){
        var box = document.getElementById('cronCards');
        if (!box || !Array.isArray(list)) return;
        box.innerHTML = '<div class="cron-cards">' + list.map(function(c){
          var ageMs = c.lastRun ? (Date.now() - new Date(c.lastRun).getTime()) : null;
          var cls = !c.lastRun ? '' : (ageMs > 25*60*1000) ? 'error' : (ageMs > 10*60*1000) ? 'warn' : 'ok';
          return '<div class="cron-card ' + cls + '"><div class="cc-n">' + esc(c.name) +
            '</div><div class="cc-v">' + esc(c.lastRunAgo || 'never run') + '</div></div>';
        }).join('') + '</div>';
      }

      function apply(data){
        applyScalars(data);
        applyAgents(data.agents);
        applyAttention(data.attention);
        applyErrClean(data);
        applyErrLevels(data);
        applyRecentErrors(data.recentErrors);
        applyFeed(data.recentOrders);
        var w = data.phase7Widgets || {};
        renderPills('notifSplit', w.notifStatusSplit, function(s){ return s==='sent'?'sent':s==='failed'?'failed':s==='skipped'?'':'pending'; }, 'No notifications dispatched this month.');
        renderPills('notifStats', data.notifStats, function(s){ return s==='failed'?'failed':s==='sent'?'sent':s==='pending'?'pending':''; }, 'No notifications this month.');
        renderPills('igStats', data.igStats, function(s){ return s==='failed'?'failed':s==='published'?'sent':s==='pending_approval'?'pending':''; }, 'No Instagram posts tracked.');
        applyCron(w.cronWidget);
      }

      function setStatus(state){
        if (!pill) return;
        pill.classList.remove('live-err', 'live-loading');
        if (state === 'ok'){ if (pillText) pillText.textContent = 'LIVE'; }
        else if (state === 'loading'){ pill.classList.add('live-loading'); if (pillText) pillText.textContent = 'UPDATING'; }
        else { pill.classList.add('live-err'); if (pillText) pillText.textContent = 'RECONNECTING'; }
      }

      var inflight = false;
      function refresh(){
        if (inflight) return;
        inflight = true;
        setStatus('loading');
        fetch('/ops/stats.json', { headers: { 'Accept': 'application/json' }, credentials: 'same-origin' })
          .then(function(r){ if (!r.ok) throw new Error('HTTP ' + r.status); return r.json(); })
          .then(function(d){ apply(d); setStatus('ok'); })
          .catch(function(){ setStatus('err'); })   // keep last-good values on screen
          .then(function(){ inflight = false; });
      }

      setInterval(refresh, POLL_MS);
      document.querySelectorAll('[data-action="reload"], .a-refresh').forEach(function(b){
        b.style.cursor = 'pointer';
        b.addEventListener('click', function(e){ e.preventDefault(); refresh(); });
      });
      refresh();
    })();
  </script>
</body>
</html>
