<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tashkheesa Ops Dashboard</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: #0f0f0f; color: #e0e0e0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, monospace; padding: 20px 24px 40px; font-size: 14px; }
    a { color: #00d4ff; text-decoration: none; }
    a:hover { text-decoration: underline; }

    .header { display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid #222; padding-bottom: 12px; margin-bottom: 24px; flex-wrap: wrap; gap: 8px; }
    .header h1 { font-size: 20px; letter-spacing: 3px; color: #00d4ff; font-weight: 700; }
    .header .hdr-right { display: flex; align-items: center; gap: 12px; }
    .header .meta { font-size: 12px; color: #777; }
    .header .countdown { font-size: 11px; color: #555; font-variant-numeric: tabular-nums; }
    .header .btn-sm { font-size: 12px; color: #888; cursor: pointer; background: none; border: 1px solid #333; border-radius: 3px; padding: 3px 8px; }
    .header .btn-sm:hover { color: #00d4ff; border-color: #00d4ff; }
    .header .logout { font-size: 12px; color: #888; }

    .section { margin-bottom: 28px; }
    .section h2 { font-size: 13px; text-transform: uppercase; letter-spacing: 2px; color: #666; margin-bottom: 12px; }
    .grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }

    .cards { display: grid; grid-template-columns: repeat(auto-fill, minmax(155px, 1fr)); gap: 10px; }
    .cards-compact { grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); }
    .card { background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 6px; padding: 14px 16px; }
    .card .label { font-size: 10px; text-transform: uppercase; letter-spacing: 1px; color: #888; margin-bottom: 4px; }
    .card .value { font-size: 26px; font-weight: 700; color: #fff; }
    .card .value-sm { font-size: 20px; }
    .card .sub { font-size: 11px; color: #555; margin-top: 2px; }
    .card.breached { border-color: #ff3c3c; box-shadow: 0 0 12px rgba(255,60,60,0.25); }
    .card.breached .value { color: #ff3c3c; }
    .card.warn { border-color: #ff9800; box-shadow: 0 0 8px rgba(255,152,0,0.2); }
    .card.warn .value { color: #ff9800; }
    .card.error { border-color: #ff3c3c; }
    .card.error .value { color: #ff3c3c; }
    .card.ok { border-color: #4caf50; }
    .card.ok .value { color: #4caf50; }
    .card a.value { text-decoration: none; }
    .card a.value:hover { text-decoration: underline; }

    table { width: 100%; border-collapse: collapse; background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 6px; overflow: hidden; }
    th { text-align: left; font-size: 10px; text-transform: uppercase; letter-spacing: 1px; color: #666; padding: 9px 12px; border-bottom: 1px solid #2a2a2a; }
    td { padding: 9px 12px; border-bottom: 1px solid #1f1f1f; font-size: 13px; }
    tr:last-child td { border-bottom: none; }
    .schedule-table td { color: #888; font-size: 12px; }
    .schedule-table td:first-child { color: #ccc; font-weight: 600; }

    .empty-msg { background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 6px; padding: 16px; text-align: center; color: #555; font-size: 13px; }

    .pills { display: flex; gap: 8px; flex-wrap: wrap; }
    .pill { background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 20px; padding: 5px 12px; font-size: 12px; color: #ccc; }
    .pill .count { font-weight: 700; color: #00d4ff; margin-left: 4px; }
    .pill.failed .count { color: #ff3c3c; }
    .pill.sent .count { color: #4caf50; }
    .pill.pending .count { color: #ff9800; }

    .sys-bar { display: flex; gap: 16px; flex-wrap: wrap; background: #141414; border: 1px solid #222; border-radius: 6px; padding: 10px 14px; font-size: 12px; color: #777; }
    .sys-bar .item { display: flex; gap: 5px; }
    .sys-bar .val { color: #ccc; font-weight: 600; }
    .sys-bar .mode-prod { color: #4caf50; }
    .sys-bar .mode-dev { color: #ff9800; }
    .sys-bar .sla-primary { color: #ff9800; font-weight: 700; }
    .sys-bar .sla-passive { color: #666; }

    .feed { background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 6px; overflow: hidden; }
    .feed-row { display: flex; align-items: center; gap: 10px; padding: 8px 14px; border-bottom: 1px solid #1f1f1f; font-size: 13px; }
    .feed-row:last-child { border-bottom: none; }
    .badge { display: inline-block; font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; padding: 2px 7px; border-radius: 3px; min-width: 60px; text-align: center; }
    .badge-completed, .badge-done, .badge-delivered { background: rgba(76,175,80,0.15); color: #4caf50; }
    .badge-breached, .badge-failed { background: rgba(255,60,60,0.15); color: #ff3c3c; }
    .badge-new, .badge-pending, .badge-awaiting_review, .badge-review, .badge-paid { background: rgba(255,152,0,0.15); color: #ff9800; }
    .badge-cancelled, .badge-expired_unpaid { background: rgba(128,128,128,0.15); color: #888; }
    .badge-error { background: rgba(255,60,60,0.15); color: #ff3c3c; }
    .badge-fatal { background: rgba(255,0,0,0.25); color: #ff0000; }
    .badge-warn { background: rgba(255,152,0,0.15); color: #ff9800; }
    .feed-detail { flex: 1; color: #ccc; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .feed-detail .svc { color: #00d4ff; }
    .feed-detail .spec { color: #666; }
    .feed-price { color: #888; font-size: 12px; min-width: 70px; text-align: right; }
    .feed-time { color: #555; font-size: 11px; min-width: 65px; text-align: right; }
    .feed-link { font-size: 11px; min-width: 30px; text-align: right; }

    .toggle-btn { font-size: 11px; cursor: pointer; border: 1px solid #333; border-radius: 3px; padding: 2px 8px; background: none; }
    .toggle-btn.on { color: #4caf50; border-color: #4caf50; }
    .toggle-btn.off { color: #ff3c3c; border-color: #ff3c3c; }
    .toggle-btn:hover { opacity: 0.8; }
    .agent-paused td { opacity: 0.4; }

    .links { display: flex; gap: 10px; flex-wrap: wrap; }
    .links a { background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 4px; padding: 7px 14px; font-size: 12px; }

    @media (max-width: 900px) { .grid-2 { grid-template-columns: 1fr; } }
    @media (max-width: 600px) {
      body { padding: 12px; }
      .cards { grid-template-columns: repeat(auto-fill, minmax(130px, 1fr)); }
      .card .value { font-size: 22px; }
      .feed-row { flex-wrap: wrap; }
    }
  </style>
</head>
<body>

  <!-- Header -->
  <div class="header">
    <h1>TASHKHEESA OPS</h1>
    <div class="hdr-right">
      <span class="meta"><%= cairoTime %> (Cairo)</span>
      <span class="countdown" id="cd">60s</span>
      <button class="btn-sm" onclick="location.reload()">&#8635; refresh</button>
      <a href="/ops/logout" class="logout">[logout]</a>
    </div>
  </div>

  <!-- System Health -->
  <div class="section">
    <div class="sys-bar">
      <div class="item">Uptime <span class="val"><%= uptime %></span></div>
      <div class="item">Mode <span class="val <%= mode === 'production' ? 'mode-prod' : 'mode-dev' %>"><%= mode %></span></div>
      <div class="item">SLA <span class="val <%= slaMode === 'primary' ? 'sla-primary' : 'sla-passive' %>"><%= slaMode %></span></div>
      <div class="item">Node <span class="val"><%= nodeVersion %></span></div>
      <div class="item">Heap <span class="val"><%= heapUsedMb %>/<%= heapTotalMb %> MB</span></div>
      <div class="item">RSS <span class="val"><%= rssMb %> MB</span></div>
      <div class="item">DB Pool <span class="val"><%= dbPoolTotal - dbPoolIdle %>/<%= dbPoolTotal %> active</span> <% if (dbPoolWaiting > 0) { %><span style="color:#ff9800">(+<%= dbPoolWaiting %> waiting)</span><% } %></div>
      <% if (gitSha) { %><div class="item">SHA <span class="val"><%= typeof gitSha === 'string' ? gitSha.slice(0,7) : '' %></span></div><% } %>
    </div>
  </div>

  <!-- Today -->
  <div class="section">
    <h2>Today</h2>
    <div class="cards cards-compact">
      <div class="card">
        <div class="label">Cases Today</div>
        <div class="value value-sm"><%= casesToday %></div>
      </div>
      <div class="card">
        <div class="label">Revenue Today</div>
        <div class="value value-sm">EGP <%= Number(revenueToday).toLocaleString('en-US') %></div>
      </div>
      <div class="card">
        <div class="label">New Patients</div>
        <div class="value value-sm"><%= newPatientsToday %></div>
      </div>
      <div class="card<%= errorsToday > 0 ? ' error' : '' %>">
        <div class="label">Errors Today</div>
        <a href="/ops/errors" class="value value-sm"><%= errorsToday %></a>
      </div>
    </div>
  </div>

  <!-- Platform Stats -->
  <div class="section">
    <h2>Platform &mdash; This Month</h2>
    <div class="cards">
      <div class="card">
        <div class="label">Cases (MTD)</div>
        <div class="value"><%= casesThisMonth %></div>
        <div class="sub"><%= totalCases %> all-time</div>
      </div>
      <div class="card<%= completedThisMonth > 0 ? ' ok' : '' %>">
        <div class="label">Completed (MTD)</div>
        <div class="value"><%= completedThisMonth %></div>
      </div>
      <div class="card">
        <div class="label">Revenue (MTD)</div>
        <div class="value">EGP <%= Number(revenueThisMonth).toLocaleString('en-US') %></div>
        <div class="sub">EGP <%= Number(revenueAllTime).toLocaleString('en-US') %> all-time</div>
      </div>
      <div class="card<%= pendingCases > 5 ? ' warn' : '' %>">
        <div class="label">Pending Cases</div>
        <div class="value"><%= pendingCases %></div>
      </div>
      <div class="card<%= breachedCases > 0 ? ' breached' : '' %>">
        <div class="label">Breached SLA</div>
        <div class="value"><%= breachedCases %></div>
      </div>
      <div class="card<%= nearBreachCases > 0 ? ' warn' : '' %>">
        <div class="label">Near Breach (&lt;2h)</div>
        <div class="value"><%= nearBreachCases %></div>
      </div>
      <div class="card">
        <div class="label">Avg Completion</div>
        <div class="value"><%= avgCompletionHrs !== null ? avgCompletionHrs + 'h' : '--' %></div>
        <div class="sub">this month</div>
      </div>
      <div class="card">
        <div class="label">Active Doctors</div>
        <div class="value"><%= activeDoctors %></div>
        <div class="sub"><%= totalDoctors %> total</div>
      </div>
      <div class="card">
        <div class="label">Total Patients</div>
        <div class="value"><%= totalPatients %></div>
      </div>
    </div>
  </div>

  <!-- Recent Activity -->
  <div class="section">
    <h2>Recent Activity</h2>
    <% if (recentOrders.length === 0) { %>
      <div class="empty-msg">No orders yet.</div>
    <% } else { %>
      <div class="feed">
        <% recentOrders.forEach(function(o) { %>
          <div class="feed-row">
            <span class="badge badge-<%= o.status %>"><%= o.status %></span>
            <span class="feed-detail">
              <%= o.patient_name %> &mdash;
              <span class="svc"><%= o.service_name %></span>
              <% if (o.specialty_name) { %><span class="spec"> / <%= o.specialty_name %></span><% } %>
            </span>
            <span class="feed-price"><% if (o.price) { %>EGP <%= Number(o.price).toLocaleString('en-US') %><% } else { %>&mdash;<% } %></span>
            <span class="feed-time"><%= o.time_ago %></span>
          </div>
        <% }); %>
      </div>
    <% } %>
  </div>

  <!-- Errors + Payments side by side -->
  <div class="section grid-2">
    <div>
      <h2>Errors (24h) <a href="/ops/errors" style="font-size:11px;text-transform:none;letter-spacing:0;font-weight:400">&rarr; view all</a></h2>
      <div class="cards" style="margin-bottom:12px">
        <div class="card<%= errors24h > 0 ? ' error' : '' %>">
          <div class="label">Total Errors</div>
          <a href="/ops/errors" class="value"><%= errors24h %></a>
        </div>
        <% errorsByLevel.forEach(function(e) { %>
          <div class="card">
            <div class="label"><%= e.level %></div>
            <a href="/ops/errors?level=<%= e.level %>" class="value"><%= e.c %></a>
          </div>
        <% }); %>
      </div>
      <% if (recentErrors.length > 0) { %>
        <div class="feed">
          <% recentErrors.slice(0, 5).forEach(function(e) { %>
            <div class="feed-row">
              <span class="badge badge-<%= e.level %>"><%= e.level %></span>
              <span class="feed-detail" title="<%= e.message %>"><%= e.message ? String(e.message).slice(0, 80) : 'No message' %></span>
              <span class="feed-time"><%= e.time_ago %></span>
              <span class="feed-link"><a href="/ops/errors/<%= e.id %>">view</a></span>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>
    <div>
      <h2>Payment Health</h2>
      <div class="cards">
        <div class="card<%= unpaidOrders > 5 ? ' warn' : '' %>">
          <div class="label">Unpaid Orders</div>
          <div class="value"><%= unpaidOrders %></div>
        </div>
        <div class="card<%= failedPayments > 0 ? ' error' : '' %>">
          <div class="label">Failed Payments</div>
          <div class="value"><%= failedPayments %></div>
        </div>
      </div>
    </div>
  </div>

  <!-- Notifications -->
  <div class="section">
    <h2>Notifications (MTD)</h2>
    <% if (notifStats.length === 0) { %>
      <div class="empty-msg">No notifications this month.</div>
    <% } else { %>
      <div class="pills">
        <% notifStats.forEach(function(n) {
          var cls = n.status === 'failed' ? 'failed' : (n.status === 'sent' ? 'sent' : (n.status === 'pending' ? 'pending' : ''));
        %>
          <span class="pill <%= cls %>"><%= n.status %><span class="count"><%= n.c %></span></span>
        <% }); %>
      </div>
    <% } %>
  </div>

  <!-- Agents -->
  <div class="section">
    <h2>Agents <span style="color:#555;font-size:11px;letter-spacing:0;text-transform:none;font-weight:400">&mdash; $<%= totalTokenSpend.toFixed(2) %> MTD total</span></h2>
    <table>
      <thead>
        <tr>
          <th>Agent</th>
          <th>Status</th>
          <th>Current Task</th>
          <th>Last Seen</th>
          <th>Tokens (MTD)</th>
          <th>Cost (MTD)</th>
          <th>Control</th>
        </tr>
      </thead>
      <tbody>
        <% agents.forEach(function(a) {
          var diffHrs = a.pinged_at ? (Date.now() - new Date(a.pinged_at).getTime()) / 3600000 : 999;
          var dot = diffHrs < 2 ? '\u{1F7E2}' : (diffHrs < 12 ? '\u{1F7E1}' : '\u{1F534}');
        %>
        <tr class="<%= !a.enabled ? 'agent-paused' : '' %>">
          <td><strong><%= a.agent_name %></strong></td>
          <td><%= dot %> <%= a.enabled ? a.status : 'paused' %></td>
          <td><%= a.current_task %></td>
          <td><%= a.last_seen %></td>
          <td><%= a.tokens_used_mtd.toLocaleString('en-US') %></td>
          <td>$<%= a.token_cost_mtd.toFixed(2) %></td>
          <td>
            <form method="POST" action="/ops/agent/toggle" style="display:inline">
              <input type="hidden" name="agent_name" value="<%= a.agent_name %>">
              <button type="submit" class="toggle-btn <%= a.enabled ? 'on' : 'off' %>"><%= a.enabled ? 'enabled' : 'paused' %></button>
            </form>
          </td>
        </tr>
        <% }); %>
      </tbody>
    </table>

    <h2 style="margin-top:18px">Scheduling</h2>
    <table class="schedule-table">
      <thead>
        <tr><th>Agent</th><th>Schedule</th><th>Responsibility</th></tr>
      </thead>
      <tbody>
        <tr><td>ops-agent</td><td>Every 4h</td><td>SLA sweep, DB health, error review</td></tr>
        <tr><td>growth-agent</td><td>Daily 8am</td><td>Instagram content, campaign prep</td></tr>
        <tr><td>care-agent</td><td>Every 6h</td><td>Pending case review, patient followups</td></tr>
        <tr><td>finance-agent</td><td>Weekly Mon</td><td>Revenue report, unpaid case sweep</td></tr>
      </tbody>
    </table>
  </div>

  <!-- Instagram Pipeline -->
  <div class="section">
    <h2>Instagram Pipeline</h2>
    <% if (igStats.length === 0) { %>
      <div class="empty-msg">No Instagram posts tracked.</div>
    <% } else { %>
      <div class="pills">
        <% igStats.forEach(function(s) {
          var cls = s.status === 'failed' ? 'failed' : (s.status === 'published' ? 'sent' : (s.status === 'pending_approval' ? 'pending' : ''));
        %>
          <span class="pill <%= cls %>"><%= s.status %><span class="count"><%= s.c %></span></span>
        <% }); %>
      </div>
    <% } %>
  </div>

  <!-- Quick Links -->
  <div class="section">
    <h2>Quick Links</h2>
    <div class="links">
      <a href="/ops/errors">Error Logs</a>
      <a href="/portal/admin/analytics" target="_blank">Analytics</a>
      <a href="/portal/admin" target="_blank">Admin Panel</a>
      <a href="/healthz" target="_blank">Health Check</a>
      <a href="/__version" target="_blank">Version Info</a>
      <a href="https://dashboard.render.com/web/srv-d5pa87u3jp1c73a0qp5g" target="_blank">Render Dashboard</a>
      <a href="https://github.com/low-iq-dev/tashkheesa" target="_blank">GitHub Repo</a>
    </div>
  </div>

  <script>
    (function(){
      var s=60, el=document.getElementById('cd');
      setInterval(function(){
        s--;
        if(s<=0){location.reload();return;}
        el.textContent=s+'s';
      },1000);
    })();
  </script>
</body>
</html>
