<%
  // Campaign detail — fork of admin_campaign_detail.ejs.
  // Fetch URLs repointed:
  //   /portal/admin/campaigns/:id/send   → /superadmin/campaigns/:id/send
  //   /portal/admin/campaigns/:id/cancel → /superadmin/campaigns/:id/cancel
  var isAr = (typeof lang !== 'undefined' && lang === 'ar');
  var _campaign = (typeof campaign !== 'undefined' && campaign) ? campaign : {};
  var _recipients = (typeof recipients !== 'undefined' && Array.isArray(recipients)) ? recipients : [];
  var _nonce = (typeof cspNonce !== 'undefined' && cspNonce) ? cspNonce : '';

  function _statusTone(s) {
    if (s === 'sent') return 'green';
    if (s === 'sending') return 'amber';
    if (s === 'scheduled') return 'accent';
    if (s === 'cancelled') return 'red';
    return 'neutral';
  }
  function _recipTone(s) {
    if (s === 'sent') return 'green';
    if (s === 'failed') return 'red';
    if (s === 'pending') return 'amber';
    return 'neutral';
  }
  function _fmtDate(iso) {
    if (!iso) return '—';
    var d = new Date(iso);
    if (Number.isNaN(d.getTime())) return '—';
    return d.toLocaleString('en-GB', { day: 'numeric', month: 'short', year: 'numeric', hour: '2-digit', minute: '2-digit' });
  }

  var totalR = _campaign.total_recipients || 0;
  var totalS = _campaign.total_sent || 0;
  var rate = totalR > 0 ? Math.round((totalS / totalR) * 100) : 0;
%>
<%- include('partials/superadmin/header', {
      title: _campaign.name || 'Campaign',
      currentSection: 'campaigns',
      user: user,
      lang: lang || 'en',
      showTabBar: false,
      sidebarBadges: (typeof sidebarBadges !== 'undefined' && sidebarBadges) ? sidebarBadges : {},
      cspNonce: _nonce
    }) %>

<%- include('partials/superadmin/page_header', {
      title: _campaign.name || 'Campaign',
      subtitle: _campaign.subject_en || '',
      breadcrumb: [
        { label: 'Dashboard', href: '/superadmin' },
        { label: isAr ? 'الحملات' : 'Campaigns', href: '/superadmin/campaigns' },
        { label: _campaign.name || 'Detail' }
      ],
      actionsHtml: '<a class="btn" href="/superadmin/campaigns">Back to list</a>'
    }) %>

<div class="page-body">
  <div style="display:flex;align-items:center;gap:10px;margin-bottom:14px;">
    <%- include('partials/superadmin/c_chip', { label: _campaign.status || '—', tone: _statusTone(_campaign.status), dot: true }) %>
    <% if (_campaign.target_audience) { %><span class="spec-tag"><%= _campaign.target_audience %></span><% } %>
  </div>

  <div class="kpi-strip" style="grid-template-columns:repeat(4, 1fr);">
    <%- include('partials/superadmin/c_kpi', { label: isAr ? 'المستلمون' : 'Recipients', value: totalR, sub: 'targeted' }) %>
    <%- include('partials/superadmin/c_kpi', { label: isAr ? 'تم الإرسال' : 'Sent', value: totalS, sub: 'delivered' }) %>
    <%- include('partials/superadmin/c_kpi', { label: isAr ? 'فشل' : 'Failed', value: _campaign.total_failed || 0, sub: 'errors' }) %>
    <%- include('partials/superadmin/c_kpi', { label: isAr ? 'معدل التسليم' : 'Delivery rate', value: rate, unit: '%', sub: 'sent / recipients' }) %>
  </div>

  <div style="margin-top:14px;">
    <%- include('partials/superadmin/c_card_open', { title: isAr ? 'تفاصيل الحملة' : 'Campaign details' }) %>
      <div style="display:grid;grid-template-columns:180px 1fr;gap:8px 16px;font-size:12.5px;">
        <div style="color:var(--fg-3);"><%= isAr ? 'الموضوع (EN)' : 'Subject (EN)' %></div>
        <div><%= _campaign.subject_en || '—' %></div>
        <% if (_campaign.subject_ar) { %>
          <div style="color:var(--fg-3);"><%= isAr ? 'الموضوع (AR)' : 'Subject (AR)' %></div>
          <div dir="rtl"><%= _campaign.subject_ar %></div>
        <% } %>
        <div style="color:var(--fg-3);"><%= isAr ? 'الجمهور' : 'Audience' %></div>
        <div><%= _campaign.target_audience %></div>
        <div style="color:var(--fg-3);"><%= isAr ? 'تاريخ الإنشاء' : 'Created' %></div>
        <div class="mono"><%= _fmtDate(_campaign.created_at) %></div>
        <% if (_campaign.scheduled_at) { %>
          <div style="color:var(--fg-3);"><%= isAr ? 'مجدول' : 'Scheduled' %></div>
          <div class="mono"><%= _fmtDate(_campaign.scheduled_at) %></div>
        <% } %>
        <% if (_campaign.sent_at) { %>
          <div style="color:var(--fg-3);"><%= isAr ? 'تم الإرسال' : 'Sent at' %></div>
          <div class="mono"><%= _fmtDate(_campaign.sent_at) %></div>
        <% } %>
        <% if (_campaign.approved_by) { %>
          <div style="color:var(--fg-3);"><%= isAr ? 'وافق عليها' : 'Approved by' %></div>
          <div><%= _campaign.approved_by %><% if (_campaign.approved_at) { %> · <%= _fmtDate(_campaign.approved_at) %><% } %></div>
        <% } %>
      </div>
    <%- include('partials/superadmin/c_card_close') %>
  </div>

  <% if (_campaign.status === 'draft' || _campaign.status === 'scheduled') { %>
    <div style="margin-top:14px;">
      <%- include('partials/superadmin/c_card_open', { title: 'Actions' }) %>
        <div style="display:flex;gap:8px;flex-wrap:wrap;">
          <% if (_campaign.status === 'draft') { %>
            <button id="sendBtn" class="btn primary"><%= isAr ? 'إرسال الآن' : 'Send now' %></button>
          <% } %>
          <button id="cancelBtn" class="btn danger"><%= isAr ? 'إلغاء الحملة' : 'Cancel campaign' %></button>
        </div>
        <div id="actionMsg" class="flash" style="display:none;margin-top:10px;"></div>
      <%- include('partials/superadmin/c_card_close') %>
    </div>
  <% } %>

  <div class="section-h standalone" style="margin-top:16px;"><h2><%= isAr ? 'المستلمون' : 'Recipients' %> · <%= _recipients.length %></h2></div>
  <%- include('partials/superadmin/c_card_open', { tight: true }) %>
    <% if (!_recipients.length) { %>
      <%- include('partials/superadmin/c_empty', { title: isAr ? 'لا يوجد مستلمون' : 'No recipients' }) %>
    <% } else { %>
      <%- include('partials/superadmin/c_table_open', { headers: [
            isAr ? 'البريد' : 'Email',
            isAr ? 'الحالة' : 'Status',
            isAr ? 'تاريخ الإرسال' : 'Sent at',
            isAr ? 'خطأ' : 'Error'
          ] }) %>
        <% _recipients.forEach(function(r) { %>
          <tr>
            <td class="mono" style="font-size:11.5px;"><%= r.email %></td>
            <td><%- include('partials/superadmin/c_chip', { label: r.status, tone: _recipTone(r.status) }) %></td>
            <td class="mono" style="color:var(--fg-3);font-size:11.5px;"><%= r.sent_at ? _fmtDate(r.sent_at) : '—' %></td>
            <td style="color:var(--red);font-size:11.5px;"><%= r.error || '' %></td>
          </tr>
        <% }); %>
      <%- include('partials/superadmin/c_table_close') %>
    <% } %>
  <%- include('partials/superadmin/c_card_close') %>
</div>

<script<% if (_nonce) { %> nonce="<%= _nonce %>"<% } %>>
(function() {
  var campaignId = '<%= _campaign.id %>';
  var csrfToken = '<%= typeof csrfToken !== "undefined" && csrfToken ? csrfToken : "" %>';
  var actionMsg = document.getElementById('actionMsg');

  function showMsg(text, ok) {
    if (!actionMsg) return;
    actionMsg.style.display = 'flex';
    actionMsg.classList.remove('ok', 'err');
    actionMsg.classList.add(ok ? 'ok' : 'err');
    actionMsg.textContent = text;
  }

  var sendBtn = document.getElementById('sendBtn');
  if (sendBtn) {
    sendBtn.addEventListener('click', function() {
      if (!confirm('<%= isAr ? "هل تريد إرسال الحملة الآن؟" : "Send this campaign now?" %>')) return;
      sendBtn.disabled = true;
      fetch('/superadmin/campaigns/' + campaignId + '/send', {
        method: 'POST',
        headers: { 'x-csrf-token': csrfToken, 'Content-Type': 'application/json' }
      })
      .then(function(r) { return r.json(); })
      .then(function(res) {
        if (res.ok) {
          showMsg(res.message || 'Sending started', true);
          setTimeout(function() { location.reload(); }, 2000);
        } else {
          showMsg(res.error || 'Error', false);
          sendBtn.disabled = false;
        }
      })
      .catch(function() { showMsg('Network error', false); sendBtn.disabled = false; });
    });
  }

  var cancelBtn = document.getElementById('cancelBtn');
  if (cancelBtn) {
    cancelBtn.addEventListener('click', function() {
      if (!confirm('<%= isAr ? "هل تريد إلغاء هذه الحملة؟" : "Cancel this campaign?" %>')) return;
      cancelBtn.disabled = true;
      fetch('/superadmin/campaigns/' + campaignId + '/cancel', {
        method: 'POST',
        headers: { 'x-csrf-token': csrfToken, 'Content-Type': 'application/json' }
      })
      .then(function(r) { return r.json(); })
      .then(function(res) {
        if (res.ok) {
          showMsg('<%= isAr ? "تم إلغاء الحملة" : "Campaign cancelled" %>', true);
          setTimeout(function() { location.reload(); }, 1000);
        } else {
          showMsg(res.error || 'Error', false);
          cancelBtn.disabled = false;
        }
      })
      .catch(function() { showMsg('Network error', false); cancelBtn.disabled = false; });
    });
  }
})();
</script>

<%- include('partials/superadmin/footer', { isAr: isAr }) %>
