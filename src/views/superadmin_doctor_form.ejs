<%
  // Doctor create/edit form. The sub-specialty multi-select panel is
  // driven by /js/superadmin_doctor_form.js — DOM contracts preserved:
  //   #specialtySelect              — parent specialty <select>
  //   #subSpecialtyOptionsJson      — hidden textarea with [{id,name,parentId}] JSON
  //   #subSpecialtySelectedJson     — hidden textarea with selected sub-id array JSON
  //   #subSpecialtiesCsv            — hidden input mirrors selected as CSV (service_ids_csv)
  //   #subSpecialtiesCsvLegacy      — legacy hidden input (sub_specialties_csv)
  //   #subSpecialties / #subSpecialtiesList — <details> panel + slot for checkboxes
  //   #subSpecialtiesEmpty / #subSpecialtiesSummary
  // Anything renaming these IDs will break the JS.
  var isAr = (typeof lang !== 'undefined' && lang === 'ar');
  var _specialties = (typeof specialties !== 'undefined' && specialties) ? specialties : [];
  var _subSpecialties = (typeof subSpecialties !== 'undefined' && subSpecialties) ? subSpecialties : [];
  var _doctor = (typeof doctor !== 'undefined') ? doctor : null;
  var _err = (typeof error !== 'undefined' && error) ? error : '';

  var _selectedSpecialtyId = (typeof selectedSpecialtyId !== 'undefined' ? selectedSpecialtyId : null)
    || (_doctor && (_doctor.specialty_id || _doctor.specialtyId || _doctor.specialty))
    || '';

  var _selectedSubIds = (typeof selectedSubIds !== 'undefined' ? selectedSubIds : null)
    || (typeof selectedSubSpecialtyIds !== 'undefined' ? selectedSubSpecialtyIds : null)
    || (_doctor && (
      _doctor.sub_specialty_ids || _doctor.subSpecialtyIds ||
      _doctor.service_ids_csv || _doctor.serviceIdsCsv ||
      _doctor.sub_specialties_csv || _doctor.subSpecialtiesCsv
    ))
    || [];

  var _selectedSubIdsArr = Array.isArray(_selectedSubIds)
    ? _selectedSubIds.map(function(x) { return String(x); })
    : (typeof _selectedSubIds === 'string' ? _selectedSubIds.split(',').map(function(s) { return s.trim(); }).filter(Boolean) : []);

  function _slugify(s) {
    return String(s || '').trim().toLowerCase()
      .replace(/&/g, 'and')
      .replace(/[^a-z0-9]+/g, '_')
      .replace(/^_+|_+$/g, '');
  }

  var _specialtyKeyById = new Map();
  _specialties.forEach(function(sp) {
    var spId = (sp && sp.id != null) ? String(sp.id).trim() : '';
    var spName = (sp && sp.name != null) ? String(sp.name).trim() : '';
    var spSlug = (sp && (sp.slug || sp.code || sp.key) != null) ? String(sp.slug || sp.code || sp.key).trim() : '';
    if (spId && spSlug) _specialtyKeyById.set(spId, _slugify(spSlug));
    if (spId && spName && !_specialtyKeyById.has(spId)) _specialtyKeyById.set(spId, _slugify(spName));
  });

  var _specialtyIdByKey = new Map();
  _specialties.forEach(function(sp) {
    var spId = (sp && sp.id != null) ? String(sp.id).trim() : '';
    var spName = (sp && sp.name != null) ? String(sp.name).trim() : '';
    var spSlug = (sp && (sp.slug || sp.code || sp.key) != null) ? String(sp.slug || sp.code || sp.key).trim() : '';
    var keys = [];
    if (spSlug) keys.push(_slugify(spSlug));
    if (spName) keys.push(_slugify(spName));
    if (spId) keys.push(_slugify(spId));
    keys.filter(Boolean).forEach(function(k) {
      if (spId && k && !_specialtyIdByKey.has(k)) _specialtyIdByKey.set(k, spId);
    });
  });

  var _options = _subSpecialties.map(function(ss) {
    var id = (ss && ss.id != null) ? String(ss.id).trim() : '';
    var name = (ss && ss.name != null) ? String(ss.name).trim() : '';
    var directParent = (ss && (
      ss.specialty_id || ss.specialtyId || ss.parent_specialty_id || ss.parentSpecialtyId || ss.specialty
    )) != null
      ? String(ss.specialty_id || ss.specialtyId || ss.parent_specialty_id || ss.parentSpecialtyId || ss.specialty).trim()
      : '';
    var parentKeyCandidate = (ss && (
      ss.specialty_slug || ss.specialtySlug || ss.specialty_key || ss.specialtyKey ||
      ss.specialty_name || ss.parent_specialty_name || ss.specialtyName || ss.parentSpecialtyName
    )) != null
      ? _slugify(ss.specialty_slug || ss.specialtySlug || ss.specialty_key || ss.specialtyKey ||
                 ss.specialty_name || ss.parent_specialty_name || ss.specialtyName || ss.parentSpecialtyName)
      : '';
    var parentId = directParent;
    if (parentId && !_specialtyKeyById.has(parentId)) {
      var maybe = _specialtyIdByKey.get(_slugify(parentId));
      if (maybe) parentId = maybe;
    }
    if (!parentId && parentKeyCandidate) {
      var maybe2 = _specialtyIdByKey.get(parentKeyCandidate);
      if (maybe2) parentId = maybe2;
    }
    return { id: id, name: name, parentId: parentId };
  }).filter(function(o) { return o.id && o.name && o.parentId; });

  var _optionsJson = JSON.stringify(_options);
  var _selectedJson = JSON.stringify(_selectedSubIdsArr);

  var _fullName = (_doctor && (_doctor.full_name || _doctor.fullName || _doctor.name)) ? String(_doctor.full_name || _doctor.fullName || _doctor.name) : '';
  var _email = (_doctor && _doctor.email) ? String(_doctor.email) : '';
  var _phone = (_doctor && (_doctor.phone || _doctor.phone_number)) ? String(_doctor.phone || _doctor.phone_number) : '';
  var _active = (_doctor && typeof _doctor.active !== 'undefined') ? !!_doctor.active : true;
  var _sendWhatsApp = (_doctor && typeof _doctor.send_whatsapp_alerts !== 'undefined') ? !!_doctor.send_whatsapp_alerts : false;

  var _formAction = (typeof formAction !== 'undefined' && formAction)
    ? formAction
    : (_doctor && _doctor.id ? ('/superadmin/doctors/' + _doctor.id + '/edit') : '/superadmin/doctors/new');
  var _formMethod = (typeof formMethod !== 'undefined' && formMethod) ? formMethod : 'POST';

  var specOpts = [{ value: '', label: 'Select specialty' }].concat(
    _specialties.map(function(sp) { return { value: String(sp.id), label: sp.name }; })
  );
%>
<%- include('partials/superadmin/header', {
      title: _doctor ? 'Edit doctor' : 'Add doctor',
      currentSection: 'doctors',
      user: user,
      lang: lang || 'en',
      showTabBar: false,
      sidebarBadges: (typeof sidebarBadges !== 'undefined' && sidebarBadges) ? sidebarBadges : {},
      cspNonce: (typeof cspNonce !== 'undefined') ? cspNonce : ''
    }) %>

<%- include('partials/superadmin/page_header', {
      title: _doctor ? 'Edit doctor' : 'Add doctor',
      subtitle: _doctor ? 'Update profile and specialties.' : 'Internal onboarding for a new doctor.',
      breadcrumb: [
        { label: 'Dashboard', href: '/superadmin' },
        { label: isAr ? 'الأطباء' : 'Doctors', href: '/superadmin/doctors' },
        { label: _doctor ? (_doctor.name || 'Edit') : 'New' }
      ],
      actionsHtml: '<a class="btn" href="/superadmin/doctors">Cancel</a>'
    }) %>

<div class="page-body">
  <% if (_err) { %>
    <div class="flash err"><%= _err %></div>
  <% } %>

  <%- include('partials/superadmin/c_card_open', { title: _doctor ? 'Doctor profile' : 'New doctor' }) %>
    <form action="<%= _formAction %>" method="<%= _formMethod %>" style="max-width:880px;">
      <%- (typeof csrfField === 'function') ? csrfField() : '' %>

      <div class="c-form-row">
        <%- include('partials/superadmin/c_form_field', { name: 'full_name', label: 'Full name', required: true, value: _fullName, autocomplete: 'name' }) %>
        <%- include('partials/superadmin/c_form_field', { name: 'email', label: 'Email', type: 'email', required: true, value: _email, autocomplete: 'email' }) %>
      </div>

      <div class="c-form-row">
        <%- include('partials/superadmin/c_form_field', { name: 'specialty_id', id: 'specialtySelect', label: 'Specialty', type: 'select', required: true, value: String(_selectedSpecialtyId || ''), options: specOpts }) %>
        <%- include('partials/superadmin/c_form_field', { name: 'phone', label: 'Phone', type: 'tel', value: _phone, autocomplete: 'tel' }) %>
      </div>

      <div class="c-field">
        <label class="c-field-label">Sub-specialties</label>
        <textarea id="subSpecialtyOptionsJson" style="display:none;" aria-hidden="true"><%- _optionsJson %></textarea>
        <textarea id="subSpecialtySelectedJson" style="display:none;" aria-hidden="true"><%- _selectedJson %></textarea>
        <input id="subSpecialtiesCsv" type="hidden" name="service_ids_csv" value="" />
        <input id="subSpecialtiesCsvLegacy" type="hidden" name="sub_specialties_csv" value="" />
        <details id="subSpecialties" class="multi-select" data-placeholder="Select sub-specialties" data-count-label="Sub-specialties" style="background:var(--bg-1);border:1px solid var(--line);border-radius:var(--r-sm);padding:8px 11px;">
          <summary id="subSpecialtiesSummary" style="cursor:pointer;font-size:13px;color:var(--fg-1);">Select sub-specialties</summary>
          <div class="multi-select-panel" style="margin-top:10px;border-top:1px solid var(--line-soft);padding-top:10px;">
            <div id="subSpecialtiesEmpty" class="empty" style="display:none;padding:10px;text-align:center;color:var(--fg-3);font-size:12px;">
              No sub-specialties for this specialty.
            </div>
            <div id="subSpecialtiesList" style="display:grid;grid-template-columns:1fr 1fr;gap:8px;"></div>
          </div>
        </details>
        <div class="c-field-help">Options are filtered once you pick a specialty above.</div>
      </div>

      <div class="c-form-row" style="align-items:end;">
        <label class="c-checkbox">
          <input type="checkbox" name="send_whatsapp_alerts" value="1" <%= _sendWhatsApp ? 'checked' : '' %> />
          <span>Send WhatsApp alerts</span>
        </label>
        <label class="c-checkbox">
          <input type="checkbox" name="active" value="1" <%= _active ? 'checked' : '' %> />
          <span>Active</span>
        </label>
      </div>

      <% if (!_doctor) { %>
        <p style="font-size:11.5px;color:var(--fg-3);margin-top:10px;">
          Initial password defaults to <strong style="color:var(--fg);">Doctor123!</strong> — the doctor can change it after their first login. A welcome email with a one-time setup link is also sent.
        </p>
      <% } %>

      <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:18px;">
        <a class="btn" href="/superadmin/doctors">Cancel</a>
        <button type="submit" class="btn primary"><%= _doctor ? 'Save doctor' : 'Create doctor' %></button>
      </div>
    </form>
  <%- include('partials/superadmin/c_card_close') %>
</div>

<script src="/js/superadmin_doctor_form.js" defer></script>

<%- include('partials/superadmin/footer', { isAr: isAr }) %>
