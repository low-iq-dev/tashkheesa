<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Tashkheesa Ops — Login</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: #0f0f0f;
      color: #fff;
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
    }
    .login-box {
      background: #1a1a1a;
      border: 1px solid #333;
      border-radius: 8px;
      padding: 40px 32px;
      width: 100%;
      max-width: 380px;
    }
    .login-box h1 {
      font-size: 18px;
      letter-spacing: 2px;
      color: #00d4ff;
      text-align: center;
      margin-bottom: 24px;
    }
    .login-box label {
      display: block;
      font-size: 13px;
      color: #aaa;
      margin-bottom: 4px;
    }
    .login-box input[type="text"],
    .login-box input[type="password"] {
      width: 100%;
      padding: 10px 12px;
      background: #0f0f0f;
      border: 1px solid #444;
      border-radius: 4px;
      color: #fff;
      font-size: 14px;
      margin-bottom: 16px;
    }
    .login-box input:focus {
      outline: none;
      border-color: #00d4ff;
    }
    .login-box button {
      width: 100%;
      padding: 10px;
      background: #00d4ff;
      color: #000;
      border: none;
      border-radius: 4px;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
    }
    .login-box button:hover { opacity: 0.9; }
    .error-msg {
      background: rgba(255,60,60,0.15);
      border: 1px solid #ff3c3c;
      color: #ff6b6b;
      padding: 8px 12px;
      border-radius: 4px;
      font-size: 13px;
      margin-bottom: 16px;
      text-align: center;
    }
  </style>
</head>
<body>
  <div class="login-box">
    <h1>TASHKHEESA OPS</h1>
    <% if (error) { %>
      <div class="error-msg"><%= error %></div>
    <% } %>
    <form method="POST" action="/ops/login">
      <%- typeof csrfField === 'function' ? csrfField() : '' %>
      <label for="username">Username</label>
      <input type="text" id="username" name="username" autocomplete="username" required>
      <label for="password">Password</label>
      <input type="password" id="password" name="password" autocomplete="current-password" required>
      <button type="submit">Sign In</button>
    </form>
  </div>
</body>
</html>
