<%- include('partials/header', { title: (typeof isAr !== 'undefined' && isAr) ? 'الأرباح' : 'Earnings', layout: 'portal', showNav: true, portalFrame: true, portalRole: 'doctor', portalActive: 'earnings', portalNext: '/portal/doctor/earnings' }) %>
<%
  var _isAr = (typeof isAr !== 'undefined') ? !!isAr : false;
  var _lang = (typeof lang === 'string' && lang) ? lang : (_isAr ? 'ar' : 'en');
  var _months = Array.isArray(typeof months !== 'undefined' ? months : []) ? months : [];
  var _lifetime = (typeof lifetime === 'object' && lifetime) ? lifetime : { total: 0, paid: 0, pending: 0 };
  function _t(en, ar) { return _isAr ? ar : en; }
  function _fmtMoney(n) {
    var v = Number(n) || 0;
    try { return v.toLocaleString(_isAr ? 'ar-EG' : 'en-US'); } catch (_) { return String(v); }
  }
  function _fmtMonth(d) {
    if (!d) return '';
    try {
      var dt = new Date(d);
      if (isNaN(dt.getTime())) return String(d);
      return dt.toLocaleDateString(_isAr ? 'ar-EG' : 'en-US', { year: 'numeric', month: 'long' });
    } catch (_) { return String(d); }
  }
%>
<%- include('partials/doctor/topbar', {
  isAr: _isAr,
  topbarTitle: _t('Earnings', 'الأرباح'),
  topbarSub: _t('Per-case fees, monthly totals and payout status', 'الأتعاب وإجماليات الشهر وحالة التحويل'),
  topbarShowSearch: false
}) %>

<% if (_months.length === 0) { %>
  <%# ─── Empty state — friendly first-login experience ──────────────────── %>
  <div class="v2-card">
    <div class="v2-card__body--flush">
      <div class="v2-empty">
        <img src="/icons/doctor/23_earnings.svg" alt="" onerror="this.style.display='none'" />
        <div class="v2-empty__title"><%= _t('Your earnings will appear here', 'ستظهر أرباحك هنا') %></div>
        <div class="v2-empty__msg">
          <%= _t('Once you complete your first case, this page will show monthly totals, fee breakdowns, and your payout status.',
                 'بعد إكمال أول حالة، ستعرض هذه الصفحة الإجماليات الشهرية وتفاصيل الأتعاب وحالة التحويل.') %>
        </div>
        <div class="v2-empty__actions">
          <a class="v2-btn v2-btn--primary" href="/portal/doctor/cases?tab=new"><%= _t('View available cases', 'عرض الحالات المتاحة') %></a>
        </div>
      </div>
    </div>
  </div>
<% } else { %>

  <%# ─── Lifetime summary tiles ───────────────────────────────────────── %>
  <div style="display:grid;grid-template-columns:repeat(3, minmax(0,1fr));gap:12px;margin-block-end:18px;">
    <div class="v2-card">
      <div class="v2-card__body" style="padding:16px;">
        <div class="v2-stat-tile__label" style="font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted, #6b7280);font-weight:700;">
          <%= _t('Lifetime earned', 'إجمالي الأرباح') %>
        </div>
        <div class="v2-stat-tile__value v2-stat-tile__value--brass" style="font-size:28px;font-weight:600;color:var(--brass, #a07d3e);margin-block-start:6px;">
          <%= _fmtMoney(_lifetime.total) %> <span style="font-size:14px;font-weight:500;color:var(--muted,#6b7280);"><%= _t('EGP', 'ج.م') %></span>
        </div>
      </div>
    </div>
    <div class="v2-card">
      <div class="v2-card__body" style="padding:16px;">
        <div class="v2-stat-tile__label" style="font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted, #6b7280);font-weight:700;">
          <%= _t('Paid out', 'تم التحويل') %>
        </div>
        <div class="v2-stat-tile__value" style="font-size:28px;font-weight:600;color:var(--ink, #1f2937);margin-block-start:6px;">
          <%= _fmtMoney(_lifetime.paid) %> <span style="font-size:14px;font-weight:500;color:var(--muted,#6b7280);"><%= _t('EGP', 'ج.م') %></span>
        </div>
      </div>
    </div>
    <div class="v2-card">
      <div class="v2-card__body" style="padding:16px;">
        <div class="v2-stat-tile__label" style="font-size:11px;letter-spacing:0.12em;text-transform:uppercase;color:var(--muted, #6b7280);font-weight:700;">
          <%= _t('Pending payout', 'بانتظار التحويل') %>
        </div>
        <div class="v2-stat-tile__value" style="font-size:28px;font-weight:600;color:var(--ink, #1f2937);margin-block-start:6px;">
          <%= _fmtMoney(_lifetime.pending) %> <span style="font-size:14px;font-weight:500;color:var(--muted,#6b7280);"><%= _t('EGP', 'ج.م') %></span>
        </div>
      </div>
    </div>
  </div>

  <%# ─── Monthly statement table ──────────────────────────────────────── %>
  <div class="v2-card">
    <div class="v2-card__header">
      <div class="v2-card__title"><%= _t('Monthly statement', 'الكشف الشهري') %></div>
      <div class="v2-card__sub"><%= _t('Last 24 months. Add-on totals include video consult and prescription fees.', 'آخر 24 شهراً. تشمل إجماليات الإضافات رسوم استشارة الفيديو والوصفات.') %></div>
    </div>
    <div class="v2-card__body" style="padding:0;">
      <table style="width:100%;border-collapse:collapse;font-size:13px;">
        <thead>
          <tr style="background:#FBF9F4;border-block-end:1px solid var(--rule, #e5e7eb);">
            <th style="text-align:start;padding:10px 16px;font-weight:600;color:var(--ink, #1f2937);"><%= _t('Month', 'الشهر') %></th>
            <th style="text-align:end;padding:10px 16px;font-weight:600;color:var(--ink, #1f2937);"><%= _t('Cases', 'الحالات') %></th>
            <th style="text-align:end;padding:10px 16px;font-weight:600;color:var(--ink, #1f2937);"><%= _t('Main fees', 'الأتعاب الأساسية') %></th>
            <th style="text-align:end;padding:10px 16px;font-weight:600;color:var(--ink, #1f2937);"><%= _t('Add-ons', 'الإضافات') %></th>
            <th style="text-align:end;padding:10px 16px;font-weight:600;color:var(--ink, #1f2937);"><%= _t('Total', 'الإجمالي') %></th>
            <th style="text-align:end;padding:10px 16px;font-weight:600;color:var(--ink, #1f2937);"><%= _t('Status', 'الحالة') %></th>
          </tr>
        </thead>
        <tbody>
          <% _months.forEach(function(m) { %>
            <tr style="border-block-end:1px solid var(--rule, #e5e7eb);">
              <td style="padding:12px 16px;color:var(--ink, #1f2937);font-weight:500;"><%= _fmtMonth(m.month) %></td>
              <td style="padding:12px 16px;text-align:end;color:var(--ink-2, #6b7280);"><%= m.case_count %></td>
              <td style="padding:12px 16px;text-align:end;color:var(--ink-2, #6b7280);"><%= _fmtMoney(m.main_total) %></td>
              <td style="padding:12px 16px;text-align:end;color:var(--ink-2, #6b7280);"><%= _fmtMoney(m.addon_total) %></td>
              <td style="padding:12px 16px;text-align:end;color:var(--ink, #1f2937);font-weight:600;"><%= _fmtMoney(m.combined_total) %> <span style="font-size:11px;color:var(--muted, #6b7280);font-weight:500;"><%= _t('EGP', 'ج.م') %></span></td>
              <td style="padding:12px 16px;text-align:end;">
                <%
                  var pendingTotal = Number(m.main_pending || 0) + Number(m.addon_pending || 0);
                  var paidTotal = Number(m.main_paid || 0) + Number(m.addon_paid || 0);
                %>
                <% if (pendingTotal > 0 && paidTotal > 0) { %>
                  <span style="font-size:11px;color:var(--brass, #a07d3e);"><%= _t('Partial', 'جزئي') %></span>
                <% } else if (pendingTotal > 0) { %>
                  <span style="font-size:11px;color:var(--muted, #6b7280);"><%= _t('Pending', 'قيد التحويل') %></span>
                <% } else { %>
                  <span style="font-size:11px;color:var(--ink, #1f2937);"><%= _t('Paid', 'مدفوع') %></span>
                <% } %>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>

  <div class="v2-note" style="margin-block-start:14px;font-size:12px;color:var(--muted, #6b7280);line-height:1.5;">
    <%= _t('Earnings are calculated from your locked per-case fee plus any urgency uplift and add-on commissions. Pending amounts move to "Paid" on the next monthly payout.',
           'تُحتسب الأرباح من رسومك المسجلة لكل حالة بالإضافة إلى أي رسوم استعجال وعمولات إضافات. تنتقل المبالغ المعلقة إلى "مدفوعة" في موعد التحويل الشهري التالي.') %>
  </div>

<% } %>

<%- include('partials/footer') %>
