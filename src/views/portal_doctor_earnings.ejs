<%- include('partials/header', { title: (typeof isAr !== 'undefined' && isAr) ? 'الأرباح' : 'Earnings', layout: 'portal', showNav: true, portalFrame: true, portalRole: 'doctor', portalActive: 'earnings', portalNext: '/portal/doctor/earnings' }) %>
<%
  var _isAr = (typeof isAr !== 'undefined') ? !!isAr : false;
  function _t(en, ar) { return _isAr ? ar : en; }
%>
<%- include('partials/doctor/topbar', {
  isAr: _isAr,
  topbarTitle: _t('Earnings', 'الأرباح'),
  topbarSub: _t('Per-case fees, monthly totals and payout schedule', 'الأتعاب وإجماليات الشهر وجدول التحويلات'),
  topbarShowSearch: false
}) %>

<div class="v2-coming-soon" style="margin-block-end:18px;">
  <div class="v2-coming-soon__glyph">$</div>
  <div>
    <div class="v2-coming-soon__title"><%= _t('Coming in v1.5', 'قريباً — الإصدار 1.5') %></div>
    <div class="v2-coming-soon__sub"><%= _t('A clear monthly view of your fees, surcharges, payout dates and downloadable statements. Until then, fees per case are visible inside each case detail.', 'عرض شهري واضح للأتعاب والرسوم الإضافية ومواعيد التحويل وكشوف قابلة للتنزيل. حتى ذلك الحين، يظهر الأجر داخل كل حالة على حدة.') %></div>
  </div>
</div>

<div class="v2-card">
  <div class="v2-card__body--flush">
    <div class="v2-empty">
      <img src="/icons/doctor/23_earnings.svg" alt="" onerror="this.style.display='none'" />
      <div class="v2-empty__title"><%= _t('Statements land here in v1.5', 'الكشوف ستظهر هنا في الإصدار 1.5') %></div>
      <div class="v2-empty__msg"><%= _t('Once you have submitted reports, this page will show monthly totals, fee breakdowns by SLA tier, and downloadable statements ready for your accountant.', 'بعد إرسال التقارير، ستعرض هذه الصفحة الإجماليات الشهرية وتفاصيل الأتعاب حسب مستوى SLA وكشوف جاهزة للمحاسب.') %></div>
      <div class="v2-empty__actions">
        <a class="v2-btn v2-btn--primary" href="/portal/doctor/cases?tab=completed"><%= _t('View completed cases', 'عرض الحالات المكتملة') %></a>
      </div>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
