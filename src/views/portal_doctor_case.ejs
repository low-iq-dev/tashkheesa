<script<% if (typeof cspNonce !== 'undefined' && cspNonce) { %> nonce="<%= cspNonce %>"<% } %>>
  // Live word counter for the report editor
  (function() {
    var nodes = document.querySelectorAll('[data-wc-for]');
    nodes.forEach(function(node) {
      var id = node.getAttribute('data-wc-for');
      var ta = document.getElementById(id);
      if (!ta) return;
      var unitEn = ' words', unitAr = ' كلمة';
      var isAr = document.documentElement.dir === 'rtl';
      var unit = isAr ? unitAr : unitEn;
      function recount() {
        var t = (ta.value || '').trim();
        var c = t ? t.split(/\s+/).length : 0;
        node.textContent = c + unit;
      }
      ta.addEventListener('input', recount);
    });
  })();

  // Copy full case ID to clipboard + brief "Copied!" toast.
  // Visual audit item 6.  CSP-safe: addEventListener, no inline handlers.
  (function() {
    var isAr = document.documentElement.dir === 'rtl';
    var COPIED = isAr ? 'تم النسخ' : 'Copied!';
    var FAILED = isAr ? 'فشل النسخ' : 'Copy failed';
    function showToast(text) {
      var t = document.createElement('div');
      t.textContent = text;
      t.style.cssText = [
        'position:fixed',
        'inset-block-end:24px',
        'inset-inline-start:50%',
        'transform:translateX(-50%)',
        'padding:10px 18px',
        'background:var(--v2-ink)',
        'color:var(--v2-on-brand)',
        'border-radius:999px',
        'font-size:13px',
        'font-weight:600',
        'box-shadow:0 6px 20px rgba(15,30,45,0.25)',
        'z-index:1100',
        'opacity:0',
        'transition:opacity 200ms ease'
      ].join(';');
      document.body.appendChild(t);
      requestAnimationFrame(function() { t.style.opacity = '1'; });
      setTimeout(function() {
        t.style.opacity = '0';
        setTimeout(function() { if (t.parentNode) t.parentNode.removeChild(t); }, 250);
      }, 1400);
    }
    document.querySelectorAll('[data-copy-id]').forEach(function(btn) {
      btn.addEventListener('click', function(e) {
        e.preventDefault();
        var full = btn.getAttribute('data-copy-id') || '';
        if (!full) return;
        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(full).then(
            function() { showToast(COPIED); },
            function() { showToast(FAILED); }
          );
        } else {
          // Fallback: textarea + execCommand for older browsers.
          var ta = document.createElement('textarea');
          ta.value = full;
          ta.style.position = 'fixed';
          ta.style.opacity = '0';
          document.body.appendChild(ta);
          ta.select();
          try { document.execCommand('copy'); showToast(COPIED); }
          catch (_) { showToast(FAILED); }
          document.body.removeChild(ta);
        }
      });
    });
  })();
</script>

<% } %>
