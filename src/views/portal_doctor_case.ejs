<%- include('partials/header', { title: (typeof isAr !== 'undefined' && isAr) ? 'تفاصيل الحالة' : 'Case Detail', layout: 'portal', showNav: true, portalFrame: true, portalRole: 'doctor', portalActive: 'cases', portalNext: '/portal/doctor/cases' }) %>
<%
  // ---- Locals guards ----
  var _isAr = (typeof isAr !== 'undefined') ? !!isAr : false;
  var _lang = (typeof lang !== 'undefined' && lang) ? lang : (_isAr ? 'ar' : 'en');
  var _order = (typeof order !== 'undefined' && order) ? order : null;
  var _files = Array.isArray(typeof files !== 'undefined' ? files : []) ? files : [];
  var _accessDenied = !!(typeof accessDenied !== 'undefined' && accessDenied);
  var _blurred = !!(typeof blurred !== 'undefined' && blurred);
  var _canView = !!(typeof canViewDetails !== 'undefined' && canViewDetails);
  var _showAccept = !!(typeof showAcceptButton !== 'undefined' && showAcceptButton);
  var _isPaid = !!(typeof isPaid !== 'undefined' && isPaid);
  var _acceptUrl = (typeof acceptActionUrl !== 'undefined' && acceptActionUrl) ? String(acceptActionUrl) : '';
  var _orderIdEnc = (_order && _order.id) ? encodeURIComponent(String(_order.id)) : '';
  var _errMsg = (typeof errorMessage !== 'undefined' && errorMessage) ? String(errorMessage) : '';
  var _ctx = (typeof clinicalContext !== 'undefined' && clinicalContext) ? clinicalContext : {};


  function _initials(name) {
    if (!name) return '?';
    var parts = String(name).split(/\s+/).filter(Boolean).slice(0, 2);
    return (parts.map(function(p){ return p.charAt(0); }).join('') || '?').toUpperCase();
  }

  function _patientName() {
    var n = _order && (_order.patient_name || _order.patientName);
    var raw = n ? String(n).trim() : '';
    /* Visual audit item 12 — when the order has no name on file (or
       carries the literal "Patient" / "مريض" demo placeholder), show
       "Anonymous patient" instead so the case header doesn't read as
       a real name. */
    if (!raw || /^patient$/i.test(raw) || raw === 'مريض') {
      return tt('Anonymous patient', 'Anonymous patient', 'مريض مجهول الهوية');
    }
    return raw;
  }

  // SLA / countdown calc
  var _sla = _order && _order.sla ? _order.sla : null;
  function _countdownParts() {
    if (!_sla) return null;
    if (_sla.isBreached) {
      var over = Math.max(1, Math.ceil((Number(_sla.minutesOverdue) || 0) / 60));
      return { kind: 'breached', h: over, m: 0, sub: tt('Overdue — submit ASAP', 'Overdue — submit ASAP', 'متأخر — أرسل بأسرع وقت'), pct: 100 };
    }
    var rem = Number(_sla.minutesRemaining);
    if (!Number.isFinite(rem)) return null;
    var h = Math.floor(rem / 60);
    var m = Math.floor(rem % 60);
    var totalMin = Number(_sla.totalMinutes) || (rem + 30);
    var pct = totalMin > 0 ? Math.min(100, Math.max(0, ((totalMin - rem) / totalMin) * 100)) : 50;
    return { kind: 'ok', h: h, m: m, sub: tt('on track', 'on track', 'في المسار'), pct: pct };
  }
  var _cd = _countdownParts();

  // Status chip
  var _statusKey = String((_order && (_order.db_status || _order.status)) || '').toLowerCase();
  var _statusChip = (function(){
    if (_statusKey === 'completed') return { kind: 'green', label: tt('Submitted', 'Submitted', 'تم الإرسال') };
    if (_statusKey === 'breached' || _statusKey === 'sla_breach') return { kind: 'red', label: tt('Overdue', 'Overdue', 'متأخرة') };
    if (_statusKey === 'in_review' || _statusKey === 'review') return { kind: 'teal', label: tt('In review', 'In review', 'قيد المراجعة') };
    // Theme 7 sub-issue D (2026-05-10): 'awaiting_files' transitional
    // fallback; migration 047 converts to 'rejected_files' canonical.
    if (_statusKey === 'awaiting_files' || _statusKey === 'rejected_files') return { kind: 'brass', label: tt('Awaiting files', 'Awaiting files', 'بانتظار الملفات') };
    return { kind: 'neutral', label: tt('Preview', 'Preview', 'معاينة') };
  })();

  // Fee — doctors only see fee, never patient price (stripPricingFields strips that already)
  var _fee = (_order && (_order.doctor_fee != null ? _order.doctor_fee : _order.fee)) || null;
  var _feeFmt = _fee ? ('EGP ' + Number(_fee).toLocaleString('en-EG')) : null;

  // Existing diagnosis (server saved)
  var _exDiag = (_order && (_order.diagnosis || _order.findings)) || '';
  var _exImpr = (_order && _order.impression) || '';
  var _exRec  = (_order && (_order.recommendations || _order.recommendation)) || '';
  function _wc(s) { var t = String(s || '').trim(); return t ? t.split(/\s+/).length : 0; }
%>

<%- include('partials/doctor/topbar', {
  isAr: _isAr,
  topbarTitle: tt('Case ', 'Case ', 'الحالة ') + (_order && _order.id ? '#' + String(_order.id).slice(0, 8).toUpperCase() + '…' : ''),
  topbarSub: (_cd ? (_cd.kind === 'breached'
                      ? tt('Overdue · ' + _cd.h + 'h past due', 'Overdue · ' + _cd.h + 'h past due', 'متأخر · ' + _cd.h + 'س')
                      : tt(_cd.h + 'h ' + _cd.m + 'm remaining', _cd.h + 'h ' + _cd.m + 'm remaining', 'متبقي ' + _cd.h + 'س ' + _cd.m + 'د'))
              : (_canView ? tt('Active case', 'Active case', 'حالة نشطة') : tt('Preview mode', 'Preview mode', 'وضع المعاينة'))),
  topbarShowSearch: false,
  topbarActions: '<a class="v2-btn v2-btn--ghost" href="/portal/doctor/cases">' + (_isAr ? '→ العودة للقائمة' : '← Back to cases') + '</a>'
}) %>

<% if (_errMsg) { %>
  <div class="v2-card" style="margin-block-end:18px;border-color:#F2C9C9;">
    <div class="v2-card__body" style="display:flex;gap:12px;align-items:flex-start;">
      <div style="width:32px;height:32px;border-radius:8px;background:var(--v2-danger-bg);color:var(--v2-danger);display:flex;align-items:center;justify-content:center;font-weight:700;flex-shrink:0;">!</div>
      <div style="flex:1;">
        <div style="font-weight:600;color:var(--v2-danger);"><%= tt('Heads up', 'Heads up', 'تنبيه') %></div>
        <div style="font-size:13px;color:var(--v2-ink-2);margin-block-start:4px;"><%= _errMsg %></div>
      </div>
    </div>
  </div>
<% } %>

<% if (_accessDenied) { %>
  <div class="v2-card">
    <div class="v2-card__body--flush">
      <div class="v2-empty">
        <div class="v2-locked__glyph" style="margin:0 auto 14px;">🔒</div>
        <div class="v2-empty__title"><%= tt('Access denied', 'Access denied', 'لا توجد صلاحية') %></div>
        <div class="v2-empty__msg"><%= tt('This case is assigned to another specialist. You will not be able to view its files or details.', 'This case is assigned to another specialist. You will not be able to view its files or details.', 'هذه الحالة مخصصة لاستشاري آخر، ولا يمكنك الاطلاع على ملفاتها أو تفاصيلها.') %></div>
        <div class="v2-empty__actions">
          <a class="v2-btn v2-btn--primary" href="/portal/doctor/cases"><%= tt('Back to cases', 'Back to cases', 'العودة للحالات') %></a>
        </div>
      </div>
    </div>
  </div>
  <%- include('partials/footer') %>
<% } else { %>

<!-- Case header card -->
<div class="v2-card v2-mb-4">
  <div class="v2-case-header">
    <div class="v2-case-header__badge"><%= _initials(_patientName()) %></div>
    <div class="v2-case-header__main">
      <div class="v2-case-header__title-line">
        <h2 class="v2-case-header__title"><%= _patientName() %></h2>
        <% if (_canView) { %>
          <span class="v2-chip v2-chip--<%= _statusChip.kind %>"><%= _statusChip.label %></span>
        <% } else { %>
          <span class="v2-chip v2-chip--brass"><%= tt('Fast-track · 24h', 'Fast-track · 24h', 'سريع · 24س') %></span>
          <span class="v2-chip v2-chip--neutral"><%= tt('Preview mode', 'Preview mode', 'معاينة') %></span>
        <% } %>
        <% if (_order && (_order.specialty_name || _order.specialty_name_ar)) { %>
          <span class="v2-chip v2-chip--teal"><%= _isAr && _order.specialty_name_ar ? _order.specialty_name_ar : _order.specialty_name %></span>
        <% } %>
      </div>
      <% if (_canView && _ctx && _ctx.question) { %>
        <div class="v2-case-header__sub"><%= _ctx.question %></div>
      <% } else if (!_canView) { %>
        <div class="v2-case-header__sub">
          <%= tt('A patient is waiting for your specialist review. Accept the case to unlock files and the report editor.', 'A patient is waiting for your specialist review. Accept the case to unlock files and the report editor.', 'يوجد مريض ينتظر مراجعتك. اقبل الحالة لفتح الملفات ومحرر التقرير.') %>
        </div>
      <% } %>
      <div class="v2-case-header__meta">
        <% if (_order && _order.id) { %>
          <%# Truncated short ID for visual readability; full UUID
              copyable via the button.  Visual audit item 6. %>
          <div class="v2-case-header__meta-item">
            <div class="k"><%= tt('Case ID', 'Case ID', 'رقم الحالة') %></div>
            <div class="v" style="display:inline-flex;align-items:center;gap:6px;">
              <span data-numeric>#<%= String(_order.id).slice(0, 8).toUpperCase() %>…</span>
              <button type="button" class="v2-iconbtn v2-iconbtn--sm" style="width:24px;height:24px;padding:0;color:var(--v2-muted);"
                      data-copy-id="<%= _order.id %>"
                      aria-label="<%= tt('Copy full case ID', 'Copy full case ID', 'نسخ رقم الحالة كاملاً') %>"
                      title="<%= tt('Copy full case ID', 'Copy full case ID', 'نسخ رقم الحالة كاملاً') %>">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="9" y="9" width="13" height="13" rx="2" ry="2"/>
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                </svg>
              </button>
            </div>
          </div>
        <% } %>
        <% if (_canView && _order && _order.created_at_human) { %>
          <div class="v2-case-header__meta-item"><div class="k"><%= tt('Submitted', 'Submitted', 'تم التقديم') %></div><div class="v"><%= _order.created_at_human %></div></div>
        <% } %>
        <% if (_feeFmt) { %>
          <div class="v2-case-header__meta-item"><div class="k"><%= tt('Fee', 'Fee', 'الأجر') %></div><div class="v" style="color:var(--v2-accent);"><%= _feeFmt %></div></div>
        <% } %>
        <% if (_canView && _order && _order.patient_age) { %>
          <div class="v2-case-header__meta-item"><div class="k"><%= tt('Patient age', 'Patient age', 'عمر المريض') %></div><div class="v"><%= _order.patient_age %></div></div>
        <% } %>
        <% if (_canView && _order && _order.report_language) { %>
          <div class="v2-case-header__meta-item"><div class="k"><%= tt('Report language', 'Report language', 'لغة التقرير') %></div><div class="v"><%= _order.report_language %></div></div>
        <% } %>
      </div>
      <% if (_canView && _order && _order.id) { %>
        <%# Quick-access prescribe button. The dedicated Prescription card
            below the report carries the full description + brass CTA;
            this hero shortcut is a fast-path for doctors who already
            know what it does and want one click from the case header. %>
        <div style="margin-block-start:14px;display:flex;gap:8px;flex-wrap:wrap;">
          <a href="/portal/doctor/case/<%= _orderIdEnc %>/prescribe" class="v2-btn v2-btn--secondary v2-btn--sm" style="text-decoration:none;display:inline-flex;align-items:center;gap:6px;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            <%= tt('Write prescription', 'Write prescription', 'كتابة وصفة') %>
          </a>
        </div>
      <% } %>
    </div>
    <% if (_cd) { %>
      <div class="v2-case-header__countdown">
        <div class="v2-case-header__countdown-k"><%= tt('Time remaining', 'Time remaining', 'الوقت المتبقي') %></div>
        <div class="v2-case-header__countdown-v" data-numeric>
          <% if (_cd.kind === 'breached') { %>
            <%= _cd.h %><span>h</span> <%= tt('over', 'over', 'تأخير') %>
          <% } else { %>
            <%= _cd.h %><span>h</span> <%= _cd.m %><span>m</span>
          <% } %>
        </div>
        <div class="v2-case-header__countdown-bar"><span style="width:<%= _cd.pct %>%;"></span></div>
        <div class="v2-case-header__countdown-sub" style="<%= _cd.kind === 'breached' ? 'color:var(--v2-danger);' : '' %>"><%= _cd.sub %></div>
      </div>
    <% } %>
  </div>
</div>

<% if (!_canView) { %>
  <!-- ============== PRE-ACCEPT (locked preview) ============== -->
  <div class="v2-layout-grid">
    <div class="v2-gated">
      <div class="v2-gated__thumbs">
        <div class="v2-gated__thumb">
          <div class="v2-gated__thumb-icon">
            <img src="/icons/doctor/18_files.svg" alt="" />
          </div>
          <div class="v2-gated__thumb-label">
            <% if (_files.length) { %>
              <span data-numeric><%= _files.length %></span> <%= tt('files attached', 'files attached', 'ملفات مرفقة') %>
            <% } else { %>
              <%= tt('Files attached', 'Files attached', 'ملفات مرفقة') %>
            <% } %>
          </div>
          <div class="v2-gated__thumb-sub"><%= tt('Imaging, labs, history — full set unlocked on accept', 'Imaging, labs, history — full set unlocked on accept', 'صور وفحوص وتاريخ مرضي — تُفتح بالكامل عند القبول') %></div>
        </div>
        <div class="v2-gated__thumb v2-gated__thumb--preview">
          <div class="v2-gated__thumb-preview-img" aria-hidden="true">
            <svg viewBox="0 0 200 140" xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
              <rect width="200" height="140" fill="#0B1418" />
              <g opacity="0.38" stroke="#E8F3F1" fill="none" stroke-width="1">
                <ellipse cx="100" cy="70" rx="62" ry="44" />
                <ellipse cx="100" cy="70" rx="46" ry="32" />
                <ellipse cx="80" cy="62" rx="10" ry="14" fill="#1a2a30" />
                <ellipse cx="122" cy="62" rx="10" ry="14" fill="#1a2a30" />
                <path d="M100 50 L100 90" />
                <circle cx="78" cy="56" r="2.5" fill="#F2E4C7" opacity="0.9" />
                <circle cx="120" cy="58" r="2" fill="#F2E4C7" opacity="0.9" />
              </g>
            </svg>
          </div>
          <div class="v2-gated__thumb-label"><%= tt('Locked preview', 'Locked preview', 'معاينة مغلقة') %></div>
          <div class="v2-gated__thumb-sub"><%= tt('Full series opens on accept', 'Full series opens on accept', 'تُفتح السلسلة الكاملة بعد القبول') %></div>
        </div>
      </div>

      <div class="v2-gated__commit">
        <div class="v2-gated__commit-title"><%= tt('Accepting this case commits you to', 'Accepting this case commits you to', 'بقبولك للحالة فإنك تلتزم بـ') %></div>
        <ul class="v2-gated__commit-list">
          <li><span class="v2-gated__check">✓</span><div><b><%= tt('24-hour turnaround', '24-hour turnaround', 'إنجاز خلال 24 ساعة') %></b><em><%= tt('Submit your report before the SLA expires.', 'Submit your report before the SLA expires.', 'أرسل تقريرك قبل انتهاء المهلة.') %></em></div></li>
          <li><span class="v2-gated__check">✓</span><div><b><%= tt('Three-field structured report', 'Three-field structured report', 'تقرير بثلاثة حقول') %></b><em><%= tt('Findings · Impression · Recommendation', 'Findings · Impression · Recommendation', 'النتائج · الانطباع · التوصية') %></em></div></li>
          <% if (_feeFmt) { %>
          <li><span class="v2-gated__check">✓</span><div><b><%= _feeFmt %></b><em><%= tt('Credited on submission · paid out monthly', 'Credited on submission · paid out monthly', 'يُحسب عند الإرسال · يُسوّى شهرياً') %></em></div></li>
          <% } %>
          <li><span class="v2-gated__check">✓</span><div><b><%= tt('Audit-logged access', 'Audit-logged access', 'وصول موثّق') %></b><em><%= tt('All file views recorded for the patient record.', 'All file views recorded for the patient record.', 'تُسجّل كل عمليات فتح الملفات في سجل المريض.') %></em></div></li>
        </ul>
        <% if (_showAccept && _acceptUrl) { %>
          <form id="acceptCaseForm" class="v2-gated__actions" method="POST" action="<%= _acceptUrl %>">
            <%- (typeof csrfField === 'function') ? csrfField() : '' %>
            <button type="submit" class="v2-btn v2-btn--primary v2-btn--lg"><%= tt('Accept case', 'Accept case', 'قبول الحالة') %></button>
            <a class="v2-btn v2-btn--ghost" href="/portal/doctor/cases"><%= tt('Decline · back to queue', 'Decline · back to queue', 'رفض · العودة للقائمة') %></a>
          </form>
        <% } else if (!_isPaid) { %>
          <div class="v2-gated__actions" style="display:block;">
            <div style="background:var(--v2-warn-bg);border:1px solid #F2D8B0;border-radius:10px;padding:10px 12px;font-size:12px;color:var(--v2-warn);font-weight:600;">
              <%= tt('Payment pending · accept will unlock once the patient completes payment.', 'Payment pending · accept will unlock once the patient completes payment.', 'الدفع قيد الانتظار · سيُفتح القبول بعد إتمام الدفع.') %>
            </div>
          </div>
        <% } %>
        <div class="v2-gated__fineprint">
          <%= tt('Files are encrypted in transit and at rest (AES-256). Access requires authentication and is audit-logged per Egyptian Medical Syndicate guidelines.', 'Files are encrypted in transit and at rest (AES-256). Access requires authentication and is audit-logged per Egyptian Medical Syndicate guidelines.', 'الملفات مشفّرة أثناء النقل والتخزين (AES-256). يستلزم الوصول مصادقة وتُسجَّل العمليات وفق إرشادات نقابة الأطباء.') %>
        </div>
      </div>
    </div>

    <div class="v2-stack">
      <div class="v2-card">
        <div class="v2-card__header"><div class="v2-card__title"><%= tt('Why you got this case', 'Why you got this case', 'لماذا أُسندت إليك') %></div></div>
        <div class="v2-card__body">
          <div class="v2-intel-group">
            <div class="v2-intel-group__label"><%= tt('Specialty match', 'Specialty match', 'تطابق التخصص') %></div>
            <div class="v2-intel-group__title"><%= _order && (_isAr && _order.specialty_name_ar ? _order.specialty_name_ar : _order.specialty_name) ? (_isAr && _order.specialty_name_ar ? _order.specialty_name_ar : _order.specialty_name) : tt('Your primary specialty', 'Your primary specialty', 'تخصصك الأساسي') %></div>
            <div class="v2-intel-group__sub"><%= tt('Routed to you by clinical operations.', 'Routed to you by clinical operations.', 'وُجِّهت إليك من فريق العمليات السريرية.') %></div>
          </div>
          <div class="v2-intel-group">
            <div class="v2-intel-group__label"><%= tt('Track record', 'Track record', 'السجل') %></div>
            <div class="v2-intel-group__title"><%= tt('Trusted reviewer', 'Trusted reviewer', 'مراجِع موثوق') %></div>
            <div class="v2-intel-group__sub"><%= tt('Your SLA compliance and patient ratings made you a top match.', 'Your SLA compliance and patient ratings made you a top match.', 'التزامك بالمهلة وتقييماتك جعلك الخيار الأنسب.') %></div>
          </div>
        </div>
      </div>
      <% if (_feeFmt) { %>
      <div class="v2-card">
        <div class="v2-card__header"><div class="v2-card__title"><%= tt('Fee breakdown', 'Fee breakdown', 'تفاصيل الأجر') %></div></div>
        <div class="v2-card__body">
          <div class="v2-fee-row"><span><%= tt('Specialist fee', 'Specialist fee', 'أجر الاستشاري') %></span><span data-numeric><%= _feeFmt %></span></div>
          <div class="v2-fee-row"><span class="muted"><%= tt('Platform fee (already deducted)', 'Platform fee (already deducted)', 'رسوم المنصة (مخصومة)') %></span><span class="muted">—</span></div>
          <div class="v2-fee-row v2-fee-row--total"><span><%= tt('You receive', 'You receive', 'تستلم') %></span><span data-numeric><%= _feeFmt %></span></div>
        </div>
      </div>
      <% } %>
    </div>
  </div>

<% } else { %>
  <!-- ============== POST-ACCEPT (full case) ============== -->
  <div class="v2-layout-grid">
    <div class="v2-stack">
      <% if (_files.length) { %>
      <div class="v2-card">
        <div class="v2-card__header">
          <div class="v2-card__title"><%= tt('Patient files', 'Patient files', 'ملفات المريض') %></div>
          <span class="v2-card__title-sub"><span data-numeric><%= _files.length %></span> <%= tt('files', 'files', 'ملف') %></span>
        </div>
        <div class="v2-card__body v2-card__body--flush">
          <% _files.forEach(function(f) {
               var ext = (f.name || '').split('.').pop().toUpperCase().slice(0, 4);
          %>
            <div class="v2-file-row">
              <div class="v2-file-row__icon"><%= ext || '·' %></div>
              <div class="v2-file-row__name"><%= f.name %></div>
              <a class="v2-btn v2-btn--ghost v2-btn--sm" href="<%= f.url %>" target="_blank" rel="noopener"><%= tt('Open', 'Open', 'فتح') %></a>
            </div>
          <% }); %>
        </div>
      </div>
      <% } %>

      <% if (_statusKey !== 'completed') { %>
      <!-- Report editor — preserves field names: diagnosis, impression, recommendations -->
      <div class="v2-card">
        <div class="v2-card__header">
          <div class="v2-card__title"><%= tt('Report', 'Report', 'التقرير') %></div>
          <span class="v2-card__title-sub"><%= tt('Auto-saved as you type', 'Auto-saved as you type', 'يُحفظ تلقائياً أثناء الكتابة') %></span>
        </div>
        <form method="POST" action="/portal/doctor/case/<%= _orderIdEnc %>/diagnosis">
          <%- (typeof csrfField === 'function') ? csrfField() : '' %>
          <div class="v2-card__body" style="display:flex;flex-direction:column;gap:14px;">
            <div class="v2-field">
              <div class="v2-field__labelrow">
