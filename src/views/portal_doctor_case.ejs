            <div class="v2-intel-group__label"><%= tt('Medical history', 'Medical history', 'التاريخ المرضي') %></div>
            <div class="v2-intel-group__sub" style="white-space:pre-wrap;"><%= _ctx.medicalHistory %></div>
          </div>
          <% } %>
          <% if (_ctx.medications) { %>
          <div class="v2-intel-group">
            <div class="v2-intel-group__label"><%= tt('Current medications', 'Current medications', 'الأدوية الحالية') %></div>
            <div class="v2-intel-group__sub" style="white-space:pre-wrap;"><%= _ctx.medications %></div>
          </div>
          <% } %>
        </div>
