          <span class="v2-chip v2-chip--soon"><%= tt('Beta', 'Beta', 'تجريبي') %></span>
        </div>
        <div class="v2-card__body">
          <div class="v2-intel-group">
            <div class="v2-intel-group__label"><%= tt('Pattern recognition', 'Pattern recognition', 'تعرّف النمط') %></div>
