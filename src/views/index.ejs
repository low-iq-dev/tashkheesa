<%
  // CSP nonce for JSON-LD structured data (Theme 2 Sub-issue E item 14).
  // JSON-LD scripts are treated as data by the browser (not executed),
  // so CSP script-src doesn't block them today — adding the nonce
  // attribute is forward-compat hygiene.
  var __nonce = String(
    (typeof cspNonce !== 'undefined' && cspNonce) ||
    (typeof locals !== 'undefined' && locals && (locals.cspNonce || locals.csp_nonce || locals.nonce)) ||
    ''
  );
  var __nonceAttr = __nonce ? (' nonce="' + __nonce + '"') : '';
%><!DOCTYPE html>
<html lang="<%= lang %>" dir="<%= dir %>">
<head>
  <meta charset="utf-8" />
  <title><%= tt('home.meta.title',
    'Tashkheesa - Expert Medical Consultations',
    'تشخيصة - استشارات طبية متخصصة') %></title>
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="<%= tt('home.meta.description',
    'Get a specialist medical second opinion from board-certified Egyptian consultants. Upload your scans, labs, or reports and receive a written review within 48 hours.',
    'خد رأي طبي تاني من استشاريين مصريين معتمدين. ارفع أشعتك أو تحاليلك أو تقاريرك واستلم مراجعة مكتوبة في خلال 48 ساعة.') %>" />
  <!-- Open Graph (Facebook / WhatsApp / LinkedIn) -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Tashkheesa" />
  <meta property="og:title" content="<%= tt('home.og.title',
    'Tashkheesa — Specialist Medical Second Opinions',
    'تشخيصة — آراء طبية تانية من دكاترة متخصصين') %>" />
  <meta property="og:description" content="<%= tt('home.meta.description',
    'Get a specialist medical second opinion from board-certified Egyptian consultants. Upload your scans, labs, or reports and receive a written review within 48 hours.',
    'خد رأي طبي تاني من استشاريين مصريين معتمدين. ارفع أشعتك أو تحاليلك أو تقاريرك واستلم مراجعة مكتوبة في خلال 48 ساعة.') %>" />
  <meta property="og:image" content="https://tashkheesa.com/assets/brand/og-image.png" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:url" content="https://tashkheesa.com" />
  <meta property="og:locale" content="<%= lang === 'ar' ? 'ar_EG' : 'en_US' %>" />
  <meta property="og:locale:alternate" content="<%= lang === 'ar' ? 'en_US' : 'ar_EG' %>" />
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="<%= tt('home.og.title',
    'Tashkheesa — Specialist Medical Second Opinions',
    'تشخيصة — آراء طبية تانية من دكاترة متخصصين') %>" />
  <meta name="twitter:description" content="<%= tt('home.meta.description',
    'Get a specialist medical second opinion from board-certified Egyptian consultants. Upload your scans, labs, or reports and receive a written review within 48 hours.',
    'خد رأي طبي تاني من استشاريين مصريين معتمدين. ارفع أشعتك أو تحاليلك أو تقاريرك واستلم مراجعة مكتوبة في خلال 48 ساعة.') %>" />
  <meta name="twitter:image" content="https://tashkheesa.com/assets/brand/og-image.png" />
  <link rel="canonical" href="https://tashkheesa.com/" />

  <!-- Structured Data (JSON-LD) -->
  <script type="application/ld+json"<%- __nonceAttr %>>
  {
    "@context": "https://schema.org",
    "@type": "MedicalBusiness",
    "name": "Tashkheesa",
    "description": "Specialist medical second opinion platform connecting patients with board-certified Egyptian consultants for remote diagnostic reviews.",
    "url": "https://tashkheesa.com",
    "logo": "https://tashkheesa.com/assets/brand/og-image.png",
    "image": "https://tashkheesa.com/assets/brand/og-image.png",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Cairo",
      "addressCountry": "EG"
    },
    "priceRange": "<%= currency %> <%= priceRangeMin %> - <%= currency %> <%= priceRangeMax %>",
    "areaServed": {
      "@type": "Country",
      "name": "Egypt"
    },
    "serviceType": ["Medical Second Opinion", "Diagnostic Imaging Review", "Lab Report Review", "Specialist Consultation"],
    "availableLanguage": ["en", "ar"],
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Sunday", "Monday", "Tuesday", "Wednesday", "Thursday"],
      "opens": "09:00",
      "closes": "17:00"
    }
  }
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Noto+Sans+Arabic:wght@400;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/site/css/variables.css" />
  <link rel="stylesheet" href="/site/css/styles.css" />
  <link rel="stylesheet" href="/site/css/animations.css" />
  <link rel="stylesheet" href="/site/css/responsive.css" />
  <link rel="icon" href="/site/assets/favicons/favicon.svg" type="image/svg+xml" />
  <link rel="icon" type="image/png" sizes="32x32" href="/site/assets/favicons/favicon-32x32.png" />
  <link rel="icon" type="image/png" sizes="16x16" href="/site/assets/favicons/favicon-16x16.png" />
  <link rel="apple-touch-icon" sizes="180x180" href="/site/assets/favicons/apple-touch-icon.png" />
  <meta name="theme-color" content="#1e3a8a" />
</head>
<body>
