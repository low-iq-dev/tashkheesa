<%- include('partials/header', { title: (typeof specialty !== 'undefined' && specialty ? specialty.name : tt('specd.title_fallback', 'Specialty', 'تخصص')), layout: 'public', showNav: true }) %>
<%
  const __isAr = !!(typeof isAr !== 'undefined' && isAr);
  const __sp = (typeof specialty !== 'undefined' && specialty) ? specialty : {};
  const __services = Array.isArray(services) ? services : [];
  const __slug = (typeof slug !== 'undefined') ? String(slug) : '';

  const name = __isAr ? (__sp.name_ar || __sp.name || '') : (__sp.name || '');
  const desc = __isAr
    ? (__sp.description_ar || __sp.description || '')
    : (__sp.description || '');

  // Latin numerals everywhere — use 'en-US' formatting in both languages
  // (per Theme 10 Phase 2B/2C: Egyptians type Latin numerals online).
  function fmtPrice(amount, currency) {
    var n = Number(amount);
    if (!isFinite(n) || n <= 0) return null;
    var cur = String(currency || 'EGP').toUpperCase();
    var formatted = n.toLocaleString('en-US', { maximumFractionDigits: 0 });
    return formatted + ' ' + cur;
  }
  function fmtSla(hours) {
    var h = Number(hours);
    if (!isFinite(h) || h <= 0) return __isAr ? '72 ساعة' : '72 hours';
    var formatted = h.toLocaleString('en-US');
    if (!__isAr) return formatted + ' hours';
    // Arabic plural noun selection. Intl.PluralRules gives six-way classification;
    // we map each to the right form of "hour":
    //   one  → ساعة      (1 hour)
    //   two  → ساعتان    (dual form, no leading numeral)
    //   few  → ساعات     (3-10 hours)
    //   many → ساعة      (11-99)
    //   other → ساعة     (100+)
    var rule;
    try { rule = new Intl.PluralRules('ar-EG').select(h); } catch (_) { rule = 'other'; }
    var noun = ({ one: 'ساعة', two: 'ساعتان', few: 'ساعات', many: 'ساعة', other: 'ساعة' })[rule] || 'ساعة';
    return rule === 'two' ? noun : (formatted + ' ' + noun);
  }
%>

<style>
.specd-page { max-width: 920px; margin: 0 auto; padding: 36px 20px 80px; }

.specd-back { display: inline-flex; align-items: center; color: #2563eb; font-size: 14px; font-weight: 500; text-decoration: none; margin-bottom: 18px; }
.specd-back:hover { color: #1d4ed8; }

.specd-hero { background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%); border: 1px solid #bfdbfe; border-radius: 18px; padding: 36px 32px; margin-bottom: 36px; }
.specd-kicker { display: inline-block; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1.4px; color: #1d4ed8; background: white; padding: 5px 12px; border-radius: 50px; margin-bottom: 14px; }
.specd-hero h1 { font-size: 36px; color: #0f2d48; font-weight: 700; margin: 0 0 12px; line-height: 1.2; }
.specd-hero p { color: #334155; font-size: 16px; line-height: 1.65; margin: 0 0 22px; max-width: 640px; }
.specd-cta { display: inline-block; background: #2563eb; color: white; padding: 12px 26px; border-radius: 50px; text-decoration: none; font-weight: 600; font-size: 15px; transition: background 0.15s, transform 0.15s; }
.specd-cta:hover { background: #1d4ed8; transform: translateY(-1px); }

.specd-section { margin-bottom: 40px; }
.specd-section h2 { font-size: 22px; color: #0f2d48; font-weight: 700; margin: 0 0 8px; }
.specd-section p.section-sub { color: #6b7280; font-size: 14.5px; margin: 0 0 18px; }

.specd-services-table { width: 100%; border-collapse: collapse; background: white; border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden; }
.specd-services-table th, .specd-services-table td { padding: 14px 18px; text-align: start; font-size: 14.5px; border-bottom: 1px solid #f1f5f9; }
.specd-services-table th { background: #f8fafc; color: #475569; font-weight: 600; font-size: 12px; text-transform: uppercase; letter-spacing: 0.6px; }
.specd-services-table tr:last-child td { border-bottom: none; }
.specd-services-table .col-service { color: #0f2d48; font-weight: 500; }
.specd-services-table .col-price { color: #0f2d48; font-weight: 600; white-space: nowrap; }
.specd-services-table .col-sla { color: #475569; white-space: nowrap; }
.specd-services-table .price-na { color: #94a3b8; font-weight: 400; font-style: italic; }

.specd-tiers { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 14px; }
.specd-tier { background: white; border: 1px solid #e2e8f0; border-radius: 12px; padding: 20px; }
.specd-tier-name { font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px; color: #1d4ed8; margin-bottom: 8px; }
.specd-tier-hours { font-size: 28px; font-weight: 700; color: #0f2d48; line-height: 1; margin-bottom: 6px; }
.specd-tier-desc { font-size: 13.5px; color: #6b7280; line-height: 1.5; }

.specd-consultants { background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 14px; padding: 26px 28px; }
.specd-consultants h2 { margin-bottom: 10px; }
.specd-consultants p { color: #475569; font-size: 14.5px; line-height: 1.65; margin: 0; }

.specd-faqlink { display: flex; align-items: center; justify-content: space-between; gap: 16px; background: white; border: 1px solid #e2e8f0; border-radius: 12px; padding: 18px 22px; text-decoration: none; color: inherit; transition: border-color 0.15s; }
.specd-faqlink:hover { border-color: #93c5fd; }
.specd-faqlink-text strong { display: block; color: #0f2d48; font-size: 15px; margin-bottom: 4px; }
.specd-faqlink-text span { color: #6b7280; font-size: 13.5px; }
.specd-faqlink-arrow { color: #2563eb; font-weight: 600; font-size: 14px; flex: 0 0 auto; }

@media (max-width: 640px) {
  .specd-page { padding: 24px 16px 60px; }
  .specd-hero { padding: 24px 20px; }
  .specd-hero h1 { font-size: 26px; }
  .specd-services-table th, .specd-services-table td { padding: 11px 12px; font-size: 13.5px; }
  .specd-services-table .col-sla { display: none; }
  .specd-services-table th.col-sla { display: none; }
}
</style>

<main class="page-shell">
  <div class="page-inner">
    <div class="specd-page">

      <a class="specd-back" href="/specialties"><%= tt('specd.back', '← All specialties', '→ كل التخصصات') %></a>

      <section class="specd-hero">
        <span class="specd-kicker"><%= tt('specd.kicker', 'Medical Specialty', 'تخصص طبي') %></span>
        <h1><%= name %></h1>
        <% if (desc) { %>
          <p><%= desc %></p>
        <% } %>
        <a class="specd-cta" href="/patient/new-case?specialty=<%= encodeURIComponent(__sp.id || '') %>"><%= tt('specd.cta', 'Book a case →', 'احجز حالة ←') %></a>
      </section>

      <% if (__services.length > 0) { %>
        <section class="specd-section">
          <h2><%= tt('specd.services_title', 'Services available', 'الخدمات المتاحة') %></h2>
          <p class="section-sub"><%= tt('specd.services_sub',
            'Each service is reviewed by a specialist consultant. Final price shown at checkout.',
            'كل خدمة بيراجعها استشاري متخصص. السعر النهائي بيظهرلك عند إتمام الحجز.') %></p>
          <table class="specd-services-table">
            <thead>
              <tr>
                <th class="col-service"><%= tt('specd.col_service', 'Service', 'الخدمة') %></th>
                <th class="col-price"><%= tt('specd.col_from', 'Starting from', 'يبدأ من') %></th>
                <th class="col-sla"><%= tt('specd.col_sla', 'Standard turnaround', 'وقت الاستلام العادي') %></th>
              </tr>
            </thead>
            <tbody>
              <% __services.forEach(function (sv) {
                   var price = fmtPrice(sv.base_price, sv.currency);
                   var slaTxt = fmtSla(sv.sla_hours);
              %>
                <tr>
                  <td class="col-service"><%= sv.name %></td>
                  <td class="col-price">
                    <% if (price) { %><%= price %><% } else { %><span class="price-na"><%= tt('specd.on_request', 'On request', 'حسب الطلب') %></span><% } %>
                  </td>
                  <td class="col-sla"><%= slaTxt %></td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        </section>
      <% } %>

      <section class="specd-section">
        <h2><%= tt('specd.sla_title', 'Turnaround tiers', 'مستويات السرعة') %></h2>
        <p class="section-sub"><%= tt('specd.sla_sub',
          'Choose the urgency that matches your case. Surcharges apply to VIP and Urgent.',
          'اختار درجة الاستعجال المناسبة لحالتك. في رسوم إضافية على VIP والعاجل.') %></p>
        <div class="specd-tiers">
          <div class="specd-tier">
            <div class="specd-tier-name"><%= tt('specd.tier.standard', 'Standard', 'عادي') %></div>
            <div class="specd-tier-hours"><%= tt('specd.tier.standard_hours', '48 hours', '48 ساعة') %></div>
            <div class="specd-tier-desc"><%= tt('specd.tier.standard_desc',
              'Base price, no surcharge.',
              'السعر الأساسي، من غير رسوم إضافية.') %></div>
          </div>
          <div class="specd-tier">
            <div class="specd-tier-name">VIP</div>
            <div class="specd-tier-hours"><%= tt('specd.tier.vip_hours', '18 hours', '18 ساعة') %></div>
            <div class="specd-tier-desc"><%= tt('specd.tier.vip_desc',
              'Priority surcharge applies.',
              'في رسوم أولوية إضافية.') %></div>
          </div>
          <div class="specd-tier">
            <div class="specd-tier-name"><%= tt('specd.tier.urgent', 'Urgent', 'عاجل') %></div>
            <div class="specd-tier-hours"><%= tt('specd.tier.urgent_hours', '4 hours', '4 ساعات') %></div>
            <div class="specd-tier-desc"><%= tt('specd.tier.urgent_desc',
              'Urgent surcharge, 7 AM – 7 PM Cairo time.',
              'رسوم استعجال، متاح من 7 الصبح لـ 7 بليل بتوقيت القاهرة.') %></div>
          </div>
        </div>
      </section>

      <section class="specd-section">
        <div class="specd-consultants">
          <h2><%= tt('specd.cons_title',
            'Reviewed by board-certified consultants',
            'مراجعة من استشاريين معتمدين') %></h2>
          <p><%= tt('specd.cons_body',
            'Every case is assigned to a specialist with verified credentials and senior consultant standing at established Egyptian hospitals. All Tashkheesa doctors hold board certification in their specialty and have substantial clinical experience.',
            'كل حالة بتروح لاستشاري بمؤهلات موثقة ومنصب استشاري كبير في مستشفى مصري معروف. كل دكاترة تشخيصة معتمدين في تخصصاتهم وعندهم خبرة سريرية كبيرة.') %></p>
        </div>
      </section>

      <section class="specd-section">
        <a class="specd-faqlink" href="/faq#how-it-works">
          <div class="specd-faqlink-text">
            <strong><%= tt('specd.faq_title', 'How does it work?', 'إزاي بتشتغل المنصة؟') %></strong>
            <span><%= tt('specd.faq_body',
              'Upload your scans, lab results, or test reports. A board-certified specialist reviews them and sends you a written second opinion in 4 to 48 hours.',
              'ارفع أشعتك أو تحاليلك أو تقاريرك الطبية. استشاري معتمد بيراجعها وبيبعتلك رأي تاني مكتوب في خلال 4 لـ 48 ساعة.') %></span>
          </div>
          <span class="specd-faqlink-arrow"><%= tt('specd.faq_link', 'Read full FAQ →', 'اقرأ كل الأسئلة الشائعة ←') %></span>
        </a>
      </section>

    </div>
  </div>
</main>

<%- include('partials/footer') %>
