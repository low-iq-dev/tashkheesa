<%
  // Soft-deleted orders. Locals: orders, restored (bool), restoreError (string|null).
  var isAr = (typeof lang !== 'undefined' && lang === 'ar');
  var _orders = (typeof orders !== 'undefined' && orders) ? orders : [];
  var _restored = (typeof restored !== 'undefined') ? !!restored : false;
  var _restoreError = (typeof restoreError !== 'undefined') ? restoreError : null;
  var _nonce = (typeof cspNonce !== 'undefined' && cspNonce) ? cspNonce : '';

  function _fmtWhen(iso) {
    if (!iso) return '—';
    var d = new Date(iso);
    if (Number.isNaN(d.getTime())) return '—';
    var diffMs = Date.now() - d.getTime();
    var mins = Math.round(diffMs / 60000);
    if (mins < 60) return mins + 'm ago';
    var hrs = Math.round(mins / 60);
    if (hrs < 24) return hrs + 'h ago';
    var days = Math.round(hrs / 24);
    return days + 'd ago';
  }
%>
<%- include('partials/superadmin/header', {
      title: 'Trash',
      currentSection: 'orders',
      user: user,
      lang: lang || 'en',
      showTabBar: false,
      sidebarBadges: (typeof sidebarBadges !== 'undefined' && sidebarBadges) ? sidebarBadges : {},
      cspNonce: _nonce
    }) %>

<%- include('partials/superadmin/page_header', {
      title: isAr ? 'الطلبات المحذوفة' : 'Trash',
      subtitle: isAr
        ? 'الحالات التي تم حذفها تلقائياً (غير مدفوعة بعد 48 ساعة) أو يدوياً. الاستعادة تُعيد الحالة إلى مجموعة الحالات النشطة.'
        : 'Cases auto-deleted (unpaid after 48h) or manually soft-deleted. Restore returns a case to the live set.',
      breadcrumb: [
        { label: 'Dashboard', href: '/superadmin' },
        { label: 'Cases', href: '/superadmin/orders' },
        { label: 'Trash' }
      ],
      actionsHtml: '<a class="btn" href="/superadmin/orders">Back to cases</a>'
    }) %>

<div class="page-body">
  <% if (_restored) { %>
    <div class="flash ok"><strong><%= isAr ? 'تم الاسترجاع.' : 'Restored.' %></strong> <%= isAr ? 'تمت إعادة الطلب إلى مجموعة الحالات النشطة.' : 'The case is back in the live set.' %></div>
  <% } %>
  <% if (_restoreError) { %>
    <div class="flash err"><strong><%= isAr ? 'تعذّر الاسترجاع.' : 'Restore failed.' %></strong>
      <%= _restoreError === 'not_deleted'
            ? (isAr ? 'الطلب غير محذوف.' : 'That case is not in the trash.')
            : _restoreError %>
    </div>
  <% } %>

  <%- include('partials/superadmin/c_card_open', { tight: true }) %>
    <% if (!_orders.length) { %>
      <%- include('partials/superadmin/c_empty', { title: isAr ? 'لا توجد طلبات محذوفة.' : 'No deleted cases', sub: isAr ? 'الطلبات المحذوفة ستظهر هنا.' : 'Soft-deleted cases will appear here.' }) %>
    <% } else { %>
      <%- include('partials/superadmin/c_table_open', { headers: [
            isAr ? 'الرقم المرجعي' : 'Reference',
            isAr ? 'المعرّف' : 'ID',
            isAr ? 'المريض' : 'Patient',
            isAr ? 'الحالة' : 'Status',
            isAr ? 'الدفع' : 'Payment',
            isAr ? 'تاريخ الإنشاء' : 'Created',
            isAr ? 'تاريخ الحذف' : 'Deleted',
            ''
          ] }) %>
        <% _orders.forEach(function(o) { %>
          <tr>
            <td class="id"><%= o.reference_id || '—' %></td>
            <td class="id"><%= String(o.id).slice(0, 8) %></td>
            <td>
              <% if (o.patient_name) { %><%= o.patient_name %><% } %>
              <% if (o.patient_email) { %><div style="font-size:11px;color:var(--fg-3);"><%= o.patient_email %></div><% } %>
              <% if (!o.patient_name && !o.patient_email) { %><span style="color:var(--fg-3);">—</span><% } %>
            </td>
            <td><%- include('partials/superadmin/c_chip', { label: o.status || '—', tone: 'neutral' }) %></td>
            <td><span style="color:var(--fg-3);font-size:11.5px;"><%= o.payment_status || 'unpaid' %></span></td>
            <td class="mono" style="color:var(--fg-3);font-size:11.5px;"><%= _fmtWhen(o.created_at) %></td>
            <td class="mono" style="color:var(--fg-3);font-size:11.5px;"><%= _fmtWhen(o.deleted_at) %></td>
            <td style="text-align:end;">
              <form method="post" action="/superadmin/orders/<%= o.id %>/restore" style="display:inline;" data-confirm-msg="<%= isAr ? 'استعادة هذا الطلب؟' : 'Restore this case?' %>">
                <%- (typeof csrfField === 'function') ? csrfField() : '' %>
                <button type="submit" class="btn"><%= isAr ? 'استعادة' : 'Restore' %></button>
              </form>
            </td>
          </tr>
        <% }); %>
      <%- include('partials/superadmin/c_table_close') %>
    <% } %>
  <%- include('partials/superadmin/c_card_close') %>
</div>

<script<% if (_nonce) { %> nonce="<%= _nonce %>"<% } %>>
(function() {
  document.querySelectorAll('form[data-confirm-msg]').forEach(function(f) {
    f.addEventListener('submit', function(ev) {
      if (!window.confirm(f.dataset.confirmMsg || 'Are you sure?')) ev.preventDefault();
    });
  });
})();
</script>

<%- include('partials/superadmin/footer', { isAr: isAr }) %>
