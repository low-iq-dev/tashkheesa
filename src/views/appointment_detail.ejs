<%- include('partials/header', { title: tt('appt.page_title', 'Appointment Details', 'تفاصيل الموعد'), layout: 'portal', showNav: false, portalFrame: true, portalRole: (typeof portalRole !== 'undefined' ? portalRole : 'patient'), portalActive: 'appointments' }) %>
<%
  const appt = (typeof appointment !== 'undefined' && appointment) ? appointment : {};
  const statusMap = {
    pending:   { label: tt('appt.status.pending',   'Pending',   'قيد الانتظار'),  color: '#D97706', bg: '#FFFBEB' },
    confirmed: { label: tt('appt.status.confirmed', 'Confirmed', 'متأكد'),         color: '#059669', bg: '#ECFDF5' },
    completed: { label: tt('appt.status.completed', 'Completed', 'مكتمل'),         color: '#6B7280', bg: '#F3F4F6' },
    cancelled: { label: tt('appt.status.cancelled', 'Cancelled', 'متلغي'),         color: '#DC2626', bg: '#FEF2F2' },
    no_show:   { label: tt('appt.status.no_show',   'No Show',   'مجاش'),           color: '#DC2626', bg: '#FEF2F2' }
  };
  const st = statusMap[appt.status] || { label: appt.status || tt('appt.status.unknown', 'Unknown', 'غير معروف'), color: '#6B7280', bg: '#F3F4F6' };

  function fmtDate(iso) {
    if (!iso) return '—';
    const d = new Date(iso);
    const dd = String(d.getDate()).padStart(2, '0');
    const mm = String(d.getMonth() + 1).padStart(2, '0');
    const yyyy = d.getFullYear();
    let hh = d.getHours();
    const min = String(d.getMinutes()).padStart(2, '0');
    const ampm = hh >= 12 ? 'PM' : 'AM';
    hh = hh % 12 || 12;
    return dd + '/' + mm + '/' + yyyy + ' ' + hh + ':' + min + ' ' + ampm;
  }

  const canCancel = (appt.status === 'pending' || appt.status === 'confirmed');
  const canJoin = (appt.status === 'confirmed' && appt.video_call_id);
%>

<div class="admin-page">
  <div class="admin-page-header">
    <div class="admin-page-header-left">
      <nav class="admin-breadcrumb">
        <a href="<%= portalRole === 'doctor' ? '/portal/doctor' : '/dashboard' %>"><%= tt('appt.crumb.dashboard', 'Dashboard', 'لوحة التحكم') %></a>
        <span class="admin-breadcrumb-sep">&rsaquo;</span>
        <a href="/portal/appointments"><%= tt('appt.crumb.appointments', 'Appointments', 'المواعيد') %></a>
        <span class="admin-breadcrumb-sep">&rsaquo;</span>
        <span><%= tt('appt.crumb.details', 'Details', 'التفاصيل') %></span>
      </nav>
      <h1 class="admin-page-title"><%= tt('appt.page_title', 'Appointment Details', 'تفاصيل الموعد') %></h1>
    </div>
  </div>

  <div style="display:grid; grid-template-columns:1fr 1fr; gap:24px; margin-top:24px;">
    <!-- Left: Status & Schedule -->
    <div class="card" style="padding:24px;">
      <div style="display:flex; align-items:center; gap:12px; margin-bottom:20px;">
        <span style="display:inline-block; padding:4px 12px; border-radius:12px; font-size:13px; font-weight:600; color:<%= st.color %>; background:<%= st.bg %>;"><%= st.label %></span>
        <span style="color:#6B7280; font-size:13px;"><%= tt('appt.id_label', 'ID', 'الرقم') %>: <%= appt.id ? appt.id.substring(0, 8) : '—' %></span>
      </div>

      <div style="margin-bottom:16px;">
        <label style="font-size:13px; color:#6B7280; display:block; margin-bottom:4px;"><%= tt('appt.scheduled', 'Scheduled', 'موعد المعاد') %></label>
        <p style="font-size:16px; font-weight:600;"><%= fmtDate(appt.scheduled_at) %></p>
      </div>

      <div style="margin-bottom:16px;">
        <label style="font-size:13px; color:#6B7280; display:block; margin-bottom:4px;"><%= tt('appt.duration', 'Duration', 'المدة') %></label>
        <p style="font-size:16px;"><%= appt.duration_minutes || 30 %> <%= tt('appt.minutes', 'minutes', 'دقيقة') %></p>
      </div>

      <% if (appt.doctor_name) { %>
      <div style="margin-bottom:16px;">
        <label style="font-size:13px; color:#6B7280; display:block; margin-bottom:4px;"><%= tt('appt.specialist', 'Specialist', 'الدكتور المتخصص') %></label>
        <p style="font-size:16px; font-weight:600;"><%= tt('appt.dr_prefix', 'Dr.', 'د.') %> <%= appt.doctor_name %></p>
      </div>
      <% } %>

      <% if (appt.price) { %>
      <div style="margin-bottom:16px;">
        <label style="font-size:13px; color:#6B7280; display:block; margin-bottom:4px;"><%= tt('appt.fee', 'Fee', 'الرسوم') %></label>
        <p style="font-size:16px; font-weight:600;"><%= appt.price %> EGP</p>
      </div>
      <% } %>

      <% if (appt.cancel_reason) { %>
      <div style="margin-bottom:16px;">
        <label style="font-size:13px; color:#6B7280; display:block; margin-bottom:4px;"><%= tt('appt.cancel_reason', 'Cancellation Reason', 'سبب الإلغاء') %></label>
        <p style="font-size:14px; color:#DC2626;"><%= appt.cancel_reason %></p>
      </div>
      <% } %>

      <div>
        <label style="font-size:13px; color:#6B7280; display:block; margin-bottom:4px;"><%= tt('appt.created', 'Created', 'تم إنشاؤه') %></label>
        <p style="font-size:14px;"><%= fmtDate(appt.created_at) %></p>
      </div>
    </div>

    <!-- Right: Actions & Notes -->
    <div class="card" style="padding:24px;">
      <h3 style="margin-bottom:16px;"><%= tt('appt.actions', 'Actions', 'الإجراءات') %></h3>

      <div style="display:flex; flex-direction:column; gap:12px;">
        <% if (canJoin) { %>
        <a href="/portal/video/<%= appt.video_call_id %>" class="p-btn p-btn-primary p-btn-lg" style="text-align:center;">
          <%= tt('appt.join_video', 'Join Video Call', 'ادخل مكالمة الفيديو') %>
        </a>
        <% } %>

        <% if (canCancel) { %>
        <button type="button" id="cancelBtn" class="p-btn p-btn-secondary" style="color:#DC2626; border-color:#DC2626;">
          <%= tt('appt.cancel_btn', 'Cancel Appointment', 'إلغاء الموعد') %>
        </button>
        <% } %>

        <a href="/portal/appointments" class="p-btn p-btn-ghost" style="text-align:center;">
          <%= tt('appt.back', 'Back to Appointments', 'ارجع للمواعيد') %>
        </a>
      </div>

      <% if (appt.case_notes) { %>
      <div style="margin-top:24px;">
        <h3 style="margin-bottom:8px;"><%= tt('appt.case_notes', 'Case Notes', 'ملاحظات الحالة') %></h3>
        <div style="padding:12px; background:#F9FAFB; border-radius:8px; font-size:14px; color:#374151; white-space:pre-wrap;"><%= appt.case_notes %></div>
      </div>
      <% } %>

      <% if (appt.notes) { %>
      <div style="margin-top:16px;">
        <h3 style="margin-bottom:8px;"><%= tt('appt.notes', 'Notes', 'ملاحظات') %></h3>
        <div style="padding:12px; background:#F9FAFB; border-radius:8px; font-size:14px; color:#374151; white-space:pre-wrap;"><%= appt.notes %></div>
      </div>
      <% } %>
    </div>
  </div>
</div>

<%- include('partials/footer', { showFooter: false }) %>

<% if (canCancel) { %>
<% var _nonce = (typeof locals !== 'undefined' && locals && (locals.cspNonce || locals.csp_nonce || locals.nonce)) ? String(locals.cspNonce || locals.csp_nonce || locals.nonce) : ''; %>
<script<% if (_nonce) { %> nonce="<%= _nonce %>"<% } %>>
(function() {
  var cancelBtn = document.getElementById('cancelBtn');
  if (!cancelBtn) return;
  var csrfToken = '<%= typeof csrfToken !== "undefined" && csrfToken ? csrfToken : "" %>';
  var PROMPT_REASON = <%- JSON.stringify(tt('appt.prompt.reason', 'Please provide a reason for cancellation:', 'اكتب سبب الإلغاء لو سمحت:')) %>;
  var BTN_CANCEL_LABEL = <%- JSON.stringify(tt('appt.cancel_btn', 'Cancel Appointment', 'إلغاء الموعد')) %>;
  var BTN_CANCELLING = <%- JSON.stringify(tt('appt.cancelling', 'Cancelling...', 'جاري الإلغاء...')) %>;
  var ERR_FAIL = <%- JSON.stringify(tt('appt.err.fail', 'Failed to cancel', 'فشل الإلغاء')) %>;
  var ERR_NETWORK = <%- JSON.stringify(tt('appt.err.network', 'Network error', 'خطأ في الاتصال')) %>;
  cancelBtn.addEventListener('click', function() {
    var reason = prompt(PROMPT_REASON);
    if (reason === null) return;
    cancelBtn.disabled = true;
    cancelBtn.textContent = BTN_CANCELLING;
    fetch('/portal/appointments/<%= appt.id %>/cancel', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-csrf-token': csrfToken },
      body: JSON.stringify({ reason: reason })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
      if (data.ok) {
        window.location.reload();
      } else {
        alert(data.error || ERR_FAIL);
        cancelBtn.disabled = false;
        cancelBtn.textContent = BTN_CANCEL_LABEL;
      }
    })
    .catch(function() {
      alert(ERR_NETWORK);
      cancelBtn.disabled = false;
      cancelBtn.textContent = BTN_CANCEL_LABEL;
    });
  });
})();
</script>
<% } %>
