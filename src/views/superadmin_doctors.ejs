<%
  // Doctors list. Locals: doctors, specialties, statusFilter,
  //                       pendingDoctorsCount, pausedDoctorsCount.
  var isAr = (typeof lang !== 'undefined' && lang === 'ar');
  var _doctors = (typeof doctors !== 'undefined' && doctors) ? doctors : [];
  var _statusFilter = (typeof statusFilter !== 'undefined' && statusFilter) ? statusFilter : 'all';
  var _pending = (typeof pendingDoctorsCount !== 'undefined') ? Number(pendingDoctorsCount) || 0 : 0;
  var _paused = (typeof pausedDoctorsCount !== 'undefined') ? Number(pausedDoctorsCount) || 0 : 0;

  function _docStatusChip(d) {
    if (d.pending_approval) return { label: 'Pending', tone: 'amber' };
    if (!d.is_active && d.rejection_reason) return { label: 'Rejected', tone: 'red' };
    if (!d.is_active) return { label: 'Inactive', tone: 'neutral' };
    if (d.is_paused) return { label: 'Paused', tone: 'amber' };
    return { label: 'Active', tone: 'green' };
  }

  function _fmtWhen(iso) {
    if (!iso) return '—';
    var d = new Date(iso);
    if (Number.isNaN(d.getTime())) return '—';
    var diffMs = Date.now() - d.getTime();
    var mins = Math.round(diffMs / 60000);
    if (mins < 60) return mins + 'm ago';
    var hrs = Math.round(mins / 60);
    if (hrs < 24) return hrs + 'h ago';
    var days = Math.round(hrs / 24);
    return days + 'd ago';
  }

  var _filterTabs = [
    { id: 'all', label: isAr ? 'الكل' : 'All' },
    { id: 'pending', label: isAr ? 'قيد المراجعة' : 'Pending', count: _pending, tone: 'amber' },
    { id: 'approved', label: isAr ? 'مفعل' : 'Approved' },
    { id: 'rejected', label: isAr ? 'مرفوض' : 'Rejected' },
    { id: 'inactive', label: isAr ? 'غير نشط' : 'Inactive' },
    { id: 'paused', label: isAr ? 'معلق' : 'Paused', count: _paused, tone: 'red' }
  ];
%>
<%- include('partials/superadmin/header', {
      title: isAr ? 'الأطباء' : 'Doctors',
      currentSection: 'doctors',
      user: user,
      lang: lang || 'en',
      showTabBar: false,
      sidebarBadges: (typeof sidebarBadges !== 'undefined' && sidebarBadges) ? sidebarBadges : {},
      cspNonce: (typeof cspNonce !== 'undefined') ? cspNonce : ''
    }) %>

<%- include('partials/superadmin/page_header', {
      title: isAr ? 'الأطباء' : 'Doctors',
      subtitle: isAr ? 'إدارة حسابات الأطباء.' : 'Manage doctor accounts and onboarding.',
      breadcrumb: [
        { label: 'Dashboard', href: '/superadmin' },
        { label: isAr ? 'الأطباء' : 'Doctors' }
      ],
      actionsHtml: '<a class="btn primary" href="/superadmin/doctors/new">+ ' + (isAr ? 'إضافة طبيب' : 'Add doctor') + '</a>'
    }) %>

<div class="page-body">
  <%- include('partials/superadmin/c_card_open', { title: 'Filters', tight: true }) %>
    <div style="display:flex;gap:6px;flex-wrap:wrap;padding:12px 14px;">
      <% _filterTabs.forEach(function(t) {
           var isActive = _statusFilter === t.id;
      %>
        <a href="/superadmin/doctors?status=<%= t.id %>"
           class="chip<%= isActive ? ' accent' : '' %>"
           style="text-decoration:none;cursor:pointer;<% if (isActive) { %>font-weight:600;<% } %>">
          <%= t.label %>
          <% if (t.count != null && t.count > 0) { %>
            <span style="margin-inline-start:6px;font-variant-numeric:tabular-nums;<% if (t.tone === 'red') { %>color:var(--red);<% } else if (t.tone === 'amber') { %>color:var(--amber);<% } %>"><%= t.count %></span>
          <% } %>
        </a>
      <% }); %>
    </div>
  <%- include('partials/superadmin/c_card_close') %>

  <div class="section-h standalone" style="margin-top:16px;"><h2><%= isAr ? 'الأطباء' : 'Doctors' %> · <%= _doctors.length %></h2></div>
  <%- include('partials/superadmin/c_card_open', { tight: true }) %>
    <% if (!_doctors.length) { %>
      <%- include('partials/superadmin/c_empty', { title: isAr ? 'لا يوجد أطباء.' : 'No doctors match this filter' }) %>
    <% } else { %>
      <%- include('partials/superadmin/c_table_open', { headers: ['Name', 'Email', 'Specialty', 'Phone', 'Status', 'Created', 'Notes', { label: 'Actions', align: 'end' }] }) %>
        <% _doctors.forEach(function(d) {
             var chip = _docStatusChip(d);
        %>
          <tr>
            <td>
              <div style="display:flex;align-items:center;gap:10px;">
                <%- include('partials/superadmin/c_avatar', { name: d.name || 'Doctor' }) %>
                <a href="/superadmin/doctors/<%= d.id %>" style="color:inherit;font-weight:500;"><%= d.name || 'Doctor' %></a>
              </div>
            </td>
            <td><%= d.email || '—' %></td>
            <td><% if (d.specialty_name) { %><span class="spec-tag"><%= d.specialty_name %></span><% } else { %>—<% } %></td>
            <td class="mono" style="font-size:11.5px;"><%= d.phone || '—' %></td>
            <td><%- include('partials/superadmin/c_chip', { label: chip.label, tone: chip.tone, dot: true }) %></td>
            <td class="mono" style="color:var(--fg-3);font-size:11.5px;"><%= _fmtWhen(d.created_at) %></td>
            <td style="max-width:240px;color:var(--fg-3);font-size:11.5px;"><% if (d.signup_notes) { %><%= String(d.signup_notes).slice(0, 80) %><% if (String(d.signup_notes).length > 80) { %>…<% } %><% } else { %>—<% } %></td>
            <td style="text-align:end;">
              <div style="display:inline-flex;gap:6px;flex-wrap:wrap;justify-content:flex-end;">
                <a class="btn" href="/superadmin/doctors/<%= d.id %>">View</a>
                <a class="btn" href="/superadmin/doctors/<%= d.id %>/edit">Edit</a>
                <% if (!d.pending_approval) { %>
                  <form method="post" action="/superadmin/doctors/<%= d.id %>/toggle" style="display:inline;">
                    <%- (typeof csrfField === 'function') ? csrfField() : '' %>
                    <button type="submit" class="btn"><%= d.is_active ? 'Deactivate' : 'Activate' %></button>
                  </form>
                  <% if (!d.rejection_reason) { %>
                    <form method="post" action="/superadmin/doctors/<%= d.id %>/resend-welcome" style="display:inline;" title="Re-issue a fresh 7-day magic link and re-queue the welcome email">
                      <%- (typeof csrfField === 'function') ? csrfField() : '' %>
                      <button type="submit" class="btn">Resend welcome</button>
                    </form>
                  <% } %>
                <% } %>
              </div>
            </td>
          </tr>
        <% }); %>
      <%- include('partials/superadmin/c_table_close') %>
    <% } %>
  <%- include('partials/superadmin/c_card_close') %>
</div>

<%- include('partials/superadmin/footer', { isAr: isAr }) %>
