<%
  // Diagnosis Report — V2 chrome (download/print fallback viewer).
  //
  // The canonical patient-facing report viewer is the V2 case-detail Report
  // tab at /portal/patient/orders/:id?tab=report. THIS view is the
  // /portal/case/:caseId/report fallback used by:
  //   • email links to the report URL
  //   • download/print flows
  //   • doctor + admin previewers (same template, role-gated extras)
  //
  // Privacy invariant (Fix 1): report-text columns must come from
  // `reportContent` only — never from `order`. The route handler enforces
  // this by SELECTing a privacy-safe column allowlist for `order` and
  // calling loadReportContentForPatient() for `reportContent`.
  //
  // Locals from src/routes/reports.js GET /portal/case/:caseId/report:
  //   user, lang, isAr
  //   order            — privacy-safe row (NO report text, NO patient notes)
  //   patient, doctor, specialty, service
  //   files, annotations
  //   existingReport, reportHistory
  //   reportContent    — { diagnosis_text, impression_text, recommendation_text,
  //                         clinical_question, doctor_name, specialty_name,
  //                         reference_code, completed_at } or null
  //   isDoctor, isAdmin, isPatient

  const __isAr = !!(typeof isAr !== 'undefined' && isAr);
  const __lang = (typeof lang === 'string' && lang) ? lang : (__isAr ? 'ar' : 'en');
  const __user = (typeof user !== 'undefined' && user) ? user : {};
  const __order = (typeof order !== 'undefined' && order) ? order : {};
  const __patient = (typeof patient !== 'undefined' && patient) ? patient : {};
  const __doctor = (typeof doctor !== 'undefined' && doctor) ? doctor : {};
  const __specialty = (typeof specialty !== 'undefined' && specialty) ? specialty : {};
  const __service = (typeof service !== 'undefined' && service) ? service : {};
  const __files = Array.isArray(files) ? files : [];
  const __annotations = Array.isArray(annotations) ? annotations : [];
  const __reportHistory = Array.isArray(reportHistory) ? reportHistory : [];
  const __existingReport = (typeof existingReport !== 'undefined' && existingReport) ? existingReport : null;
  const __reportContent = (typeof reportContent !== 'undefined' && reportContent) ? reportContent : null;
  const __isDoctor = !!(typeof isDoctor !== 'undefined' && isDoctor);
  const __isAdmin = !!(typeof isAdmin !== 'undefined' && isAdmin);
  const __isPatient = !!(typeof isPatient !== 'undefined' && isPatient);
  function L(en, ar) { return __isAr ? ar : en; }

  const caseRef = (__reportContent && __reportContent.reference_code)
    || __order.reference_code
    || ('TSH-' + String(__order.id || '').slice(0, 12).toUpperCase());
  const issuedDate = __order.completed_at || (__reportContent && __reportContent.completed_at) || __order.updated_at;
  const issuedDay = issuedDate ? (function() {
    try {
      const dt = new Date(issuedDate);
      if (isNaN(dt.getTime())) return '';
      return dt.toLocaleDateString(__isAr ? 'ar-EG' : 'en-GB', { weekday: 'short', day: 'numeric', month: 'short', year: 'numeric' });
    } catch (_) { return ''; }
  })() : '';
  const docName = (__reportContent && __reportContent.doctor_name) || __doctor.name || '';
  const specName = (__reportContent && __reportContent.specialty_name) || __specialty.name || '';
  const sections = __reportContent ? [
    { h: L('Clinical question', 'السؤال السريري'),  b: __reportContent.clinical_question || '' },
    { h: L('Findings', 'النتائج'),                   b: __reportContent.diagnosis_text    || '' },
    { h: L('Impression', 'الانطباع'),                b: __reportContent.impression_text   || '' },
    { h: L('Recommendation', 'التوصية'),             b: __reportContent.recommendation_text || '' }
  ].filter(s => s.b && String(s.b).trim().length > 0) : [];
%>
<%- include('partials/patient/head', {
  active: 'cases',
  title: L('Diagnosis report', 'تقرير التشخيص'),
  user: __user,
  lang: __lang,
  bodyClass: 'p-page-report'
}) %>

<%- include('partials/patient/topbar', {
  title: L('Your report', 'تقريرك'),
  sub: docName ? L(docName + ' — ' + (issuedDay || ''), docName + ' — ' + (issuedDay || '')) : (issuedDay || ''),
  serif: true,
  isAr: __isAr,
  actions: '<span class="p-chip p-chip--teal">' + (__isAr ? 'مكتمل' : 'Complete') + '</span>'
}) %>

<%# Action bar — print, download, back. Hidden in @media print. %>
<div class="p-report-actions" style="display:flex;flex-wrap:wrap;gap:10px;margin-bottom:18px;">
  <button type="button" class="p-btn p-btn--secondary" id="print-report-btn">
    <%- include('partials/patient/icon', { name: 'eye', size: 14 }) %>
    <%= L('Print', 'طباعة') %>
  </button>
  <% if (__order.report_url) { %>
    <a class="p-btn p-btn--primary" href="<%= __order.report_url %>" download="Tashkheesa-Report-<%= caseRef %>.pdf">
      <%- include('partials/patient/icon', { name: 'download', size: 14 }) %>
      <%= L('Download PDF', 'تنزيل PDF') %>
    </a>
  <% } else if (__existingReport) { %>
    <a class="p-btn p-btn--primary" href="/portal/case/<%= __order.id %>/download-report" download="Tashkheesa-Report-<%= caseRef %>.pdf">
      <%- include('partials/patient/icon', { name: 'download', size: 14 }) %>
      <%= L('Download PDF', 'تنزيل PDF') %>
    </a>
  <% } %>
  <% if (__isPatient && __order.id) { %>
    <a class="p-btn p-btn--ghost" href="/portal/patient/orders/<%= __order.id %>?tab=messages">
      <%- include('partials/patient/icon', { name: 'message', size: 14 }) %>
      <%= L('Ask a question', 'اطرح سؤالاً') %>
    </a>
  <% } %>
  <% if (__isDoctor) { %>
    <button type="button" class="p-btn p-btn--secondary" data-action="generate-pdf" id="generatePdfBtn">
      <%= L('Generate new PDF', 'إنشاء PDF جديد') %>
    </button>
    <button type="button" class="p-btn p-btn--secondary" data-action="email-report" id="emailReportBtn">
      <%= L('Email to patient', 'إرسال للمريض') %>
    </button>
  <% } %>
  <a class="p-btn p-btn--ghost"
     href="<%= __isPatient ? ('/portal/patient/orders/' + __order.id + '?tab=report') : (__isDoctor ? '/portal/doctor/case/' + __order.id : '/dashboard') %>">
    <%= L('Back', 'رجوع') %>
  </a>
</div>

<%# Letterhead — mirrors the V2 case-detail Report tab. %>
<div class="p-report-document p-card" style="padding:36px 44px;margin-bottom:18px;">
  <%# Masthead %>
  <div style="text-align:center;padding-bottom:24px;margin-bottom:24px;border-bottom:1px solid var(--rule);">
    <div class="p-sidebar__tile" aria-hidden="true" style="width:42px;height:42px;font-size:24px;margin:0 auto 10px;">ت</div>
    <div style="font-family:var(--font-display);font-size:22px;font-weight:500;letter-spacing:-0.005em;">
      <%= L('Medical Second Opinion', 'الرأي الطبي الثاني') %>
    </div>
    <div style="font-size:11.5px;color:var(--muted);margin-top:6px;font-family:var(--font-mono);">
      <%= caseRef %>
      <% if (issuedDay) { %> · <%= L('Issued', 'صادر في') %> <%= issuedDay %><% } %>
    </div>
  </div>

  <%# Patient + specialist info row %>
  <div style="display:grid;grid-template-columns:1fr 1fr;gap:20px;padding-bottom:24px;margin-bottom:24px;border-bottom:1px solid var(--rule);font-size:12.5px;">
    <div>
      <div style="font-size:10.5px;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);font-weight:700;"><%= L('Patient', 'المريض') %></div>
      <div style="margin-top:4px;color:var(--ink);"><%= __patient.name || L('Patient', 'المريض') %></div>
    </div>
    <div>
      <div style="font-size:10.5px;text-transform:uppercase;letter-spacing:0.12em;color:var(--muted);font-weight:700;"><%= L('Consulting specialist', 'الطبيب المستشار') %></div>
      <div style="margin-top:4px;color:var(--ink);">
        <%= docName || L('—', '—') %>
        <% if (specName) { %><br/><span style="color:var(--ink-2);"><%= specName %></span><% } %>
      </div>
    </div>
  </div>

  <%# Report sections — only render those with content, identical to V2 viewer. %>
  <% if (sections.length === 0) { %>
    <div style="padding:18px 22px;background:var(--surface-2);border:1px solid var(--rule);border-radius:10px;color:var(--ink-2);font-size:13.5px;line-height:1.6;">
      <%= L('Report content has not been added yet. Once your specialist completes the written opinion, it will appear here.',
            'لم تتم إضافة محتوى التقرير بعد. سيظهر هنا فور انتهاء الطبيب من كتابة رأيه.') %>
    </div>
  <% } else { %>
    <% sections.forEach(function(s) { %>
      <div style="margin-bottom:22px;">
        <div style="font-size:10.5px;text-transform:uppercase;letter-spacing:0.14em;color:var(--primary-dark);font-weight:700;margin-bottom:8px;">
          <%= s.h %>
        </div>
        <div style="font-size:14px;line-height:1.7;color:var(--ink);white-space:pre-wrap;"><%= s.b %></div>
      </div>
    <% }); %>
  <% } %>

  <%# Annotated images attached by the doctor. Patient-uploaded files do NOT
      appear here — those live on the Documents tab. This block is purely
      doctor-authored visuals (annotations on the original imaging). %>
  <% if (__annotations.length > 0) { %>
    <div style="margin-top:24px;padding-top:22px;border-top:1px solid var(--rule);">
      <div style="font-size:10.5px;text-transform:uppercase;letter-spacing:0.14em;color:var(--primary-dark);font-weight:700;margin-bottom:12px;">
        <%= L('Annotated images', 'الصور المُعلَّق عليها') %>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:12px;">
        <% __annotations.forEach(function(ann) { %>
          <a href="/api/annotations/<%= encodeURIComponent(String(ann.image_id)) %>/image" target="_blank" rel="noopener noreferrer"
             style="display:block;border:1px solid var(--rule);border-radius:10px;overflow:hidden;background:#fff;text-decoration:none;color:inherit;">
            <img src="/api/annotations/<%= encodeURIComponent(String(ann.image_id)) %>/image"
                 alt="<%= L('Annotated image', 'صورة مُعلَّق عليها') %>"
                 loading="lazy"
                 style="display:block;width:100%;aspect-ratio:4/3;object-fit:cover;background:var(--surface-2);" />
            <div style="padding:8px 10px;font-size:12px;">
              <div style="color:var(--ink);font-weight:600;"><%= ann.doctor_name || L('Specialist', 'الطبيب') %></div>
              <div style="color:var(--muted);font-size:11px;margin-top:2px;">
                <%= ann.updated_at ? new Date(ann.updated_at).toLocaleDateString(__isAr ? 'ar-EG' : 'en-GB') : '' %>
              </div>
            </div>
          </a>
        <% }); %>
      </div>
    </div>
  <% } %>

  <%# Doctor signature block. %>
  <% if (docName) { %>
    <div style="margin-top:26px;padding-top:22px;border-top:1px solid var(--rule);display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:14px;">
      <div>
        <div style="font-family:var(--font-display);font-size:22px;font-style:italic;color:var(--primary-dark);"><%= docName %></div>
        <div style="font-size:11.5px;color:var(--muted);margin-top:4px;">
          <%= specName || L('Consulting specialist', 'الطبيب المستشار') %>
        </div>
      </div>
      <div style="font-size:10.5px;text-transform:uppercase;letter-spacing:0.14em;color:var(--accent-dark);font-weight:700;">
        <%= L('Signed electronically', 'موقّع إلكترونياً') %>
      </div>
    </div>
  <% } %>
</div>

<%# Standing footer — disclaimer + ask-a-question CTA (patient view only). %>
<div class="p-report-footer p-card" style="padding:18px;background:#FBF9F4;border-color:var(--rule);margin-bottom:18px;">
  <div style="display:grid;grid-template-columns:1fr auto;gap:14px;align-items:center;">
    <div style="font-size:12.5px;color:var(--ink-2);line-height:1.6;">
      <strong style="color:var(--ink);"><%= L('A written opinion is not treatment.', 'الرأي المكتوب ليس علاجاً.') %></strong>
      <%= L(' Share this report with your treating doctor — they know your full medical picture and can act on these findings. Tashkheesa specialists do not prescribe or initiate care.',
            ' شارك هذا التقرير مع طبيبك المعالج — فهو يعرف ملفك الطبي كاملاً ويمكنه التصرف بناءً على هذه النتائج. أطباء تشخيصة لا يصفون أدوية ولا يبدؤون علاجاً.') %>
    </div>
    <% if (__isPatient && __order.id) { %>
      <a class="p-btn p-btn--ghost p-btn--sm p-report-ask"
         href="/portal/patient/orders/<%= __order.id %>?tab=messages">
        <%- include('partials/patient/icon', { name: 'message', size: 13 }) %>
        <%= L('Ask a question', 'اطرح سؤالاً') %>
      </a>
    <% } %>
  </div>
</div>

<%# Doctor + admin extras — export history. Not shown to patients. %>
<% if (__reportHistory.length > 0 && (__isDoctor || __isAdmin)) { %>
  <div class="p-card" style="margin-bottom:18px;">
    <div class="p-card__header">
      <div class="p-card__title"><%= L('Export history', 'سجل التصدير') %></div>
    </div>
    <div class="p-card__body" style="padding:0;">
      <table style="width:100%;border-collapse:collapse;font-size:12.5px;">
        <thead>
          <tr style="background:var(--surface-2);">
            <th style="text-align:start;padding:10px 14px;color:var(--muted);font-size:10.5px;text-transform:uppercase;letter-spacing:0.12em;font-weight:700;border-bottom:1px solid var(--rule);"><%= L('Date', 'التاريخ') %></th>
            <th style="text-align:start;padding:10px 14px;color:var(--muted);font-size:10.5px;text-transform:uppercase;letter-spacing:0.12em;font-weight:700;border-bottom:1px solid var(--rule);"><%= L('Generated by', 'بواسطة') %></th>
            <th style="border-bottom:1px solid var(--rule);"></th>
          </tr>
        </thead>
        <tbody>
          <% __reportHistory.forEach(function(rh) { %>
            <tr>
              <td style="padding:10px 14px;color:var(--ink-2);border-bottom:1px solid var(--rule);">
                <%= rh.created_at ? new Date(rh.created_at).toLocaleString(__isAr ? 'ar-EG' : 'en-GB') : '—' %>
              </td>
              <td style="padding:10px 14px;color:var(--ink);border-bottom:1px solid var(--rule);"><%= rh.created_by_name || '—' %></td>
              <td style="padding:10px 14px;border-bottom:1px solid var(--rule);text-align:end;">
                <a class="p-btn p-btn--ghost p-btn--sm" href="/portal/case/<%= __order.id %>/download-report"><%= L('Download', 'تحميل') %></a>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </div>
<% } %>

<%# Print button wires to window.print(). Print stylesheet is in
    patient-portal-v2.css and hides .p-sidebar/.p-tabbar/.p-topbar/.p-report-actions
    automatically — and we add page-specific rules below for elements only
    this template renders. %>
<style>
  @media print {
    @page { margin: 18mm 16mm; }
    html, body { background: #fff !important; color: #000 !important; }
    .p-sidebar, .p-tabbar, .p-topbar, .p-report-actions, .p-report-footer { display: none !important; }
    .p-app { display: block !important; }
    .p-main { padding: 0 !important; }
    .p-card { box-shadow: none !important; border: none !important; background: #fff !important; }
    .p-report-document { padding: 0 !important; }
  }
</style>

<% var __nonce = (typeof cspNonce !== 'undefined' && cspNonce) ? String(cspNonce) : ''; %>
<script<% if (__nonce) { %> nonce="<%= __nonce %>"<% } %>>
  (function() {
    var printBtn = document.getElementById('print-report-btn');
    if (printBtn) {
      printBtn.addEventListener('click', function() { window.print(); });
    }
  })();
</script>

<% if (__isDoctor) { %>
<script<% if (__nonce) { %> nonce="<%= __nonce %>"<% } %>>
(function() {
  var csrfToken = '<%= typeof csrfToken !== "undefined" && csrfToken ? csrfToken : "" %>';

  function generatePdf() {
    var btn = document.getElementById('generatePdfBtn');
    if (!btn) return;
    btn.disabled = true;
    btn.textContent = '<%= __isAr ? "جاري الإنشاء..." : "Generating..." %>';
    fetch('/portal/case/<%= __order.id %>/generate-pdf', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-csrf-token': csrfToken }
    })
    .then(function(res) { return res.json(); })
    .then(function(data) {
      if (data.ok && data.reportUrl) {
        btn.textContent = '<%= __isAr ? "تم الإنشاء!" : "Generated!" %>';
        window.open(data.reportUrl, '_blank');
        setTimeout(function() { location.reload(); }, 1000);
      } else {
        btn.textContent = '<%= __isAr ? "فشل" : "Failed" %>';
        alert(data.error || 'Failed to generate PDF');
        btn.disabled = false;
      }
    })
    .catch(function(err) {
      btn.textContent = '<%= __isAr ? "خطأ" : "Error" %>';
      alert(err.message);
      btn.disabled = false;
    });
  }

  function emailReport() {
    var btn = document.getElementById('emailReportBtn');
    if (!btn) return;
    btn.disabled = true;
    btn.textContent = '<%= __isAr ? "جاري الإرسال..." : "Sending..." %>';
    fetch('/portal/case/<%= __order.id %>/email-report', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'x-csrf-token': csrfToken }
    })
    .then(function(res) { return res.json(); })
    .then(function(data) {
      if (data.ok) {
        btn.textContent = '<%= __isAr ? "تم الإرسال!" : "Sent!" %>';
      } else {
        btn.textContent = '<%= __isAr ? "فشل" : "Failed" %>';
        alert(data.error || 'Failed to send email');
        btn.disabled = false;
      }
    })
    .catch(function(err) {
      btn.textContent = '<%= __isAr ? "خطأ" : "Error" %>';
      alert(err.message);
      btn.disabled = false;
    });
  }

  document.addEventListener('click', function(e) {
    var btn = e.target.closest('[data-action]');
    if (!btn) return;
    var action = btn.getAttribute('data-action');
    if (action === 'generate-pdf') generatePdf();
    else if (action === 'email-report') emailReport();
  });
})();
</script>
<% } %>

<%- include('partials/patient/foot', { active: 'cases', isAr: __isAr }) %>
