<%
  // Mark-payment form. Locals: order, methods.
  var isAr = (typeof lang !== 'undefined' && lang === 'ar');
  var _order = order || {};
  var _methods = (typeof methods !== 'undefined' && methods) ? methods : [];
  var methodOpts = _methods.map(function(m) { return { value: m, label: String(m).replace(/_/g, ' ') }; });
  var currentMethod = _order.payment_method || (methodOpts.length > 0 ? methodOpts[0].value : '');
%>
<%- include('partials/superadmin/header', {
      title: 'Mark payment',
      currentSection: 'orders',
      user: user,
      lang: lang || 'en',
      showTabBar: false,
      sidebarBadges: (typeof sidebarBadges !== 'undefined' && sidebarBadges) ? sidebarBadges : {},
      cspNonce: (typeof cspNonce !== 'undefined') ? cspNonce : ''
    }) %>

<%- include('partials/superadmin/page_header', {
      title: 'Mark payment as paid',
      subtitle: 'Update payment status for this case.',
      breadcrumb: [
        { label: 'Dashboard', href: '/superadmin' },
        { label: 'Cases', href: '/superadmin/orders' },
        { label: _order.reference_id || String(_order.id || '').slice(0, 8), href: '/superadmin/orders/' + _order.id },
        { label: 'Payment' }
      ],
      actionsHtml: '<a class="btn" href="/superadmin/orders/' + _order.id + '">Back to case</a>'
    }) %>

<div class="page-body">
  <%- include('partials/superadmin/c_card_open', { title: 'Case summary' }) %>
    <div style="display:grid;grid-template-columns:repeat(2, 1fr);gap:12px;font-size:12.5px;">
      <div><div style="font-size:11px;color:var(--fg-3);text-transform:uppercase;letter-spacing:.06em;">Case ID</div><div class="mono"><%= _order.id %></div></div>
      <div><div style="font-size:11px;color:var(--fg-3);text-transform:uppercase;letter-spacing:.06em;">Patient</div><div><%= _order.patient_name || 'Unknown' %> <span style="color:var(--fg-3);">· <%= _order.patient_email || '—' %></span></div></div>
      <div><div style="font-size:11px;color:var(--fg-3);text-transform:uppercase;letter-spacing:.06em;">Status</div><div><%= _order.status || '—' %></div></div>
      <div><div style="font-size:11px;color:var(--fg-3);text-transform:uppercase;letter-spacing:.06em;">Payment</div><div><%- include('partials/superadmin/c_chip', { label: _order.payment_status || 'unpaid', tone: (String(_order.payment_status).toLowerCase() === 'paid' ? 'green' : 'amber') }) %></div></div>
      <div><div style="font-size:11px;color:var(--fg-3);text-transform:uppercase;letter-spacing:.06em;">Price</div><div class="tabular" style="font-weight:600;"><%= _order.currency || 'EGP' %> <%= _order.price != null ? Number(_order.price).toLocaleString('en-US') : '—' %></div></div>
    </div>
  <%- include('partials/superadmin/c_card_close') %>

  <div style="margin-top:14px;">
    <%- include('partials/superadmin/c_card_open', { title: 'Record payment' }) %>
      <form method="post" action="/superadmin/orders/<%= _order.id %>/mark-paid" style="max-width:520px;">
        <%- (typeof csrfField === 'function') ? csrfField() : '' %>
        <div class="c-form-row">
          <%- include('partials/superadmin/c_form_field', { name: 'payment_method', label: 'Method', type: 'select', required: true, value: currentMethod, options: methodOpts }) %>
          <%- include('partials/superadmin/c_form_field', { name: 'payment_reference', label: 'Reference', value: String(_order.payment_reference || ''), placeholder: 'Paymob ID, bank ref, etc.' }) %>
        </div>
        <div style="display:flex;gap:8px;justify-content:flex-end;">
          <a class="btn" href="/superadmin/orders/<%= _order.id %>">Cancel</a>
          <button type="submit" class="btn primary">Save &amp; mark as paid</button>
        </div>
      </form>
    <%- include('partials/superadmin/c_card_close') %>
  </div>
</div>

<%- include('partials/superadmin/footer', { isAr: isAr }) %>
