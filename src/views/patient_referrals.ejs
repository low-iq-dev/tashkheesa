<%
  // Patient referrals — V2 chrome.
  // Locals from src/routes/patient.js:
  //   referralCode    — string code
  //   codeRow         — { times_used, ... }
  //   redemptions     — array of redemption rows
  //   totalReferred   — number
  //   totalRewarded   — number
  //   user, lang, isAr
  //   pageTitle, brand — optional

  var _lang = (typeof lang !== 'undefined') ? lang : 'en';
  var _isAr = (typeof isAr !== 'undefined') ? isAr : false;
  var __isAr = _isAr;
  var __lang = _lang;
  function L(en, ar) { return _isAr ? ar : en; }

  var _code = (typeof referralCode !== 'undefined') ? referralCode : '';
  var _codeRow = (typeof codeRow !== 'undefined') ? codeRow : {};
  var _redemptions = (typeof redemptions !== 'undefined' && Array.isArray(redemptions)) ? redemptions : [];
  var _totalReferred = (typeof totalReferred !== 'undefined') ? totalReferred : 0;
  var _totalRewarded = (typeof totalRewarded !== 'undefined') ? totalRewarded : 0;

  function fmtDate(iso) {
    if (!iso) return '';
    var d = new Date(iso);
    return d.toLocaleDateString(_lang === 'ar' ? 'ar-EG' : 'en-US', { year: 'numeric', month: 'short', day: 'numeric' });
  }
%>
<%- include('partials/patient/head', {
  active: 'referrals',
  title: L('Referral Program', 'برنامج الإحالة'),
  user: (typeof user !== 'undefined' ? user : {}),
  lang: __lang,
  bodyClass: 'p-page-referrals'
}) %>

<%- include('partials/patient/topbar', {
  title: L('Referral Program', 'برنامج الإحالة'),
  sub:   L('Share Tashkheesa and earn rewards.', 'شارك تشخيصة واحصل على مكافآت.'),
  serif: false,
  isAr:  __isAr,
  hideBell: false
}) %>

<!-- Your Referral Code -->
<div class="p-card" style="text-align:center;margin-bottom:18px;border-left:4px solid var(--primary);padding:18px;">
  <div class="section-head" style="justify-content:center;">
    <span class="section-title"><%= L('Your Referral Code', 'كود الإحالة الخاص بك') %></span>
  </div>
  <div id="ref-code" style="font-size:2rem;font-weight:800;color:var(--primary-dark);letter-spacing:3px;margin:16px 0 8px;font-family:'JetBrains Mono','Space Mono',monospace;"><%= _code %></div>
  <div style="font-size:0.85rem;color:var(--accent);font-weight:600;margin-bottom:16px;"><%= L('10% discount for you and your friend', 'خصم 10% لك ولصديقك') %></div>
  <div style="display:flex;gap:0.5rem;justify-content:center;flex-wrap:wrap;">
    <button class="p-btn p-btn--primary" id="copy-btn" data-action="copy-referral"><%= L('Copy Code', 'نسخ الكود') %></button>
    <a class="p-btn" style="background:#25d366;color:#fff;border:none;text-decoration:none;" href="https://wa.me/?text=<%= encodeURIComponent(L('Try Tashkheesa for medical second opinions! Use my referral code: ', 'جرب تشخيصة للرأي الطبي الثاني! استخدم كود الإحالة: ') + _code) %>" target="_blank"><%= L('Share via WhatsApp', 'شارك عبر واتساب') %></a>
  </div>
</div>

<!-- Referral Stats -->
<div class="portal-stats" style="grid-template-columns:repeat(3, 1fr);">
  <div class="stat-card" style="border-left:4px solid var(--primary);">
    <div class="stat-label"><%= L('Total Referred', 'تمت الإحالة') %></div>
    <div class="stat-value"><%= _totalReferred %></div>
  </div>
  <div class="stat-card" style="border-left:4px solid var(--accent);">
    <div class="stat-label"><%= L('Rewards Earned', 'مكافآت ممنوحة') %></div>
    <div class="stat-value"><%= _totalRewarded %></div>
  </div>
  <div class="stat-card" style="border-left:4px solid var(--warn);">
    <div class="stat-label"><%= L('Times Used', 'مرات الاستخدام') %></div>
    <div class="stat-value"><%= _codeRow.times_used || 0 %></div>
  </div>
</div>

<!-- Referral History -->
<div class="p-card" style="padding:18px;">
  <div class="section-head">
    <span class="section-title"><%= L('Referral History', 'سجل الإحالات') %></span>
  </div>

  <% if (_redemptions.length === 0) { %>
    <div style="text-align:center;padding:36px 24px;">
      <div style="font-size:2.2rem;margin-bottom:10px;">↗️</div>
      <h3 style="margin-bottom:6px;color:var(--ink);"><%= L('No referrals yet', 'لا توجد إحالات بعد') %></h3>
      <p style="color:var(--ink-2);font-size:0.85rem;"><%= L('Share your code with friends and earn rewards!', 'شارك الكود مع أصدقائك واحصل على مكافآت!') %></p>
    </div>
  <% } else { %>
    <table>
      <thead>
        <tr>
          <th><%= L('Name', 'الاسم') %></th>
          <th><%= L('Date', 'التاريخ') %></th>
          <th><%= L('Status', 'الحالة') %></th>
        </tr>
      </thead>
      <tbody>
        <% _redemptions.forEach(function(r) { %>
          <tr>
            <td style="font-weight:500;"><%= r.referred_name || L('User', 'مستخدم') %></td>
            <td style="font-size:0.82rem;color:var(--ink-2);"><%= fmtDate(r.created_at) %></td>
            <td>
              <span class="p-chip <%= r.reward_granted ? 'p-chip--teal' : 'p-chip--brass' %>">
                <%= r.reward_granted ? L('Rewarded', 'مكافأة ممنوحة') : L('Pending', 'قيد الانتظار') %>
              </span>
            </td>
          </tr>
        <% }); %>
      </tbody>
    </table>
  <% } %>
</div>

<script<% if (typeof cspNonce !== 'undefined' && cspNonce) { %> nonce="<%= cspNonce %>"<% } %>>
(function() {
  function copyCode() {
    var code = document.getElementById('ref-code').textContent.trim();
    navigator.clipboard.writeText(code).then(function() {
      var btn = document.getElementById('copy-btn');
      btn.textContent = '<%= _isAr ? "تم النسخ!" : "Copied!" %>';
      setTimeout(function() { btn.textContent = '<%= _isAr ? "نسخ الكود" : "Copy Code" %>'; }, 2000);
    });
  }

  document.addEventListener('click', function(e) {
    var btn = e.target.closest('[data-action="copy-referral"]');
    if (btn) copyCode();
  });
})();
</script>

<%- include('partials/patient/foot', { active: 'referrals', isAr: __isAr }) %>
