</div><%# /.doctor-profile-page %>

<% var _nonce = (typeof locals !== 'undefined' && locals && (locals.cspNonce || locals.csp_nonce || locals.nonce)) ? String(locals.cspNonce || locals.csp_nonce || locals.nonce) : ''; %>
<%# Autocomplete data — must execute BEFORE the inline IIFE below.
    Synchronous (no defer/async) so window.__PROFILE_AUTOCOMPLETE_DATA__
    is populated when the IIFE reads it. CSP requires nonce for any
    src-loaded script even though the file itself comes from /self. %>
<script src="/js/profile-autocomplete-data.js"<% if (_nonce) { %> nonce="<%= _nonce %>"<% } %>></script>
<script<% if (_nonce) { %> nonce="<%= _nonce %>"<% } %>>
(function() {
  var page = document.querySelector('.doctor-profile-page');
  if (!page) return;
  var form = document.getElementById('dpForm');
  if (!form) return;

  // ---------- Photo: submit dpPhotoForm when a file is picked ----------
  // Wired here (inside a nonce'd <script>) instead of via an inline
  // onchange="" attribute, because the page CSP is
  //   script-src 'self' 'nonce-...'
  // with no 'unsafe-inline', which silently blocks inline event-handler
  // attributes. Curl evidence in CLAUDE_CODE_BRIEF_PROFILE_PRESCRIBE.md
  // ("Photo upload FIXED (round 3)") confirms this was the actual blocker.
  var photoFile = document.getElementById('dpPhotoFile');
  var photoForm = document.getElementById('dpPhotoForm');
  if (photoFile && photoForm) {
    photoFile.addEventListener('change', function() {
      if (photoFile.files && photoFile.files.length) {
        photoForm.submit();
      }
    });
  }

  // ---------- Signature: same pattern as photo above ----------
  var sigFile = document.getElementById('dpSignatureFile');
  var sigForm = document.getElementById('dpSignatureForm');
  if (sigFile && sigForm) {
    sigFile.addEventListener('change', function() {
      if (sigFile.files && sigFile.files.length) {
        sigForm.submit();
      }
    });
  }

  var I18N_REMOVE_EN = 'Remove';
  var I18N_REMOVE_AR = 'إزالة';
  var I18N = {
    isAr: <%= _isAr ? 'true' : 'false' %>,
    unsaved: <%- JSON.stringify(tt('Unsaved changes', 'Unsaved changes', 'تغييرات غير محفوظة')) %>,
    saving:  <%- JSON.stringify(tt('Saving…', 'Saving…', 'جارٍ الحفظ…')) %>,
    saved:   <%- JSON.stringify(tt('All changes saved', 'All changes saved', 'تم حفظ التغييرات')) %>,
    upToDate:<%- JSON.stringify(tt('All up to date', 'All up to date', 'كل شيء محدَّث')) %>
  };

  // ---------- Save-bar dirty tracking ----------
  var saveDot   = document.getElementById('dpSaveDot');
  var saveLabel = document.getElementById('dpSaveLabel');
  var saveBtn   = document.getElementById('dpSaveBtn');
  var discardBtn= document.getElementById('dpDiscardBtn');
  var dirty = false;

  function setDirty(v) {
    dirty = !!v;
    if (saveDot) {
      saveDot.classList.toggle('dirty', dirty);
      saveDot.classList.remove('saved');
    }
    if (saveLabel) saveLabel.textContent = dirty ? I18N.unsaved : I18N.upToDate;
    if (discardBtn) discardBtn.disabled = !dirty;
  }

  // Mark dirty on any form input change
  form.addEventListener('input',  function(){ setDirty(true); }, true);
  form.addEventListener('change', function(){ setDirty(true); }, true);
  // File input doesn't bubble through .form events when triggered programmatically
  form.addEventListener('submit', function(){
    if (saveBtn) { saveBtn.disabled = true; }
    if (saveLabel) saveLabel.textContent = I18N.saving;
    if (saveDot) saveDot.classList.add('dirty');
  });
  if (discardBtn) {
    discardBtn.addEventListener('click', function(){
      if (!dirty) return;
      window.location.href = window.location.pathname;
    });
  }

  // Show saved toast briefly when ?success=... was rendered.
  var initialSuccess = <%= _success ? 'true' : 'false' %>;
  if (initialSuccess) {
    var toast = document.getElementById('dpSavedToast');
    if (toast) {
      toast.classList.add('show');
      setTimeout(function(){ toast.classList.remove('show'); }, 2400);
    }
  }

  // ---------- Bio tabs ----------
  var bioTabs = page.querySelectorAll('[data-bio-tab]');
  var bioPanes = page.querySelectorAll('[data-bio-pane]');
  bioTabs.forEach(function(btn) {
    btn.addEventListener('click', function() {
      var which = btn.getAttribute('data-bio-tab');
      bioTabs.forEach(function(b) {
        var active = b.getAttribute('data-bio-tab') === which;
        b.classList.toggle('active', active);
        b.setAttribute('aria-selected', active ? 'true' : 'false');
      });
      bioPanes.forEach(function(p) {
        p.hidden = p.getAttribute('data-bio-pane') !== which;
      });
    });
  });
  // Live char counts
  var bioEn = document.getElementById('dp-bio-en');
  var bioAr = document.getElementById('dp-bio-ar');
  function bindBioCount(area, key) {
    if (!area) return;
    var counter = page.querySelector('[data-bio-count="' + key + '"]');
    if (!counter) return;
    area.addEventListener('input', function() { counter.textContent = String(area.value.length); });
  }
  bindBioCount(bioEn, 'en');
  bindBioCount(bioAr, 'ar');

  // ---------- Chipset (sub-specialties + languages) ----------
  // Backed by a hidden JSON input. Reads existing chips on load and re-syncs
  // the hidden field on any add/remove.
  var chipsets = page.querySelectorAll('[data-chipset]');
  chipsets.forEach(function(cs) {
    var targetId = cs.getAttribute('data-target');
    var hidden = document.getElementById(targetId);
    var input = cs.querySelector('[data-chip-input]');
    var countEl = page.querySelector('[data-chipset-count="' + cs.getAttribute('data-chipset') + '"]');

    function readCurrent() {
      try {
        var v = hidden && hidden.value ? JSON.parse(hidden.value) : [];
        return Array.isArray(v) ? v.filter(function(x){ return typeof x === 'string' && x; }) : [];
      } catch (_) { return []; }
    }
    function sync(values) {
      if (hidden) hidden.value = JSON.stringify(values);
      if (countEl) countEl.textContent = String(values.length);
    }
    function rerender() {
      // Remove all existing .chipset__item children, keep the input
      Array.prototype.slice.call(cs.querySelectorAll('.chipset__item')).forEach(function(n){ n.remove(); });
      var values = readCurrent();
      values.forEach(function(v) {
        var item = document.createElement('span');
        item.className = 'chipset__item';
        item.setAttribute('data-chip', v);
        var label = document.createElement('span');
        label.textContent = v;
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.setAttribute('data-chip-remove', '');
        btn.setAttribute('aria-label', I18N.isAr ? I18N_REMOVE_AR : I18N_REMOVE_EN);
        btn.textContent = '×';
        item.appendChild(label);
        item.appendChild(btn);
        cs.insertBefore(item, input);
      });
      sync(values);
    }

    function add(value) {
      var v = String(value || '').trim();
      if (!v) return;
      var current = readCurrent();
      // Prevent duplicates (case-insensitive)
      var lower = current.map(function(x){ return x.toLowerCase(); });
      if (lower.indexOf(v.toLowerCase()) !== -1) return;
      current.push(v);
      sync(current);
      rerender();
      setDirty(true);
    }
    function remove(value) {
      var v = String(value || '');
      var current = readCurrent().filter(function(x){ return x !== v; });
      sync(current);
      rerender();
      setDirty(true);
    }

    // Click [×] removes the chip
    cs.addEventListener('click', function(e) {
      var btn = e.target.closest('[data-chip-remove]');
      if (!btn) return;
      var item = btn.closest('[data-chip]');
      if (!item) return;
      remove(item.getAttribute('data-chip'));
    });

    // Enter / comma adds the chip
    if (input) {
      input.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ',') {
          e.preventDefault();
          add(input.value);
          input.value = '';
        } else if (e.key === 'Backspace' && !input.value) {
          var current = readCurrent();
          if (current.length) {
            remove(current[current.length - 1]);
          }
        }
      });
      input.addEventListener('blur', function() {
        if (input.value.trim()) {
          add(input.value);
          input.value = '';
        }
      });
    }
  });

  // ---------- Autocomplete typeahead ----------
  // Backed by /js/profile-autocomplete-data.js (loaded synchronously above
  // this IIFE). Three pools: LANGUAGES (langs chipset), SUB_SPECIALTIES
  // keyed by specialty name (subs chipset, gated on the doctor's selected
  // specialty), and BOARD_CERTIFICATIONS (cert-name input in section 05).
  var AC_DATA  = (typeof window !== 'undefined' && window.__PROFILE_AUTOCOMPLETE_DATA__) || {};
  var AC_LANGS = Array.isArray(AC_DATA.LANGUAGES)            ? AC_DATA.LANGUAGES            : [];
  var AC_CERTS = Array.isArray(AC_DATA.BOARD_CERTIFICATIONS) ? AC_DATA.BOARD_CERTIFICATIONS : [];
  var AC_SUBS  = (AC_DATA.SUB_SPECIALTIES && typeof AC_DATA.SUB_SPECIALTIES === 'object')
                   ? AC_DATA.SUB_SPECIALTIES : {};

  function fuzzy(q, str) {
    if (!q) return true;
    return String(str || '').toLowerCase().indexOf(String(q).toLowerCase()) !== -1;
  }
  function specialtyName() {
    var sel = page.querySelector('select[name="specialty_id"]');
    if (!sel || sel.selectedIndex < 0) return '';
    var opt = sel.options[sel.selectedIndex];
    return (opt && opt.text) ? String(opt.text).trim() : '';
  }

  // Generic dropdown attached to an input. getItems() returns either
  // an array of {value, secondary} OR { items, emptyMsg }. onPick(value)
  // is called when the user clicks/Enter-selects.
  function attachAc(input, getItems, onPick) {
    if (!input || input.__acWired) return;
    input.__acWired = true;

    var wrap = input.closest('[data-ac-wrap]');
    if (!wrap) {
      wrap = input.parentElement;
      if (wrap && getComputedStyle(wrap).position === 'static') {
        wrap.style.position = 'relative';
      }
    }
    if (!wrap) return;

    var dd = document.createElement('div');
    dd.className = 'dp-ac';
    dd.setAttribute('role', 'listbox');
    dd.hidden = true;
    wrap.appendChild(dd);

    var cursor = -1;
    var lastItems = [];

    function render() {
      var got = getItems() || {};
      var items = Array.isArray(got) ? got : (Array.isArray(got.items) ? got.items : []);
      var emptyMsg = (Array.isArray(got) ? null : got.emptyMsg) || (I18N.isAr ? 'لا توجد نتائج' : 'No matches');
      lastItems = items;
      dd.innerHTML = '';
      if (!items.length) {
        var empty = document.createElement('div');
        empty.className = 'dp-ac__empty';
        empty.textContent = emptyMsg;
        dd.appendChild(empty);
      } else {
        items.forEach(function(it, i) {
          var row = document.createElement('div');
          row.className = 'dp-ac__item' + (i === cursor ? ' is-active' : '');
          row.setAttribute('role', 'option');
          var t = document.createElement('span');
          t.textContent = it.value;
          row.appendChild(t);
          if (it.secondary) {
            var m = document.createElement('span');
            m.className = 'dp-ac__meta';
            m.textContent = it.secondary;
            row.appendChild(m);
          }
          row.addEventListener('mousedown', function(e) {
            e.preventDefault();
            onPick(it.value);
            close();
          });
          dd.appendChild(row);
        });
      }
      dd.hidden = false;
    }
    function close() { dd.hidden = true; cursor = -1; }

    input.addEventListener('focus', function(){ cursor = -1; render(); });
    input.addEventListener('input', function(){ cursor = -1; render(); });
    input.addEventListener('keydown', function(e) {
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        cursor = Math.min(cursor + 1, lastItems.length - 1);
        render();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        cursor = Math.max(cursor - 1, -1);
        render();
      } else if (e.key === 'Enter') {
        if (cursor >= 0 && lastItems[cursor]) {
          e.preventDefault();
          onPick(lastItems[cursor].value);
          close();
        }
      } else if (e.key === 'Escape') {
        close();
      }
    });
    document.addEventListener('mousedown', function(e) {
      if (!wrap.contains(e.target)) close();
    });
  }

  function rerenderChipsFromHidden(cs, hidden, input) {
    Array.prototype.slice.call(cs.querySelectorAll('.chipset__item')).forEach(function(n){ n.remove(); });
    var values;
    try { values = JSON.parse(hidden.value || '[]') || []; } catch (_) { values = []; }
    if (!Array.isArray(values)) values = [];
    values.forEach(function(v) {
      var item = document.createElement('span');
      item.className = 'chipset__item';
      item.setAttribute('data-chip', v);
      var label = document.createElement('span');
      label.textContent = v;
      var btn = document.createElement('button');
      btn.type = 'button';
      btn.setAttribute('data-chip-remove', '');
      btn.setAttribute('aria-label', I18N.isAr ? I18N_REMOVE_AR : I18N_REMOVE_EN);
      btn.textContent = '×';
      item.appendChild(label);
      item.appendChild(btn);
      cs.insertBefore(item, input);
    });
  }

  page.querySelectorAll('[data-chipset]').forEach(function(cs) {
    var kind  = cs.getAttribute('data-chipset');
    var input = cs.querySelector('[data-chip-input]');
    var hidden = document.getElementById(cs.getAttribute('data-target'));
    if (!input || !hidden) return;

    function readPicked() {
      try {
        var v = JSON.parse(hidden.value || '[]');
        return Array.isArray(v) ? v.map(function(x){ return String(x).toLowerCase(); }) : [];
      } catch (_) { return []; }
    }
    function commit(value) {
      var v = String(value || '').trim();
      if (!v) return;
      var picked = readPicked();
      if (picked.indexOf(v.toLowerCase()) !== -1) { input.value = ''; return; }
      var current;
      try { current = JSON.parse(hidden.value || '[]') || []; } catch (_) { current = []; }
      if (!Array.isArray(current)) current = [];
      current.push(v);
      hidden.value = JSON.stringify(current);
      input.value = '';
      rerenderChipsFromHidden(cs, hidden, input);
      var countEl = page.querySelector('[data-chipset-count="' + kind + '"]');
      if (countEl) countEl.textContent = String(current.length);
      setDirty(true);
    }

    if (kind === 'langs') {
      attachAc(input, function() {
        var q = input.value.trim();
        var picked = readPicked();
        var pool = AC_LANGS.filter(function(l) {
          var primary = I18N.isAr ? (l.ar || l.en) : l.en;
          var alt     = I18N.isAr ? l.en : (l.ar || '');
          return fuzzy(q, primary) || fuzzy(q, alt) || fuzzy(q, l.code);
        }).filter(function(l) {
          var primary = I18N.isAr ? (l.ar || l.en) : l.en;
          return picked.indexOf(String(primary).toLowerCase()) === -1;
        }).slice(0, 8).map(function(l) {
          return {
            value: I18N.isAr ? (l.ar || l.en) : l.en,
            secondary: I18N.isAr ? l.en : (l.ar || '')
          };
        });
        return { items: pool };
      }, commit);
    } else if (kind === 'subs') {
      attachAc(input, function() {
        var q = input.value.trim();
        var sName = specialtyName();
        if (!sName) {
          return {
            items: [],
            emptyMsg: I18N.isAr ? 'اختر التخصص أولاً لعرض الاقتراحات' : 'Pick a specialty first to see suggestions'
          };
        }
        var raw = Array.isArray(AC_SUBS[sName]) ? AC_SUBS[sName] : [];
        var picked = readPicked();
        var pool = raw.filter(function(s) { return fuzzy(q, s); })
                      .filter(function(s) { return picked.indexOf(String(s).toLowerCase()) === -1; })
                      .slice(0, 8)
                      .map(function(s) { return { value: s }; });
        return {
          items: pool,
          emptyMsg: I18N.isAr ? 'لا توجد اقتراحات لهذا التخصص' : 'No suggestions for this specialty'
        };
      }, commit);
    }
  });

  function wireCertAcRow(row) {
    var input = row && row.querySelector ? row.querySelector('[data-cert-name]') : null;
    if (!input || input.__acWired) return;
    var wrap = input.closest('[data-ac-wrap]');
    if (!wrap) {
      wrap = document.createElement('div');
      wrap.setAttribute('data-ac-wrap', '');
      wrap.style.position = 'relative';
      input.parentNode.insertBefore(wrap, input);
      wrap.appendChild(input);
    }
    attachAc(input, function() {
      var q = input.value.trim();
      var pool = AC_CERTS.filter(function(c) {
        var primary = I18N.isAr ? (c.ar || c.en) : c.en;
        return fuzzy(q, primary) || fuzzy(q, c.en);
      }).slice(0, 8).map(function(c) {
        return {
          value: I18N.isAr ? (c.ar || c.en) : c.en,
          secondary: c.country || ''
        };
      });
      return { items: pool };
    }, function(value) {
      input.value = value;
      input.dispatchEvent(new Event('input', { bubbles: true }));
    });
  }
  page.querySelectorAll('[data-rptr="certs"] [data-rptr-row]').forEach(wireCertAcRow);
  // Expose for addCertRow() further down in this IIFE.
  window.__dpWireCertAcRow = wireCertAcRow;
  // ---------- end Autocomplete ----------

  // ---------- Repeaters (affiliations + certifications) ----------
  function readAffilsFromDom() {
    var rows = page.querySelectorAll('[data-rptr="affils"] [data-rptr-row]');
    var out = [];
    rows.forEach(function(row) {
      var name = row.querySelector('[data-affil-name]');
      var role = row.querySelector('[data-affil-role]');
      var n = name ? String(name.value || '').trim() : '';
      var r = role ? String(role.value || '').trim() : '';
      if (n || r) out.push({ name: n, role: r });
    });
    return out;
  }
  function readCertsFromDom() {
    var rows = page.querySelectorAll('[data-rptr="certs"] [data-rptr-row]');
    var out = [];
    rows.forEach(function(row) {
      var nameEl = row.querySelector('[data-cert-name]');
      var bodyEl = row.querySelector('[data-cert-body]');
      var yearEl = row.querySelector('[data-cert-year]');
      var n = nameEl ? String(nameEl.value || '').trim() : '';
      var b = bodyEl ? String(bodyEl.value || '').trim() : '';
      var y = yearEl ? parseInt(String(yearEl.value || '').trim(), 10) : NaN;
      if (n || b || Number.isFinite(y)) {
        out.push({ name: n, body: b, year: Number.isFinite(y) ? y : null });
      }
    });
    return out;
  }
  function syncAffils() {
    var hidden = document.getElementById('dp-affiliations-json');
    if (hidden) hidden.value = JSON.stringify(readAffilsFromDom());
  }
  function syncCerts() {
    var hidden = document.getElementById('dp-certifications-json');
    if (hidden) hidden.value = JSON.stringify(readCertsFromDom());
  }

  function attachRptrRowEvents(row, kind) {
    row.addEventListener('input',  function(){ kind === 'affils' ? syncAffils() : syncCerts(); }, true);
    var del = row.querySelector('[data-rptr-del]');
    if (del) {
      del.addEventListener('click', function() {
        row.parentNode.removeChild(row);
        kind === 'affils' ? syncAffils() : syncCerts();
        // Show / hide the certs header based on remaining row count
        if (kind === 'certs') refreshCertsHeader();
        setDirty(true);
      });
    }
  }
  // Wire up existing rows
  page.querySelectorAll('[data-rptr="affils"] [data-rptr-row]').forEach(function(r){ attachRptrRowEvents(r, 'affils'); });
  page.querySelectorAll('[data-rptr="certs"]  [data-rptr-row]').forEach(function(r){ attachRptrRowEvents(r, 'certs'); });

  function refreshCertsHeader() {
    var container = page.querySelector('[data-rptr="certs"]');
    if (!container) return;
    var header = container.querySelector('.rptr--header');
    var hasRows = container.querySelector('[data-rptr-row]');
    if (hasRows && !header) {
      var hdr = document.createElement('div');
      hdr.className = 'rptr rptr--header';
      hdr.setAttribute('aria-hidden', 'true');
      hdr.innerHTML = '<div>' + (I18N.isAr ? 'الشهادة' : 'Certification') +
                      '</div><div>' + (I18N.isAr ? 'الجهة المانحة' : 'Issuing body') +
                      '</div><div>' + (I18N.isAr ? 'السنة' : 'Year') + '</div><div></div>';
      container.insertBefore(hdr, container.firstChild);
    } else if (!hasRows && header) {
      header.parentNode.removeChild(header);
    }
  }

  function trashSvg() {
    return '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M8 6V4a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v2M6 6l1 14a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2l1-14"/></svg>';
  }

  function addAffilRow() {
    var container = page.querySelector('[data-rptr="affils"]');
    if (!container) return;
    var row = document.createElement('div');
    row.className = 'affil--add';
    row.setAttribute('data-rptr-row', '');
    row.innerHTML =
      '<label class="field"><span class="field__label">' + (I18N.isAr ? 'اسم المستشفى' : 'Hospital name') + '</span>' +
        '<input class="field__input" data-affil-name value="" /></label>' +
      '<label class="field"><span class="field__label">' + (I18N.isAr ? 'الدور' : 'Role') + '</span>' +
        '<input class="field__input" data-affil-role value="" /></label>' +
      '<button type="button" class="rptr__del" data-rptr-del aria-label="' + (I18N.isAr ? I18N_REMOVE_AR : I18N_REMOVE_EN) + '">' + trashSvg() + '</button>';
    container.appendChild(row);
    attachRptrRowEvents(row, 'affils');
    var firstInput = row.querySelector('input');
    if (firstInput) firstInput.focus();
    syncAffils();
    setDirty(true);
  }

  function addCertRow() {
    var container = page.querySelector('[data-rptr="certs"]');
    if (!container) return;
    var row = document.createElement('div');
    row.className = 'rptr';
    row.setAttribute('data-rptr-row', '');
    if (container.querySelector('[data-rptr-row]')) {
      row.style.borderTop = '1px solid var(--rule)';
    }
    row.innerHTML =
      '<input class="field__input" data-cert-name value="" />' +
      '<input class="field__input" data-cert-body value="" />' +
      '<input class="field__input" data-cert-year type="number" dir="ltr" value="" />' +
      '<button type="button" class="rptr__del" data-rptr-del aria-label="' + (I18N.isAr ? I18N_REMOVE_AR : I18N_REMOVE_EN) + '">' + trashSvg() + '</button>';
    container.appendChild(row);
    attachRptrRowEvents(row, 'certs');
    if (typeof window.__dpWireCertAcRow === 'function') {
      try { window.__dpWireCertAcRow(row); } catch (_) {}
    }
    refreshCertsHeader();
    var firstInput = row.querySelector('input');
    if (firstInput) firstInput.focus();
    syncCerts();
    setDirty(true);
  }

  // Add buttons
  var addAffilBtn = page.querySelector('[data-rptr-add="affils"]');
  if (addAffilBtn) addAffilBtn.addEventListener('click', addAffilRow);
  var addCertBtn  = page.querySelector('[data-rptr-add="certs"]');
  if (addCertBtn) addCertBtn.addEventListener('click', addCertRow);

  // Make sure the hidden JSON inputs are fresh right before submit
  form.addEventListener('submit', function() {
    syncAffils();
    syncCerts();
  });
})();
</script>

