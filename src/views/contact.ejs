<%- include('partials/header', { title: tt('contact.page_title', 'Contact Us', 'كلمنا'), layout: "public", showNav: true }) %>
<% const biz = (typeof BUSINESS_INFO !== 'undefined' && BUSINESS_INFO) ? BUSINESS_INFO : {}; %>

<main class="page-shell">
  <div class="page-inner">
    <section class="content-card legal-page">
      <h1><%= tt('contact.heading', 'Contact Us', 'كلمنا') %></h1>
      <p class="subtitle"><%= tt('contact.subtitle',
        'We\'re here to help. Reach out with any questions about our services.',
        'إحنا هنا عشان نساعدك. اسأل في أي حاجة عن خدماتنا.') %></p>

      <div class="contact-cards">
        <div class="contact-info-card">
          <div class="contact-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#0066CC" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><polyline points="22,4 12,13 2,4"/></svg>
          </div>
          <h3><%= tt('contact.email_label', 'Email', 'البريد الإلكتروني') %></h3>
          <p><a href="mailto:<%= biz.email || 'info@tashkheesa.com' %>"><%= biz.email || 'info@tashkheesa.com' %></a></p>
        </div>
        <div class="contact-info-card">
          <div class="contact-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#0066CC" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
          </div>
          <h3><%= tt('contact.phone_label', 'Phone', 'التليفون') %></h3>
          <p><%= biz.phone || '+20 110 200 9886' %></p>
        </div>
        <div class="contact-info-card">
          <div class="contact-icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#0066CC" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <h3><%= tt('contact.address_label', 'Address', 'العنوان') %></h3>
          <p><%= tt('contact.address_value',
            biz.address || 'Cairo, Egypt',
            biz.address_ar || 'القاهرة، مصر') %></p>
        </div>
      </div>

      <h2><%= tt('contact.form.heading', 'Send Us a Message', 'ابعتلنا رسالة') %></h2>
      <form
        id="contact-form"
        method="post"
        action="/contact"
        class="contact-form"
        data-csrf="<%= typeof csrfToken !== 'undefined' && csrfToken ? csrfToken : '' %>"
      >
        <%- (typeof csrfField === 'function') ? csrfField() : '' %>
        <div class="form-row">
          <div class="form-group">
            <label class="form-label"><%= tt('contact.form.name', 'Name', 'الاسم') %></label>
            <input type="text" name="name" required class="form-control" placeholder="<%= tt('contact.form.name_ph', 'Your full name', 'اسمك بالكامل') %>" />
          </div>
          <div class="form-group">
            <label class="form-label"><%= tt('contact.form.email', 'Email', 'البريد الإلكتروني') %></label>
            <input type="email" name="email" required class="form-control" placeholder="you@example.com" dir="ltr" />
          </div>
        </div>
        <div class="form-group">
          <label class="form-label"><%= tt('contact.form.subject', 'Subject', 'الموضوع') %></label>
          <select name="subject" required class="form-control">
            <option value=""><%= tt('contact.form.subject.choose', 'Select a topic', 'اختار موضوع') %></option>
            <option value="General Inquiry"><%= tt('contact.form.subject.general', 'General Inquiry', 'استفسار عام') %></option>
            <option value="Service Question"><%= tt('contact.form.subject.service', 'Service Question', 'سؤال عن الخدمة') %></option>
            <option value="Technical Support"><%= tt('contact.form.subject.tech', 'Technical Support', 'دعم فني') %></option>
            <option value="Refund Request"><%= tt('contact.form.subject.refund', 'Refund Request', 'طلب استرجاع') %></option>
            <option value="Other"><%= tt('contact.form.subject.other', 'Other', 'حاجة تانية') %></option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label"><%= tt('contact.form.message', 'Message', 'الرسالة') %></label>
          <textarea name="message" rows="5" required class="form-control" placeholder="<%= tt('contact.form.message_ph', 'How can we help?', 'إزاي نقدر نساعدك؟') %>"></textarea>
        </div>
        <button type="submit" class="btn-primary-link" style="display:inline-block; border:none; cursor:pointer; font-size:15px;"><%= tt('contact.form.send', 'Send Message', 'ابعت الرسالة') %></button>
      </form>

      <div class="contact-hours">
        <h3><%= tt('contact.hours.title', 'Business Hours', 'مواعيد العمل') %></h3>
        <p><%= tt('contact.hours.weekdays_value',
          biz.businessHours || 'Sunday – Thursday: 9:00 AM – 5:00 PM (Cairo Time)',
          biz.businessHours_ar || 'الأحد – الخميس: 9:00 صباحاً – 5:00 مساءً (بتوقيت القاهرة)') %></p>
        <p><%= tt('contact.hours.weekend',
          'Friday – Saturday: Closed',
          'الجمعة – السبت: مقفول') %></p>
        <p class="contact-response-note"><%= tt('contact.hours.response',
          'We typically respond within 24 hours during business days.',
          'بنرد في العادة في خلال 24 ساعة في أيام الشغل.') %></p>
      </div>

      <% if (biz.instagram) { %>
      <div class="contact-social">
        <h3><%= tt('contact.social.follow', 'Follow Us', 'تابعنا') %></h3>
        <a href="<%= biz.instagram %>" target="_blank" rel="noopener">Instagram</a>
      </div>
      <% } %>
    </section>
  </div>
</main>

<%- include('partials/footer') %>
