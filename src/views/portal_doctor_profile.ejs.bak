<%- include('partials/header', { title: (typeof isAr !== 'undefined' && isAr) ? 'الملف الشخصي' : 'Profile', layout: 'portal', showNav: true, portalFrame: true, portalRole: 'doctor', portalActive: 'profile', portalNext: '/portal/doctor/profile' }) %>
<%
  // ---- Locals guards ----
  var _isAr = (typeof isAr !== 'undefined') ? !!isAr : false;
  var _doctor = (typeof doctor !== 'undefined' && doctor) ? doctor : {};
  var _specialty = (typeof specialty !== 'undefined' && specialty) ? specialty : null;
  var _specialties = Array.isArray(typeof specialties !== 'undefined' ? specialties : []) ? specialties : [];
  var _success = (typeof success !== 'undefined' && success) ? String(success) : '';
  var _error   = (typeof error   !== 'undefined' && error)   ? String(error)   : '';
  var _fe      = (typeof fieldErrors !== 'undefined' && fieldErrors) ? fieldErrors : {};
  var _reviews = Array.isArray(typeof profileReviews !== 'undefined' ? profileReviews : []) ? profileReviews : [];
  var _stats   = (typeof profileReviewStats !== 'undefined' && profileReviewStats) ? profileReviewStats : { avg: null, count: 0 };

  function _t(en, ar) { return _isAr ? ar : en; }
  function _val(v) { return v == null ? '' : String(v); }
  function _fmtAvg(v) { return v == null ? '—' : Number(v).toFixed(2); }
  function _stars(n) {
    var full = Math.max(0, Math.min(5, Math.round(Number(n) || 0)));
    return { full: full, empty: 5 - full };
  }
  function _humanDate(s) {
    if (!s) return '';
    try { return new Date(s).toLocaleDateString(_isAr ? 'ar-EG' : 'en-US', { year: 'numeric', month: 'short', day: 'numeric' }); }
    catch (_) { return String(s); }
  }

  var _spokenLangs = [];
  if (Array.isArray(_doctor.spoken_languages)) _spokenLangs = _doctor.spoken_languages;
  var _subSpecs = [];
  if (Array.isArray(_doctor.sub_specialties)) _subSpecs = _doctor.sub_specialties;
%>

<%- include('partials/doctor/topbar', {
  isAr: _isAr,
  topbarTitle: _t('Profile', 'الملف الشخصي'),
  topbarSub: _t('Public specialist profile shown to patients', 'الملف الشخصي العام الذي يظهر للمرضى'),
  topbarShowSearch: false
}) %>

<% if (_success) { %>
  <div class="v2-card" style="margin-block-end:18px;border-color:#C2E6D2;">
    <div class="v2-card__body" style="display:flex;gap:12px;align-items:center;color:var(--v2-success);font-size:13px;font-weight:600;">
      <div style="width:28px;height:28px;border-radius:8px;background:var(--v2-success-bg);color:var(--v2-success);display:flex;align-items:center;justify-content:center;font-weight:700;">✓</div>
      <%= _success %>
    </div>
  </div>
<% } %>
<% if (_error) { %>
  <div class="v2-card" style="margin-block-end:18px;border-color:#F2C9C9;">
    <div class="v2-card__body" style="display:flex;gap:12px;align-items:center;color:var(--v2-danger);font-size:13px;font-weight:600;">
      <div style="width:28px;height:28px;border-radius:8px;background:var(--v2-danger-bg);color:var(--v2-danger);display:flex;align-items:center;justify-content:center;font-weight:700;">!</div>
      <%= _error %>
    </div>
  </div>
<% } %>

<form method="POST" action="/portal/doctor/profile">
  <%- (typeof csrfField === 'function') ? csrfField() : '' %>
  <input type="hidden" name="affiliations_json" value="<%= _val(_doctor.affiliations ? JSON.stringify(_doctor.affiliations) : '[]') %>" />
  <input type="hidden" name="certifications_json" value="<%= _val(_doctor.certifications ? JSON.stringify(_doctor.certifications) : '[]') %>" />
  <input type="hidden" name="sub_specialties" value="<%= _val(_subSpecs.length ? JSON.stringify(_subSpecs) : '[]') %>" />
  <input type="hidden" name="spoken_languages" value="<%= _val(_spokenLangs.length ? JSON.stringify(_spokenLangs) : '[]') %>" />

  <div class="v2-layout-grid">
    <div class="v2-stack">
      <div class="v2-card">
        <div class="v2-card__header">
          <div class="v2-card__title"><%= _t('Professional details', 'البيانات المهنية') %></div>
        </div>
        <div class="v2-card__body" style="display:grid;grid-template-columns:1fr 1fr;gap:14px;">
          <div class="v2-field">
            <label class="v2-field__label" for="pf-name"><%= _t('Full name', 'الاسم الكامل') %></label>
            <input class="v2-field__input" id="pf-name" name="name" value="<%= _val(_doctor.name) %>" />
          </div>
          <div class="v2-field">
            <label class="v2-field__label" for="pf-name-ar"><%= _t('Name (Arabic)', 'الاسم بالعربية') %></label>
            <input class="v2-field__input" id="pf-name-ar" name="name_ar" value="<%= _val(_doctor.name_ar) %>" />
          </div>
          <div class="v2-field">
            <label class="v2-field__label" for="pf-phone"><%= _t('Phone', 'الهاتف') %></label>
            <input class="v2-field__input" id="pf-phone" name="phone" value="<%= _val(_doctor.phone) %>" />
          </div>
          <div class="v2-field">
            <label class="v2-field__label" for="pf-cc"><%= _t('Country code', 'رمز الدولة') %></label>
            <input class="v2-field__input" id="pf-cc" name="country_code" value="<%= _val(_doctor.country_code) %>" />
          </div>
          <div class="v2-field">
            <label class="v2-field__label" for="pf-spec"><%= _t('Specialty', 'التخصص') %></label>
            <select class="v2-field__select" id="pf-spec" name="specialty_id">
              <option value=""><%= _t('— select —', '— اختر —') %></option>
              <% _specialties.forEach(function(s){ %>
                <option value="<%= s.id %>" <%= String(_doctor.specialty_id || '') === String(s.id) ? 'selected' : '' %>><%= s.name %></option>
              <% }); %>
            </select>
          </div>
          <div class="v2-field">
            <label class="v2-field__label" for="pf-yrs"><%= _t('Years of practice', 'سنوات الخبرة') %></label>
            <input class="v2-field__input" id="pf-yrs" type="number" name="years_of_experience" value="<%= _val(_doctor.years_of_experience) %>" />
          </div>
          <div class="v2-field">
            <label class="v2-field__label" for="pf-lic"><%= _t('License #', 'رقم الترخيص') %></label>
            <input class="v2-field__input" id="pf-lic" name="medical_license_number" value="<%= _val(_doctor.medical_license_number) %>" />
          </div>
          <div class="v2-field">
            <label class="v2-field__label" for="pf-lic-c"><%= _t('License country', 'دولة الترخيص') %></label>
            <input class="v2-field__input" id="pf-lic-c" name="license_country" value="<%= _val(_doctor.license_country) %>" />
          </div>
          <div class="v2-field" style="grid-column:span 2;">
            <label class="v2-field__label" for="pf-school"><%= _t('Medical school', 'كلية الطب') %></label>
            <input class="v2-field__input" id="pf-school" name="medical_school" value="<%= _val(_doctor.medical_school) %>" />
          </div>
          <div class="v2-field" style="grid-column:span 2;">
            <label class="v2-field__label" for="pf-bio"><%= _t('Bio · shown to patients (English)', 'النبذة المعروضة للمرضى (إنجليزي)') %></label>
            <textarea class="v2-field__textarea" id="pf-bio" name="bio" rows="3"><%= _val(_doctor.bio) %></textarea>
          </div>
          <div class="v2-field" style="grid-column:span 2;">
            <label class="v2-field__label" for="pf-bio-ar"><%= _t('Bio (Arabic)', 'النبذة بالعربية') %></label>
            <textarea class="v2-field__textarea" id="pf-bio-ar" name="bio_ar" rows="3" dir="rtl"><%= _val(_doctor.bio_ar) %></textarea>
          </div>
        </div>
      </div>

      <% if (_reviews.length) { %>
      <div class="v2-card">
        <div class="v2-card__header">
          <div class="v2-card__title"><%= _t('Patient reviews', 'تقييمات المرضى') %></div>
          <% if (_stats.count) { %>
            <span class="v2-card__title-sub" data-numeric><%= _stats.count %> <%= _t('reviews', 'تقييماً') %></span>
          <% } %>
        </div>
        <% if (_stats.count > 0) { %>
        <div class="v2-card__body" style="display:flex;align-items:center;gap:18px;border-block-end:1px solid var(--v2-rule);">
          <div>
            <div class="v2-stat-tile__label"><%= _t('Average', 'المتوسط') %></div>
            <div class="v2-stat-tile__value v2-stat-tile__value--brass" data-numeric><%= _fmtAvg(_stats.avg) %><span style="font-size:14px;color:var(--v2-muted);font-weight:500;"> / 5</span></div>
          </div>
          <% var avgStars = _stars(_stats.avg); %>
          <div class="v2-review-row__stars">
            <% for (var i=0; i<avgStars.full; i++) { %>★<% } %><span class="v2-review-row__stars-empty"><% for (var j=0; j<avgStars.empty; j++) { %>★<% } %></span>
          </div>
        </div>
        <% } %>
        <div class="v2-card__body v2-card__body--flush">
          <% _reviews.forEach(function(r) {
               var s = _stars(r.rating);
               var who = r.is_anonymous ? _t('Anonymous patient', 'مريض مجهول الهوية') : (r.patient_name || _t('Patient', 'مريض'));
          %>
            <div class="v2-review-row">
              <div class="v2-review-row__stars">
                <% for (var k=0; k<s.full; k++) { %>★<% } %><span class="v2-review-row__stars-empty"><% for (var l=0; l<s.empty; l++) { %>★<% } %></span>
              </div>
              <% if (r.review_text) { %>
                <div class="v2-review-row__text">"<%= r.review_text %>"</div>
              <% } %>
              <div class="v2-review-row__meta"><%= who %> · <%= _humanDate(r.created_at) %></div>
            </div>
          <% }); %>
        </div>
      </div>
      <% } else { %>
      <div class="v2-card">
        <div class="v2-card__header"><div class="v2-card__title"><%= _t('Patient reviews', 'تقييمات المرضى') %></div></div>
        <div class="v2-card__body--flush">
          <div class="v2-empty">
            <div class="v2-locked__glyph" style="margin:0 auto 14px;">★</div>
            <div class="v2-empty__title"><%= _t('No reviews yet', 'لا توجد تقييمات بعد') %></div>
            <div class="v2-empty__msg"><%= _t('Patients can leave a review after you submit their report. Reviews surface here once visible.', 'يمكن للمرضى ترك تقييم بعد إرسال التقرير. ستظهر التقييمات هنا حالما تكون مرئية.') %></div>
          </div>
        </div>
      </div>
      <% } %>
    </div>

    <div class="v2-stack">
      <div class="v2-card">
        <div class="v2-card__header"><div class="v2-card__title"><%= _t('Verification', 'التحقق') %></div></div>
        <div class="v2-card__body">
          <% [
            ['license', _t('Medical license', 'الترخيص الطبي'), _doctor.medical_license_number ? _t('On file', 'مسجّل') : _t('Missing', 'غير مسجّل'), _doctor.medical_license_number ? 'success' : 'warn'],
            ['photo',   _t('Profile photo', 'الصورة الشخصية'),   _doctor.profile_photo_url ? _t('Uploaded', 'تم الرفع') : _t('Not uploaded', 'لم تُرفع'), _doctor.profile_photo_url ? 'success' : 'warn'],
            ['phone',   _t('Phone',           'الهاتف'),          _doctor.phone ? _t('Verified', 'موثَّق') : _t('Missing', 'مفقود'), _doctor.phone ? 'success' : 'warn']
          ].forEach(function(row, i){
            var label = row[1], val = row[2], tone = row[3];
            var color = tone === 'success' ? 'var(--v2-success)' : 'var(--v2-warn)';
          %>
            <div style="display:flex;justify-content:space-between;padding:10px 0;border-block-start:<%= i ? '1px solid var(--v2-rule)' : 'none' %>;font-size:13px;">
              <span><%= label %></span>
              <span style="color:<%= color %>;font-weight:600;font-size:12px;"><%= val %></span>
            </div>
          <% }); %>
        </div>
      </div>

      <div class="v2-card">
        <div class="v2-card__header"><div class="v2-card__title"><%= _t('Languages & specialties', 'اللغات والتخصصات') %></div></div>
        <div class="v2-card__body">
          <div class="v2-stat-tile__label v2-mb-3"><%= _t('Spoken languages', 'اللغات المتاحة') %></div>
          <div style="display:flex;gap:6px;flex-wrap:wrap;margin-block-end:14px;">
            <% if (_spokenLangs.length) {
                 _spokenLangs.forEach(function(l){ %>
                   <span class="v2-chip v2-chip--teal"><%= l %></span>
            <%   });
               } else { %>
                 <span class="v2-chip v2-chip--neutral"><%= _t('None set', 'لم تُحدّد') %></span>
            <% } %>
          </div>
          <div class="v2-stat-tile__label v2-mb-3"><%= _t('Primary specialty', 'التخصص الأساسي') %></div>
          <div style="display:flex;gap:6px;flex-wrap:wrap;margin-block-end:<%= _subSpecs.length ? '14px' : '0' %>;">
            <% if (_specialty && _specialty.name) { %>
              <span class="v2-chip v2-chip--brass"><%= _specialty.name %></span>
            <% } else { %>
              <span class="v2-chip v2-chip--neutral"><%= _t('None set', 'لم يُحدَّد') %></span>
            <% } %>
          </div>
          <% if (_subSpecs.length) { %>
            <div class="v2-stat-tile__label v2-mb-3"><%= _t('Sub-specialties', 'التخصصات الفرعية') %></div>
            <div style="display:flex;gap:6px;flex-wrap:wrap;">
              <% _subSpecs.forEach(function(s){ %>
                <span class="v2-chip v2-chip--neutral"><%= s %></span>
              <% }); %>
            </div>
          <% } %>
        </div>
      </div>

      <div class="v2-card">
        <div class="v2-card__body" style="display:flex;justify-content:space-between;align-items:center;gap:10px;">
          <a class="v2-btn v2-btn--ghost" href="<%= _doctor.id ? ('/portal/doctor/' + _doctor.id + '/reviews') : '#' %>"><%= _t('Preview as patient →', 'معاينة كمريض →') %></a>
          <button type="submit" class="v2-btn v2-btn--primary"><%= _t('Save changes', 'حفظ التغييرات') %></button>
        </div>
      </div>
    </div>
  </div>
</form>

<%- include('partials/footer') %>
