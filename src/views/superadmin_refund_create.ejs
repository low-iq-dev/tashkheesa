<%
  // Operator-initiated refund form (side issue #44). Restyled to cockpit
  // chrome. All form input bounds preserved verbatim:
  //   amount: step=0.01, min=0.01, max=_maxAmt (= base_price + urgency_uplift)
  //   instapay_handle: minlength=3, maxlength=100, required
  //   notes: maxlength=1000
  // Server-side mirrors at POST /superadmin/refunds/create.
  // Locals: order (with patient_name + patient_email), defaultAmount,
  //         existingRefund (null OR { id, status }), formError, lang, isAr.
  function fmtAmt(n) {
    if (n == null || n === '') return '0.00';
    const num = Number(n);
    if (!Number.isFinite(num)) return '0.00';
    return num.toFixed(2);
  }
  const _isAr = !!(typeof isAr !== 'undefined' && isAr);
  const _orderId = (order && order.id) || '';
  const _ref = (order && order.reference_id)
    ? order.reference_id
    : String(_orderId).slice(0, 12).toUpperCase();
  // Refund ceiling: full case price = base + urgency uplift. Computed
  // inline because it appears in both the display table and the form
  // input's max= attribute. Server-side equivalent in POST handler.
  const _maxAmt = Number(order && order.base_price || 0) + Number(order && order.urgency_uplift_amount || 0);
  const _tt = (typeof tt === 'function') ? tt : function(_k, en, ar) { return _isAr ? ar : en; };
%>
<%- include('partials/superadmin/header', {
      title: _tt('New refund', 'New refund', 'استرداد جديد'),
      currentSection: 'refunds',
      user: user,
      lang: lang || 'en',
      showTabBar: false,
      sidebarBadges: (typeof sidebarBadges !== 'undefined' && sidebarBadges) ? sidebarBadges : {},
      cspNonce: (typeof cspNonce !== 'undefined') ? cspNonce : ''
    }) %>

<%- include('partials/superadmin/page_header', {
      title: _tt('Create refund on patient\'s behalf', 'Create refund on patient\'s behalf', 'إنشاء استرداد نيابةً عن المريض'),
      subtitle: _tt('Operator-initiated. Status starts at pending; you approve it next.', 'Operator-initiated. Status starts at pending; you approve it next.', 'استرداد بواسطة المشغّل. الحالة تبدأ معلّقة؛ هتعتمدها بعد كده.'),
      breadcrumb: [
        { label: 'Dashboard', href: '/superadmin' },
        { label: _tt('Refunds', 'Refunds', 'الاستردادات'), href: '/superadmin/refunds' },
        { label: _tt('New refund', 'New refund', 'استرداد جديد') }
      ],
      actionsHtml: '<a href="/superadmin/refunds" class="btn">' + _tt('Cancel', 'Cancel', 'إلغاء') + '</a>'
    }) %>

<div class="page-body" style="max-width:780px;">
  <% if (formError) { %>
    <div class="flash err">
      <strong><%= _tt('Error', 'Error', 'خطأ') %>:</strong>
      <% if (formError === 'order_not_paid') { %>
        <%= _tt('This order is not in paid status. Refund cannot be issued.', 'This order is not in paid status. Refund cannot be issued.', 'الطلب ده مش في حالة مدفوع. مينفعش نعمل استرداد.') %>
      <% } else if (formError === 'refund_already_exists') { %>
        <%= _tt('A refund row already exists for this order. Use the queue instead.', 'A refund row already exists for this order. Use the queue instead.', 'فيه طلب استرداد موجود بالفعل. استخدم القائمة.') %>
      <% } else if (formError === 'invalid_amount') { %>
        <%= _tt('Amount must be greater than zero.', 'Amount must be greater than zero.', 'لازم يكون المبلغ أكبر من صفر.') %>
      <% } else if (formError === 'amount_exceeds_max') { %>
        <%= _tt('Amount exceeds the full case price.', 'Amount exceeds the full case price.', 'المبلغ أكبر من سعر الحالة الكامل.') %>
      <% } else if (formError === 'instapay_required') { %>
        <%= _tt('Instapay handle is required (3-100 characters).', 'Instapay handle is required (3-100 characters).', 'لازم تكتب رقم إنستاباي صحيح (3-100 حرف).') %>
      <% } else if (formError === 'insert_failed') { %>
        <%= _tt('Database error. Try again or check the error logs.', 'Database error. Try again or check the error logs.', 'خطأ في قاعدة البيانات. حاول تاني.') %>
      <% } else { %>
        <%= formError %>
      <% } %>
    </div>
  <% } %>

  <% if (existingRefund) { %>
    <%- include('partials/superadmin/c_card_open', {
          title: _tt('Refund already exists', 'Refund already exists', 'طلب استرداد موجود'),
          actionsHtml: '<span class="chip amber">existing</span>'
        }) %>
      <p style="margin:0 0 12px 0;font-size:12.5px;color:var(--fg-2);">
        <%= _tt('There is already a non-terminal refund row for this order. Use the queue to manage it.', 'There is already a non-terminal refund row for this order. Use the queue to manage it.', 'فيه طلب استرداد بالفعل لطلب الحالة ده. ادخل القائمة وتعامل معاه.') %>
        (<%= _tt('Status', 'Status', 'الحالة') %>: <code class="mono"><%= existingRefund.status %></code>)
      </p>
      <a href="/superadmin/refunds" class="btn"><%= _tt('Back to queue', 'Back to queue', 'ارجع للقائمة') %></a>
    <%- include('partials/superadmin/c_card_close') %>
  <% } else { %>

  <%- include('partials/superadmin/c_card_open', { title: _tt('Order context', 'Order context', 'تفاصيل الطلب') }) %>
    <div style="display:grid;grid-template-columns:160px 1fr;gap:8px 16px;font-size:12.5px;">
      <div style="color:var(--fg-3);"><%= _tt('Order ID', 'Order ID', 'رقم الطلب') %></div>
      <div><code class="mono"><%= _orderId %></code></div>
      <div style="color:var(--fg-3);"><%= _tt('Reference', 'Reference', 'المرجع') %></div>
      <div><strong class="mono"><%= _ref %></strong></div>
      <div style="color:var(--fg-3);"><%= _tt('Patient', 'Patient', 'المريض') %></div>
      <div><%= (order && order.patient_name) || '—' %><% if (order && order.patient_email) { %> · <code class="mono" style="font-size:11.5px;"><%= order.patient_email %></code><% } %></div>
      <div style="color:var(--fg-3);"><%= _tt('Base price', 'Base price', 'السعر الأساسي') %></div>
      <div class="tabular"><%= fmtAmt(order && order.base_price) %> EGP</div>
      <div style="color:var(--fg-3);"><%= _tt('Urgency uplift', 'Urgency uplift', 'علاوة الاستعجال') %></div>
      <div class="tabular"><%= fmtAmt(order && order.urgency_uplift_amount) %> EGP</div>
      <div style="color:var(--fg-3);"><%= _tt('Maximum refund', 'Maximum refund', 'أقصى مبلغ للاسترداد') %></div>
      <div class="tabular" style="font-weight:600;color:var(--accent);"><%= fmtAmt(_maxAmt) %> EGP</div>
    </div>
  <%- include('partials/superadmin/c_card_close') %>

  <div style="margin-top:14px;">
    <%- include('partials/superadmin/c_card_open', { title: _tt('Refund details', 'Refund details', 'تفاصيل الاسترداد') }) %>
      <form method="post" action="/superadmin/refunds/create" style="display:flex;flex-direction:column;gap:14px;">
        <%- (typeof csrfField === 'function') ? csrfField() : '' %>
        <input type="hidden" name="order_id" value="<%= _orderId %>" />

        <div class="c-field">
          <label class="c-field-label" for="amount">
            <%= _tt('Amount (EGP)', 'Amount (EGP)', 'المبلغ (جنيه)') %><span class="req">*</span>
          </label>
          <input class="c-input tabular" id="amount" type="number" name="amount" step="0.01" min="0.01" max="<%= fmtAmt(_maxAmt) %>" value="<%= fmtAmt(_maxAmt) %>" required dir="ltr" style="font-size:15px;" />
          <div class="c-field-help"><%= _tt('Default is the full case price. Edit down for partial refunds.', 'Default is the full case price. Edit down for partial refunds.', 'القيمة الافتراضية هي السعر الكامل. عدّل لأقل لو استرداد جزئي.') %></div>
        </div>

        <div class="c-field">
          <label class="c-field-label" for="instapay_handle">
            <%= _tt('Patient Instapay handle', 'Patient Instapay handle', 'رقم الإنستاباي للمريض') %><span class="req">*</span>
          </label>
          <input class="c-input" id="instapay_handle" type="text" name="instapay_handle" minlength="3" maxlength="100" required dir="ltr" placeholder="patient@instapay" />
          <div class="c-field-help"><%= _tt('Required. The patient will see this in the notification — they can reply if it\'s wrong.', 'Required. The patient will see this in the notification — they can reply if it\'s wrong.', 'مطلوب. هيشوف المريض الرقم في الإشعار — يقدر يرد لو غلط.') %></div>
        </div>

        <div class="c-field">
          <label class="c-field-label" for="notes">
            <%= _tt('Notes (optional)', 'Notes (optional)', 'ملاحظات (اختياري)') %>
          </label>
          <textarea class="c-textarea" id="notes" name="notes" maxlength="1000" rows="3"></textarea>
          <div class="c-field-help"><%= _tt('Audit-only. Appears in the operator_refund_created event log.', 'Audit-only. Appears in the operator_refund_created event log.', 'للمراجعة فقط. هيظهر في سجل الأحداث.') %></div>
        </div>

        <div style="display:flex;gap:8px;justify-content:flex-end;margin-top:6px;">
          <a href="/superadmin/refunds" class="btn"><%= _tt('Cancel', 'Cancel', 'إلغاء') %></a>
          <button type="submit" class="btn primary"><%= _tt('Create refund', 'Create refund', 'إنشاء الاسترداد') %></button>
        </div>
      </form>
    <%- include('partials/superadmin/c_card_close') %>
  </div>
  <% } %>
</div>

<%- include('partials/superadmin/footer', { isAr: _isAr }) %>
