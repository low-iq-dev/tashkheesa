<%- include('partials/header', { title: "Find Your Service – Tashkheesa", layout: "public", showNav: true }) %>

<main class="page-shell">
  <div class="page-inner" style="max-width:600px; margin:0 auto; padding:40px 20px;">
    <div style="text-align:center; margin-bottom:32px;">
      <div style="font-size:48px; margin-bottom:12px;">🩺</div>
      <h1 style="font-size:32px; font-weight:700; color:#1f2937; margin-bottom:8px;">
        <%= lang === 'ar' ? 'مش عارف تختار؟' : "Not sure which service you need?" %>
      </h1>
      <p style="color:#6b7280; font-size:16px; line-height:1.6;">
        <%= lang === 'ar'
          ? 'أجب على سؤالين بسيطين وسيعثر مساعدنا على الخدمة الأنسب لحالتك.'
          : 'Answer a couple of quick questions and our assistant will match you to the right specialist review.' %>
      </p>
    </div>

    <!-- Inline full-height chat UI (same component, different layout) -->
    <div class="sa-panel" style="border-radius:16px; box-shadow:0 4px 24px rgba(0,0,0,0.1); overflow:hidden;">
      <div class="sa-header">
        <div class="sa-header-left">
          <div class="sa-avatar">🩺</div>
          <div>
            <div class="sa-title"><%= lang === 'ar' ? 'مساعد تشخيصة' : 'Tashkheesa Assistant' %></div>
            <div class="sa-subtitle"><%= lang === 'ar' ? 'سيساعدك في اختيار الخدمة المناسبة' : "I'll help you find the right service" %></div>
          </div>
        </div>
      </div>

      <div id="sa-messages" class="sa-messages" style="min-height:260px; max-height:400px;">
        <div class="sa-msg sa-msg-bot">
          <div class="sa-msg-bubble">
            <%= lang === 'ar'
              ? 'أهلاً! أنا هنا أساعدك تختار الخدمة الصح. بإيجاز، إيه اللي عندك؟ مثلاً: تقرير، صورة أشعة، تحليل دم؟'
              : "Hi! I'm here to help you find the right service. In a few words — what do you have? For example: a scan, a lab result, a doctor's report?" %>
          </div>
        </div>
      </div>

      <div id="sa-recommendation" class="sa-recommendation" style="display:none;">
        <div class="sa-rec-label"><%= lang === 'ar' ? '✅ توصيتي لك' : '✅ My recommendation' %></div>
        <div class="sa-rec-name" id="sa-rec-name"></div>
        <div class="sa-rec-specialty" id="sa-rec-specialty"></div>
        <div class="sa-rec-reason" id="sa-rec-reason"></div>
        <a id="sa-rec-cta" href="#" class="sa-rec-btn">
          <%= lang === 'ar' ? 'ابدأ هنا ←' : 'Start with this service →' %>
        </a>
        <button class="sa-rec-reset" onclick="saReset()">
          <%= lang === 'ar' ? 'إبحث من جديد' : 'Start over' %>
        </button>
      </div>

      <div id="sa-input-area" class="sa-input-area">
        <textarea id="sa-input" class="sa-input" rows="2"
          placeholder="<%= lang === 'ar' ? 'اكتب هنا...' : 'Type here...' %>"
          onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();saSend();}"></textarea>
        <button class="sa-send" onclick="saSend()">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M2 21l21-9L2 3v7l15 2-15 2z"/></svg>
        </button>
      </div>
    </div>

    <p style="text-align:center; margin-top:24px; font-size:13px; color:#9ca3af;">
      <%= lang === 'ar'
        ? 'أو <a href="/services" style="color:#2563eb;">تصفح كل الخدمات</a> بنفسك'
        : 'Or <a href="/services" style="color:#2563eb;">browse all services</a> yourself' %>
    </p>
  </div>
</main>

<style>
/* Reuse the same styles from the partial */
.sa-panel { display:flex; flex-direction:column; }
.sa-header { background:#1e40af; color:white; padding:16px; display:flex; align-items:center; justify-content:space-between; }
.sa-header-left { display:flex; align-items:center; gap:10px; }
.sa-avatar { font-size:26px; line-height:1; }
.sa-title { font-weight:700; font-size:15px; }
.sa-subtitle { font-size:12px; opacity:0.8; margin-top:2px; }
.sa-messages { flex:1; overflow-y:auto; padding:16px; display:flex; flex-direction:column; gap:10px; }
.sa-msg { display:flex; }
.sa-msg-bot { justify-content:flex-start; }
.sa-msg-user { justify-content:flex-end; }
.sa-msg-bubble { max-width:82%; padding:10px 14px; border-radius:14px; font-size:15px; line-height:1.5; }
.sa-msg-bot .sa-msg-bubble { background:#f3f4f6; color:#1f2937; border-bottom-left-radius:4px; }
.sa-msg-user .sa-msg-bubble { background:#2563eb; color:white; border-bottom-right-radius:4px; }
.sa-typing { display:flex; gap:4px; padding:10px 14px; background:#f3f4f6; border-radius:14px; border-bottom-left-radius:4px; width:fit-content; }
.sa-typing span { width:6px; height:6px; background:#9ca3af; border-radius:50%; animation:sa-bounce 1.2s infinite; }
.sa-typing span:nth-child(2) { animation-delay:0.2s; }
.sa-typing span:nth-child(3) { animation-delay:0.4s; }
@keyframes sa-bounce { 0%,60%,100%{transform:translateY(0)} 30%{transform:translateY(-6px)} }
.sa-recommendation { margin:0 16px 12px; padding:14px; background:#eff6ff; border:2px solid #93c5fd; border-radius:12px; }
.sa-rec-label { font-size:12px; font-weight:700; color:#1e40af; margin-bottom:6px; }
.sa-rec-name { font-size:16px; font-weight:700; color:#1f2937; margin-bottom:2px; }
.sa-rec-specialty { font-size:12px; color:#6b7280; margin-bottom:6px; }
.sa-rec-reason { font-size:13px; color:#374151; margin-bottom:12px; line-height:1.4; }
.sa-rec-btn { display:block; background:#2563eb; color:white; text-align:center; padding:12px; border-radius:8px; font-weight:600; font-size:15px; text-decoration:none; margin-bottom:8px; transition:background 0.2s; }
.sa-rec-btn:hover { background:#1d4ed8; }
.sa-rec-reset { background:none; border:none; color:#6b7280; font-size:12px; cursor:pointer; text-decoration:underline; display:block; margin:0 auto; }
.sa-input-area { display:flex; align-items:flex-end; gap:8px; padding:12px 16px; border-top:1px solid #e5e7eb; }
.sa-input { flex:1; border:1.5px solid #e5e7eb; border-radius:10px; padding:10px 12px; font-size:15px; resize:none; outline:none; font-family:inherit; line-height:1.4; }
.sa-input:focus { border-color:#2563eb; }
.sa-send { background:#2563eb; color:white; border:none; border-radius:10px; width:44px; height:44px; display:flex; align-items:center; justify-content:center; cursor:pointer; flex-shrink:0; transition:background 0.2s; }
.sa-send:hover { background:#1d4ed8; }
.sa-send:disabled { background:#93c5fd; cursor:not-allowed; }
</style>

<script>
(function() {
  const SUBMIT_BASE = '/order/start';
  const LANG = '<%= lang || "en" %>';
  let history = [];
  let busy = false;
  let hasRec = false;

  window.saReset = function() {
    history = [];
    hasRec = false;
    const msgs = document.getElementById('sa-messages');
    msgs.innerHTML = `<div class="sa-msg sa-msg-bot"><div class="sa-msg-bubble">${LANG === 'ar' ? 'أهلاً! أنا هنا أساعدك تختار الخدمة الصح. بإيجاز، إيه اللي عندك؟ مثلاً: تقرير، صورة أشعة، تحليل دم؟' : "Hi! I'm here to help you find the right service. In a few words — what do you have? For example: a scan, a lab result, a doctor's report?"}</div></div>`;
    document.getElementById('sa-recommendation').style.display = 'none';
    document.getElementById('sa-input-area').style.display = 'flex';
    document.getElementById('sa-input').value = '';
  };

  window.saSend = function() {
    if (busy || hasRec) return;
    const input = document.getElementById('sa-input');
    const text = input.value.trim();
    if (!text) return;
    input.value = '';
    appendMsg('user', text);
    history.push({ role: 'user', content: text });
    const typingId = 'sa-typing-' + Date.now();
    appendTyping(typingId);
    busy = true;
    document.querySelector('.sa-send').disabled = true;

    fetch('/api/help-me-choose', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ messages: history, lang: LANG })
    })
    .then(r => r.json())
    .then(data => {
      removeTyping(typingId);
      busy = false;
      document.querySelector('.sa-send').disabled = false;
      if (!data.ok) { appendMsg('bot', LANG === 'ar' ? 'حدث خطأ. حاول مرة أخرى.' : 'Something went wrong. Please try again.'); return; }
      if (data.message) { appendMsg('bot', data.message); history.push({ role: 'assistant', content: data.message }); }
      if (data.recommendation) showRecommendation(data.recommendation);
    })
    .catch(() => {
      removeTyping(typingId);
      busy = false;
      document.querySelector('.sa-send').disabled = false;
      appendMsg('bot', LANG === 'ar' ? 'حدث خطأ. حاول مرة أخرى.' : 'Something went wrong. Please try again.');
    });
  };

  function appendMsg(role, text) {
    const msgs = document.getElementById('sa-messages');
    const div = document.createElement('div');
    div.className = `sa-msg sa-msg-${role === 'user' ? 'user' : 'bot'}`;
    div.innerHTML = `<div class="sa-msg-bubble">${escHtml(text)}</div>`;
    msgs.appendChild(div);
    msgs.scrollTop = msgs.scrollHeight;
  }
  function appendTyping(id) {
    const msgs = document.getElementById('sa-messages');
    const div = document.createElement('div');
    div.className = 'sa-msg sa-msg-bot';
    div.id = id;
    div.innerHTML = '<div class="sa-typing"><span></span><span></span><span></span></div>';
    msgs.appendChild(div);
    msgs.scrollTop = msgs.scrollHeight;
  }
  function removeTyping(id) { const el = document.getElementById(id); if (el) el.remove(); }
  function showRecommendation(rec) {
    hasRec = true;
    document.getElementById('sa-input-area').style.display = 'none';
    document.getElementById('sa-rec-name').textContent = rec.service_name || '';
    document.getElementById('sa-rec-specialty').textContent = rec.specialty || '';
    document.getElementById('sa-rec-reason').textContent = rec.reason || '';
    document.getElementById('sa-rec-cta').href = SUBMIT_BASE + '?service_id=' + encodeURIComponent(rec.service_id);
    document.getElementById('sa-recommendation').style.display = 'block';
    document.getElementById('sa-messages').scrollTop = 9999;
  }
  function escHtml(str) { return str.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br>'); }
})();
</script>

<%- include('partials/footer') %>
