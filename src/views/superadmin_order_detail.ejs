<%
  // Case detail. Locals: order, statusUi (optional), events, doctors,
  //                      additionalFilesRequest (optional).
  // All POST endpoints preserved verbatim — see MIGRATION_NOTES for the
  // /admin/orders/:id/uploads/{lock,unlock} cross-portal exception.
  var isAr = (typeof lang !== 'undefined' && lang === 'ar');
  var _order = order || {};
  var _events = (typeof events !== 'undefined' && events) ? events : [];
  var _doctors = (typeof doctors !== 'undefined' && doctors) ? doctors : [];
  var _nonce = (typeof cspNonce !== 'undefined' && cspNonce) ? cspNonce : '';
  var paymentLink = _order.payment_link || _order.service_payment_link || null;

  function _fmtWhen(iso) {
    if (!iso) return '—';
    var d = new Date(iso);
    if (Number.isNaN(d.getTime())) return '—';
    var diffMs = Date.now() - d.getTime();
    var mins = Math.round(diffMs / 60000);
    if (mins < 1) return 'now';
    if (mins < 60) return mins + 'm ago';
    var hrs = Math.round(mins / 60);
    if (hrs < 24) return hrs + 'h ago';
    var days = Math.round(hrs / 24);
    return days + 'd ago';
  }

  function _statusTone(s) {
    var v = String(s || '').toLowerCase();
    if (v === 'completed') return 'green';
    if (v === 'breached' || v === 'breached_sla' || v === 'delayed') return 'red';
    if (v === 'accepted' || v === 'in_review') return 'accent';
    if (v === 'awaiting_files' || v === 'rejected_files') return 'amber';
    return 'neutral';
  }

  var orderStatus = String(_order.status || '').toLowerCase();
  var isPaid = String(_order.payment_status || '').toLowerCase() === 'paid';
  var hasDoctor = !!_order.doctor_id;
  var isCompleted = ['completed','done','delivered'].indexOf(orderStatus) >= 0;
  var isInReview = orderStatus === 'in_review' || orderStatus === 'accepted';
  var isBreach = orderStatus === 'breached' || orderStatus === 'breached_sla' || orderStatus === 'delayed';
  var hasReport = !!_order.completed_at;

  var timelineSteps = [
    { key: 'created', label: isAr ? 'تم الإنشاء' : 'Created' },
    { key: 'payment', label: isAr ? 'الدفع' : 'Payment' },
    { key: 'assigned', label: isAr ? 'تم التعيين' : 'Assigned' },
    { key: 'in_review', label: isAr ? 'قيد المراجعة' : 'In review' },
    { key: 'report', label: isAr ? 'التقرير' : 'Report' },
    { key: 'completed', label: isAr ? 'مكتملة' : 'Completed' }
  ];
  function _stepDone(key) {
    if (key === 'created') return true;
    if (key === 'payment') return isPaid;
    if (key === 'assigned') return hasDoctor;
    if (key === 'in_review') return isInReview || hasReport || isCompleted;
    if (key === 'report') return hasReport || isCompleted;
    if (key === 'completed') return isCompleted;
    return false;
  }
  function _stepActive(key) {
    if (key === 'payment' && !isPaid) return true;
    if (key === 'assigned' && isPaid && !hasDoctor) return true;
    if (key === 'in_review' && hasDoctor && !isCompleted && !hasReport) return true;
    if (key === 'report' && isInReview && !hasReport) return true;
    if (key === 'completed' && hasReport && !isCompleted) return true;
    return false;
  }

  // Additional-files request derivation (preserved from legacy view)
  var afr = (typeof additionalFilesRequest !== 'undefined' && additionalFilesRequest) ? additionalFilesRequest : null;
  var hasReq = !!(afr && afr.request);
  var reqMeta = hasReq ? (afr.request.meta || {}) : {};
  var reqReason = (reqMeta && typeof reqMeta === 'object' && reqMeta.reason) ? String(reqMeta.reason) : '';
  var reqDoctorId = (reqMeta && typeof reqMeta === 'object' && reqMeta.doctorId) ? String(reqMeta.doctorId) : '';
  var hasDecision = !!(afr && afr.decision);
  var decisionLabel = hasDecision && afr.decision.label ? String(afr.decision.label).toLowerCase() : '';
  var decisionMeta = hasDecision ? (afr.decision.meta || {}) : {};
  var decisionNote = (decisionMeta && typeof decisionMeta === 'object' && decisionMeta.support_note) ? String(decisionMeta.support_note) : '';
  var uploadsLocked = Number(_order && _order.uploads_locked != null ? _order.uploads_locked : 0);
  var hasReqFlag = Number(_order && _order.additional_files_requested != null ? _order.additional_files_requested : 0) === 1;
  var isApprovedDecision = decisionLabel.indexOf('approved') >= 0
    || decisionLabel === 'admin_approved_files_request'
    || decisionLabel === 'superadmin_approved_files_request';
  var afrStatus = !hasReq
    ? 'none'
    : (hasDecision
      ? (isApprovedDecision ? 'approved'
        : ((decisionLabel.indexOf('reject') >= 0 || decisionLabel.indexOf('denied') >= 0) ? 'rejected' : 'pending'))
      : ((hasReqFlag && uploadsLocked === 0) ? 'approved' : 'pending'));
  var afrTone = afrStatus === 'approved' ? 'green' : (afrStatus === 'pending' ? 'amber' : (afrStatus === 'rejected' ? 'red' : 'neutral'));
  var afrLabel = afrStatus === 'approved' ? 'Approved' : (afrStatus === 'pending' ? 'Pending' : (afrStatus === 'rejected' ? 'Rejected' : 'None'));

  var statusLabelText = (typeof statusUi !== 'undefined' && statusUi && (statusUi.title || statusUi.label))
    ? (statusUi.title || statusUi.label)
    : String(_order.status || 'new').replace(/_/g, ' ').replace(/^./, function(c){ return c.toUpperCase(); });
%>
<%- include('partials/superadmin/header', {
      title: 'Case ' + (_order.reference_id || String(_order.id).slice(0, 8)),
      currentSection: 'orders',
      user: user,
      lang: lang || 'en',
      showTabBar: false,
      sidebarBadges: (typeof sidebarBadges !== 'undefined' && sidebarBadges) ? sidebarBadges : {},
      cspNonce: _nonce
    }) %>

<%- include('partials/superadmin/page_header', {
      title: 'Case ' + (_order.reference_id || String(_order.id).slice(0, 8)),
      subtitle: (_order.service_name || 'Service') + (_order.specialty_name ? ' · ' + _order.specialty_name : ''),
      breadcrumb: [
        { label: 'Dashboard', href: '/superadmin' },
        { label: 'Cases', href: '/superadmin/orders' },
        { label: _order.reference_id || String(_order.id).slice(0, 8) }
      ],
      actionsHtml: '<a class="btn" href="/superadmin/orders">Back to list</a>'
    }) %>

<div class="page-body">
  <div class="grid-2">
    <%- include('partials/superadmin/c_card_open', {
          title: 'Summary',
          actionsHtml: '<span class="chip ' + _statusTone(_order.status) + ' dot">' + statusLabelText + '</span>'
        }) %>
      <div style="display:grid;grid-template-columns:140px 1fr;gap:10px 16px;font-size:12.5px;">
        <div style="color:var(--fg-3);">Patient</div>
        <div><%= _order.patient_name || '—' %> <% if (_order.patient_email) { %><span style="color:var(--fg-3);">· <%= _order.patient_email %></span><% } %></div>
        <div style="color:var(--fg-3);">Doctor</div>
        <div><% if (_order.doctor_name) { %><%= _order.doctor_name %><% } else { %><span style="color:var(--fg-3);">Unassigned</span><% } %></div>
        <div style="color:var(--fg-3);">Specialty</div>
        <div><%= _order.specialty_name || '—' %></div>
        <div style="color:var(--fg-3);">Service</div>
        <div><%= _order.service_name || '—' %></div>
        <div style="color:var(--fg-3);">SLA</div>
        <div><%= _order.sla_hours || '—' %>h</div>
        <div style="color:var(--fg-3);">Created</div>
        <div class="mono"><%= _fmtWhen(_order.created_at) %></div>
        <% if (_order.deadline_at) { %>
          <div style="color:var(--fg-3);">Deadline</div>
          <div class="mono"><%= _fmtWhen(_order.deadline_at) %></div>
        <% } %>
      </div>
    <%- include('partials/superadmin/c_card_close') %>

    <%- include('partials/superadmin/c_card_open', {
          title: 'Payment',
          actionsHtml: '<span class="chip ' + (isPaid ? 'green' : 'amber') + '">' + (isPaid ? 'Paid' : 'Unpaid') + '</span>'
        }) %>
      <div style="font-size:13px;margin-bottom:8px;">
        <strong class="tabular"><%= _order.displayCurrency || 'EGP' %> <%= _order.displayPrice != null ? Number(_order.displayPrice).toLocaleString('en-US') : '—' %></strong>
        <span style="color:var(--fg-3);">· doctor fee <%= _order.displayDoctorFee != null ? Number(_order.displayDoctorFee).toLocaleString('en-US') : '—' %></span>
      </div>
      <% if (_order.payment_method || _order.payment_reference) { %>
        <div style="font-size:11.5px;color:var(--fg-3);margin-bottom:8px;">
          <% if (_order.payment_method) { %>Method: <strong style="color:var(--fg-1);"><%= _order.payment_method %></strong><% } %>
          <% if (_order.payment_reference) { %> · Ref: <strong style="color:var(--fg-1);"><%= _order.payment_reference %></strong><% } %>
        </div>
      <% } %>
      <% if (paymentLink) { %>
        <a class="btn" href="<%= paymentLink %>" target="_blank" rel="noopener">Open payment link</a>
      <% } %>
      <% if (!isPaid) { %>
        <form method="post" action="/superadmin/orders/<%= _order.id %>/mark-paid" style="margin-top:12px;">
          <%- (typeof csrfField === 'function') ? csrfField() : '' %>
          <div class="c-form-row">
            <%- include('partials/superadmin/c_form_field', { name: 'payment_method', label: 'Method', placeholder: 'Paymob, card, cash…', value: String(_order.payment_method || '') }) %>
            <%- include('partials/superadmin/c_form_field', { name: 'payment_reference', label: 'Reference', placeholder: 'Transaction ID', value: String(_order.payment_reference || '') }) %>
          </div>
          <button type="submit" class="btn primary">Mark paid</button>
        </form>
      <% } else { %>
        <form method="post" action="/superadmin/orders/<%= _order.id %>/mark-unpaid" style="margin-top:10px;">
          <%- (typeof csrfField === 'function') ? csrfField() : '' %>
          <button type="submit" class="btn">Mark as unpaid</button>
        </form>
      <% } %>
    <%- include('partials/superadmin/c_card_close') %>
  </div>

  <div class="grid-2" style="margin-top:14px;">
    <%- include('partials/superadmin/c_card_open', {
          title: 'Uploads',
          actionsHtml: '<span id="uploadsStatePill" class="chip ' + (uploadsLocked === 1 ? 'red' : 'green') + '" data-locked="' + uploadsLocked + '">' + (uploadsLocked === 1 ? 'Locked' : 'Unlocked') + '</span>'
        }) %>
      <p style="font-size:11.5px;color:var(--fg-3);margin:0 0 8px;">If uploads are locked, support can unlock them so the patient can add missing files.</p>
      <div id="uploadsActionMsg" style="display:none;font-size:11.5px;margin-bottom:8px;"></div>
      <div style="display:flex;gap:8px;align-items:flex-end;flex-wrap:wrap;">
        <div style="flex:1;min-width:240px;">
          <label class="c-field-label">Reason (audit)</label>
          <input id="unlockReason" class="c-input" type="text" value="support_unlock" />
        </div>
        <div id="uploadsCsrf" style="display:none;">
          <%- (typeof csrfField === 'function') ? csrfField() : '' %>
        </div>
        <button id="unlockUploadsBtn" type="button" class="btn"
                data-action="/admin/orders/<%= _order.id %>/uploads/unlock?format=json">Unlock uploads</button>
        <button id="lockUploadsBtn" type="button" class="btn"
                data-action="/admin/orders/<%= _order.id %>/uploads/lock?format=json">Lock uploads</button>
      </div>
    <%- include('partials/superadmin/c_card_close') %>

    <%- include('partials/superadmin/c_card_open', {
          title: 'Additional-files request',
          actionsHtml: '<span class="chip ' + afrTone + '">' + afrLabel + '</span>'
        }) %>
      <% if (!hasReq) { %>
        <p style="font-size:12px;color:var(--fg-3);margin:0;">No additional-files requests for this case.</p>
      <% } else { %>
        <div style="font-size:12px;color:var(--fg-3);margin-bottom:8px;">
          Doctors can request a re-upload when files are unclear. Support must approve before the patient is asked.
        </div>
        <div style="font-size:12px;color:var(--fg-3);margin-bottom:8px;">
          <% if (afr.request.at) { %>Requested: <strong style="color:var(--fg-1);"><%= _fmtWhen(afr.request.at) %></strong><% } %>
          <% if (reqDoctorId) { %> · Doctor: <strong style="color:var(--fg-1);"><%= reqDoctorId %></strong><% } %>
        </div>
        <% if (reqReason) { %>
          <div style="margin-top:8px;">
            <div style="font-size:11.5px;font-weight:600;">Doctor reason</div>
            <div style="font-size:12px;color:var(--fg-1);white-space:pre-line;margin-top:3px;"><%= reqReason %></div>
          </div>
        <% } %>
        <% if (afrStatus !== 'pending' && (afr.decision && (afr.decision.at || decisionNote))) { %>
          <div style="margin-top:10px;">
            <div style="font-size:11.5px;font-weight:600;">Last decision</div>
            <div style="font-size:12px;color:var(--fg-3);margin-top:3px;">
              <% if (afr.decision.at) { %>At: <strong style="color:var(--fg-1);"><%= _fmtWhen(afr.decision.at) %></strong><% } %>
            </div>
            <% if (decisionNote) { %>
              <div style="font-size:12px;white-space:pre-line;margin-top:3px;"><%= decisionNote %></div>
            <% } %>
          </div>
        <% } %>
        <% if (afrStatus === 'pending') { %>
          <form method="post" action="/superadmin/orders/<%= _order.id %>/additional-files/approve" style="margin-top:12px;">
            <%- (typeof csrfField === 'function') ? csrfField() : '' %>
            <input type="hidden" name="request_event_id" value="<%= afr.request.id %>" />
            <%- include('partials/superadmin/c_form_field', { name: 'support_note', label: 'Support note (optional)', placeholder: 'e.g. approved — ask patient to re-upload clearer axial series' }) %>
            <button type="submit" class="btn primary">Approve request</button>
          </form>
          <form method="post" action="/superadmin/orders/<%= _order.id %>/additional-files/reject" style="margin-top:10px;">
            <%- (typeof csrfField === 'function') ? csrfField() : '' %>
            <input type="hidden" name="request_event_id" value="<%= afr.request.id %>" />
            <%- include('partials/superadmin/c_form_field', { name: 'support_note', label: 'Rejection note (optional)', placeholder: 'e.g. rejected — request not specific enough' }) %>
            <button type="submit" class="btn">Reject request</button>
          </form>
          <p style="font-size:11.5px;color:var(--fg-3);margin-top:10px;">Approving moves the case into "awaiting files" and notifies the patient. Rejecting logs the decision and keeps the case moving.</p>
        <% } %>
      <% } %>
    <%- include('partials/superadmin/c_card_close') %>
  </div>

  <div style="margin-top:14px;">
    <%- include('partials/superadmin/c_card_open', { title: 'Case timeline' }) %>
      <div style="display:flex;align-items:flex-start;gap:0;overflow-x:auto;padding:4px 0;">
        <% timelineSteps.forEach(function(step, idx) {
             var done = _stepDone(step.key);
             var active = _stepActive(step.key);
             var dotColor = done ? 'var(--green)' : (active ? 'var(--amber)' : 'var(--bg-3)');
             var textColor = done ? 'var(--green)' : (active ? 'var(--amber)' : 'var(--fg-3)');
             var lineColor = done ? 'var(--green)' : 'var(--line)';
        %>
          <div style="display:flex;flex-direction:column;align-items:center;min-width:80px;">
            <div style="width:28px;height:28px;border-radius:50%;background:<%= dotColor %>;display:flex;align-items:center;justify-content:center;color:white;">
              <% if (done) { %>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
              <% } else if (active) { %>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><circle cx="12" cy="12" r="4"/></svg>
              <% } else { %>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="6"/></svg>
              <% } %>
            </div>
            <div style="font-size:11px;font-weight:600;color:<%= textColor %>;margin-top:6px;text-align:center;"><%= step.label %></div>
          </div>
          <% if (idx < timelineSteps.length - 1) { %>
            <div style="flex:1;height:2px;background:<%= lineColor %>;margin-top:14px;min-width:20px;"></div>
          <% } %>
        <% }); %>
      </div>
      <% if (isBreach) { %>
        <div class="flash err" style="margin:8px 0 0;"><strong><%= isAr ? '⚠️' : '⚠' %></strong> <%= isAr ? 'هذه الحالة تجاوزت الموعد النهائي لـ SLA' : 'This case has breached its SLA deadline' %></div>
      <% } %>
    <%- include('partials/superadmin/c_card_close') %>
  </div>

  <div style="margin-top:14px;">
    <%- include('partials/superadmin/c_card_open', { title: 'Reassign doctor' }) %>
      <form method="post" action="/superadmin/orders/<%= _order.id %>/reassign" style="display:flex;gap:8px;align-items:flex-end;flex-wrap:wrap;">
        <%- (typeof csrfField === 'function') ? csrfField() : '' %>
        <div style="flex:1;min-width:240px;">
          <%
            var doctorOpts = [{ value: '', label: 'Choose doctor' }].concat(
              _doctors.map(function(doc) { return { value: doc.id, label: doc.name || 'Doctor' }; })
            );
          %>
          <%- include('partials/superadmin/c_form_field', { name: 'doctor_id', label: 'Doctor', type: 'select', options: doctorOpts, required: true, value: String(_order.doctor_id || '') }) %>
        </div>
        <button type="submit" class="btn primary" style="margin-bottom:14px;">Reassign</button>
      </form>
      <p style="font-size:11.5px;color:var(--fg-3);margin:0;">Reassigning notifies the new doctor and logs an event.</p>
    <%- include('partials/superadmin/c_card_close') %>
  </div>

  <% if ((_order.sla_hours && _order.deadline_at) || (_order.status !== 'cancelled')) { %>
    <div style="margin-top:14px;">
      <%- include('partials/superadmin/c_card_open', { title: 'Danger zone', sub: 'owner-only destructive actions' }) %>
        <div style="display:flex;gap:8px;flex-wrap:wrap;align-items:center;">
          <% if (_order.sla_hours && _order.deadline_at) { %>
            <form method="post" action="/superadmin/orders/<%= _order.id %>/extend-sla" style="display:inline-flex;gap:6px;align-items:flex-end;">
              <%- (typeof csrfField === 'function') ? csrfField() : '' %>
              <div>
                <label class="c-field-label" for="extra_hours">Extend by (hours)</label>
                <input class="c-input" id="extra_hours" type="number" name="extra_hours" value="24" min="1" max="168" style="width:90px;" dir="ltr" />
              </div>
              <button type="submit" class="btn" style="margin-bottom:0;">Extend SLA</button>
            </form>
          <% } %>
          <% if (_order.status !== 'cancelled') { %>
            <form method="post" action="/superadmin/orders/<%= _order.id %>/cancel" style="display:inline-block;" data-confirm-msg="<%= isAr ? 'هل أنت متأكد من إلغاء هذه الحالة؟' : 'Cancel this case?' %>">
              <%- (typeof csrfField === 'function') ? csrfField() : '' %>
              <button type="submit" class="btn danger">Cancel case</button>
            </form>
          <% } %>
        </div>
      <%- include('partials/superadmin/c_card_close') %>
    </div>
  <% } %>

  <div style="margin-top:14px;">
    <%- include('partials/superadmin/c_card_open', { title: 'Activity', tight: true }) %>
      <% if (!_events.length) { %>
        <%- include('partials/superadmin/c_empty', { title: 'No events yet' }) %>
      <% } else { %>
        <%- include('partials/superadmin/c_table_open', { headers: ['Event', 'When', 'Meta'] }) %>
          <% _events.forEach(function(ev) { %>
            <tr>
              <td><%= ev.label %></td>
              <td class="mono" style="color:var(--fg-3);font-size:11.5px;"><%= _fmtWhen(ev.at) %></td>
              <td style="font-size:11.5px;color:var(--fg-3);font-family:var(--font-mono);max-width:480px;">
                <% if (ev.meta) {
                     var metaText = (typeof ev.meta === 'string') ? ev.meta : JSON.stringify(ev.meta);
                %><%= metaText.length > 200 ? metaText.slice(0, 200) + '…' : metaText %><% } %>
              </td>
            </tr>
          <% }); %>
        <%- include('partials/superadmin/c_table_close') %>
      <% } %>
    <%- include('partials/superadmin/c_card_close') %>
  </div>
</div>

<script<% if (_nonce) { %> nonce="<%= _nonce %>"<% } %>>
(function() {
  // Confirm dialogs for destructive actions
  document.querySelectorAll('form[data-confirm-msg]').forEach(function(f) {
    f.addEventListener('submit', function(ev) {
      if (!window.confirm(f.dataset.confirmMsg || 'Are you sure?')) ev.preventDefault();
    });
  });

  // Uploads lock/unlock — JSON POST, no redirect.
  // ORIGINAL ROUTES PRESERVED at /admin/orders/:id/uploads/{lock,unlock} —
  // see MIGRATION_NOTES "cross-portal exceptions". Functionally identical.
  var unlockBtn = document.getElementById('unlockUploadsBtn');
  var lockBtn = document.getElementById('lockUploadsBtn');
  var uploadsCsrf = document.getElementById('uploadsCsrf');
  var msg = document.getElementById('uploadsActionMsg');
  var reasonEl = document.getElementById('unlockReason');
  var pill = document.getElementById('uploadsStatePill');

  function show(text, isError) {
    if (!msg) return;
    msg.style.display = 'block';
    msg.style.color = isError ? 'var(--red)' : 'var(--green)';
    msg.textContent = text;
  }
  function setPillLocked(isLocked) {
    if (!pill) return;
    pill.dataset.locked = isLocked ? '1' : '0';
    pill.textContent = isLocked ? 'Locked' : 'Unlocked';
    pill.classList.remove('red', 'green');
    pill.classList.add(isLocked ? 'red' : 'green');
  }
  function getCsrf() {
    var el = uploadsCsrf ? uploadsCsrf.querySelector('input[name="_csrf"]') : null;
    return el && el.value ? String(el.value) : '';
  }
  async function callAction(btn) {
    var csrf = getCsrf();
    if (!csrf) throw new Error('Missing CSRF token. Refresh and try again.');
    var url = btn.dataset.action;
    var reason = (reasonEl && reasonEl.value ? reasonEl.value : 'support_change').trim() || 'support_change';
    var body = new URLSearchParams();
    body.set('_csrf', csrf);
    body.set('reason', reason);
    var res = await fetch(url, {
      method: 'POST', credentials: 'same-origin', redirect: 'manual',
      headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest', 'Content-Type': 'application/x-www-form-urlencoded; charset=UTF-8' },
      body: body.toString()
    });
    if (res.status >= 300 && res.status < 400) throw new Error('Server redirected (expected JSON). Refresh and retry.');
    var ct = (res.headers.get('content-type') || '').toLowerCase();
    if (!ct.includes('application/json')) throw new Error('Expected JSON response.');
    var data = await res.json().catch(function(){ return null; });
    if (!res.ok) throw new Error((data && (data.error || data.message)) || (res.status + ' ' + res.statusText));
    return data;
  }
  function wire(btn, locking) {
    if (!btn) return;
    btn.addEventListener('click', async function(e) {
      e.preventDefault();
      var prev = btn.textContent;
      btn.disabled = true;
      btn.textContent = locking ? 'Locking…' : 'Unlocking…';
      show(locking ? 'Locking uploads…' : 'Unlocking uploads…', false);
      try {
        var data = await callAction(btn);
        setPillLocked(locking);
        show((locking ? 'Uploads locked ✅' : 'Uploads unlocked ✅') + ' (reason: ' + (data && data.reason ? data.reason : '—') + ')', false);
      } catch (err) {
        show((locking ? 'Lock' : 'Unlock') + ' failed: ' + err.message, true);
      } finally {
        btn.disabled = false;
        btn.textContent = prev;
      }
    });
  }
  wire(unlockBtn, false);
  wire(lockBtn, true);
})();
</script>

