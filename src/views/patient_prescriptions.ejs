<%
  // Patient prescriptions list — V2 chrome.
  // Locals from src/routes/patient.js:
  //   prescriptions  — array of prescription rows
  //   user, lang, isAr, brand
  //   pageTitle      — optional

  var _lang = (typeof lang !== 'undefined') ? lang : 'en';
  var isAr = (typeof isAr !== 'undefined') ? isAr : (String(_lang).toLowerCase() === 'ar');
  var __isAr = isAr;
  var __lang = _lang;
  function L(en, ar) { return isAr ? ar : en; }

  var _prescriptions = (typeof prescriptions !== 'undefined' && Array.isArray(prescriptions)) ? prescriptions : [];

  function fmtDate(iso) {
    if (!iso) return '';
    try {
      var d = new Date(iso);
      if (isNaN(d.getTime())) return String(iso);
      return d.toLocaleDateString(_lang === 'ar' ? 'ar-EG' : 'en-US', { year: 'numeric', month: 'short', day: 'numeric' });
    } catch (e) { return String(iso); }
  }

  function isExpired(validUntil) {
    if (!validUntil) return false;
    try { return new Date(validUntil) < new Date(); } catch (e) { return false; }
  }

  function countMeds(medsJson) {
    try { return JSON.parse(medsJson || '[]').length; } catch (_) { return 0; }
  }
%>
<%- include('partials/patient/head', {
  active: 'prescriptions',
  title: L('My Prescriptions', 'وصفاتي الطبية'),
  user: (typeof user !== 'undefined' ? user : {}),
  lang: __lang,
  bodyClass: 'p-page-prescriptions'
}) %>

<%- include('partials/patient/topbar', {
  title: L('My Prescriptions', 'وصفاتي الطبية'),
  sub:   L('All prescriptions issued by your doctors.', 'جميع الوصفات الطبية الصادرة لك.'),
  serif: false,
  isAr:  __isAr,
  hideBell: false
}) %>

<% if (_prescriptions.length === 0) { %>
  <div class="p-card" style="text-align:center;padding:3rem 1.5rem;">
    <div style="margin-bottom:1rem;">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none"
           stroke="var(--muted)" stroke-width="1.5"
           stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M10.5 20.5 20.5 10.5a4.95 4.95 0 1 0-7-7L3.5 13.5a4.95 4.95 0 1 0 7 7Z"/>
        <path d="m8.5 8.5 7 7"/>
      </svg>
    </div>
    <h3 style="color:var(--ink-2);margin:0 0 0.25rem;"><%= L('No Prescriptions Yet', 'لا توجد وصفات طبية') %></h3>
    <p style="color:var(--muted);margin:0;font-size:0.85rem;"><%= L('Prescriptions from your doctors will appear here.', 'ستظهر الوصفات الطبية هنا بعد إصدارها من طبيبك.') %></p>
  </div>
<% } else { %>
  <div style="display:grid;grid-template-columns:repeat(auto-fill, minmax(320px, 1fr));gap:0.75rem;">
    <% _prescriptions.forEach(function(rx) {
      var expired = isExpired(rx.valid_until);
      var medCount = countMeds(rx.medications);
    %>
      <div class="p-card" style="padding:18px;">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:0.5rem;">
          <div>
            <h3 style="margin:0 0 0.15rem;color:var(--ink);"><%= L('Dr. ', 'د. ') %><%= rx.doctor_name || '-' %></h3>
            <% if (rx.specialty_name) { %>
              <p style="margin:0;font-size:0.78rem;color:var(--muted);"><%= rx.specialty_name %></p>
            <% } %>
          </div>
          <span style="font-size:0.78rem;color:var(--muted);flex-shrink:0;"><%= fmtDate(rx.created_at) %></span>
        </div>

        <div style="display:flex;gap:0.75rem;align-items:center;margin-bottom:0.75rem;font-size:0.82rem;color:var(--ink-2);flex-wrap:wrap;">
          <span><%= medCount %> <%= L('medications', 'أدوية') %></span>
          <% if (rx.valid_until) { %>
            <span><%= L('Valid until: ', 'صالحة حتى: ') %><%= fmtDate(rx.valid_until) %></span>
          <% } %>
          <span class="p-chip <%= expired ? 'p-chip--neutral' : 'p-chip--teal' %>">
            <%= expired ? L('Expired', 'منتهية') : L('Active', 'نشطة') %>
          </span>
        </div>

        <div style="display:flex;gap:0.5rem;flex-wrap:wrap;">
          <a href="/portal/patient/prescription/<%= rx.id %>" class="p-btn p-btn--secondary p-btn--sm"><%= L('View Details', 'عرض التفاصيل') %></a>
          <% if (rx.pdf_url) { %>
            <a href="/portal/patient/prescription/<%= rx.id %>/download" class="p-btn p-btn--primary p-btn--sm"><%= L('Download PDF', 'تحميل PDF') %></a>
          <% } %>
        </div>
      </div>
    <% }); %>
  </div>
<% } %>

<%- include('partials/patient/foot', { active: 'prescriptions', isAr: __isAr }) %>
