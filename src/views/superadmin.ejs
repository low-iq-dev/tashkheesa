<%
  // Superadmin cockpit dashboard.
  // Locals (set by routes/superadmin.js GET /superadmin):
  //   user, lang, range, activeTab
  //   pills, attentionItems, attentionSeverity, sidebarBadges
  //   ops, finance, doctors, patients, marketing, health  (per-tab data)
  //   cspNonce
  var _activeTab = (typeof activeTab !== 'undefined' && activeTab) ? String(activeTab) : 'operations';
  var _range = (typeof range !== 'undefined' && range) ? String(range) : '7d';
  var _validTabs = ['operations', 'finance', 'doctors', 'patients', 'marketing', 'health'];
  if (_validTabs.indexOf(_activeTab) < 0) _activeTab = 'operations';
  var _nonce = (typeof cspNonce !== 'undefined' && cspNonce) ? cspNonce : '';
%>
<%- include('partials/superadmin/header', {
      title: 'Owner cockpit',
      currentSection: 'dashboard',
      user: user,
      lang: lang || 'en',
      showTabBar: true,
      activeTab: _activeTab,
      range: _range,
      pills: pills,
      attentionItems: attentionItems,
      attentionSeverity: attentionSeverity,
      sidebarBadges: sidebarBadges,
      cspNonce: _nonce
    }) %>

  <div class="tab-pane<%= _activeTab === 'operations' ? ' active' : '' %>" id="pane-operations">
    <%- include('partials/superadmin/tab_operations', { data: ops, csrfField: typeof csrfField === 'function' ? csrfField : null }) %>
  </div>
  <div class="tab-pane<%= _activeTab === 'finance' ? ' active' : '' %>" id="pane-finance">
    <%- include('partials/superadmin/tab_finance', { data: finance }) %>
  </div>
  <div class="tab-pane<%= _activeTab === 'doctors' ? ' active' : '' %>" id="pane-doctors">
    <%- include('partials/superadmin/tab_doctors', { data: doctors }) %>
  </div>
  <div class="tab-pane<%= _activeTab === 'patients' ? ' active' : '' %>" id="pane-patients">
    <%- include('partials/superadmin/tab_patients', { data: patients }) %>
  </div>
  <div class="tab-pane<%= _activeTab === 'marketing' ? ' active' : '' %>" id="pane-marketing">
    <%- include('partials/superadmin/tab_marketing', { data: marketing }) %>
  </div>
  <div class="tab-pane<%= _activeTab === 'health' ? ' active' : '' %>" id="pane-health">
    <%- include('partials/superadmin/tab_health', { data: health }) %>
  </div>

<script<% if (_nonce) { %> nonce="<%= _nonce %>"<% } %>>
(function() {
  var validTabs = ['operations', 'finance', 'doctors', 'patients', 'marketing', 'health'];
  function activateTab(name) {
    if (validTabs.indexOf(name) < 0) name = 'operations';
    document.querySelectorAll('.tab-pane').forEach(function(p) {
      p.classList.toggle('active', p.id === 'pane-' + name);
    });
    document.querySelectorAll('.tabs .tab').forEach(function(t) {
      var isActive = t.getAttribute('data-tab') === name;
      t.classList.toggle('active', isActive);
      t.setAttribute('aria-selected', isActive ? 'true' : 'false');
    });
  }
  var initial = (location.hash || '').replace('#', '');
  if (initial && validTabs.indexOf(initial) >= 0) activateTab(initial);
  document.querySelectorAll('.tabs .tab[data-tab]').forEach(function(t) {
    t.addEventListener('click', function(e) {
      e.preventDefault();
      var name = t.getAttribute('data-tab');
      location.hash = name;
      activateTab(name);
    });
  });
  window.addEventListener('hashchange', function() {
    var name = (location.hash || '').replace('#', '');
    if (validTabs.indexOf(name) >= 0) activateTab(name);
  });
})();
</script>

<%- include('partials/superadmin/footer', { isAr: (lang === 'ar') }) %>
