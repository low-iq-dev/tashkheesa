<%
  // Patient Dashboard — v2 (3 states + optional DRAFT tile).
  //
  // Locals from routes/patient.js GET /dashboard:
  //   user                 — req.user-equivalent object
  //   lang                 — 'en' | 'ar'
  //   isAr                 — boolean
  //   dashboardState       — 'empty' | 'active' | 'ready'
  //   activeOrder          — non-null only when state === 'active'
  //   reportReadyOrder     — non-null only when state === 'ready' (NEVER contains report text)
  //   draftOrder           — optional; surfaces "Continue your case" tile in empty state
  //   activeUnreadMessages — number, drives sidebar/tabbar badge
  //   isLimbo              — boolean, when activeOrder is paid but unassigned
  //
  // Privacy invariant: this template MUST NOT render any field that could carry report
  // content (notes, diagnosis_text, impression_text, recommendation_text, response).
  // The route handler already filters those out of the SELECT — defense in depth.

  const __isAr = !!isAr;
  const __user = (typeof user === 'object' && user) ? user : {};
  const __firstName = String((__user.name || '').split(/\s+/)[0] || '');

  // ── Localization helpers ───────────────────────────────────────────────
  function fmtDayDate(d) {
    if (!d) return '';
    try {
      const dt = new Date(d);
      if (isNaN(dt.getTime())) return '';
      return dt.toLocaleDateString(__isAr ? 'ar-EG' : 'en-GB', { weekday: 'short', day: 'numeric', month: 'short' });
    } catch (_) { return ''; }
  }
  function fmtRelative(d) {
    if (!d) return '';
    try {
      const dt = new Date(d);
      if (isNaN(dt.getTime())) return '';
      const diffSec = Math.max(0, Math.floor((Date.now() - dt.getTime()) / 1000));
      if (diffSec < 60)         return tt('just now', 'just now', 'الآن');
      if (diffSec < 3600)       return tt(Math.floor(diffSec/60) + 'm ago', Math.floor(diffSec/60) + 'm ago', 'منذ ' + Math.floor(diffSec/60) + ' دقيقة');
      if (diffSec < 86400)      return tt(Math.floor(diffSec/3600) + 'h ago', Math.floor(diffSec/3600) + 'h ago', 'منذ ' + Math.floor(diffSec/3600) + ' ساعة');
      if (diffSec < 7 * 86400)  return tt(Math.floor(diffSec/86400) + 'd ago', Math.floor(diffSec/86400) + 'd ago', 'منذ ' + Math.floor(diffSec/86400) + ' يوم');
      return dt.toLocaleDateString(__isAr ? 'ar-EG' : 'en-GB', { day: 'numeric', month: 'short' });
    } catch (_) { return ''; }
  }
  function deriveInitials(n) {
    if (!n) return '·';
    const parts = String(n).trim().split(/\s+/).slice(0, 2);
    return parts.map(p => p[0] || '').join('').toUpperCase() || '·';
  }

  // ── Derived view-models ────────────────────────────────────────────────
  const __activeOrder = activeOrder || null;
  const __reportReadyOrder = reportReadyOrder || null;
  const __draftOrder = draftOrder || null;
  const __unread = Number(activeUnreadMessages) || 0;
  const __limbo = !!isLimbo;

  // Active state copy resolution.
  const activeStatus = String(__activeOrder ? (__activeOrder.effectiveStatus || __activeOrder.status || '') : '').toUpperCase();
  const activeDoctorName = (__activeOrder && __activeOrder.doctor_name) ? String(__activeOrder.doctor_name) : '';
  const activeDoctorShort = activeDoctorName.split(/\s+/).slice(0, 2).join(' ');
  const expectedBy = (__activeOrder && __activeOrder.deadline_at) ? fmtDayDate(__activeOrder.deadline_at) : '';

  // Hero copy varies by status. NEVER references "Step N of 5".
  let heroTitle, heroSub, whatsHappeningEyebrow, whatsHappeningTitle, whatsHappeningBody, whatsHappeningIcon;
  if (__activeOrder) {
    if (__limbo) {
      heroTitle = tt('We’re matching you with the right specialist.', 'We’re matching you with the right specialist.', 'نعمل على إيجاد الطبيب المناسب لحالتك.');
      heroSub = tt('You’ll see your specialist’s name here within a few hours. We’ll email and SMS you the moment they’re assigned.', 'You’ll see your specialist’s name here within a few hours. We’ll email and SMS you the moment they’re assigned.', 'سيظهر اسم الطبيب هنا خلال ساعات قليلة. سنبلغك بالبريد والرسائل النصية فور التعيين.');
      whatsHappeningEyebrow = tt('WHAT’S HAPPENING NOW', 'WHAT’S HAPPENING NOW', 'ما يحدث الآن');
      whatsHappeningTitle = tt('We’re reviewing your case to choose the best specialist.', 'We’re reviewing your case to choose the best specialist.', 'نراجع حالتك لاختيار أفضل اختصاصي.');
      whatsHappeningBody = tt('Nothing is needed from you. If anything is missing, we’ll reach out by message.', 'Nothing is needed from you. If anything is missing, we’ll reach out by message.', 'لا يلزم منك أي إجراء. إذا احتجنا لشيء، سنتواصل عبر الرسائل.');
      whatsHappeningIcon = 'sparkle';
    } else if (activeStatus === 'REJECTED_FILES') {
      heroTitle = tt('Your specialist needs another look at one of your files.', 'Your specialist needs another look at one of your files.', 'يحتاج طبيبك إلى مراجعة أحد ملفاتك.');
      heroSub = tt('They’ll send you a quick note about which file. Open the case to respond.', 'They’ll send you a quick note about which file. Open the case to respond.', 'ستصلك رسالة سريعة بتفاصيل الملف المطلوب.');
      whatsHappeningEyebrow = tt('NEEDS YOUR ATTENTION', 'NEEDS YOUR ATTENTION', 'يحتاج اهتمامك');
      whatsHappeningTitle = tt((activeDoctorShort || 'Your specialist') + ' has asked for a clearer copy of one file.', (activeDoctorShort || 'Your specialist') + ' has asked for a clearer copy of one file.', (activeDoctorShort || 'طبيبك') + ' طلب نسخة أوضح من أحد الملفات.');
      whatsHappeningBody = tt('Open the case to see which file and reply with the new copy.', 'Open the case to see which file and reply with the new copy.', 'افتح الحالة لمعرفة الملف المطلوب وإرسال النسخة الجديدة.');
      whatsHappeningIcon = 'alert';
    } else if (activeStatus === 'SLA_BREACH') {
      heroTitle = tt((activeDoctorShort || 'Your specialist') + ' is taking a little longer than expected.', (activeDoctorShort || 'Your specialist') + ' is taking a little longer than expected.', (activeDoctorShort || 'طبيبك') + ' يحتاج وقتاً إضافياً قليلاً.');
      heroSub = tt('Sometimes a thorough read takes more time. We’re in touch with the specialist and will update you shortly.', 'Sometimes a thorough read takes more time. We’re in touch with the specialist and will update you shortly.', 'أحياناً تستغرق المراجعة الدقيقة وقتاً أطول. نحن على تواصل مع الطبيب وسنعود إليك قريباً.');
      whatsHappeningEyebrow = tt('WHAT’S HAPPENING NOW', 'WHAT’S HAPPENING NOW', 'ما يحدث الآن');
      whatsHappeningTitle = tt('We’re checking in with ' + (activeDoctorShort || 'your specialist') + ' on timing.', 'We’re checking in with ' + (activeDoctorShort || 'your specialist') + ' on timing.', 'نتابع التوقيت مع ' + (activeDoctorShort || 'طبيبك') + '.');
      whatsHappeningBody = tt('You’ll hear from us as soon as we have an update.', 'You’ll hear from us as soon as we have an update.', 'سنبلغك فور الحصول على أي تحديث.');
      whatsHappeningIcon = 'clock';
    } else {
      // Standard active: ASSIGNED, IN_REVIEW, REASSIGNED, etc.
      heroTitle = tt('Your specialist is reviewing your files now.', 'Your specialist is reviewing your files now.', 'طبيبك يراجع ملفاتك الآن.');
      heroSub = tt((activeDoctorShort ? (activeDoctorShort + ' is on your case.') : 'Your specialist is on your case.') + ' You’ll get an email and SMS the moment the written opinion is ready — no need to keep checking.', (activeDoctorShort ? (activeDoctorShort + ' is on your case.') : 'Your specialist is on your case.') + ' You’ll get an email and SMS the moment the written opinion is ready — no need to keep checking.', (activeDoctorShort ? (activeDoctorShort + ' يعمل على حالتك.') : 'طبيبك يعمل على حالتك.') + ' سنرسل لك بريداً ورسالة فور جاهزية الرأي المكتوب.');
      whatsHappeningEyebrow = tt('WHAT’S HAPPENING NOW', 'WHAT’S HAPPENING NOW', 'ما يحدث الآن');
      whatsHappeningTitle = (activeDoctorShort
        ? tt(activeDoctorShort + ' is going through your scans and prior reports.', activeDoctorShort + ' is going through your scans and prior reports.', activeDoctorShort + ' يطّلع على فحوصاتك وتقاريرك السابقة.')
        : tt('Your specialist is going through your scans and prior reports.', 'Your specialist is going through your scans and prior reports.', 'يطّلع طبيبك على فحوصاتك وتقاريرك السابقة.'));
      whatsHappeningBody = tt('Nothing is needed from you. If a question comes up, it’ll arrive here as a message.', 'Nothing is needed from you. If a question comes up, it’ll arrive here as a message.', 'لا يلزم منك أي إجراء. إن طرأ أي استفسار سيصلك كرسالة هنا.');
      whatsHappeningIcon = 'eye';
    }
  }

  // Report-ready copy. NEVER includes report text.
  const __readyDoctorName = (__reportReadyOrder && __reportReadyOrder.doctor_name) ? String(__reportReadyOrder.doctor_name) : '';
  const __readyDoctorShort = __readyDoctorName.split(/\s+/).slice(0, 2).join(' ');
  const __reportDeliveredAgo = (__reportReadyOrder && __reportReadyOrder.report_delivered_at)
    ? fmtRelative(__reportReadyOrder.report_delivered_at) : '';
  const __reportCaseId = __reportReadyOrder ? __reportReadyOrder.id : '';

  // Active timeline — derived from status (no event-log query on dashboard).
  function buildSimpleTimeline() {
    if (!__activeOrder) return [];
    const submitted = { state: 'done', k: tt('SUBMITTED', 'SUBMITTED', 'تم الإرسال'),
                        title: tt('Case submitted', 'Case submitted', 'تم إرسال الحالة'),
                        sub: __activeOrder.created_at ? fmtDayDate(__activeOrder.created_at) : '' };
    let reviewing;
    if (__limbo) {
      reviewing = { state: '', k: tt('REVIEWING', 'REVIEWING', 'المراجعة'), title: tt('Specialist will be assigned soon', 'Specialist will be assigned soon', 'سيتم تعيين الطبيب قريباً'), sub: tt('Usually within a few hours', 'Usually within a few hours', 'عادة خلال ساعات قليلة') };
    } else if (activeStatus === 'COMPLETED') {
      reviewing = { state: 'done', k: tt('REVIEWING', 'REVIEWING', 'المراجعة'), title: tt('Specialist completed review', 'Specialist completed review', 'انتهى الطبيب من المراجعة'), sub: __activeOrder.completed_at ? fmtDayDate(__activeOrder.completed_at) : '' };
    } else {
      reviewing = { state: 'active', k: tt('REVIEWING', 'REVIEWING', 'المراجعة'),
                    title: activeDoctorShort ? tt(activeDoctorShort + ' is reviewing', activeDoctorShort + ' is reviewing', activeDoctorShort + ' يراجع') : tt('Specialist is reviewing', 'Specialist is reviewing', 'الطبيب يراجع'),
                    sub: expectedBy ? tt('Expected by ' + expectedBy, 'Expected by ' + expectedBy, 'متوقع بحلول ' + expectedBy) : '' };
    }
    const delivered = { state: '', k: tt('OPINION', 'OPINION', 'الرأي'),
                        title: tt('Your written opinion', 'Your written opinion', 'رأيك المكتوب'),
                        sub: tt('Delivered to your portal and email', 'Delivered to your portal and email', 'يصلك على البوابة والبريد') };
    return [submitted, reviewing, delivered];
  }
  const __timelineSteps = buildSimpleTimeline();

  // Title (page <head>)
  const __dashboardState = String(dashboardState || 'empty');
  const __pageTitle = (__dashboardState === 'ready')
    ? tt('Your opinion is ready', 'Your opinion is ready', 'رأيك جاهز')
    : (__dashboardState === 'active'
        ? tt('Your case', 'Your case', 'حالتك')
        : tt('Welcome', 'Welcome', 'أهلاً بك'));
%>
<%- include('partials/patient/head', {
  title: __pageTitle,
  active: 'dashboard',
  variant: 'dark',
  trustDensity: 'heavy',
  unreadCount: __unread,
  caseCount: __activeOrder ? 1 : 0,
  user: __user,
  lang: lang,
  cspNonce: typeof cspNonce !== 'undefined' ? cspNonce : ''
}) %>

<%- include('partials/patient/topbar', {
  title: (__dashboardState === 'ready')
    ? tt('Your opinion is ready', 'Your opinion is ready', 'رأيك جاهز') + (__firstName ? (', ' + __firstName + '.') : '.')
    : (__dashboardState === 'active'
        ? tt('Good day', 'Good day', 'يومك سعيد') + (__firstName ? (', ' + __firstName + '.') : '.')
        : tt('Welcome', 'Welcome', 'أهلاً') + (__firstName ? (', ' + __firstName + '.') : '.')),
  sub: (__dashboardState === 'ready')
    ? (__readyDoctorShort
        ? tt(__readyDoctorShort + ' delivered your report ' + __reportDeliveredAgo + '.', __readyDoctorShort + ' delivered your report ' + __reportDeliveredAgo + '.', __readyDoctorShort + ' سلّم تقريرك ' + __reportDeliveredAgo + '.')
        : tt('Your report has been delivered.', 'Your report has been delivered.', 'تم تسليم تقريرك.'))
    : (__dashboardState === 'active'
        ? tt('Here’s where your case stands today.', 'Here’s where your case stands today.', 'هذه حالة طلبك اليوم.')
        : tt('Let’s get your case in front of the right specialist.', 'Let’s get your case in front of the right specialist.', 'دعنا نضع حالتك أمام الطبيب المناسب.')),
  serif: true,
  actions: '<span class="p-chip p-chip--teal" aria-hidden="false"><span style="display:inline-flex;align-items:center;gap:4px;">'
           + (__isAr ? 'خصوصية مشفّرة' : 'Encrypted')
           + '</span></span>'
}) %>

<% if (__dashboardState === 'ready' && __reportReadyOrder) { %>
  <%# REPORT READY STATE — Fix 1 privacy block. Template MUST NOT render any
      column carrying medical text. Route already filters them out at SELECT. %>
  <section style="
    background: linear-gradient(135deg, #0B6B5F 0%, #074B43 100%);
    border-radius: 16px; padding: 28px; color: #F8F5EF; margin-bottom: 18px;
    display: grid; grid-template-columns: 1fr auto; gap: 28px; align-items: center;
    position: relative; overflow: hidden;
  ">
    <div aria-hidden="true" style="position:absolute;top:-30px;inset-inline-end:-30px;font-family:var(--font-display);font-size:240px;color:#B38B3E;opacity:0.15;font-weight:500;line-height:1;">✓</div>
    <div>
      <div style="font-size:10.5px;letter-spacing:0.14em;text-transform:uppercase;color:#E6D7B0;font-weight:700;margin-bottom:10px;">
        <%= tt('Report delivered', 'Report delivered', 'تم تسليم التقرير') %><% if (__reportDeliveredAgo) { %> · <%= __reportDeliveredAgo %><% } %>
      </div>
      <h2 style="font-family:var(--font-display);font-size:32px;font-weight:500;letter-spacing:-0.005em;line-height:1.2;margin:0 0 8px;max-width:640px;">
        <%= tt('Your opinion is ready.', 'Your opinion is ready.', 'رأيك جاهز.') %>
      </h2>
      <p style="font-size:15px;line-height:1.55;color:rgba(248,245,239,0.85);margin:0 0 6px;max-width:560px;">
        <% if (__readyDoctorShort) { %>
          <%= tt(__readyDoctorShort + ' delivered your report ' + __reportDeliveredAgo + '.', __readyDoctorShort + ' delivered your report ' + __reportDeliveredAgo + '.', __readyDoctorShort + ' سلّم تقريرك ' + __reportDeliveredAgo + '.') %>
        <% } else { %>
          <%= tt('Your written opinion has been delivered.', 'Your written opinion has been delivered.', 'تم تسليم رأيك المكتوب.') %>
        <% } %>
      </p>
      <p style="font-size:14px;line-height:1.55;color:rgba(248,245,239,0.7);margin:0;max-width:560px;">
        <%= tt('Take your time reading it — and message ' + (__readyDoctorShort || 'your specialist') + ' if anything’s unclear.', 'Take your time reading it — and message ' + (__readyDoctorShort || 'your specialist') + ' if anything’s unclear.', 'خذ وقتك في قراءته — وراسل ' + (__readyDoctorShort || 'الطبيب') + ' إذا كان هناك أي شيء غير واضح.') %>
      </p>
    </div>
    <div style="display:flex;flex-direction:column;gap:10px;min-width:200px;">
      <a class="p-btn p-btn--brass p-btn--lg" href="/portal/case/<%= __reportCaseId %>/report"><%= tt('Read the report', 'Read the report', 'اقرأ التقرير') %></a>
      <a class="p-btn p-btn--lg" href="/portal/case/<%= __reportCaseId %>/download-report" style="background:rgba(255,255,255,0.1);color:#F8F5EF;border:1px solid rgba(255,255,255,0.2);">
        <%- include('partials/patient/icon', { name: 'download', size: 14 }) %>
        <%= tt('Download PDF', 'Download PDF', 'تنزيل PDF') %>
      </a>
    </div>
  </section>

  <div style="display:grid;grid-template-columns:2fr 1fr;gap:18px;" class="p-dash-cols">
    <div class="stack">
      <% if (__readyDoctorName) { %>
        <div class="p-card">
          <div class="p-card__header"><div class="p-card__title"><%= tt('Your specialist', 'Your specialist', 'طبيبك') %></div></div>
          <div class="p-card__body">
            <%- include('partials/patient/doctor-card', {
              doctor: { name: __readyDoctorName, role: ((__isAr && __reportReadyOrder.specialty_name_ar ? __reportReadyOrder.specialty_name_ar : __reportReadyOrder.specialty_name) || ''), credentials: '' },
              compact: true,
              isAr: __isAr
            }) %>
          </div>
        </div>
      <% } %>
    </div>
    <div class="stack">
      <%- include('partials/patient/reassure-card', {
        eyebrow: tt('Our promise', 'Our promise', 'وعدنا'),
        title: tt('Your report stays yours — forever.', 'Your report stays yours — forever.', 'تقريرك ملكك — إلى الأبد.'),
        body: tt('Download it, share it with your treating doctor, keep a copy. We never share your records with anyone.', 'Download it, share it with your treating doctor, keep a copy. We never share your records with anyone.', 'حمّله، شاركه مع طبيبك المعالج، احتفظ بنسخة. لا نشارك سجلاتك مع أي طرف.'),
        isAr: __isAr
      }) %>
      <%- include('partials/patient/need-help-card', { isAr: __isAr }) %>
    </div>
  </div>

<% } else if (__dashboardState === 'active' && __activeOrder) { %>
  <!-- ─── ACTIVE STATE ───────────────────────────────────────────── -->
  <div class="dash-hero">
    <div>
      <div class="dash-hero__eyebrow"><%= tt('YOUR ACTIVE CASE', 'YOUR ACTIVE CASE', 'حالتك النشطة') %></div>
      <h2 class="dash-hero__title"><%= heroTitle %></h2>
      <p class="dash-hero__sub"><%= heroSub %></p>
      <div style="display:flex;gap:10px;margin-top:18px;flex-wrap:wrap;">
        <a class="p-btn p-btn--primary" href="/portal/patient/orders/<%= __activeOrder.id %>"><%= tt('Open case', 'Open case', 'افتح الحالة') %></a>
        <% if (activeDoctorName && !__limbo) { %>
          <a class="p-btn p-btn--ghost" href="/portal/patient/orders/<%= __activeOrder.id %>?tab=messages">
            <%- include('partials/patient/icon', { name: 'message', size: 14 }) %>
            <%= tt('Message ' + activeDoctorShort, 'Message ' + activeDoctorShort, 'راسل ' + activeDoctorShort) %>
          </a>
        <% } %>
      </div>
    </div>
    <div style="text-align:end;">
      <% if (expectedBy && !__limbo) { %>
        <div style="font-size:10.5px;letter-spacing:0.14em;text-transform:uppercase;color:var(--muted);font-weight:700;">
          <%= tt('Expected by', 'Expected by', 'متوقع بحلول') %>
        </div>
        <div class="p-num" style="font-family:var(--font-display);font-size:36px;font-weight:500;letter-spacing:-0.005em;color:var(--ink);margin-top:4px;line-height:1.1;">
          <%= expectedBy %>
        </div>
      <% } else { %>
        <div style="font-size:10.5px;letter-spacing:0.14em;text-transform:uppercase;color:var(--muted);font-weight:700;">
          <%= tt('Status', 'Status', 'الحالة') %>
        </div>
        <div style="font-family:var(--font-display);font-size:24px;font-weight:500;color:var(--ink);margin-top:4px;line-height:1.2;max-width:220px;">
          <%= __limbo ? tt('Matching specialist', 'Matching specialist', 'تعيين الطبيب') : (__activeOrder.statusUi && __activeOrder.statusUi.title ? __activeOrder.statusUi.title : tt('In progress', 'In progress', 'قيد التنفيذ')) %>
        </div>
      <% } %>
      <div style="margin-top:14px;">
        <span class="case-status">
          <span class="case-status__dot" aria-hidden="true"></span>
          <%= __limbo ? tt('Awaiting assignment', 'Awaiting assignment', 'بانتظار التعيين') : (__activeOrder.statusUi && __activeOrder.statusUi.title ? __activeOrder.statusUi.title : tt('In review', 'In review', 'قيد المراجعة')) %>
        </span>
      </div>
    </div>
  </div>

  <div style="margin-bottom:18px;">
    <%- include('partials/patient/whats-happening-card', {
      icon: whatsHappeningIcon,
      eyebrow: whatsHappeningEyebrow,
      title: whatsHappeningTitle,
      body: whatsHappeningBody,
      action: { label: tt('View details', 'View details', 'عرض التفاصيل'), href: '/portal/patient/orders/' + __activeOrder.id }
    }) %>
  </div>

  <div style="display:grid;grid-template-columns:2fr 1fr;gap:18px;" class="p-dash-cols">
    <div class="stack">
      <div class="p-card">
        <div class="p-card__header">
          <div class="p-card__title"><%= tt('Your case timeline', 'Your case timeline', 'الجدول الزمني لحالتك') %></div>
          <% if (__activeOrder.reference_code || __activeOrder.id) { %>
            <div class="p-card__sub" style="font-family:var(--font-mono);font-size:11px;">
              <%= __activeOrder.reference_code || ('#' + String(__activeOrder.id).substring(0, 8)) %>
            </div>
          <% } %>
        </div>
        <div class="p-card__body">
          <%- include('partials/patient/timeline', { steps: __timelineSteps }) %>
        </div>
      </div>
    </div>
    <div class="stack">
      <% if (activeDoctorName && !__limbo) { %>
        <div class="p-card">
          <div class="p-card__header"><div class="p-card__title"><%= tt('Your specialist', 'Your specialist', 'طبيبك') %></div></div>
          <div class="p-card__body">
            <%- include('partials/patient/doctor-card', {
              doctor: { name: activeDoctorName, role: ((__isAr && __activeOrder.specialty_name_ar ? __activeOrder.specialty_name_ar : __activeOrder.specialty_name) || tt('Consultant', 'Consultant', 'استشاري')), credentials: '' },
              compact: true,
              isAr: __isAr
            }) %>
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:14px;">
              <a class="p-btn p-btn--secondary p-btn--sm" href="/portal/patient/orders/<%= __activeOrder.id %>?tab=messages">
                <%- include('partials/patient/icon', { name: 'message', size: 13 }) %>
                <%= tt('Message', 'Message', 'مراسلة') %>
              </a>
              <a class="p-btn p-btn--ghost p-btn--sm" href="/portal/patient/orders/<%= __activeOrder.id %>">
                <%- include('partials/patient/icon', { name: 'eye', size: 13 }) %>
                <%= tt('Open case', 'Open case', 'افتح الحالة') %>
              </a>
            </div>
          </div>
        </div>
      <% } %>
      <%- include('partials/patient/reassure-card', {
        eyebrow: tt('Our promise', 'Our promise', 'وعدنا'),
        title: tt('Written opinion in 48 hours standard, as fast as 4 hours — miss your chosen deadline and your urgency surcharge is refunded.', 'Written opinion in 48 hours standard, as fast as 4 hours — miss your chosen deadline and your urgency surcharge is refunded.', 'رأي مكتوب خلال 48 ساعة قياسي، وأسرع لحد 4 ساعات — ولو اتأخرنا عن موعدك بنرجّعلك رسوم الاستعجال.'),
