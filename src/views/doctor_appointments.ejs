<%- include('partials/header', { title: 'Appointments', layout: 'portal', showNav: true, portalFrame: true, portalRole: 'doctor', portalActive: 'appointments', portalNext: '/portal/doctor/appointments' }) %>
<%
  const isAr = (typeof lang !== 'undefined' && String(lang).toLowerCase() === 'ar');
  const _filters = (typeof filters !== 'undefined' && filters) ? filters : { status: 'all', period: 'all' };
  const _stats = (typeof stats !== 'undefined' && stats) ? stats : { totalEarnings: 0, monthEarnings: 0, completedCount: 0, noShowCount: 0 };
  const _appointments = (typeof appointments !== 'undefined' && appointments) ? appointments : [];
  const _upcoming = (typeof upcoming !== 'undefined' && upcoming) ? upcoming : [];
  const _todayAppts = (typeof todayAppts !== 'undefined' && todayAppts) ? todayAppts : [];

  function apptStatusLabel(val) {
    var v = (val || '').toLowerCase();
    if (isAr) {
      if (v === 'pending') return 'في الانتظار';
      if (v === 'confirmed') return 'مؤكد';
      if (v === 'started') return 'جارية';
      if (v === 'completed') return 'مكتمل';
      if (v === 'cancelled') return 'ملغى';
      if (v === 'no_show_patient') return 'غياب المريض';
      if (v === 'no_show_doctor') return 'غياب الطبيب';
      return v;
    }
    if (v === 'pending') return 'Pending';
    if (v === 'confirmed') return 'Confirmed';
    if (v === 'started') return 'In Progress';
    if (v === 'completed') return 'Completed';
    if (v === 'cancelled') return 'Cancelled';
    if (v === 'no_show_patient') return 'Patient No-Show';
    if (v === 'no_show_doctor') return 'Doctor No-Show';
    return v ? v.charAt(0).toUpperCase() + v.slice(1).replace(/_/g, ' ') : 'Unknown';
  }

  function statusBadgeClass(val) {
    var v = (val || '').toLowerCase();
    if (v === 'confirmed') return 'dap-badge dap-badge--confirmed';
    if (v === 'started') return 'dap-badge dap-badge--in-review';
    if (v === 'completed') return 'dap-badge dap-badge--completed';
    if (v === 'cancelled') return 'dap-badge dap-badge--cancelled';
    if (v === 'no_show_patient' || v === 'no_show_doctor') return 'dap-badge dap-badge--no-show';
    return 'dap-badge dap-badge--pending';
  }

  function formatDate(iso) {
    if (!iso) return '—';
    var d = new Date(iso);
    return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
  }
  function formatTime(iso) {
    if (!iso) return '';
    var d = new Date(iso);
    return d.toLocaleTimeString('en-GB', { hour: '2-digit', minute: '2-digit', hour12: true });
  }
%>

<link rel="stylesheet" href="/css/doctor-appointments.css" />

<div class="dap-page">

  <!-- Header -->
  <div class="dap-header">
    <div class="dap-header-main">
      <h1 class="dap-header-title"><%= isAr ? 'المواعيد' : 'Appointments' %></h1>
      <p class="dap-header-sub"><%= isAr ? 'إدارة مواعيد الاستشارات' : 'Manage your consultation appointments' %></p>
    </div>
    <a class="dap-btn dap-btn-secondary" href="/portal/appointments/availability">
      <%= isAr ? 'إعداد الأوقات' : 'Set Availability' %>
    </a>
  </div>

  <!-- KPI row -->
  <div class="dap-kpi-grid">
    <div class="dap-kpi">
      <div class="dap-kpi-value"><%= _stats.completedCount %></div>
      <div class="dap-kpi-label"><%= isAr ? 'استشارات مكتملة' : 'Completed' %></div>
    </div>
    <div class="dap-kpi">
      <div class="dap-kpi-value"><%= _upcoming.length %></div>
      <div class="dap-kpi-label"><%= isAr ? 'قادمة' : 'Upcoming' %></div>
    </div>
    <div class="dap-kpi">
      <div class="dap-kpi-value"><%= _stats.noShowCount %></div>
      <div class="dap-kpi-label"><%= isAr ? 'غياب' : 'No-shows' %></div>
    </div>
    <div class="dap-kpi">
      <div class="dap-kpi-value"><%= Number(_stats.monthEarnings).toFixed(0) %></div>
      <div class="dap-kpi-label"><%= isAr ? 'أرباح الشهر (EGP)' : 'This month (EGP)' %></div>
    </div>
  </div>

  <!-- Filters -->
  <form class="dap-filters" method="get" action="/portal/doctor/appointments">
    <div class="dap-field">
      <label class="dap-field-label"><%= isAr ? 'الفترة' : 'Period' %></label>
      <select class="dap-select" name="period">
        <option value="all" <%= _filters.period === 'all' ? 'selected' : '' %>><%= isAr ? 'الكل' : 'All time' %></option>
        <option value="today" <%= _filters.period === 'today' ? 'selected' : '' %>><%= isAr ? 'اليوم' : 'Today' %></option>
        <option value="week" <%= _filters.period === 'week' ? 'selected' : '' %>><%= isAr ? 'هذا الأسبوع' : 'This week' %></option>
        <option value="month" <%= _filters.period === 'month' ? 'selected' : '' %>><%= isAr ? 'هذا الشهر' : 'This month' %></option>
      </select>
    </div>
    <div class="dap-field">
      <label class="dap-field-label"><%= isAr ? 'الحالة' : 'Status' %></label>
      <select class="dap-select" name="status">
        <option value="all" <%= _filters.status === 'all' ? 'selected' : '' %>><%= isAr ? 'كل الحالات' : 'All statuses' %></option>
        <option value="confirmed" <%= _filters.status === 'confirmed' ? 'selected' : '' %>><%= isAr ? 'مؤكد' : 'Confirmed' %></option>
        <option value="started" <%= _filters.status === 'started' ? 'selected' : '' %>><%= isAr ? 'جارية' : 'In progress' %></option>
        <option value="completed" <%= _filters.status === 'completed' ? 'selected' : '' %>><%= isAr ? 'مكتمل' : 'Completed' %></option>
        <option value="cancelled" <%= _filters.status === 'cancelled' ? 'selected' : '' %>><%= isAr ? 'ملغى' : 'Cancelled' %></option>
        <option value="no_show_patient" <%= _filters.status === 'no_show_patient' ? 'selected' : '' %>><%= isAr ? 'غياب المريض' : 'Patient no-show' %></option>
      </select>
    </div>
    <div class="dap-filters-actions">
      <button class="dap-btn dap-btn-primary" type="submit"><%= isAr ? 'تطبيق' : 'Apply' %></button>
      <a href="/portal/doctor/appointments" class="dap-btn dap-btn-ghost"><%= isAr ? 'إعادة' : 'Reset' %></a>
    </div>
  </form>

  <!-- 01 Today's appointments -->
  <% if (_todayAppts.length > 0) { %>
  <section class="dap-sec dap-sec--today">
    <header class="dap-sec-head">
      <span class="dap-sec-num">01</span>
      <span class="dap-sec-label"><%= isAr ? 'مواعيد اليوم' : "Today's appointments" %></span>
      <span class="dap-sec-count"><%= _todayAppts.length %></span>
    </header>
    <div class="dap-table-wrap">
      <table class="dap-table">
        <thead>
          <tr>
            <th><%= isAr ? 'الوقت' : 'Time' %></th>
            <th><%= isAr ? 'المريض' : 'Patient' %></th>
            <th><%= isAr ? 'الخدمة' : 'Service' %></th>
            <th><%= isAr ? 'الحالة' : 'Status' %></th>
            <th><%= isAr ? 'إجراءات' : 'Actions' %></th>
          </tr>
        </thead>
        <tbody>
          <% _todayAppts.forEach(function(a) { %>
            <tr>
              <td>
                <div class="dap-cell-strong"><%= formatTime(a.scheduled_at) %></div>
                <% if (a.canJoin) { %>
                  <span class="dap-badge dap-badge--confirmed dap-badge--sm"><%= isAr ? 'جاهز الآن' : 'Ready now' %></span>
                <% } else if (a.minsAway > 0) { %>
                  <span class="dap-cell-muted"><%= isAr ? 'خلال ' + a.minsAway + ' دقيقة' : 'in ' + a.minsAway + ' min' %></span>
                <% } %>
              </td>
              <td>
                <div class="dap-cell-strong"><%= a.patient_name || 'Patient' %></div>
                <% if (a.patient_email) { %><div class="dap-cell-muted"><%= a.patient_email %></div><% } %>
              </td>
              <td><%= a.service_name || '—' %></td>
              <td>
                <span class="<%= statusBadgeClass(a.status) %>"><%= apptStatusLabel(a.status) %></span>
              </td>
              <td>
                <div class="dap-actions">
                  <% if (a.canJoin) { %>
                    <a class="dap-btn dap-btn-primary dap-btn-sm" href="/portal/video/call/<%= a.id %>"><%= isAr ? 'انضمام' : 'Join call' %></a>
                  <% } %>
                  <a class="dap-btn dap-btn-ghost dap-btn-sm" href="/portal/video/appointment/<%= a.id %>"><%= isAr ? 'تفاصيل' : 'Details' %></a>
                  <% if (a.canMarkNoShow) { %>
                    <form method="post" action="/portal/video/appointment/<%= a.id %>/no-show" class="dap-inline-form">
                      <%- csrfField() %>
                      <input type="hidden" name="no_show_type" value="patient">
                      <button type="submit" class="dap-btn dap-btn-warning dap-btn-sm" data-confirm="<%= isAr ? 'تأكيد تسجيل غياب المريض؟' : 'Confirm patient no-show?' %>"><%= isAr ? 'غياب' : 'No-show' %></button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }); %>
        </tbody>
      </table>
    </div>
  </section>
  <% } %>

  <!-- 02 All appointments -->
  <section class="dap-sec">
    <header class="dap-sec-head">
      <span class="dap-sec-num"><%= _todayAppts.length > 0 ? '02' : '01' %></span>
      <span class="dap-sec-label"><%= isAr ? 'كل المواعيد' : 'All appointments' %></span>
      <span class="dap-sec-count"><%= _appointments.length %></span>
    </header>
    <div class="dap-table-wrap">
      <table class="dap-table">
        <thead>
          <tr>
            <th><%= isAr ? 'التاريخ' : 'Date' %></th>
            <th><%= isAr ? 'الوقت' : 'Time' %></th>
            <th><%= isAr ? 'المريض' : 'Patient' %></th>
            <th><%= isAr ? 'الخدمة' : 'Service' %></th>
            <th><%= isAr ? 'الحالة' : 'Status' %></th>
            <th><%= isAr ? 'المبلغ' : 'Amount' %></th>
            <th><%= isAr ? 'إجراءات' : 'Actions' %></th>
          </tr>
        </thead>
        <tbody>
          <% if (_appointments.length > 0) { %>
            <% _appointments.forEach(function(a) { %>
              <tr class="<%= a.isToday ? 'dap-row--today' : '' %>">
                <td>
                  <div class="dap-cell-strong"><%= formatDate(a.scheduled_at) %></div>
                  <% if (a.isToday) { %>
                    <span class="dap-badge dap-badge--in-review dap-badge--sm"><%= isAr ? 'اليوم' : 'TODAY' %></span>
                  <% } %>
                </td>
                <td><%= formatTime(a.scheduled_at) %></td>
                <td class="dap-cell-strong"><%= a.patient_name || 'Patient' %></td>
                <td><%= a.service_name || '—' %></td>
                <td>
                  <span class="<%= statusBadgeClass(a.status) %>"><%= apptStatusLabel(a.status) %></span>
                </td>
                <td>
                  <% if (a.price) { %>
                    <span class="dap-cell-strong"><%= Number(a.price).toFixed(0) %></span>
                    <span class="dap-cell-muted">EGP</span>
                  <% } else { %>
                    —
                  <% } %>
                </td>
                <td>
                  <div class="dap-actions">
                    <% if (a.canJoin) { %>
                      <a class="dap-btn dap-btn-primary dap-btn-sm" href="/portal/video/call/<%= a.id %>"><%= isAr ? 'انضمام' : 'Join' %></a>
                    <% } %>
                    <a class="dap-btn dap-btn-ghost dap-btn-sm" href="/portal/video/appointment/<%= a.id %>"><%= isAr ? 'عرض' : 'View' %></a>
                    <% if (a.canReschedule) { %>
                      <button class="dap-btn dap-btn-ghost dap-btn-sm" data-action="open-reschedule" data-id="<%= a.id %>"><%= isAr ? 'إعادة جدولة' : 'Reschedule' %></button>
                    <% } %>
                    <% if (a.canCancel) { %>
                      <form method="post" action="/portal/video/appointment/<%= a.id %>/cancel" class="dap-inline-form">
                        <%- csrfField() %>
                        <input type="hidden" name="reason" value="Cancelled by doctor">
                        <button type="submit" class="dap-btn dap-btn-danger dap-btn-sm" data-confirm="<%= isAr ? 'هل أنت متأكد من إلغاء هذا الموعد؟' : 'Cancel this appointment?' %>"><%= isAr ? 'إلغاء' : 'Cancel' %></button>
                      </form>
                    <% } %>
                    <% if (a.canMarkNoShow) { %>
                      <form method="post" action="/portal/video/appointment/<%= a.id %>/no-show" class="dap-inline-form">
                        <%- csrfField() %>
                        <input type="hidden" name="no_show_type" value="patient">
                        <button type="submit" class="dap-btn dap-btn-warning dap-btn-sm" data-confirm="<%= isAr ? 'تأكيد تسجيل غياب المريض؟' : 'Mark patient as no-show?' %>"><%= isAr ? 'غياب' : 'No-show' %></button>
                      </form>
                    <% } %>
                  </div>
                </td>
              </tr>
            <% }); %>
          <% } else { %>
            <tr>
              <td colspan="7">
                <div class="dap-empty">
                  <div class="dap-empty-k"><%= isAr ? 'لا توجد مواعيد' : 'No appointments' %></div>
                  <div class="dap-empty-v"><%= isAr ? 'لا توجد مواعيد مطابقة للفلاتر المحددة.' : 'No appointments match the selected filters.' %></div>
                </div>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </section>

  <!-- 03 Earnings summary -->
  <section class="dap-sec">
    <header class="dap-sec-head">
      <span class="dap-sec-num"><%= _todayAppts.length > 0 ? '03' : '02' %></span>
      <span class="dap-sec-label"><%= isAr ? 'ملخص الأرباح' : 'Earnings summary' %></span>
    </header>
    <div class="dap-earnings">
      <div class="dap-earn-cell">
        <div class="dap-earn-k"><%= isAr ? 'إجمالي الأرباح' : 'Total earnings' %></div>
        <div class="dap-earn-v">
          <span class="dap-earn-num"><%= Number(_stats.totalEarnings).toFixed(2) %></span>
          <span class="dap-earn-unit">EGP</span>
        </div>
      </div>
      <div class="dap-earn-cell">
        <div class="dap-earn-k"><%= isAr ? 'أرباح هذا الشهر' : 'This month' %></div>
        <div class="dap-earn-v">
          <span class="dap-earn-num"><%= Number(_stats.monthEarnings).toFixed(2) %></span>
          <span class="dap-earn-unit">EGP</span>
        </div>
      </div>
      <div class="dap-earn-cell">
        <div class="dap-earn-k"><%= isAr ? 'استشارات مكتملة' : 'Completed consultations' %></div>
        <div class="dap-earn-v">
          <span class="dap-earn-num"><%= _stats.completedCount %></span>
        </div>
      </div>
    </div>
  </section>

</div>

<!-- Reschedule modal — IDs, classList('active'), data-action, data-id preserved -->
<div class="dap-modal-overlay" id="reschedule-modal">
  <div class="dap-modal">
    <div class="dap-modal-head">
      <h3 class="dap-modal-title"><%= isAr ? 'إعادة جدولة الموعد' : 'Reschedule appointment' %></h3>
      <button class="dap-modal-close" data-action="close-reschedule" aria-label="Close">&times;</button>
    </div>
    <form id="reschedule-form" method="post">
      <%- csrfField() %>
      <div class="dap-modal-body">
        <div class="dap-field">
          <label class="dap-field-label"><%= isAr ? 'التاريخ والوقت الجديد' : 'New date & time' %></label>
          <input type="datetime-local" name="new_scheduled_at" required class="dap-input">
        </div>
      </div>
      <div class="dap-modal-foot">
        <button type="button" class="dap-btn dap-btn-ghost" data-action="close-reschedule"><%= isAr ? 'إلغاء' : 'Cancel' %></button>
        <button type="submit" class="dap-btn dap-btn-primary"><%= isAr ? 'تأكيد' : 'Confirm' %></button>
      </div>
    </form>
  </div>
</div>

<% var _nonce = (typeof locals !== 'undefined' && locals && (locals.cspNonce || locals.csp_nonce || locals.nonce)) ? String(locals.cspNonce || locals.csp_nonce || locals.nonce) : ''; var _nonceAttr = _nonce ? ' nonce="' + _nonce + '"' : ''; %>
<script<%- _nonceAttr %>>
function openReschedule(appointmentId) {
  var modal = document.getElementById('reschedule-modal');
  var form = document.getElementById('reschedule-form');
  form.action = '/portal/video/appointment/' + appointmentId + '/reschedule';
  modal.classList.add('active');
}
function closeReschedule() {
  document.getElementById('reschedule-modal').classList.remove('active');
}
document.getElementById('reschedule-modal').addEventListener('click', function(e) {
  if (e.target === this) closeReschedule();
});
/* Event delegation for data-confirm and data-action attributes */
document.addEventListener('click', function(e) {
  var target = e.target.closest('[data-action]');
  if (target) {
    var action = target.getAttribute('data-action');
    if (action === 'open-reschedule') {
      openReschedule(target.getAttribute('data-id'));
      return;
    }
    if (action === 'close-reschedule') {
      closeReschedule();
      return;
    }
  }
  var confirmBtn = e.target.closest('[data-confirm]');
  if (confirmBtn) {
    var msg = confirmBtn.getAttribute('data-confirm');
    if (!confirm(msg)) {
      e.preventDefault();
      e.stopImmediatePropagation();
    }
  }
});
</script>
<%- include('partials/footer') %>
