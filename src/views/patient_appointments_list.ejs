<%
  // Patient appointments list — V2 chrome.
  // Rendered by src/routes/video.js:1254 for patients on /portal/video/appointments
  // (also reached via 302 from /portal/patient/appointments).
  //
  // Locals:
  //   appointments  — array of enriched appointment rows (id, status,
  //                   scheduled_at, price, currency, doctor_name,
  //                   specialty_name)
  //   user, lang, isAr, brand, activePage

  const isAr = (typeof lang !== 'undefined') ? String(lang).toLowerCase() === 'ar' : false;
  const __isAr = isAr;
  const __lang = (typeof lang === 'string' && lang) ? lang : (isAr ? 'ar' : 'en');
  function L(en, ar) { return isAr ? ar : en; }

  const _appointments = (typeof appointments !== 'undefined' && Array.isArray(appointments)) ? appointments : [];

  // Strip _patient / _doctor suffix and lowercase before matching, so
  // canonical names (no_show, cancelled) and DB variants
  // (NO_SHOW_PATIENT, CANCELLED_DOCTOR) map to the same label and chip.
  function normalizeStatus(status) {
    return String(status || '').toLowerCase().replace(/_(patient|doctor)$/, '');
  }

  function statusChipClass(status) {
    var s = normalizeStatus(status);
    if (s === 'confirmed') return 'p-chip--teal';
    if (s === 'pending') return 'p-chip--brass';
    if (s === 'cancelled' || s === 'canceled') return 'p-chip--neutral';
    if (s === 'completed' || s === 'done') return 'p-chip--teal';
    if (s === 'no_show') return 'p-chip--neutral';
    return 'p-chip--info';
  }

  function statusLabel(status) {
    var s = normalizeStatus(status);
    if (s === 'confirmed') return isAr ? 'مؤكد' : 'Confirmed';
    if (s === 'pending') return isAr ? 'قيد الانتظار' : 'Pending';
    if (s === 'cancelled' || s === 'canceled') return isAr ? 'ملغي' : 'Cancelled';
    if (s === 'completed' || s === 'done') return isAr ? 'مكتمل' : 'Completed';
    if (s === 'no_show') return isAr ? 'لم يحضر' : 'No-show';
    return isAr ? 'معلّق' : 'Pending';
  }

  function fmtDateTime(iso) {
    if (!iso) return '';
    try {
      var d = new Date(iso);
      if (isNaN(d.getTime())) return String(iso);
      return d.toLocaleDateString(isAr ? 'ar-EG' : 'en-US', { year: 'numeric', month: 'short', day: 'numeric' })
        + ' ' + d.toLocaleTimeString(isAr ? 'ar-EG' : 'en-US', { hour: '2-digit', minute: '2-digit' });
    } catch (e) { return String(iso); }
  }
%>
<%- include('partials/patient/head', {
  active: 'appointments',
  title: L('My Appointments', 'مواعيدي'),
  user: (typeof user !== 'undefined' ? user : {}),
  lang: __lang,
  bodyClass: 'p-page-appointments'
}) %>

<%- include('partials/patient/topbar', {
  title: L('My Appointments', 'مواعيدي'),
  sub:   L('All your scheduled appointments.', 'جميع مواعيدك المحجوزة.'),
  serif: false,
  isAr:  __isAr,
  hideBell: false
}) %>

<% if (!_appointments || _appointments.length === 0) { %>
  <div class="p-card" style="text-align:center;padding:3rem 1.5rem;">
    <div style="margin-bottom:1rem;">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
        <line x1="16" y1="2" x2="16" y2="6"/>
        <line x1="8" y1="2" x2="8" y2="6"/>
        <line x1="3" y1="10" x2="21" y2="10"/>
      </svg>
    </div>
    <h3 style="color:var(--ink-2);margin:0 0 0.25rem;"><%= L('No Appointments', 'لا توجد مواعيد') %></h3>
    <p style="color:var(--muted);margin:0;font-size:0.85rem;"><%= L('You have no scheduled appointments yet.', 'لا توجد مواعيد محجوزة حالياً.') %></p>
  </div>
<% } else { %>
  <div style="display:grid;gap:0.75rem;">
    <% _appointments.forEach(function(appt) { %>
      <div class="p-card" style="padding:18px;">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:0.75rem;">
          <div style="flex:1;min-width:0;">
            <h3 style="margin:0 0 0.35rem;color:var(--ink);">
              <%= appt.doctor_name ? L('Dr. ', 'د. ') + appt.doctor_name : L('Dr. TBD', 'طبيب') %>
            </h3>
            <div style="display:flex;flex-direction:column;gap:0.25rem;font-size:0.83rem;color:var(--ink-2);">
              <span>
                <strong><%= L('Specialty:', 'التخصص:') %></strong> <%= appt.specialty_name || '—' %>
              </span>
              <span>
                <strong><%= L('Scheduled:', 'الموعد:') %></strong>
                <%= appt.scheduled_at ? fmtDateTime(appt.scheduled_at) : '—' %>
              </span>
              <% if (appt.price) { %>
                <span>
                  <strong><%= L('Price:', 'السعر:') %></strong> <%= appt.price %> <%= L('EGP', 'ج.م') %>
                </span>
              <% } %>
            </div>
          </div>
          <div style="display:flex;flex-direction:column;align-items:flex-end;gap:0.5rem;">
            <span class="p-chip <%= statusChipClass(appt.status) %>"><%= statusLabel(appt.status) %></span>
            <% if (normalizeStatus(appt.status) === 'confirmed') { %>
              <a href="/portal/video/call/<%= appt.id %>" class="p-btn p-btn--primary"><%= L('Join Call', 'دخول الاستشارة') %></a>
            <% } %>
          </div>
        </div>
      </div>
    <% }); %>
  </div>
<% } %>

<% var _nonce = (typeof locals !== 'undefined' && locals && (locals.cspNonce || locals.csp_nonce || locals.nonce)) ? String(locals.cspNonce || locals.csp_nonce || locals.nonce) : ''; %>
<script src="/js/tours/patient-tour.js" defer></script>
<script<% if (_nonce) { %> nonce="<%= _nonce %>"<% } %>>
document.addEventListener('DOMContentLoaded', function() {
  if (typeof PortalTour !== 'undefined' && !PortalTour.isDone('patient_appointments')) {
    setTimeout(function() { PortalTour.start('patient_appointments', patientAppointmentsTour); }, 800);
  }
  window.startPortalTour = function() {
    PortalTour.reset('patient_appointments');
    PortalTour.start('patient_appointments', patientAppointmentsTour);
  };
});
</script>

<%- include('partials/patient/foot', { active: 'appointments', isAr: __isAr }) %>
