<%- include('partials/header', { title: (typeof isAr !== 'undefined' && isAr) ? 'اليوم' : 'Today', layout: 'portal', showNav: true, portalFrame: true, portalRole: 'doctor', portalActive: 'today', portalNext: '/portal/doctor/today' }) %>
<%
  // ----- Locals guards -----
  var _user = (typeof user !== 'undefined' && user) ? user : (typeof locals !== 'undefined' ? (locals.user || {}) : {});
  var _isAr = (typeof isAr !== 'undefined') ? isAr : false;
  var _lang = (typeof lang !== 'undefined' && lang) ? lang : (_isAr ? 'ar' : 'en');

  function _asArr(v) { return Array.isArray(v) ? v : []; }
  function _num(v, f) { var n = Number(v); return Number.isFinite(n) && n >= 0 ? Math.trunc(n) : (f || 0); }

  // ----- Redesign payload (from the GET handler) -----
  var _month = (typeof monthMetrics !== 'undefined' && monthMetrics) ? monthMetrics : { completedThisMonth: 0, earningsThisMonth: 0, currency: 'EGP' };
  var _priority = _asArr(typeof priorityQueue !== 'undefined' ? priorityQueue : []);
  var _newAssigns = _asArr(typeof newCases !== 'undefined' ? newCases : []).slice(0, 6);
  var _activity = _asArr(typeof activityFeed !== 'undefined' ? activityFeed : []);
  var _perf = (typeof perfSnapshot !== 'undefined' && perfSnapshot) ? perfSnapshot : { completed: 0, compliancePct: null, avgTurnaroundHours: null, avgTurnaround30dHours: null, avgTurnaround30dCount: 0 };
  var _reviews = _asArr(typeof reviewCases !== 'undefined' ? reviewCases : (typeof inReviewCases !== 'undefined' ? inReviewCases : []));
  var _completed = _asArr(typeof completedCases !== 'undefined' ? completedCases : []);
  var _completedTotal = _num(typeof completedTotal !== 'undefined' ? completedTotal : 0, 0);
  var _alerts = _asArr(typeof alerts !== 'undefined' ? alerts : []);

  // ----- KPI counts -----
  var _inReviewTotal = _num(typeof inReviewTotal !== 'undefined' ? inReviewTotal : 0, 0);
  var _newCasesTotal = _num(typeof newCasesTotal !== 'undefined' ? newCasesTotal : 0, 0);

  // ----- Welcome header bits -----
  var _name = (_user && _user.name) ? String(_user.name).trim() : '';
  var _firstName = _name.split(/\s+/)[0] || '';

  var _now = new Date();
  var _hour = _now.getHours();
  var _greetKeyEn = _hour < 12 ? 'Good morning' : (_hour < 18 ? 'Good afternoon' : 'Good evening');
  var _greetKeyAr = _hour < 12 ? 'صباح الخير' : (_hour < 18 ? 'مساء الخير' : 'مساء الخير');
  var _titleDoctor = _isAr ? 'د.' : 'Dr.';

  // Today's date, localized
  var _dateStr;
  try {
    _dateStr = _now.toLocaleDateString(_isAr ? 'ar-EG' : 'en-US',
      { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
  } catch (_) { _dateStr = _now.toDateString(); }

  // ----- Helpers -----
  function _initials(name) {
    if (!name) return '?';
    var parts = String(name).split(/\s+/).filter(Boolean).slice(0, 2);
    return (parts.map(function(w){ return w.charAt(0); }).join('') || '?').toUpperCase();
  }

  function _slaDotClass(caseItem) {
    if (!caseItem || !caseItem.sla) return 'dd-dot--ok';
    if (caseItem.sla.isBreached) return 'dd-dot--breach';
    var min = Number(caseItem.sla.minutesRemaining);
    if (!Number.isFinite(min)) return 'dd-dot--ok';
    if (min <= 24 * 60) return 'dd-dot--urgent';
    if (min <= 48 * 60) return 'dd-dot--warn';
    return 'dd-dot--ok';
  }

  function _slaTimeLabel(caseItem) {
    if (!caseItem || !caseItem.sla) return '';
    var sla = caseItem.sla;
    if (sla.isBreached) {
      var over = Number(sla.minutesOverdue) || 0;
      var oH = Math.floor(over / 60), oM = Math.floor(over % 60);
      var overStr = (oH > 0 ? (oH + 'h ') : '') + oM + 'm';
      return _isAr ? ('تأخّرت ' + overStr) : ('overdue ' + overStr);
    }
    var rem = Number(sla.minutesRemaining);
    if (!Number.isFinite(rem) || rem < 0) return '';
    var d = Math.floor(rem / (60 * 24));
    var h = Math.floor((rem % (60 * 24)) / 60);
    var m = Math.floor(rem % 60);
    var str;
    if (d >= 1) str = d + 'd ' + h + 'h';
    else if (h >= 1) str = h + 'h ' + m + 'm';
    else str = m + 'm';
    return _isAr ? ('خلال ' + str) : ('due in ' + str);
  }

  function _patientLabel(caseItem) {
    if (!caseItem) return '';
    var name = caseItem.patient_name || caseItem.patientName || '';
    if (name) return name;
    return _initials(caseItem.patient_full_name || caseItem.patient_id || caseItem.id);
  }

  function _caseRef(caseItem) {
    if (!caseItem) return '';
    var ref = caseItem.reference_id || caseItem.reference || caseItem.id || '';
    ref = String(ref);
    return ref ? ('#' + ref) : '';
  }

  // Activity-label mapping (single source of truth from handler)
  var _ACTIVITY_MAP = (typeof activityLabelMap !== 'undefined' && activityLabelMap)
    ? activityLabelMap
    : {};
  var _ACTIVITY_PATTERNS = [];
  try {
    var _rawPatterns = (typeof activityLabelPatterns !== 'undefined' && Array.isArray(activityLabelPatterns))
      ? activityLabelPatterns
      : [];
    _ACTIVITY_PATTERNS = _rawPatterns.map(function (p) {
      return { match: new RegExp(p.source, p.flags || ''), template: p.template };
    });
  } catch (_) { _ACTIVITY_PATTERNS = []; }

  function _activityText(ev) {
    if (!ev) return '';
    var ref = ev.reference_id ? ('#' + ev.reference_id) : (ev.order_id ? ('#' + String(ev.order_id).slice(0, 8)) : '');
    var tmpl = _ACTIVITY_MAP[ev.label];
    if (!tmpl) {
      for (var i = 0; i < _ACTIVITY_PATTERNS.length; i++) {
        if (_ACTIVITY_PATTERNS[i].match.test(String(ev.label || ''))) {
          tmpl = _ACTIVITY_PATTERNS[i].template;
          break;
        }
      }
    }
    if (tmpl) {
      return (_isAr ? tmpl.ar : tmpl.en).replace('{ref}', ref);
    }
    try { console.warn('[dashboard.view] Unmapped activity label at render:', JSON.stringify(ev.label)); } catch (_) {}
    return (_isAr ? 'نشاط: ' : '') + String(ev.label || '') + (ref ? (' ' + ref) : '');
  }

  function _relTime(when) {
    if (!when) return '';
    var t = new Date(when).getTime();
    if (!Number.isFinite(t)) return '';
    var diff = Math.max(0, Date.now() - t);
    var mins = Math.floor(diff / 60000);
    if (mins < 1) return _isAr ? 'الآن' : 'just now';
    if (mins < 60) return _isAr ? ('منذ ' + mins + ' د') : (mins + 'm ago');
    var h = Math.floor(mins / 60);
    if (h < 24) return _isAr ? ('منذ ' + h + ' س') : (h + 'h ago');
    var d = Math.floor(h / 24);
    if (d < 30) return _isAr ? ('منذ ' + d + ' ي') : (d + 'd ago');
    var mo = Math.floor(d / 30);
    return _isAr ? ('منذ ' + mo + ' ش') : (mo + 'mo ago');
  }

  function _fmtEgp(n) {
    var x = Math.max(0, Math.round(Number(n) || 0));
    return x.toLocaleString(_isAr ? 'ar-EG' : 'en-US');
  }

  var _attentionCount = _inReviewTotal + _newCasesTotal;
%>

<link rel="stylesheet" href="/css/doctor-dashboard.css" />

<%
  // P1-DOC-5 view-side guards.
  var _mode  = (typeof dashboardMode !== 'undefined' && dashboardMode) ? String(dashboardMode) : 'has-active';
  var _showWelcome = !!(typeof showWelcomeModal !== 'undefined' && showWelcomeModal);
  var _banner = (typeof slaBanner !== 'undefined' && slaBanner) ? slaBanner : { level: null, count: 0, redCount: 0, amberCount: 0, items: [] };
%>

<style>
/* P1-DOC-5: SLA banner. Tier-agnostic, percentage-driven (red ≤10% of
   sla_hours remaining, amber 10–25%). Sits above the greeting header. */
.dd-sla-banner { display: flex; align-items: center; gap: 14px; padding: 14px 18px; border-radius: 12px; margin-bottom: 18px; border: 1px solid; font-size: 14px; line-height: 1.45; }
.dd-sla-banner--amber { background: #fffbeb; border-color: #fde68a; color: #78350f; }
.dd-sla-banner--red   { background: #fef2f2; border-color: #fecaca; color: #7f1d1d; }
.dd-sla-banner-icon { flex: 0 0 22px; width: 22px; height: 22px; display: inline-flex; align-items: center; justify-content: center; }
.dd-sla-banner-body { flex: 1 1 auto; }
.dd-sla-banner-title { font-weight: 700; margin-bottom: 2px; font-size: 14px; }
.dd-sla-banner-cases { display: inline-flex; flex-wrap: wrap; gap: 6px; margin-top: 4px; }
.dd-sla-banner-cases a { color: inherit; text-decoration: underline; font-weight: 600; }
.dd-sla-banner-cta { font-weight: 600; text-decoration: none; color: inherit; flex: 0 0 auto; white-space: nowrap; }
.dd-sla-banner-cta:hover { text-decoration: underline; }

/* P1-DOC-5: smart routing emphasis. Each mode reorders/highlights via
   classes — sections are always rendered, only their visual weight
   shifts. */
.dd-page[data-mode="history-only"] .dd-page-section--priority,
.dd-page[data-mode="history-only"] .dd-page-section--newcases { opacity: 0.85; }
.dd-page[data-mode="new-doctor"] .dd-page-section--priority,
.dd-page[data-mode="new-doctor"] .dd-page-section--review { display: none; }
.dd-page[data-mode="new-doctor"] .dd-newdoc-tips { display: block; }
.dd-newdoc-tips { display: none; background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%); border: 1px solid #bfdbfe; border-radius: 14px; padding: 22px 26px; margin: 18px 0; }
.dd-newdoc-tips h3 { margin: 0 0 8px; font-size: 17px; color: #0f2d48; }
.dd-newdoc-tips p { margin: 0 0 6px; color: #475569; font-size: 14px; line-height: 1.6; }
.dd-newdoc-tips ul { margin: 6px 0 0; padding-inline-start: 20px; color: #475569; font-size: 14px; line-height: 1.7; }

/* P1-DOC-5: welcome modal. Full-screen overlay shown only when
   first_login_at IS NULL. Native <dialog> with backdrop + 3 panels. */
.dd-welcome-overlay { position: fixed; inset: 0; background: rgba(15, 45, 72, 0.55); display: flex; align-items: center; justify-content: center; z-index: 9999; padding: 20px; }
.dd-welcome-modal { background: white; border-radius: 18px; padding: 36px 36px 30px; max-width: 560px; width: 100%; box-shadow: 0 25px 60px rgba(15, 45, 72, 0.25); animation: ddWelcomeIn 0.22s ease-out; }
@keyframes ddWelcomeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
.dd-welcome-header { text-align: center; margin-bottom: 24px; }
.dd-welcome-kicker { display: inline-block; font-size: 11px; font-weight: 700; letter-spacing: 1.2px; text-transform: uppercase; color: #2563eb; margin-bottom: 8px; }
.dd-welcome-title { margin: 0; font-size: 26px; font-weight: 700; color: #0f2d48; line-height: 1.25; }
.dd-welcome-panels { display: flex; flex-direction: column; gap: 18px; margin-bottom: 28px; }
.dd-welcome-panel { display: flex; gap: 14px; align-items: flex-start; }
.dd-welcome-panel-num { flex: 0 0 28px; width: 28px; height: 28px; border-radius: 50%; background: #eff6ff; color: #2563eb; display: inline-flex; align-items: center; justify-content: center; font-weight: 700; font-size: 13px; }
.dd-welcome-panel-body { flex: 1 1 auto; }
.dd-welcome-panel-title { font-weight: 700; color: #0f2d48; font-size: 15px; margin-bottom: 4px; }
.dd-welcome-panel-text { color: #475569; font-size: 14px; line-height: 1.6; }
.dd-welcome-actions { display: flex; justify-content: center; }
.dd-welcome-cta { background: #2563eb; color: white; border: none; padding: 11px 38px; border-radius: 50px; font-weight: 600; font-size: 15px; cursor: pointer; transition: background 0.15s, transform 0.15s; }
.dd-welcome-cta:hover { background: #1d4ed8; transform: translateY(-1px); }
.dd-welcome-cta:focus-visible { outline: 2px solid #93c5fd; outline-offset: 2px; }

[dir="rtl"] .dd-sla-banner-icon { /* mirror not needed for warning glyph */ }

/* P1-DOC-7: dashboard activity widgets */
.dd-widgets-strip { margin-bottom: 16px; }
.dd-widget { padding: 16px 18px; display: block; text-decoration: none; color: inherit; transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s; }
a.dd-widget:hover { border-color: #93c5fd; box-shadow: 0 2px 8px rgba(15, 45, 72, 0.06); transform: translateY(-1px); }
.dd-widget-label { font-size: 11px; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.6px; margin-bottom: 6px; }
.dd-widget-value { font-size: 22px; font-weight: 700; color: #0f2d48; line-height: 1.2; margin-bottom: 4px; }
.dd-widget-meta { font-size: 13px; color: #64748b; }
.dd-widget--empty .dd-widget-empty { font-size: 14px; color: #94a3b8; padding-top: 4px; }
</style>

<div class="dd-page" data-mode="<%= _mode %>">

  <% if (_banner && _banner.level && _banner.count > 0) { %>
    <div class="dd-sla-banner dd-sla-banner--<%= _banner.level %>" role="alert">
      <span class="dd-sla-banner-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86 1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      </span>
      <div class="dd-sla-banner-body">
        <div class="dd-sla-banner-title">
          <% if (_isAr) { %>
            ⚠️ <%= _banner.count %> <%= _banner.count === 1 ? 'حالة تقترب من المهلة' : 'حالات تقترب من المهلة' %> — راجعها الآن
          <% } else { %>
            ⚠️ <%= _banner.count %> case<%= _banner.count === 1 ? '' : 's' %> approaching SLA — review now
          <% } %>
        </div>
        <% if (_banner.items && _banner.items.length > 0) { %>
          <span class="dd-sla-banner-cases">
            <% _banner.items.forEach(function (it, i) { %>
              <a href="#dd-priority-<%= encodeURIComponent(it.id) %>" data-fallback="#dd-priority-list"><%= it.reference_id || ('#' + String(it.id).slice(0, 6)) %></a><% if (i < _banner.items.length - 1) { %>,<% } %>
            <% }); %>
            <% if (_banner.count > _banner.items.length) { %>
              <span>+<%= _banner.count - _banner.items.length %> <%= _isAr ? 'أخرى' : 'more' %></span>
            <% } %>
          </span>
        <% } %>
      </div>
      <a href="#dd-priority-list" class="dd-sla-banner-cta"><%= _isAr ? 'افتح القائمة ←' : 'Jump to list →' %></a>
    </div>
  <% } %>

  <% if (_mode === 'new-doctor') { %>
    <div class="dd-newdoc-tips">
      <h3><%= _isAr ? 'بداية موفقة' : 'Get started' %></h3>
      <p><%= _isAr ? 'لم يتم إسناد أي حالات إليك بعد. هذه الصفحة ستتحدث تلقائياً عندما يقدّم مريض حالة في تخصصك.' : 'No cases assigned yet. This page will update automatically when a patient submits a case in your specialty.' %></p>
      <ul>
        <li><%= _isAr ? 'تأكد من إكمال ملفك الشخصي وملاحظاتك السريرية في صفحة الملف الشخصي.' : 'Make sure your profile and clinical notes are complete in the Profile page.' %></li>
        <li><%= _isAr ? 'تصلك إشعارات الواتساب فور إسناد حالة جديدة.' : 'WhatsApp notifications fire as soon as a new case is assigned.' %></li>
        <li><%= _isAr ? 'يمكنك مراجعة دليل الطبيب من زر المساعدة.' : 'See the Help button for the doctor handbook.' %></li>
      </ul>
    </div>
  <% } %>

  <!-- ===================================================================
       HEADER — greeting + date + actions
       =================================================================== -->
  <div class="dd-header">
    <div class="dd-greeting">
      <h1 class="dd-greeting-title">
        <%= _isAr ? _greetKeyAr : _greetKeyEn %><%= _isAr ? '، ' : ', ' %><%= _titleDoctor %> <%= _firstName || (_isAr ? 'الطبيب' : 'Doctor') %>
      </h1>
      <p class="dd-greeting-sub">
        <%= _dateStr %>
        <% if (_attentionCount > 0) { %>
          &middot; <%= _isAr
            ? (_attentionCount + ' ' + (_attentionCount === 1 ? 'حالة تحتاج انتباهك اليوم' : 'حالات تحتاج انتباهك اليوم'))
            : (_attentionCount + ' ' + (_attentionCount === 1 ? 'case needs' : 'cases need') + ' your attention today') %>
        <% } %>
      </p>
    </div>
    <div class="dd-header-actions">
      <%- include('partials/doctor/bell', { isAr: _isAr }) %>
      <a class="v2-iconbtn" href="/portal/doctor/guide" aria-label="<%= _isAr ? 'المساعدة' : 'Help' %>" title="<%= _isAr ? 'المساعدة' : 'Help' %>">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 015.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/>
        </svg>
      </a>
      <a href="/portal/doctor/queue" class="dd-btn-primary">
        <%= _isAr ? 'قائمة الحالات' : 'View Queue' %>
      </a>
    </div>
  </div>

  <!-- ===================================================================
       HERO STATS — 4 tiles
       =================================================================== -->
  <div class="dd-stats">
    <div class="dd-stat dd-stat--teal">
      <div class="dd-stat-label"><%= _isAr ? 'أرباح هذا الشهر' : 'Earnings this month' %></div>
      <div class="dd-stat-value"><span class="dd-stat-currency"><%= _month.currency || 'EGP' %></span><%= _fmtEgp(_month.earningsThisMonth) %></div>
      <div class="dd-stat-sub"><%= _num(_month.completedThisMonth, 0) %> <%= _isAr ? 'حالة أُكملت' : 'cases completed' %></div>
    </div>
    <div class="dd-stat dd-stat--amber">
      <div class="dd-stat-label"><%= _isAr ? 'حالات نشطة' : 'Active cases' %></div>
      <div class="dd-stat-value"><%= _inReviewTotal + _newCasesTotal %></div>
      <div class="dd-stat-sub"><%= _newCasesTotal %> <%= _isAr ? 'جديدة' : 'new' %> &middot; <%= _inReviewTotal %> <%= _isAr ? 'قيد المراجعة' : 'in review' %></div>
    </div>
    <div class="dd-stat dd-stat--green">
      <div class="dd-stat-label"><%= _isAr ? 'مكتملة' : 'Completed' %></div>
      <div class="dd-stat-value"><%= _num(_month.completedThisMonth, 0) %></div>
      <div class="dd-stat-sub">
        <% if (_perf.compliancePct !== null && _perf.compliancePct !== undefined) { %>
          <span class="dd-stat-trend--up"><%= _perf.compliancePct %>%</span> <%= _isAr ? 'التزام SLA' : 'SLA compliance' %>
        <% } else { %>
          <%= _isAr ? 'هذا الشهر' : 'this month' %>
        <% } %>
      </div>
    </div>
    <div class="dd-stat dd-stat--rose">
      <div class="dd-stat-label"><%= _isAr ? 'سلسلة الإنجاز' : 'Week streak' %></div>
      <div class="dd-stat-value"><%= _num(typeof streakCount !== 'undefined' ? streakCount : 0, 0) %></div>
      <div class="dd-stat-sub"><%= _isAr ? 'حالات هذا الأسبوع' : 'cases this week' %></div>
    </div>
  </div>

  <!-- ===================================================================
       GRID ROW 1 — New Assignments + Recent Alerts
       =================================================================== -->
  <div class="dd-grid">
    <!-- NEW ASSIGNMENTS -->
    <div class="dd-card" data-tour="case-queue">
      <div class="dd-card-head">
        <div class="dd-card-title">
          <%= _isAr ? 'تعيينات جديدة' : 'New Assignments' %>
          <span class="dd-card-count<%= _newCasesTotal > 0 ? ' dd-card-count--urgent' : '' %>"><%= _newCasesTotal %></span>
        </div>
        <a href="/portal/doctor/queue?filter=new" class="dd-card-link"><%= _isAr ? 'عرض الكل ←' : 'View all →' %></a>
      </div>
      <% if (_newAssigns.length === 0) { %>
        <div class="dd-card-empty">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M9 12l2 2 4-4"/></svg>
          <span><%= _isAr ? 'لا توجد تعيينات جديدة الآن' : 'No new assignments right now' %></span>
        </div>
      <% } else { %>
        <% _newAssigns.forEach(function (c) { %>
          <div class="dd-case-row">
            <div class="dd-case-badge"><%= _initials(c.patient_name || c.patientName || c.id) %></div>
            <div class="dd-case-info">
              <div class="dd-case-title">
                <%= _isAr ? 'حالة' : 'Case' %> <%= _caseRef(c) %>
                <% if (c.sla && c.sla.minutesRemaining != null && c.sla.minutesRemaining <= 24 * 60) { %>
                  <span class="dd-sla-pill dd-sla-pill--urgent"><%= _isAr ? 'عاجلة' : 'Fast-track' %></span>
                <% } %>
              </div>
              <div class="dd-case-meta"><%= c.specialtyLabel || '—' %></div>
            </div>
            <div class="dd-case-status">
              <div class="dd-case-actions-inline">
                <form method="POST" action="/portal/doctor/case/<%= encodeURIComponent(c.id || '') %>/accept" style="display:inline;margin:0;">
                  <%- (typeof csrfField === 'function') ? csrfField() : '' %>
                  <button type="submit" class="dd-btn-accept"><%= _isAr ? 'قبول' : 'Accept' %></button>
                </form>
                <a class="dd-btn-view" href="<%= c.href || ('/portal/doctor/case/' + encodeURIComponent(c.id || '')) %>">
                  <%= _isAr ? 'عرض' : 'View' %>
                </a>
              </div>
            </div>
          </div>
        <% }); %>
      <% } %>
    </div>

    <!-- RECENT ALERTS -->
    <div class="dd-card">
      <div class="dd-card-head">
        <div class="dd-card-title">
          <%= _isAr ? 'تنبيهات حديثة' : 'Recent Alerts' %>
          <span class="dd-card-count"><%= _alerts.length %></span>
        </div>
        <a href="/portal/doctor/alerts" class="dd-card-link"><%= _isAr ? 'عرض الكل ←' : 'View all →' %></a>
      </div>
      <% if (_alerts.length === 0) { %>
        <div class="dd-card-empty">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M18 8A6 6 0 006 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 01-3.46 0"/></svg>
          <span><%= _isAr ? 'لا توجد تنبيهات حالياً' : 'No recent alerts' %></span>
        </div>
      <% } else { %>
        <% _alerts.slice(0, 4).forEach(function (alert) { %>
          <div class="dd-alert-row">
            <div class="dd-alert-icon dd-alert-icon--<%= alert.type || 'info' %>">
              <% if (alert.type === 'urgent') { %>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              <% } else if (alert.type === 'warning') { %>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              <% } else if (alert.type === 'success') { %>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
              <% } else { %>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/><rect x="8" y="2" width="8" height="4"/></svg>
              <% } %>
            </div>
            <div class="dd-alert-body">
              <div class="dd-alert-title">
                <% if (alert.href) { %><a href="<%= alert.href %>"><%= alert.title %></a><% } else { %><%= alert.title %><% } %>
              </div>
              <div class="dd-alert-message"><%= alert.message %></div>
              <% if (alert.timeLabel) { %><div class="dd-alert-time"><%= alert.timeLabel %></div><% } %>
            </div>
          </div>
        <% }); %>
      <% } %>
    </div>
  </div>

  <!-- ===================================================================
       GRID ROW 2 — In Review + Completed
       =================================================================== -->
  <div class="dd-grid">
    <!-- IN REVIEW (SLA-priority ordered) -->
    <div class="dd-card dd-page-section--priority dd-page-section--review" id="dd-priority-list">
      <div class="dd-card-head">
        <div class="dd-card-title">
          <%= _isAr ? 'قيد المراجعة' : 'In Review' %>
          <span class="dd-card-count"><%= _inReviewTotal %></span>
        </div>
        <a href="/portal/doctor/queue" class="dd-card-link"><%= _isAr ? 'عرض الكل ←' : 'View all →' %></a>
      </div>
      <% var _reviewDisplay = _priority.length > 0 ? _priority : _reviews; %>
      <% if (_reviewDisplay.length === 0) { %>
        <div class="dd-card-empty">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
          <span><%= _isAr ? 'لا توجد حالات قيد المراجعة' : 'No cases in review right now' %></span>
        </div>
      <% } else { %>
        <% _reviewDisplay.slice(0, 5).forEach(function (c) { %>
          <a id="dd-priority-<%= encodeURIComponent(c.id || '') %>" href="<%= c.href || ('/portal/doctor/case/' + encodeURIComponent(c.id || '')) %>" class="dd-case-row dd-case-row--link">
            <div class="dd-case-badge"><%= _initials(c.patient_name || c.patientName || c.id) %></div>
            <div class="dd-case-info">
              <div class="dd-case-title">
                <%= _isAr ? 'حالة' : 'Case' %> <%= _caseRef(c) %>
                <% if (c.sla && (c.sla.isBreached || (c.sla.minutesRemaining != null && c.sla.minutesRemaining <= 24 * 60))) { %>
                  <span class="dd-sla-pill dd-sla-pill--urgent"><%= _isAr ? 'عاجلة' : 'Urgent' %></span>
                <% } %>
              </div>
              <div class="dd-case-meta"><%= _patientLabel(c) %> &middot; <%= c.specialtyLabel || '—' %></div>
            </div>
            <div class="dd-case-status">
              <div><span class="dd-status-dot <%= _slaDotClass(c) %>"></span><span class="dd-status-text"><%= _slaTimeLabel(c) %></span></div>
            </div>
          </a>
        <% }); %>
      <% } %>
    </div>

    <!-- COMPLETED -->
    <div class="dd-card">
      <div class="dd-card-head">
        <div class="dd-card-title">
          <%= _isAr ? 'مكتملة' : 'Completed' %>
          <span class="dd-card-count"><%= _completedTotal %></span>
        </div>
        <a href="/portal/doctor/completed" class="dd-card-link"><%= _isAr ? 'عرض الكل ←' : 'View all →' %></a>
      </div>
      <% if (_completed.length === 0) { %>
        <div class="dd-card-empty">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 11.08V12a10 10 0 11-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span><%= _isAr ? 'لا حالات مكتملة بعد' : 'No completed cases yet' %></span>
        </div>
      <% } else { %>
        <% _completed.slice(0, 4).forEach(function (c) { %>
          <a href="<%= c.href || ('/portal/doctor/case/' + encodeURIComponent(c.id || '')) %>" class="dd-case-row dd-case-row--link">
            <div class="dd-case-badge dd-case-badge--success">&#10003;</div>
            <div class="dd-case-info">
              <div class="dd-case-title"><%= _isAr ? 'حالة' : 'Case' %> <%= _caseRef(c) %></div>
              <div class="dd-case-meta"><%= c.specialtyLabel || '—' %></div>
            </div>
            <div class="dd-case-status">
              <div class="dd-status-sub"><%= _relTime(c.completed_at || c.updated_at) %></div>
            </div>
          </a>
        <% }); %>
      <% } %>
    </div>
  </div>

  <!-- ===================================================================
       GRID ROW 2.5 — Activity widgets (P1-DOC-7)
       Compact strip surfacing two signals not in the order_events feed:
       unread patient messages and most-recent paid earning. Each widget
       links to the relevant case detail (per-case fallback while
       /portal/doctor/messages and /portal/doctor/earnings remain stubs).
       =================================================================== -->
  <%
    var _unread = (typeof unreadMessages !== 'undefined' && unreadMessages)
      ? unreadMessages : { count: 0, conversationCount: 0, mostRecentOrderId: null };
    var _earning = (typeof recentEarning !== 'undefined' && recentEarning) ? recentEarning : null;
    var _earningHref = (_earning && _earning.orderId)
      ? ('/portal/doctor/case/' + encodeURIComponent(_earning.orderId)) : null;
  %>
  <div class="dd-grid dd-grid--equal dd-widgets-strip">
    <!-- UNREAD MESSAGES -->
    <% if (_unread.count > 0 && _unread.mostRecentOrderId) { %>
      <a href="/portal/doctor/case/<%= encodeURIComponent(_unread.mostRecentOrderId) %>" class="dd-card dd-widget">
        <div class="dd-widget-label"><%= _isAr ? 'رسائل غير مقروءة' : 'Unread messages' %></div>
        <div class="dd-widget-value"><%= _unread.count %></div>
        <div class="dd-widget-meta">
          <% if (_isAr) { %>
            <%= _unread.conversationCount === 1 ? 'من محادثة واحدة' : ('من ' + _unread.conversationCount + ' محادثات') %>
          <% } else { %>
            <%= _unread.conversationCount === 1 ? 'from 1 conversation' : ('from ' + _unread.conversationCount + ' conversations') %>
          <% } %>
        </div>
      </a>
    <% } else { %>
      <div class="dd-card dd-widget dd-widget--empty">
        <div class="dd-widget-label"><%= _isAr ? 'رسائل غير مقروءة' : 'Unread messages' %></div>
        <div class="dd-widget-empty"><%= _isAr ? 'لا توجد رسائل غير مقروءة' : 'No unread messages' %></div>
      </div>
    <% } %>

    <!-- RECENTLY PAID EARNING -->
    <% if (_earning && _earningHref) { %>
      <a href="<%= _earningHref %>" class="dd-card dd-widget">
        <div class="dd-widget-label"><%= _isAr ? 'الأرباح الأخيرة' : 'Recently paid' %></div>
        <div class="dd-widget-value"><%= _isAr ? '' : 'EGP ' %><%= _fmtEgp(_earning.earnedAmount) %><%= _isAr ? ' ج.م' : '' %></div>
        <div class="dd-widget-meta"><%= _relTime(_earning.paidAt) %></div>
      </a>
    <% } else if (_earning) { %>
      <div class="dd-card dd-widget">
        <div class="dd-widget-label"><%= _isAr ? 'الأرباح الأخيرة' : 'Recently paid' %></div>
        <div class="dd-widget-value"><%= _isAr ? '' : 'EGP ' %><%= _fmtEgp(_earning.earnedAmount) %><%= _isAr ? ' ج.م' : '' %></div>
        <div class="dd-widget-meta"><%= _relTime(_earning.paidAt) %></div>
      </div>
    <% } else { %>
      <div class="dd-card dd-widget dd-widget--empty">
        <div class="dd-widget-label"><%= _isAr ? 'الأرباح الأخيرة' : 'Recently paid' %></div>
        <div class="dd-widget-empty"><%= _isAr ? 'لا توجد أرباح حديثة' : 'No recent earnings' %></div>
      </div>
    <% } %>
  </div>

  <!-- ===================================================================
       GRID ROW 3 — Recent Activity + Performance
       =================================================================== -->
  <div class="dd-grid dd-grid--equal">
    <!-- RECENT ACTIVITY -->
    <div class="dd-card">
      <div class="dd-card-head">
        <div class="dd-card-title"><%= _isAr ? 'النشاط الأخير' : 'Recent Activity' %></div>
      </div>
      <% if (_activity.length === 0) { %>
        <div class="dd-card-empty">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span><%= _isAr ? 'لا يوجد نشاط بعد' : 'No activity yet' %></span>
        </div>
      <% } else { %>
        <% _activity.forEach(function (ev) { %>
          <div class="dd-activity-row">
            <span class="dd-activity-dot"></span>
            <div class="dd-activity-body">
              <% if (ev.order_id) { %>
                <a href="/portal/doctor/case/<%= encodeURIComponent(ev.order_id) %>"><%= _activityText(ev) %></a>
              <% } else { %>
                <%= _activityText(ev) %>
              <% } %>
            </div>
            <span class="dd-activity-time"><%= ev.relativeTime || _relTime(ev.at) %></span>
          </div>
        <% }); %>
      <% } %>
    </div>

    <!-- THIS MONTH PERFORMANCE -->
    <div class="dd-card">
      <div class="dd-card-head">
        <div class="dd-card-title"><%= _isAr ? 'أداء هذا الشهر' : 'This Month' %></div>
        <a href="/portal/doctor/analytics" class="dd-card-link"><%= _isAr ? 'التحليلات ←' : 'Analytics →' %></a>
      </div>
      <div class="dd-perf-grid">
        <div class="dd-perf-item">
          <div class="dd-perf-label"><%= _isAr ? 'أُكملت' : 'Completed' %></div>
          <div class="dd-perf-value"><%= _perf.completed %></div>
        </div>
        <% if (_perf.compliancePct !== null && _perf.compliancePct !== undefined) { %>
        <div class="dd-perf-item">
          <div class="dd-perf-label"><%= _isAr ? 'التزام SLA' : 'SLA' %></div>
          <div class="dd-perf-value"><%= _perf.compliancePct %>%</div>
        </div>
        <% } %>
        <% if (_perf.avgTurnaroundHours !== null && _perf.avgTurnaroundHours !== undefined) { %>
        <div class="dd-perf-item">
          <div class="dd-perf-label"><%= _isAr ? 'متوسط الإنجاز' : 'Avg. TAT' %></div>
          <div class="dd-perf-value"><%= _perf.avgTurnaroundHours %>h</div>
        </div>
        <% } %>
        <% if (_perf.avgTurnaround30dHours !== null && _perf.avgTurnaround30dHours !== undefined && _perf.avgTurnaround30dCount >= 3) { %>
        <div class="dd-perf-item">
          <div class="dd-perf-label"><%= _isAr ? 'متوسط الإنجاز (٣٠ يوم)' : 'Avg. turnaround (30d)' %></div>
          <div class="dd-perf-value"><%= _perf.avgTurnaround30dHours %><%= _isAr ? ' ساعة' : 'h' %></div>
        </div>
        <% } %>
      </div>
    </div>
  </div>

</div>

<script<% if (typeof cspNonce !== 'undefined' && cspNonce) { %> nonce="<%= cspNonce %>"<% } %>>
  // Dashboard-specific tour. Overrides the layout-level fallback so the
  // tour starts fresh every time the button is clicked on this page.
  window.startPortalTour = function() {
    if (typeof PortalTour === 'undefined' || typeof doctorDashboardTour === 'undefined') return;
    PortalTour.reset('doctor_dashboard');
    PortalTour.start('doctor_dashboard', doctorDashboardTour);
  };
</script>

<% if (_showWelcome) { %>
  <%
    var _welcomeName = _firstName || (_isAr ? 'الطبيب' : 'Doctor');
    // Locked copy — see commit message for approval workflow.
    var _welcomePanels = _isAr ? [
      { title: 'أين تظهر الحالات الجديدة',
        body:  'تظهر الحالات الجديدة المطابقة لتخصصك في قسم "الحالات الجديدة" فور تقديمها من المريض. نخطرك عبر الواتساب وداخل المنصة — لست بحاجة لإبقاء هذه الصفحة مفتوحة.' },
      { title: 'قبول الحالة',
        body:  'انقر على أي حالة لقراءة ملفات المريض. حين تكون مستعداً للالتزام، انقر "قبول" — يبدأ عداد الموعد النهائي عند تلك اللحظة، وليس قبلها. يمكنك رفض الحالة إذا كانت خارج نطاق تخصصك.' },
      { title: 'كيف تعمل أرباحك',
        body:  'تكسب رسوم الطبيب الموضحة لكل خدمة. تبقى الأرباح في حالة "معلّقة" أثناء فتح الحالة وتتحول إلى "مدفوعة" عند إكمال التقرير. تابع كل شيء في تبويب "الأرباح".' }
    ] : [
      { title: 'Where new cases appear',
        body:  'New cases matching your specialty appear in the New cases section as soon as a patient submits. We notify you on WhatsApp and inside the portal — you don\'t need to keep this page open.' },
      { title: 'Accepting a case',
        body:  'Click any case to read the patient\'s files. When you\'re ready to commit, click Accept — the SLA clock starts at that moment, not before. You can decline a case if it\'s outside your scope.' },
      { title: 'How your earnings work',
        body:  'You earn the doctor fee shown on each service. Earnings stay pending while a case is open and move to paid when you complete the report. Track everything on the Earnings tab.' }
    ];
    var _welcomeKicker = _isAr ? 'مرحباً بك' : 'Welcome';
    var _welcomeTitle  = _isAr ? ('أهلاً بك في تشخيصة، د. ' + _welcomeName) : ('Welcome to Tashkheesa, Dr. ' + _welcomeName);
    var _welcomeCta    = _isAr ? 'فهمت' : 'Got it';
  %>
  <div class="dd-welcome-overlay" id="dd-welcome-overlay" role="dialog" aria-modal="true" aria-labelledby="dd-welcome-title">
    <div class="dd-welcome-modal">
      <header class="dd-welcome-header">
        <span class="dd-welcome-kicker"><%= _welcomeKicker %></span>
        <h2 class="dd-welcome-title" id="dd-welcome-title"><%= _welcomeTitle %></h2>
      </header>
      <div class="dd-welcome-panels">
        <% _welcomePanels.forEach(function (p, i) { %>
          <div class="dd-welcome-panel">
            <span class="dd-welcome-panel-num" aria-hidden="true"><%= i + 1 %></span>
            <div class="dd-welcome-panel-body">
              <div class="dd-welcome-panel-title"><%= p.title %></div>
              <div class="dd-welcome-panel-text"><%= p.body %></div>
            </div>
          </div>
        <% }); %>
      </div>
      <div class="dd-welcome-actions">
        <button type="button" class="dd-welcome-cta" id="dd-welcome-dismiss" autofocus><%= _welcomeCta %></button>
      </div>
    </div>
  </div>
  <script<% if (typeof cspNonce !== 'undefined' && cspNonce) { %> nonce="<%= cspNonce %>"<% } %>>
  (function () {
    // Welcome-modal dismiss. Server-side handler also fire-and-forgets
    // an UPDATE on first page-load, so a network failure here doesn't
    // strand the user — they just won't see the overlay on next load
    // either way.
    var overlay = document.getElementById('dd-welcome-overlay');
    var btn     = document.getElementById('dd-welcome-dismiss');
    if (!overlay || !btn) return;
    function dismiss() {
      overlay.style.display = 'none';
      // P1-DOC-7: auto-chain the dashboard tour the first time the
      // welcome modal is dismissed (per browser, gated by localStorage).
      // The manual "Start tour" button remains independent so a doctor
      // who skipped the tour can still trigger it later.
      var tourFlag = 'tour_seen_dashboard_v1';
      var shouldAutoTour = false;
      try { shouldAutoTour = !window.localStorage.getItem(tourFlag); } catch (_) {}
      if (shouldAutoTour) {
        try { window.localStorage.setItem(tourFlag, String(Date.now())); } catch (_) {}
        // 250ms lets the overlay paint as hidden before the tour spotlight
        // begins; without it the first step renders behind the fading overlay.
        setTimeout(function () {
          if (typeof window.startPortalTour === 'function') {
            try { window.startPortalTour(); } catch (_) {}
          }
        }, 250);
      }
      try {
        fetch('/portal/doctor/onboarding/dismiss', {
          method: 'POST',
          credentials: 'same-origin',
          headers: { 'Content-Type': 'application/json' }
        }).catch(function () { /* server-side mark already fired; ignore */ });
      } catch (_) {}
    }
    btn.addEventListener('click', dismiss);
    // Esc-key dismiss for accessibility.
    document.addEventListener('keydown', function (e) {
      if (overlay.style.display !== 'none' && (e.key === 'Escape' || e.key === 'Esc')) dismiss();
    });
  })();
  </script>
<% } %>

<% if (_banner && _banner.level && _banner.count > 0 && _banner.items && _banner.items.length > 0) { %>
  <script<% if (typeof cspNonce !== 'undefined' && cspNonce) { %> nonce="<%= cspNonce %>"<% } %>>
  (function () {
    // SLA banner anchor links: per-case anchor first, fallback to the
    // priority-queue list section if the case isn't in the top-N
    // priorityQueue (per banner case-ref behavior decision).
    document.querySelectorAll('.dd-sla-banner-cases a[data-fallback]').forEach(function (a) {
      a.addEventListener('click', function (e) {
        var hash = a.getAttribute('href') || '';
        var target = hash && hash.charAt(0) === '#' ? document.querySelector(hash) : null;
        if (!target) {
          var fb = a.getAttribute('data-fallback');
          var fbEl = fb ? document.querySelector(fb) : null;
          if (fbEl) {
            e.preventDefault();
            fbEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }
      });
    });
  })();
  </script>
<% } %>

<%- include('partials/footer') %>
