<%- include('partials/header', { title: 'Dashboard', layout: 'portal', showNav: true, portalFrame: true, portalRole: 'doctor', portalActive: 'dashboard', portalNext: '/portal/doctor/dashboard' }) %>
<%
  // ----- Locals guards -----
  var _user = (typeof user !== 'undefined' && user) ? user : (typeof locals !== 'undefined' ? (locals.user || {}) : {});
  var _isAr = (typeof isAr !== 'undefined') ? isAr : false;
  var _lang = (typeof lang !== 'undefined' && lang) ? lang : (_isAr ? 'ar' : 'en');

  function _asArr(v) { return Array.isArray(v) ? v : []; }
  function _num(v, f) { var n = Number(v); return Number.isFinite(n) && n >= 0 ? Math.trunc(n) : (f || 0); }

  // ----- Redesign payload (from the GET handler) -----
  var _sla = (typeof slaHealth !== 'undefined' && slaHealth) ? slaHealth : { urgent: 0, warn: 0, onTrack: 0, breached: 0 };
  var _month = (typeof monthMetrics !== 'undefined' && monthMetrics) ? monthMetrics : { completedThisMonth: 0, earningsThisMonth: 0, currency: 'EGP' };
  var _priority = _asArr(typeof priorityQueue !== 'undefined' ? priorityQueue : []);
  var _newAssigns = _asArr(typeof newCases !== 'undefined' ? newCases : []).slice(0, 3);
  var _activity = _asArr(typeof activityFeed !== 'undefined' ? activityFeed : []);
  var _perf = (typeof perfSnapshot !== 'undefined' && perfSnapshot) ? perfSnapshot : { completed: 0, compliancePct: null, avgTurnaroundHours: null };

  // ----- KPI counts -----
  var _inReviewTotal = _num(typeof inReviewTotal !== 'undefined' ? inReviewTotal : 0, 0);
  var _newCasesTotal = _num(typeof newCasesTotal !== 'undefined' ? newCasesTotal : 0, 0);

  // ----- Welcome header bits -----
  var _name = (_user && _user.name) ? String(_user.name).trim() : '';
  var _firstName = _name.split(/\s+/)[0] || '';

  var _now = new Date();
  var _hour = _now.getHours();
  var _greetKeyEn = _hour < 12 ? 'Good morning' : (_hour < 18 ? 'Good afternoon' : 'Good evening');
  var _greetKeyAr = _hour < 12 ? 'صباح الخير' : (_hour < 18 ? 'مساء الخير' : 'مساء الخير');
  var _titleDoctor = _isAr ? 'د.' : 'Dr.';

  // Today's date, localized
  var _dateStr;
  try {
    _dateStr = _now.toLocaleDateString(_isAr ? 'ar-EG' : 'en-US',
      { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
  } catch (_) { _dateStr = _now.toDateString(); }

  // ----- SLA health chip selection -----
  // Priority: breached/urgent → urgent, else warn → warn, else ok.
  var _slaUrgentTotal = (_sla.urgent || 0) + (_sla.breached || 0);
  var _slaChipClass, _slaChipLabel;
  if (_slaUrgentTotal > 0) {
    _slaChipClass = 'dd-sla-chip--urgent';
    _slaChipLabel = _isAr
      ? (_slaUrgentTotal + ' ' + (_slaUrgentTotal === 1 ? 'حالة عاجلة' : 'حالات عاجلة'))
      : (_slaUrgentTotal + ' ' + (_slaUrgentTotal === 1 ? 'case urgent' : 'cases urgent'));
  } else if ((_sla.warn || 0) > 0) {
    _slaChipClass = 'dd-sla-chip--warn';
    _slaChipLabel = _isAr
      ? (_sla.warn + ' ' + (_sla.warn === 1 ? 'حالة تقترب من المهلة' : 'حالات تقترب من المهلة'))
      : (_sla.warn + ' ' + (_sla.warn === 1 ? 'case approaching SLA' : 'cases approaching SLA'));
  } else {
    _slaChipClass = 'dd-sla-chip--ok';
    _slaChipLabel = _isAr ? 'كل شيء في مساره' : 'All on track';
  }

  // ----- Helpers -----
  function _initials(name) {
    if (!name) return '?';
    var parts = String(name).split(/\s+/).filter(Boolean).slice(0, 2);
    return (parts.map(function(w){ return w.charAt(0); }).join('') || '?').toUpperCase();
  }

  // SLA dot class from minutes remaining (breach / <24h / 24-48h / >48h)
  function _slaDotClass(caseItem) {
    if (!caseItem || !caseItem.sla) return 'dd-case-sla-dot--ok';
    if (caseItem.sla.isBreached) return 'dd-case-sla-dot--breach';
    var min = Number(caseItem.sla.minutesRemaining);
    if (!Number.isFinite(min)) return 'dd-case-sla-dot--ok';
    if (min <= 24 * 60) return 'dd-case-sla-dot--urgent';
    if (min <= 48 * 60) return 'dd-case-sla-dot--warn';
    return 'dd-case-sla-dot--ok';
  }

  // Format a concise "due in Xh Ym" / "overdue by …" string from the SLA object
  function _slaTimeLabel(caseItem) {
    if (!caseItem || !caseItem.sla) return '';
    var sla = caseItem.sla;
    if (sla.isBreached) {
      var over = Number(sla.minutesOverdue) || 0;
      var oH = Math.floor(over / 60), oM = Math.floor(over % 60);
      var overStr = (oH > 0 ? (oH + 'h ') : '') + oM + 'm';
      return _isAr ? ('تأخّرت ' + overStr) : ('overdue ' + overStr);
    }
    var rem = Number(sla.minutesRemaining);
    if (!Number.isFinite(rem) || rem < 0) return '';
    var d = Math.floor(rem / (60 * 24));
    var h = Math.floor((rem % (60 * 24)) / 60);
    var m = Math.floor(rem % 60);
    var str;
    if (d >= 1) str = d + 'd ' + h + 'h';
    else if (h >= 1) str = h + 'h ' + m + 'm';
    else str = m + 'm';
    return _isAr ? ('خلال ' + str) : ('due in ' + str);
  }

  // Build "F, 54" / "M, 38" style chip from case fields (falls back gracefully)
  function _ageSexChip(caseItem) {
    if (!caseItem) return '';
    var sex = caseItem.patient_sex || caseItem.sex || caseItem.gender || '';
    var age = caseItem.patient_age || caseItem.age || '';
    var s = '';
    if (sex) s += String(sex).charAt(0).toUpperCase();
    if (age) s += (s ? ', ' : '') + age;
    return s;
  }

  // Patient identifier for case row (initials or name + age/sex)
  function _patientLabel(caseItem) {
    if (!caseItem) return '';
    var name = caseItem.patient_name || caseItem.patientName || '';
    if (name) return name;
    return _initials(caseItem.patient_full_name || caseItem.patient_id || caseItem.id);
  }

  // Reference ID like #TK-2847 (falls back to id)
  function _caseRef(caseItem) {
    if (!caseItem) return '';
    var ref = caseItem.reference_id || caseItem.reference || caseItem.id || '';
    ref = String(ref);
    return ref ? ('#' + ref) : '';
  }

  // Specialty icon — generic stethoscope; uses currentColor.
  function _specIcon() {
    return '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">' +
           '<path d="M6 2v6a4 4 0 0 0 8 0V2"/><path d="M10 12v3a5 5 0 0 0 10 0v-2"/>' +
           '<circle cx="20" cy="11" r="2"/><path d="M6 2H4M10 2h2"/>' +
           '</svg>';
  }

  // Activity-label mapping and regex patterns come from the handler —
  // single source of truth, see TECH DEBT note in src/routes/doctor.js.
  var _ACTIVITY_MAP = (typeof activityLabelMap !== 'undefined' && activityLabelMap)
    ? activityLabelMap
    : {};
  var _ACTIVITY_PATTERNS = [];
  try {
    var _rawPatterns = (typeof activityLabelPatterns !== 'undefined' && Array.isArray(activityLabelPatterns))
      ? activityLabelPatterns
      : [];
    _ACTIVITY_PATTERNS = _rawPatterns.map(function (p) {
      return { match: new RegExp(p.source, p.flags || ''), template: p.template };
    });
  } catch (_) { _ACTIVITY_PATTERNS = []; }

  function _activityText(ev) {
    if (!ev) return '';
    var ref = ev.reference_id ? ('#' + ev.reference_id) : (ev.order_id ? ('#' + String(ev.order_id).slice(0, 8)) : '');

    // 1. Exact-match lookup.
    var tmpl = _ACTIVITY_MAP[ev.label];

    // 2. Regex fallback (e.g. "Assigned to …" variants with baked-in doctor id).
    if (!tmpl) {
      for (var i = 0; i < _ACTIVITY_PATTERNS.length; i++) {
        if (_ACTIVITY_PATTERNS[i].match.test(String(ev.label || ''))) {
          tmpl = _ACTIVITY_PATTERNS[i].template;
          break;
        }
      }
    }

    if (tmpl) {
      return (_isAr ? tmpl.ar : tmpl.en).replace('{ref}', ref);
    }

    // 3. Still unmapped — log at render-site so the warn fires at the actual
    // lookup point (belt-and-braces; handler also warns upstream).
    try { console.warn('[dashboard.view] Unmapped activity label at render:', JSON.stringify(ev.label)); } catch (_) {}
    return (_isAr ? 'نشاط: ' : '') + String(ev.label || '') + (ref ? (' ' + ref) : '');
  }

  function _relTime(when) {
    if (!when) return '';
    var t = new Date(when).getTime();
    if (!Number.isFinite(t)) return '';
    var diff = Math.max(0, Date.now() - t);
    var mins = Math.floor(diff / 60000);
    if (mins < 1) return _isAr ? 'الآن' : 'just now';
    if (mins < 60) return _isAr ? ('منذ ' + mins + ' د') : (mins + 'm ago');
    var h = Math.floor(mins / 60);
    if (h < 24) return _isAr ? ('منذ ' + h + ' س') : (h + 'h ago');
    var d = Math.floor(h / 24);
    if (d < 30) return _isAr ? ('منذ ' + d + ' ي') : (d + 'd ago');
    var mo = Math.floor(d / 30);
    return _isAr ? ('منذ ' + mo + ' ش') : (mo + 'mo ago');
  }

  function _fmtEgp(n) {
    var x = Math.max(0, Math.round(Number(n) || 0));
    return x.toLocaleString(_isAr ? 'ar-EG' : 'en-US');
  }
%>

<link rel="stylesheet" href="/css/doctor-profile.css" />
<link rel="stylesheet" href="/css/doctor-dashboard.css" />

<div class="dd-page">

  <!-- ===================================================================
       § 1 — Welcome strip (no kicker, per brief)
       =================================================================== -->
  <div class="dd-welcome">
    <div class="dd-welcome-main">
      <h1 class="dd-welcome-title">
        <span>
          <%= _isAr ? _greetKeyAr : _greetKeyEn %><%= _isAr ? '، ' : ', ' %><%= _titleDoctor %> <%= _firstName || (_isAr ? 'الطبيب' : 'Doctor') %>
        </span>
        <span class="dd-sla-chip <%= _slaChipClass %>">
          <span class="dd-sla-chip-dot"></span>
          <%= _slaChipLabel %>
        </span>
      </h1>
      <span class="dd-welcome-date"><%= _dateStr %></span>
    </div>
  </div>

  <!-- ===================================================================
       § 2 — KPI row (no kicker, per brief)
       =================================================================== -->
  <div class="dd-kpi-grid">
    <div class="dd-kpi">
      <span class="dd-kpi-kicker"><%= _isAr ? 'قيد المراجعة' : 'In review' %></span>
      <span class="dd-kpi-value"><%= _inReviewTotal %></span>
    </div>
    <div class="dd-kpi">
      <span class="dd-kpi-kicker"><%= _isAr ? 'تعيينات جديدة' : 'New assignments' %></span>
      <span class="dd-kpi-value"><%= _newCasesTotal %></span>
    </div>
    <div class="dd-kpi">
      <span class="dd-kpi-kicker"><%= _isAr ? 'أُكملت هذا الشهر' : 'Completed this month' %></span>
      <span class="dd-kpi-value"><%= _num(_month.completedThisMonth, 0) %></span>
    </div>
    <div class="dd-kpi">
      <span class="dd-kpi-kicker"><%= _isAr ? 'أرباح هذا الشهر' : 'Earnings this month' %></span>
      <span class="dd-kpi-value dd-kpi-value--inline-currency">
        <span class="dd-kpi-currency">EGP</span>
        <span><%= _fmtEgp(_month.earningsThisMonth) %></span>
      </span>
    </div>
  </div>

  <!-- ===================================================================
       § 3 — Priority queue (kicker 01)
       =================================================================== -->
  <section class="dp-sec">
    <div class="dp-sec-head">
      <div class="dp-sec-kicker">01</div>
      <div class="dp-sec-title"><%= _isAr ? 'الأولوية للمراجعة' : 'Priority queue' %></div>
      <div class="dp-sec-desc"><%= _isAr ? 'الحالات قيد المراجعة مرتبةً من الأقرب انتهاءً لاتفاقية مستوى الخدمة.' : 'In-review cases sorted by how soon SLA runs out.' %></div>
    </div>
    <div class="dp-sec-body">
      <% if (_priority.length === 0) { %>
        <div class="dd-empty"><%= _isAr ? 'لا توجد حالات للمراجعة الآن.' : 'No cases to review right now.' %></div>
      <% } else { %>
        <div class="dd-case-list">
          <% _priority.forEach(function (c) { %>
            <div class="dd-case-row">
              <div class="dd-case-icon"><%- _specIcon() %></div>
              <div class="dd-case-main">
                <div class="dd-case-topline">
                  <span class="dd-case-patient"><%= _patientLabel(c) %></span>
                  <% var _ageSex = _ageSexChip(c); if (_ageSex) { %>
                    <span class="dd-case-age"><%= _ageSex %></span>
                  <% } %>
                  <span class="dd-case-ref"><%= _caseRef(c) %></span>
                </div>
                <div class="dd-case-service"><%= c.specialtyLabel || '—' %></div>
              </div>
              <div class="dd-case-sla">
                <span class="dd-case-sla-dot <%= _slaDotClass(c) %>"></span>
                <span class="dd-case-sla-time"><%= _slaTimeLabel(c) %></span>
              </div>
              <div class="dd-case-actions">
                <a class="dd-case-btn dd-case-btn--primary" href="<%= c.href || ('/portal/doctor/case/' + encodeURIComponent(c.id || '')) %>">
                  <%= _isAr ? 'مراجعة' : 'Review' %>
                </a>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
      <div class="dd-sec-footer">
        <a href="/portal/doctor/queue"><%= _isAr ? 'كل الحالات ←' : 'View all cases →' %></a>
      </div>
    </div>
  </section>

  <!-- ===================================================================
       § 4 — New assignments (kicker 02)
       =================================================================== -->
  <section class="dp-sec">
    <div class="dp-sec-head">
      <div class="dp-sec-kicker">02</div>
      <div class="dp-sec-title"><%= _isAr ? 'تعيينات جديدة' : 'New assignments' %></div>
      <div class="dp-sec-desc"><%= _isAr ? 'حالات مُعيَّنة لم تُقبل بعد. اقبل لبدء المراجعة أو ارفض ليُعاد توزيعها.' : "Cases assigned to you but not yet accepted. Accept to start, or decline to re-route." %></div>
    </div>
    <div class="dp-sec-body">
      <% if (_newAssigns.length === 0) { %>
        <div class="dd-empty"><%= _isAr ? 'لا توجد تعيينات جديدة.' : 'No new assignments right now.' %></div>
      <% } else { %>
        <div class="dd-case-list">
          <% _newAssigns.forEach(function (c) { %>
            <div class="dd-case-row">
              <div class="dd-case-icon"><%- _specIcon() %></div>
              <div class="dd-case-main">
                <div class="dd-case-topline">
                  <span class="dd-case-patient"><%= _patientLabel(c) %></span>
                  <% var _ageSex2 = _ageSexChip(c); if (_ageSex2) { %>
                    <span class="dd-case-age"><%= _ageSex2 %></span>
                  <% } %>
                  <span class="dd-case-ref"><%= _caseRef(c) %></span>
                </div>
                <div class="dd-case-service"><%= c.specialtyLabel || '—' %></div>
              </div>
              <div class="dd-case-sla">
                <span class="dd-case-sla-dot <%= _slaDotClass(c) %>"></span>
                <span class="dd-case-sla-time"><%= _slaTimeLabel(c) %></span>
              </div>
              <div class="dd-case-actions">
                <form method="POST" action="/portal/doctor/case/<%= encodeURIComponent(c.id || '') %>/accept" style="display:inline-flex;gap:8px;margin:0;">
                  <%- (typeof csrfField === 'function') ? csrfField() : '' %>
                  <button type="submit" class="dd-case-btn dd-case-btn--primary"><%= _isAr ? 'قبول' : 'Accept' %></button>
                </form>
                <a class="dd-case-btn dd-case-btn--danger" href="<%= c.href || ('/portal/doctor/case/' + encodeURIComponent(c.id || '')) %>">
                  <%= _isAr ? 'رفض' : 'Decline' %>
                </a>
              </div>
            </div>
          <% }); %>
        </div>
      <% } %>
      <% if (_newCasesTotal > _newAssigns.length) { %>
        <div class="dd-sec-footer">
          <a href="/portal/doctor/queue?filter=new"><%= _isAr ? 'كل التعيينات ←' : 'View all assignments →' %></a>
        </div>
      <% } %>
    </div>
  </section>

  <!-- ===================================================================
       § 5 — Activity feed (kicker 03)
       =================================================================== -->
  <section class="dp-sec">
    <div class="dp-sec-head">
      <div class="dp-sec-kicker">03</div>
      <div class="dp-sec-title"><%= _isAr ? 'النشاط الأخير' : 'Recent activity' %></div>
      <div class="dp-sec-desc"><%= _isAr ? 'آخر خمس خطوات على حالاتك — للتذكير لا للإجراء.' : 'Your last five case events — informational, not actionable.' %></div>
    </div>
    <div class="dp-sec-body">
      <% if (_activity.length === 0) { %>
        <div class="dd-empty"><%= _isAr ? 'لا يوجد نشاط بعد.' : 'No activity yet.' %></div>
      <% } else { %>
        <div class="dd-activity">
          <% _activity.forEach(function (ev) { %>
            <div class="dd-activity-item">
              <span class="dd-activity-dot"></span>
              <div class="dd-activity-text">
                <% if (ev.order_id) { %>
                  <a href="/portal/doctor/case/<%= encodeURIComponent(ev.order_id) %>"><%= _activityText(ev) %></a>
                <% } else { %>
                  <%= _activityText(ev) %>
                <% } %>
              </div>
              <span class="dd-activity-when"><%= _relTime(ev.at) %></span>
            </div>
          <% }); %>
        </div>
      <% } %>
    </div>
  </section>

  <!-- ===================================================================
       § 6 — Performance snapshot (kicker 04)
       =================================================================== -->
  <section class="dp-sec">
    <div class="dp-sec-head">
      <div class="dp-sec-kicker">04</div>
      <div class="dp-sec-title"><%= _isAr ? 'أداء هذا الشهر' : 'This month, at a glance' %></div>
      <div class="dp-sec-desc"><%= _isAr ? 'سطر واحد. التفاصيل في صفحة التحليلات.' : 'One line. Full breakdown lives in analytics.' %></div>
    </div>
    <div class="dp-sec-body">
      <div class="dd-perf">
        <div class="dd-perf-line">
          <% if (_perf.completed > 0) { %>
            <span><span class="dd-perf-metric"><%= _perf.completed %></span> <%= _isAr ? 'حالة أُكملت' : (_perf.completed === 1 ? 'case completed' : 'cases completed') %></span>
            <% if (_perf.compliancePct !== null && _perf.compliancePct !== undefined) { %>
              <span class="dd-perf-sep">•</span>
              <span><span class="dd-perf-metric"><%= _perf.compliancePct %>%</span> <%= _isAr ? 'التزام بالمهلة' : 'SLA compliance' %></span>
            <% } %>
            <% if (_perf.avgTurnaroundHours !== null && _perf.avgTurnaroundHours !== undefined) { %>
              <span class="dd-perf-sep">•</span>
              <span><%= _isAr ? 'متوسط زمن الإنجاز' : 'avg turnaround' %> <span class="dd-perf-metric"><%= _perf.avgTurnaroundHours %>h</span></span>
            <% } %>
          <% } else { %>
            <span><%= _isAr ? 'لا حالات مكتملة هذا الشهر بعد.' : 'No completed cases this month yet.' %></span>
          <% } %>
        </div>
        <a class="dd-perf-link" href="/portal/doctor/analytics"><%= _isAr ? 'عرض التحليلات ←' : 'View analytics →' %></a>
      </div>
    </div>
  </section>

</div>

<%- include('partials/footer') %>
