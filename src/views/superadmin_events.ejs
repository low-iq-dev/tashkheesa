<%
  // Audit log — restyled to new superadmin chrome (Batch 7). Same content,
  // same query params (label/order_id/role/from/to), same form action.
  const isAr = (typeof lang !== 'undefined' && lang === 'ar');
  const _filters = (typeof filters !== 'undefined' && filters) ? filters : {};
  const _events = (typeof events !== 'undefined' && Array.isArray(events)) ? events : [];
  const _nonce = (typeof cspNonce !== 'undefined' && cspNonce) ? cspNonce : '';
  const _roles = ['all', 'patient', 'doctor', 'admin', 'superadmin', 'system'];
%>
<%- include('partials/superadmin/header', {
      title: isAr ? 'سجل التدقيق' : 'Audit Log',
      currentSection: 'events',
      user: user,
      lang: (typeof lang !== 'undefined' && lang) ? lang : 'en',
      showTabBar: false,
      sidebarBadges: (typeof sidebarBadges !== 'undefined' && sidebarBadges) ? sidebarBadges : {},
      cspNonce: _nonce
    }) %>

<%- include('partials/superadmin/page_header', {
      title: isAr ? 'سجل التدقيق' : 'Audit Log',
      subtitle: isAr ? 'الأحداث الأخيرة عبر المنصة.' : 'Recent events across the platform.',
      breadcrumb: [
        { label: isAr ? 'لوحة التحكم' : 'Dashboard', href: '/superadmin' },
        { label: isAr ? 'سجل التدقيق' : 'Audit Log' }
      ]
    }) %>

<div class="page-body">

  <%- include('partials/superadmin/c_card_open', { title: isAr ? 'تصفية' : 'Filters' }) %>
    <form method="get" action="/superadmin/events">
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(160px,1fr));gap:12px;align-items:end;">
        <div>
          <label style="font-size:12px;font-weight:600;color:var(--fg-2);display:block;margin-bottom:4px;"><%= isAr ? 'التصنيف' : 'Label' %></label>
          <input type="text" name="label" value="<%= _filters.label || '' %>" placeholder="<%= isAr ? 'البحث عن تصنيف...' : 'Search label...' %>"
                 style="width:100%;padding:8px 10px;border:1px solid var(--bd);border-radius:6px;font-size:13px;background:var(--bg);color:var(--fg);" />
        </div>
        <div>
          <label style="font-size:12px;font-weight:600;color:var(--fg-2);display:block;margin-bottom:4px;"><%= isAr ? 'رقم الطلب' : 'Order ID' %></label>
          <input type="text" name="order_id" value="<%= _filters.order_id || '' %>" placeholder="order id"
                 style="width:100%;padding:8px 10px;border:1px solid var(--bd);border-radius:6px;font-size:13px;background:var(--bg);color:var(--fg);" />
        </div>
        <div>
          <label style="font-size:12px;font-weight:600;color:var(--fg-2);display:block;margin-bottom:4px;"><%= isAr ? 'الدور' : 'Role' %></label>
          <select name="role" style="width:100%;padding:8px 10px;border:1px solid var(--bd);border-radius:6px;font-size:13px;background:var(--bg);color:var(--fg);">
            <% _roles.forEach(function(r){ %>
              <option value="<%= r %>" <%= _filters.role === r ? 'selected' : '' %>><%= r.charAt(0).toUpperCase() + r.slice(1) %></option>
            <% }); %>
          </select>
        </div>
        <div>
          <label style="font-size:12px;font-weight:600;color:var(--fg-2);display:block;margin-bottom:4px;"><%= isAr ? 'من' : 'From' %></label>
          <input type="date" name="from" value="<%= _filters.from || '' %>" dir="ltr"
                 style="width:100%;padding:8px 10px;border:1px solid var(--bd);border-radius:6px;font-size:13px;background:var(--bg);color:var(--fg);" />
        </div>
        <div>
          <label style="font-size:12px;font-weight:600;color:var(--fg-2);display:block;margin-bottom:4px;"><%= isAr ? 'إلى' : 'To' %></label>
          <input type="date" name="to" value="<%= _filters.to || '' %>" dir="ltr"
                 style="width:100%;padding:8px 10px;border:1px solid var(--bd);border-radius:6px;font-size:13px;background:var(--bg);color:var(--fg);" />
        </div>
        <div style="display:flex;gap:8px;align-items:flex-end;">
          <button class="btn primary" type="submit"><%= isAr ? 'تطبيق' : 'Apply' %></button>
          <a class="btn" href="/superadmin/events"><%= isAr ? 'إعادة' : 'Reset' %></a>
        </div>
      </div>
    </form>
  <%- include('partials/superadmin/c_card_close') %>

  <div style="height:16px;"></div>

  <%- include('partials/superadmin/c_card_open', { tight: true }) %>
    <% if (!_events.length) { %>
      <%- include('partials/superadmin/c_empty', { title: isAr ? 'لا توجد أحداث' : 'No events found' }) %>
    <% } else { %>
      <%- include('partials/superadmin/c_table_open', { headers: [
            isAr ? 'الوقت' : 'Time',
            isAr ? 'الطلب' : 'Order',
            isAr ? 'الفاعل' : 'Actor',
            isAr ? 'الدور' : 'Role',
            isAr ? 'التصنيف' : 'Label'
          ] }) %>
        <% _events.forEach(function(ev){ %>
          <tr>
            <td class="mono" style="font-size:11.5px;color:var(--fg-3);white-space:nowrap;"><%= formatEventDate(ev.at) %></td>
            <td>
              <% if (ev.order_id) { %>
                <a class="mono" href="/superadmin/orders/<%= ev.order_id %>"><%= ev.order_id %></a>
              <% } else { %>
                <span style="color:var(--fg-3);">—</span>
              <% } %>
            </td>
            <td>
              <% if (ev.actor_user_id && (ev.actor_role === 'doctor') && ev.doctor_name) { %>
                <%= ev.doctor_name %>
              <% } else if (ev.actor_user_id && (ev.actor_role === 'patient') && ev.patient_name) { %>
                <%= ev.patient_name %>
              <% } else { %>
                <%= ev.actor_role || 'System' %>
              <% } %>
            </td>
            <td><%- include('partials/superadmin/c_chip', { label: ev.actor_role || 'system', tone: 'neutral' }) %></td>
            <td><%= ev.label %></td>
          </tr>
        <% }); %>
      <%- include('partials/superadmin/c_table_close') %>
    <% } %>
  <%- include('partials/superadmin/c_card_close') %>

</div>

<%- include('partials/superadmin/footer', { isAr: isAr }) %>
