<%- include('partials/header', { title: tt('cs.title', 'Coming Soon — Tashkheesa', 'قريب — تشخيصة'), layout: "public", showNav: true }) %>
<%
  var fv = (typeof formValues !== 'undefined' && formValues) ? formValues : {};
  var fe = (typeof formErrors !== 'undefined' && formErrors) ? formErrors : {};
  var st = (typeof formState !== 'undefined' && formState) ? formState : 'idle';
  var isAr = (typeof lang !== 'undefined' && lang === 'ar') || (locals && locals.isAr);
  var csrfFieldFn = (typeof csrfField === 'function') ? csrfField : function() { return ''; };
  var _utmSource   = (typeof utm_source   !== 'undefined' && utm_source)   ? utm_source   : '';
  var _utmMedium   = (typeof utm_medium   !== 'undefined' && utm_medium)   ? utm_medium   : '';
  var _utmCampaign = (typeof utm_campaign !== 'undefined' && utm_campaign) ? utm_campaign : '';
%>

<main class="cs-page" dir="<%= isAr ? 'rtl' : 'ltr' %>">

  <!-- HERO -->
  <section class="cs-hero">
    <div class="cs-hero-inner">
      <span class="cs-trust-pill" aria-label="<%= tt('cs.trust.shifa', 'Backed by Shifa Hospital Group', 'بدعم مجموعة مستشفيات شفا') %>">
        <span class="cs-trust-dot" aria-hidden="true"></span>
        <%= tt('cs.trust.shifa', 'Backed by Shifa Hospital Group', 'بدعم مجموعة مستشفيات شفا') %>
      </span>
      <h1 class="cs-headline">
        <%= tt('cs.hero.title', 'A second opinion that actually changes the picture.', 'رأي طبي تاني — يبصّر ويفرق.') %>
      </h1>
      <p class="cs-subhead">
        <%= tt('cs.hero.sub', 'Specialist review of your records, written in plain language, in both Arabic and English.', 'مراجعة ملفاتك من دكتور متخصص، بلغة بسيطة، بالعربي والإنجليزي.') %>
      </p>

      <div class="cs-hero-points">
        <div class="cs-hero-point">
          <strong><%= tt('cs.hero.p1.t', '48 hours standard', '48 ساعة قياسي') %></strong>
          <span><%= tt('cs.hero.p1.s', 'as fast as 4 hours with Urgent', 'وحتى 4 ساعات مع Urgent') %></span>
        </div>
        <div class="cs-hero-point">
          <strong><%= tt('cs.hero.p2.t', 'Bilingual report', 'تقرير بلغتين') %></strong>
          <span><%= tt('cs.hero.p2.s', 'one you keep, one to share with your doctor', 'واحد ليك وواحد لدكتورك') %></span>
        </div>
        <div class="cs-hero-point">
          <strong><%= tt('cs.hero.p3.t', 'Secure & private', 'آمن وخاص') %></strong>
          <span><%= tt('cs.hero.p3.s', 'encrypted records, never resold', 'ملفات مشفّرة، مفيش بيع بيانات') %></span>
        </div>
      </div>

      <p class="cs-hero-lede">
        <%= tt('cs.hero.cta_line', 'We are opening soon. Leave your details and we will let you know the moment we go live.', 'هنفتح قريب. سيب بياناتك وهنبلغك أول ما نطلق.') %>
      </p>
      <a href="#cs-form" class="cs-btn cs-btn-primary cs-btn-large">
        <%= tt('cs.hero.cta', 'Get notified at launch', 'سجّل اهتمامك') %>
      </a>
    </div>
  </section>

  <!-- TRUST BAND -->
  <section class="cs-trust-band" aria-labelledby="cs-trust-h">
    <h2 id="cs-trust-h" class="cs-sr-only"><%= tt('cs.trust.h', 'Why Tashkheesa', 'ليه تشخيصة') %></h2>
    <div class="cs-trust-grid">
      <article class="cs-trust-card">
        <h3><%= tt('cs.trust1.title', 'Hospital-backed', 'مدعومة من مستشفى') %></h3>
        <p><%= tt('cs.trust1.sub', 'Backed by Shifa Hospital Group. Board-certified specialists, not anonymous referrers.', 'بدعم مجموعة مستشفيات شفا. دكاترة متخصصين معتمدين، مش وسطاء.') %></p>
      </article>
      <article class="cs-trust-card">
        <h3><%= tt('cs.trust2.title', 'Bilingual reports', 'تقارير بلغتين') %></h3>
        <p><%= tt('cs.trust2.sub', 'Every report is written in English and Arabic — useful for you and shareable with the doctor you already trust.', 'كل تقرير بإنجليزي وعربي — مفيد ليك وممكن تشاركه مع الدكتور اللي بتثق فيه.') %></p>
      </article>
      <article class="cs-trust-card">
        <h3><%= tt('cs.trust3.title', 'A second voice, not a replacement', 'صوت تاني، مش بديل') %></h3>
        <p><%= tt('cs.trust3.sub', 'A second opinion is for peace of mind and clarity. Your doctor stays your doctor.', 'الرأي التاني للاطمئنان والوضوح. دكتورك يفضل دكتورك.') %></p>
      </article>
    </div>
  </section>

  <!-- WHAT WE'RE BUILDING -->
  <section class="cs-features" aria-labelledby="cs-features-h">
    <h2 id="cs-features-h" class="cs-section-title">
      <%= tt('cs.features.h', "What you'll be able to do", 'إيه اللي هتقدر تعمله') %>
    </h2>
    <ul class="cs-feature-list">
      <li><%= tt('cs.feat.upload', 'Upload imaging, labs, biopsies, ECGs, or treatment plans', 'ارفع الأشعة، التحاليل، العينات، رسم القلب، أو خطط العلاج') %></li>
      <li><%= tt('cs.feat.review', 'Get a specialist review — radiology, cardiology, oncology, neurology and more', 'مراجعة من متخصص — أشعة، قلب، أورام، مخ وأعصاب وغيرهم') %></li>
      <li><%= tt('cs.feat.sla', '48 hours standard turnaround. Urgent option as fast as 4 hours.', '48 ساعة قياسي. وفي الحالات العاجلة، حتى 4 ساعات.') %></li>
      <li><%= tt('cs.feat.report', 'A clear written report in both Arabic and English', 'تقرير مكتوب واضح بالعربي والإنجليزي') %></li>
      <li><%= tt('cs.feat.privacy', 'Encrypted records, no advertising lists, never resold', 'ملفات مشفّرة، مفيش قوائم إعلانات، مفيش بيع بيانات') %></li>
    </ul>
  </section>

  <!-- FORM -->
  <section id="cs-form" class="cs-form-section" aria-labelledby="cs-form-h">
    <h2 id="cs-form-h" class="cs-section-title">
      <%= tt('cs.form.title2', 'Register your interest', 'سجّل اهتمامك') %>
    </h2>
    <p class="cs-section-sub">
      <%= tt('cs.form.sub2', 'Two minutes. We use this only to send you launch news and (if you allow it) a confirmation message.', 'دقيقتين. هنستخدمها بس عشان نبعتلك خبر الإطلاق و(لو سمحت) رسالة تأكيد.') %>
    </p>

    <% if (st === 'success') { %>
      <div class="cs-alert cs-alert-success" role="status" aria-live="polite">
        <strong><%= tt('cs.success.heading', "We've got it.", 'وصلنا اهتمامك.') %></strong>
        <p><%= tt('cs.success.body2', "If you ticked the consent box, check your inbox for a confirmation. We'll be in touch the day we open.", 'لو وافقت، شوف الإيميل بتاعك للتأكيد. هنبعتلك خبر يوم ما نفتح.') %></p>
      </div>
    <% } else { %>
      <% if (st === 'error') { %>
        <div class="cs-alert cs-alert-error" role="alert" aria-live="assertive">
          <strong><%= tt('cs.error.heading', "Let's fix a couple of things.", 'فيه شوية حاجات نظبطها.') %></strong>
        </div>
      <% } %>

      <form id="cs-form-el" class="cs-form" method="POST" action="/api/pre-launch-interest" novalidate>
        <%- csrfFieldFn() %>
        <input type="hidden" name="utm_source"   value="<%= _utmSource %>">
        <input type="hidden" name="utm_medium"   value="<%= _utmMedium %>">
        <input type="hidden" name="utm_campaign" value="<%= _utmCampaign %>">

        <!-- Honeypot: real users never see/fill this. -->
        <div class="cs-honeypot" aria-hidden="true">
          <label>Website
            <input type="text" name="website" tabindex="-1" autocomplete="off" value="">
          </label>
        </div>

        <div class="cs-row">
          <div class="cs-field <%= fe.name ? 'cs-field-error' : '' %>">
            <label for="cs-name"><%= tt('cs.form.name', 'Name', 'الاسم') %> <span aria-hidden="true">*</span></label>
            <input id="cs-name" type="text" name="name" required autocomplete="name"
                   value="<%= (fv.name || '') %>"
                   placeholder="<%= tt('cs.form.name_ph', 'Your name', 'اسمك') %>">
            <% if (fe.name) { %><small class="cs-field-msg"><%= tt('cs.form.name_err', 'Please enter your name.', 'سيب اسمك من فضلك.') %></small><% } %>
          </div>

          <div class="cs-field <%= fe.email ? 'cs-field-error' : '' %>">
            <label for="cs-email"><%= tt('cs.form.email', 'Email', 'البريد الإلكتروني') %> <span aria-hidden="true">*</span></label>
            <input id="cs-email" type="email" name="email" required autocomplete="email" dir="ltr"
                   value="<%= (fv.email || '') %>"
                   placeholder="your@email.com">
            <% if (fe.email) { %><small class="cs-field-msg"><%= tt('cs.form.email_err', 'Please enter a valid email.', 'إيميل صحيح من فضلك.') %></small><% } %>
          </div>
        </div>

        <div class="cs-row">
          <div class="cs-field">
            <label for="cs-phone">
              <%= tt('cs.form.phone', 'Phone', 'التليفون') %>
              <small class="cs-field-hint">(<%= tt('cs.form.phone_opt', 'optional', 'اختياري') %>)</small>
            </label>
            <input id="cs-phone" type="tel" name="phone" autocomplete="tel" dir="ltr"
                   value="<%= (fv.phone || '') %>"
                   placeholder="+20 1XX XXX XXXX">
            <small class="cs-field-hint">
              <%= tt('cs.form.phone_hint', "We'll only text you if you tick the consent box below.", 'مش هنبعتلك رسالة إلا لو وافقت تحت.') %>
            </small>
          </div>

          <div class="cs-field">
            <label for="cs-lang"><%= tt('cs.form.language', 'Preferred language', 'اللغة المفضّلة') %></label>
            <select id="cs-lang" name="language">
              <option value="ar" <%= (fv.language === 'ar' || (isAr && !fv.language)) ? 'selected' : '' %>>العربية</option>
              <option value="en" <%= (fv.language === 'en' || (!isAr && !fv.language)) ? 'selected' : '' %>>English</option>
              <option value="both" <%= (fv.language === 'both') ? 'selected' : '' %>><%= tt('cs.form.lang.both', 'Both', 'الاتنين') %></option>
            </select>
          </div>
        </div>

        <div class="cs-field">
          <label for="cs-service"><%= tt('cs.form.service', 'What do you want a second opinion on?', 'محتاج رأي تاني في إيه؟') %></label>
          <select id="cs-service" name="service_interest">
            <option value=""><%= tt('cs.form.service.choose', 'Select an option', 'اختار') %></option>
            <option value="imaging"   <%= fv.service_interest === 'imaging'   ? 'selected' : '' %>><%= tt('cs.form.service.imaging',   'Imaging (X-ray, MRI, CT)',                'أشعة (عادية، رنين، مقطعية)') %></option>
            <option value="labs"      <%= fv.service_interest === 'labs'      ? 'selected' : '' %>><%= tt('cs.form.service.labs',      'Labs (Blood work, Pathology)',            'تحاليل (دم، باثولوجي)') %></option>
            <option value="treatment" <%= fv.service_interest === 'treatment' ? 'selected' : '' %>><%= tt('cs.form.service.treatment', 'Treatment review (Surgery, Medications)', 'مراجعة العلاج (عمليات، أدوية)') %></option>
            <option value="general"   <%= fv.service_interest === 'general'   ? 'selected' : '' %>><%= tt('cs.form.service.general',   'General medical consultation',            'استشارة طبية عامة') %></option>
            <option value="all"       <%= (fv.service_interest === 'all' || !fv.service_interest) ? 'selected' : '' %>><%= tt('cs.form.service.all', 'Not sure yet',  'لسه مش متأكد') %></option>
          </select>
        </div>

        <div class="cs-field">
          <label for="cs-case">
            <%= tt('cs.form.case', 'Tell us about your case', 'احكيلنا عن حالتك') %>
            <small class="cs-field-hint">(<%= tt('cs.form.case_opt', 'optional', 'اختياري') %>)</small>
          </label>
          <textarea id="cs-case" name="case_description" rows="3"
                    placeholder="<%= tt('cs.form.case_ph2', 'A sentence or two so we can prepare. No prices, no commitment.', 'جملتين عشان نجهز. مفيش أسعار، مفيش التزام.') %>"><%= (fv.case_description || '') %></textarea>
        </div>

        <label class="cs-consent">
          <input type="checkbox" name="consent" value="true" <%= fv.consent ? 'checked' : '' %>>
          <span><%= tt('cs.form.consent', "I agree to be contacted by email or SMS about Tashkheesa's launch.", 'أوافق على التواصل معايا بالإيميل أو الرسائل بخصوص إطلاق تشخيصة.') %></span>
        </label>

        <button type="submit" id="cs-submit" class="cs-btn cs-btn-primary cs-btn-block">
          <%= tt('cs.form.submit2', 'Get notified at launch', 'سجّل اهتمامك') %>
        </button>

        <p class="cs-privacy-note">
          <%= tt('cs.privacy.line', 'No prices on this page, no obligation. You can unsubscribe any time.', 'مفيش أسعار، مفيش التزام. تقدر تلغي الاشتراك في أي وقت.') %>
        </p>
      </form>
    <% } %>
  </section>
</main>

<%
  var _nonce = (typeof cspNonce !== 'undefined' && cspNonce) ? cspNonce : '';
%>
<script<% if (_nonce) { %> nonce="<%= _nonce %>"<% } %>>
(function() {
  var form = document.getElementById('cs-form-el');
  if (!form) return;
  var submit = document.getElementById('cs-submit');
  var SUBMIT_LBL = submit ? submit.textContent.trim() : '';
  var BUSY_LBL = <%- JSON.stringify(tt('cs.form.busy', 'Submitting…', 'جاري الإرسال…')) %>;
  var SUCCESS_T = <%- JSON.stringify(tt('cs.success.heading', "We've got it.", 'وصلنا اهتمامك.')) %>;
  var SUCCESS_B = <%- JSON.stringify(tt('cs.success.body2', "If you ticked the consent box, check your inbox for a confirmation. We'll be in touch the day we open.", 'لو وافقت، شوف الإيميل بتاعك للتأكيد. هنبعتلك خبر يوم ما نفتح.')) %>;
  var ERR_FIELDS  = <%- JSON.stringify(tt('cs.error.fields', 'Please review the highlighted fields and try again.', 'راجع الحقول وحاول تاني.')) %>;
  var ERR_GENERIC = <%- JSON.stringify(tt('cs.error.generic', "Couldn't save right now. Please try again in a moment.", 'مقدرناش نحفظ دلوقتي. حاول كمان شوية.')) %>;
  var ERR_NETWORK = <%- JSON.stringify(tt('cs.error.network', 'Network error. Please try again.', 'مشكلة شبكة. حاول تاني.')) %>;

  form.addEventListener('submit', function(ev) {
    ev.preventDefault();
    if (submit) { submit.disabled = true; submit.textContent = BUSY_LBL; }
    var fd = new FormData(form);
    var payload = {};
    fd.forEach(function(v, k) { payload[k] = v; });
    payload.consent = !!(form.elements['consent'] && form.elements['consent'].checked);
    var csrfEl = form.querySelector('input[name="_csrf"]');
    var csrf = csrfEl ? csrfEl.value : '';
    fetch('/api/pre-launch-interest', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json',
        'x-csrf-token': csrf,
        'x-requested-with': 'XMLHttpRequest'
      },
      body: JSON.stringify(payload)
    })
    .then(function(r) { return r.json().then(function(j) { return { status: r.status, body: j }; }); })
    .then(function(res) {
      if (res.body && res.body.success) {
        var section = document.getElementById('cs-form');
        if (section) {
          section.innerHTML = '<h2 class="cs-section-title">' + SUCCESS_T + '</h2>' +
            '<div class="cs-alert cs-alert-success" role="status"><strong>' + SUCCESS_T + '</strong><p>' + SUCCESS_B + '</p></div>';
          section.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
        return;
      }
      if (submit) { submit.disabled = false; submit.textContent = SUBMIT_LBL; }
      var msg = (res.body && res.body.fields && Object.keys(res.body.fields).length) ? ERR_FIELDS : ERR_GENERIC;
      alert(msg);
    })
    .catch(function() {
      if (submit) { submit.disabled = false; submit.textContent = SUBMIT_LBL; }
      alert(ERR_NETWORK);
    });
  });
})();
</script>

<%- include('partials/footer') %>
